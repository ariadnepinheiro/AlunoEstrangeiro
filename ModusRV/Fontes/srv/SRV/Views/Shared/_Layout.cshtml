@using SRV.Common
@using SRV.Models.DTO
@using SRV.Common.Extension

<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge"/>
    <title>SEEDUC - Remuneração Variável</title>
    <link href="@Url.Content("~/Content/images/favicon.ico")" rel="Shortcut Icon" />
    <link href="@Url.Content("~/Content/Default.css?_=" + @AppInfo.GetVersion())" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/Toolbar.css?_=" + @AppInfo.GetVersion())" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/menu.css")" rel="stylesheet" type="text/css" />

    @if (ViewBag.Consolidado != null)
    {
        <link href="@Url.Content("~/Content/Consolidado.css")" rel="stylesheet" type="text/css" />
    }

    <!--[if lte IE 7]>
        <link href="@Url.Content("~/Content/menu_ie.css")" rel="stylesheet" type="text/css" />

        <style type="text/css">
            img { behavior: url(@Url.Content("~/Content/iepngfix.htc")) }    
        </style>
    <![endif]-->

    <link href="@Url.Content("~/Content/smoothness/jquery-ui-1.8.16.custom.css")" rel="stylesheet" type="text/css" />
    
    <script src="@Url.Content("~/Scripts/jquery-1.5.1.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/jquery.maskedinput-1.2.2.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/jquery.maskMoney.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/jquery-ui-1.8.11.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/jquery.ui.datepicker-pt-BR.js")" type="text/javascript"></script>

    <script src="@Url.Content("~/Scripts/hoverIntent.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/jquery.dropdown.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/jquery.bgiframe.js")" type="text/javascript"></script>

    <script src="@Url.Content("~/Scripts/functions.js?_=" + @AppInfo.GetVersion())" type="text/javascript"></script>
    
    <script src="@Url.Content("~/Scripts/jquery.unobtrusive-ajax.js")" type="text/javascript"></script>

</head>

<body> <!-- onselectstart="disableSelection()" -->

    <div class="boxHeader">
        <img alt="" src="@Url.Content("~/Content/images/topo.png")" />
    </div>


    <div class="all_menu">
        
        @{
            MenuItem menu = (MenuItem)@ViewBag.UsuarioLogado.Menu;
        }

        @foreach (var sistema in menu.children[0].children)
        {
            <ul class="dropdown">
            	<li><a href="#">@sistema.title</a>
                    <ul class="sub_menu">

                        @if (!sistema.group)
                        {
                            <li>
                                @Html.ActionLink((string)@sistema.title, (string)@sistema.action, (string)@sistema.controller)
                            </li>
                        }
                        else
                        {
                            foreach (var modulo in sistema.children)
                            {
                                if (!modulo.group)
                                {
                                    <li>
                                        @Html.ActionLink((string)@modulo.title, (string)@modulo.action, (string)@modulo.controller)
                                    </li>
                                }
                                else
                                {
                                    <li><a href="#">@modulo.title</a>
                                        <ul>
                                            @foreach (var projeto in modulo.children)
                                            {
                                                <li>
                                                    @Html.ActionLink((string)@projeto.title, (string)@projeto.action, (string)@projeto.controller)
                                                </li>
                                            }
                                        </ul>

                                    </li>
                                }
                            }
                        }

                    </ul>
                </li>
            </ul>        
        }

                    
        <div class="boxCiclo">
            @if(@ViewBag.UsuarioLogado.Ciclo != 0) 
            { 
                @:Ciclo de Gestão:  @ViewBag.UsuarioLogado.Ciclo 
            } 
        </div>
        
        <ul class="boxHdrLinks">
            <li>@ViewBag.UsuarioLogado.Nome</li>
            <li>|</li>

            @if (@Role.IsGranted("Administrador, Secretaria"))
            {
                <li><a href="#" id="showModalAlterarSenha">Alterar Senha</a></li>
                <li>|</li>
            }

            <li>@Html.ActionLink("Sair", "Logout", "Login")</li>
        </ul>

    </div>


    <div class="clear"> </div>



    <div class="boxTitle">
        <ul class="breadcrumb">

            @{if (!String.IsNullOrEmpty(@ViewBag.CaminhoPao.Nivel1))
              {
                <li><img alt="" src="@Url.Content("~/Content/images/separador.png")"/></li>
                <li>@ViewBag.CaminhoPao.Nivel1</li>
              }
            }
            @{if (!String.IsNullOrEmpty(@ViewBag.CaminhoPao.Nivel2))
              {
                <li><img alt="" src="@Url.Content("~/Content/images/separador.png")"/></li>
                <li>@ViewBag.CaminhoPao.Nivel2</li>
              }
            }
            @{if (!String.IsNullOrEmpty(@ViewBag.CaminhoPao.Nivel3))
              {
                <li><img alt="" src="@Url.Content("~/Content/images/separador.png")"/></li>
                <li>@ViewBag.CaminhoPao.Nivel3</li>
              }
            }
        </ul>
    </div>


    @RenderBody()

    @{Html.RenderPartial("Version");}

    <div id="modalAlteracaoSenha" title="Alteração de Senha" style="display:none;"></div>
    <div id="modalFormatoArquivo" title="Formato do Arquivo" style="display:none;"></div>
    <div id="modalStatus" title="Detalhes" style="display:none;"></div>

    <div id="modalLoading" title="Processando" style="display: none; text-align: center;">
        <img alt="" src="@Url.Content("~/Content/images/ajax-loader.gif")" />
        <br/>
        Processando... Aguarde
    </div>

    <div id="modalLoadingDownload" title="Processando" style="display: none; text-align: center;">
        <img alt="" src="@Url.Content("~/Content/images/ajax-loader.gif")" />
        <br/>
        Processando... Aguarde
    </div>

    <script type="text/javascript">
        var disableWaiting = false;
        var timerCheckDownload;
        var isReport = false;

        jQuery(function ($) {
            @* Desabilita cache para ajax
               Define método tradicional para serialização da url, por causa do envio de array como parâmetro *@
            $.ajaxSetup({ 
                cache: false, 
                traditional: true,
                beforeSend: function() {
                    openWaiting();
                },
                complete: function(){
                   // closeWaiting();
                }
            });

            $(document).ajaxComplete(function (event, request, options) {
               closeWaiting();
            });

            $(document).ajaxError(function (event, request, options) {
                if (request.status === 403) {
                    alert("Sua sessão expirou. Por favor efetue novo login");
                }
            });

            if(document.forms[0]) {
                document.forms[0].onsubmit = function(e) {
                    if (!isReport){
                        openWaiting();
                    }
                };
            }

            $('.btExportarExcel').submit(function () {
                checkDownload();
            });

            @* Hack para ocultar combos ao exibir modal no IE6 *@
            //$('#modalDadosUsuario').bgiframe();

            $("ul.sub_menu").bgiframe();
            $("ul.sub_menu ul").bgiframe();

            $(".date").datepicker({
                showOn: "both",
                buttonText: '',
                buttonImageOnly: true,
                buttonImage: '@Url.Content("~/Content/images/calendar.gif")'
            });

            $(".date").mask("99/99/9999");

            $('#showModalAlterarSenha').click(function () {

                var dlg = $("#modalAlteracaoSenha").dialog({
                    title: 'Alterar senha',
                    height: 'auto',
                    width: 400,
                    modal: true,
                    resizable: false,
                    open: function () {
                        $(this).load('@Url.Action("Modal", "AlteracaoSenha")');
                    },
                    beforeClose: function (event, ui) {
                        $('#modalAlterarSenha').empty();
                    }
                });
            });

        });

        function openWaiting() {
            if(!disableWaiting) {
                var dlg = $("#modalLoading").dialog({
                    title: 'Processando',
                    height: 'auto',
                    width: 400,
                    modal: true,
                    resizable: false,
                    open: function(event, ui) {
                        $(this).parent().children().children(".ui-dialog-titlebar-close").hide();
                    }
                });
            }
        }

        function closeWaiting() {
            $('#modalLoading').dialog('close');
        }


        function openWaitingDownload() {
            if(!disableWaiting) {
                var dlg = $("#modalLoadingDownload").dialog({
                    title: 'Processando',
                    height: 'auto',
                    width: 400,
                    modal: true,
                    resizable: false,
                    open: function(event, ui) {
                        $(this).parent().children().children(".ui-dialog-titlebar-close").hide();
                    }
                });
            }
        }

        function closeWaitingDownload() {
            $('#modalLoadingDownload').dialog('close');
        }

        function checkDownload() {
            var token = new Date().getTime();

            $('#download_token_value').val(token);
            
            openWaitingDownload();
            
            timerCheckDownload = window.setInterval(
                function () {
                    var cookieValue = getCookie('downloadToken');

                    if (cookieValue == token)
                    {
                        window.clearInterval(timerCheckDownload);
                        deleteCookie('downloadToken');
                        closeWaitingDownload();
                    }
            }, 1000);
        }

        function getCookie(strCookie) {
            var strName = strCookie + "=";
            var cookies = document.cookie.split(';');

            for (var i = 0; i < cookies.length; i++) {
                var strCookieValue = cookies[i];
                
                while (strCookieValue.charAt(0) == ' ') {
                    strCookieValue = strCookieValue.substring(1, strCookieValue.length);
                }
                
                if (strCookieValue.indexOf(strName) == 0) {
                    return strCookieValue.substring(strName.length, strCookieValue.length);
                }
            }
            return null;
        }

        function deleteCookie(strCookie) {
            var dtData = new Date();
            
            dtData.setTime(dtData.getTime() + (-1 * 24 * 60 * 60 * 1000));
            var strExpires = "; expires=" + dtData.toGMTString();

            document.cookie = strCookie + "=" + strExpires + "; path=/";
        }

        //Função para abrir os detalhes dos logs de importação
        function openDetalheStatus(idArquivoImportacao) {

            var dlg = $("#modalStatus").dialog({
                title: 'Log de Importação',
                height: 520,
                width: 720,
                modal: true,
                resizable: false,
                open: function () {
                    $(this).load('@Html.Raw(Url.Action("Index", "LogImportacao"))' + '?id=' + idArquivoImportacao);
                },
                beforeClose: function (event, ui) {
                    $('#modalStatus').empty();
                }
            });
        }

    </script>

</body>
</html>
