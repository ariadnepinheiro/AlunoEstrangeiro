@{
    Layout = null;
}

<div class="boxContent">

    <p>As colunas do arquivo de importação devem ser obrigatoriamente separadas por ponto-e-vírgula.</p>

    <table class="grid">
        
        @* Cabeçalho *@
        <thead>
            <tr>
                <th width="50px">Coluna</th>
                <th width="200px">Campo</th>
                <th width="100%">Descrição</th>
                <th width="120px">Tamanho Máximo</th> 
            </tr>
        </thead>

        @* Corpo *@
        <tbody>
            <tr class="gridrow">        
                <td width="50px">1</td>
                <td width="200px">COD_SERVIDOR</td>
                <td width="100%">Código do Servidor</td>
                <td width="120px">8</td>
            </tr>

            <tr class="gridrow_alternate">
                <td width="50px">2</td>
                <td width="200px">COD_OCORRENCIA</td>
                <td width="100%">Código da Ocorrência</td>
                <td width="120px">9</td>
            </tr>

            <tr class="gridrow">        
                <td width="50px">3</td>
                <td width="200px">DT_INICIO_OCORRENCIA</td>
                <td width="100%">Data de Início da Ocorrência</td>
                <td width="120px">DD/MM/AAAA</td>
            </tr>

            <tr class="gridrow_alternate">
                <td width="50px">4</td>
                <td width="200px">DT_FIM_OCORRENCIA</td>
                <td width="100%">Data Final da Ocorrência</td>
                <td width="120px">DD/MM/AAAA</td>
            </tr>

        </tbody>
    </table>      
</div>