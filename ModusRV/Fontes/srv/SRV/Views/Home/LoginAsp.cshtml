@model SRV.Models.DTO.Manager.Login

@{
    Layout = null;
}
<!DOCTYPE html>

<html>
<head>
    <script src="@Url.Content("~/Scripts/jquery-1.5.1.min.js")" type="text/javascript"></script>
</head>
<body>

    <form action="@ViewBag.PathAppAsp" method="post">
    
        <input type="hidden" id="param1" name="param1" value="@Model.Usuario" />
        <input type="hidden" id="param2" name="param2" value="@Model.Senha" />
        <input type="hidden" id="param3" name="param3" value="@Model.CdRegional" />

    </form>

    <script type="text/javascript">
        jQuery(document).ready(function () {
            $('#param1').closest("form").submit();
        });
    </script>
</body>
</html>