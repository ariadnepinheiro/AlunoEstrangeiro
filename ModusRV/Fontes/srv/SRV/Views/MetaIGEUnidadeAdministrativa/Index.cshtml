@model SRV.Models.DTO.FiltroMetaIGEUnidadeAdministrativa

@using SRV.Common.Extension
@using MvcContrib.UI.Grid

@using (Html.BeginForm())
{
    using (Html.BeginToolbar())
    {
        @Html.ToolbarItemSubmit(true, "btPesquisar")
        @Html.ToolbarItemLink(true, "Upload", null, null, "btImportar")
    }

    <div class="boxContent">
        @if (TempData["message"] != null)
        {
            <div class="boxInfo">@TempData["message"]</div>
        }

        @Html.ValidationSummary(true)

        <div class="formColumn">
            <table class="tableForm">
                <tr>
                    <td class="labelRight">@Html.LabelFor(m => m.IdUnidadeAdministrativa)</td>
                    <td>
                        @Html.DropDownListFor(m => m.IdUnidadeAdministrativa, (IEnumerable<SelectListItem>)Model.UnidadesAdministrativas ?? new List<SelectListItem>(), "", new { style = "width:250px;" })
                    </td>
                </tr>
            </table>
        </div>

        <div style="clear:both"></div>

        @if (Model != null)
        {
            if (Model.Metas != null)
            {
            @Html.Pager(Model.Metas)

            @Html.Grid(Model.Metas.Items).Columns(column =>
            {
                if (@Role.IsGranted("Administrador"))
                {
                    column.For(c => Html.ActionLink(" ", "", null, new { href = "#", @class = "icoLinkDelete", onclick = "deleteItem(this, '" + @Url.Action("Delete", "MetaIGEUnidadeAdministrativa") + "', " + @c.UnidadeAdministrativa.IdUnidadeAdministrativa + ", " + @c.AnoReferencia.IdAnoReferencia + ")" })).Named("Excluir").Attributes(width => "42px", align => "center").HeaderAttributes(width => "42px", align => "center").Encode(false);
                }
                    column.For(c => c.UnidadeAdministrativa.DesUnidadeAdministrativa).Named("Unidade Administrativa").Attributes(width => "100%").HeaderAttributes(width => "100%");
                    column.For(c => c.AnoReferencia.IdAnoReferencia).Named("Ano de Referência").Attributes(width => "130px", align => "right").HeaderAttributes(width => "130px");
                    column.For(c => c.MetaIge).Named("Meta").Attributes(width => "130px", align => "right").HeaderAttributes(width => "130px");
                
                }).Empty("Nenhum registro encontrado")
            }
        }
    </div>                       
}

<script type="text/javascript">

    jQuery(function ($) {
        
    });

</script>