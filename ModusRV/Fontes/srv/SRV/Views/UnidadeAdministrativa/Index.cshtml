@model SRV.Models.DTO.FiltroUnidadeAdministrativa

@using SRV.Common.Extension
@using MvcContrib.UI.Grid

@using (Html.BeginForm())
{
    using (Html.BeginToolbar())
    {
        @Html.ToolbarItemSubmit(true, "btPesquisar")
        @Html.ToolbarItemLink(true, "Upload", null, null, "btImportar")
    }

    <div class="boxContent">
        @if (TempData["message"] != null)
        {
            <div class="boxInfo">@TempData["message"]</div>
        }

        @Html.ValidationSummary(true)

        <div class="formColumn">
            <table class="tableForm">
                <tr>
                    <td class="labelRight">@Html.LabelFor(m => m.IdRegional)</td>
                    <td>
                        @Html.DropDownListFor(m => m.IdRegional, (IEnumerable<SelectListItem>)Model.Regionais ?? new List<SelectListItem>(), "", new { style = "width:405px;" })
                        @Html.ValidationMessageFor(m => m.IdRegional)
                    </td>
                </tr>
                <tr>
                    <td class="labelRight">@Html.LabelFor(m => m.IdTipoUnidadeAdministrativa)</td>
                    <td>
                        @Html.DropDownListFor(m => m.IdTipoUnidadeAdministrativa, (IEnumerable<SelectListItem>)Model.TiposUnidadesAdministrativa ?? new List<SelectListItem>(), "", new { style = "width:405px;" })
                    </td>
                </tr>
            </table>
        </div>

        <div style="clear:both"></div>

        @if (Model.Unidades != null)
        {
            @Html.Pager(Model.Unidades)

            @Html.Grid(Model.Unidades.Items).Columns(column =>
            {
                if (@Role.IsGranted("Administrador"))
                {
                    column.For(c => Html.ActionLink(" ", "", null, new { href = "#", @class = "icoLinkDelete", onclick = "deleteItem(this, '" + @Url.Action("Delete", "UnidadeAdministrativa") + "', " + @c.IdUnidadeAdministrativa + ")" })).Named("Excluir").Attributes(width => "42px", align => "center").HeaderAttributes(width => "42px", align => "center").Encode(false);
                }
                column.For(c => c.IdUnidadeAdministrativa).Named("Código").Attributes(width => "80px", align => "right").HeaderAttributes(width => "80px");
                column.For(c => c.DesUnidadeAdministrativa).Named("Unidade Administrativa").Attributes(width => "60%").HeaderAttributes(width => "60%");
                column.For(c => c.Regional != null ? c.Regional.DesUnidadeAdministrativa : null).Named("Regional").Attributes(width => "40%").HeaderAttributes(width => "40%");
                column.For(c => c.TipoUnidadeAdministrativa != null ? c.TipoUnidadeAdministrativa.DesTipoUnidAdm : null).Named("Tipo Unidade Administrativa").Attributes(width => "300px").HeaderAttributes(width => "300px");
            }).Empty("Nenhum registro encontrado")
        }
    </div>                       
}
