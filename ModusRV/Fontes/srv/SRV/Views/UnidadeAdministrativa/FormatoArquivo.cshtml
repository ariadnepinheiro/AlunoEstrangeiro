@{
    Layout = null;
}

<div class="boxContent">

    <p>As colunas do arquivo de importação devem ser obrigatoriamente separadas por ponto-e-vírgula.</p>
    <p>Unidades Regionais</p>
    <table class="grid">
        
        @* Cabeçalho *@
        <thead>
            <tr>
                <th width="50px">Coluna</th>
                <th width="200px">Campo</th>
                <th width="100%">Descrição</th>
                <th width="120px">Tamanho Máximo</th> 
            </tr>
        </thead>

        @* Corpo *@
        <tbody>
            <tr class="gridrow">
                <td width="50px">1</td>
                <td width="200px">COD_UNIDADE_ADMINISTRATIVA</td>
                <td width="100%">Código da Unidade Administrativa</td>
                <td width="120px">6</td>
            </tr>

            <tr class="gridrow_alternate">        
                <td width="50px">2</td>
                <td width="200px">DES_UNIDADE_ADMINISTRATIVA</td>
                <td width="100%">Descrição Unidade Administrativa</td>
                <td width="120px">200</td>
            </tr>

            <tr class="gridrow">        
                <td width="50px">3</td>
                <td width="200px">COD_CENSO (Opcional)</td>
                <td width="100%">Código do Censo</td>
                <td width="120px">8</td>
            </tr>

        </tbody>
    </table>      
