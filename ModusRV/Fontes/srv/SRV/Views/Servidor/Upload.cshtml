@model IList<SRV.Models.Domain.ArquivoImportacao>

@using SRV.Common.Extension
@using MvcContrib.UI.Grid

@using (Html.BeginForm("Upload", "Servidor", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmUpload" }))
{
    using (Html.BeginToolbar())
    {
        @Html.ToolbarItemJS(true, "openFormatoArquivo", new { id = "formatoArquivo" }, "btFormatoArquivo")
        @Html.ToolbarItemLink(true, "Upload", null, null, "btAtualizar")
        @Html.ToolbarItemLink(true, "Index", null, null, "btVoltarPesquisa")
    }
    
    <div class="boxContent">
        @if (TempData["message"] != null)
        {
            <div class="boxInfo">@TempData["message"]</div>
        }

        @Html.ValidationSummary(true)

        <div style="background-color: #F8F8F8 ;
                    border: Gray 1px solid;
                    padding: 5px 10px 5px 10px;
                    margin: 5px 5px 5px 5px;
                    color: Gray;
                    -moz-border-radius: 5px;
                    border-radius: 5px;">

            Caso o arquivo de importação não esteja no formato ISO(Windows) poderão ocorrer problemas na importação dos dados.
            É recomendável a utilização do Microsoft Excel para geração dos arquivos ".csv"
        </div>

        <div >
            <label class="labelRight">Enviar novo arquivo</label>
            <input id="fileUpload" type="file" name="fileUpload" size="50" />
            <a href="#" id="enviarArquivo">Enviar arquivo</a>
        </div>

        <br/>
        <div class="labelTitulo">Arquivos</div>

        @Html.Grid(Model).Columns(column =>
   {
       column.For(c => c.StatusImportacao != SRV.Models.Domain.StatusImportacao.Concluido ? Html.ActionLink(" ", "Import", new { id = @c.IdArquivoImportacao }, new { @class = "icoLinkImport", onclick = "openWaiting()" }) : null).Named("Importar").Attributes(width => "60px", align => "center").HeaderAttributes(width => "60px", align => "center").Encode(false);
       column.For(c => c.StatusImportacao != SRV.Models.Domain.StatusImportacao.Concluido ? Html.ActionLink(" ", "", null, new { href = "#", @class = "icoLinkDelete", onclick = "deleteItemAndRedirect(this, '" + @Url.Action("DeleteImport", "Servidor") + "', '" + @Url.Action("Upload", "Servidor") + "', " + @c.IdArquivoImportacao + ")" }) : null).Named("Excluir").Attributes(width => "45px", align => "center").HeaderAttributes(width => "45px", align => "center").Encode(false);
       column.For(c => c.DesArquivoOriginal).Named("Arquivo").Attributes(width => "100%").HeaderAttributes(width => "100%");
       column.For(c => c.NmLinhas).Named("Qtd. linhas").Attributes(width => "80px", align => "right").HeaderAttributes(width => "80px");
       column.For(c => c.DtUpload).Named("Data do envio").Attributes(width => "130px").HeaderAttributes(width => "130px");
       column.For(c => c.StatusImportacao.ToDescription()).Named("Status").Attributes(width => "130px").HeaderAttributes(width => "130px");
       column.For(c => c.StatusImportacao == SRV.Models.Domain.StatusImportacao.Falha ? @Html.ActionLink(" ", "", null, new { href = "#", @class = "icoLinkOpen", onclick = "openDetalheStatus(" + c.IdArquivoImportacao + ")" }) : @Html.Label("-")).Named("Log").Attributes(width => "40px", align => "center").HeaderAttributes(width => "40px");

   }).Empty("Nenhum registro encontrado")

    </div>  
    
}

<script type="text/javascript">

    $(function () {
        $('#enviarArquivo').button();

        $('#enviarArquivo').click(function () {

            $('#frmUpload').submit();
        });

        $('#formatoArquivo').click(function () {

            openFormatoArquivo();
        });

    });

    function openFormatoArquivo() {

        var dlg = $("#modalFormatoArquivo").dialog({
            title: 'Formato do Arquivo',
            height: 'auto',
            width: 750,
            position: ['center', 120],
            modal: true,
            resizable: false,
            open: function () {
                $(this).load('@Url.Action("FormatoArquivo", "Servidor")');
            },
            beforeClose: function (event, ui) {
                $('#modalFormatoArquivo').empty();
            }
        });

    }

</script>
