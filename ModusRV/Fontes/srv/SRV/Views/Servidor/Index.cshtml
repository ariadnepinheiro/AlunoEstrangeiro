@model SRV.Models.DTO.FiltroServidor

@using SRV.Common.Extension
@using MvcContrib.UI.Grid

@using (Html.BeginForm())
{
    using (Html.BeginToolbar())
    {
        @Html.ToolbarItemSubmit(true, "btPesquisar")
        @Html.ToolbarItemLink(true, "Upload", null, null, "btImportar")
    }

    <div class="boxContent">
        @if (TempData["message"] != null)
        {
            <div class="boxInfo">@TempData["message"]</div>
        }

        @Html.ValidationSummary(true)

        <div class="formColumn">
            <table class="tableForm">
                <tr>
                    <td class="labelRight">@Html.LabelFor(m => m.Nome)</td>
                    <td>
                        @Html.TextBoxFor(m => m.Nome, new { style = "width: 300px", maxlength = "50" })
                    </td>
                </tr>
                <tr>
                    <td class="labelRight">@Html.LabelFor(m => m.Cpf)</td>
                    <td>
                        @Html.TextBoxFor(m => m.Cpf, new { style = "width: 100px", maxlength = "11" })
                    </td>
                </tr>
            </table>
        </div>

        <div style="clear:both"></div>

        @if (Model.Servidores != null)
        {
            @Html.Pager(Model.Servidores)

            @Html.Grid(Model.Servidores.Items).Columns(column =>
            {
                if (@Role.IsGranted("Administrador"))
                {
                    column.For(c => Html.ActionLink(" ", "", null, new { href = "#", @class = "icoLinkDelete", onclick = "deleteItem(this, '" + @Url.Action("Delete", "Servidor") + "', " + @c.IdServidor + ")" })).Named("Excluir").Attributes(width => "42px", align => "center").HeaderAttributes(width => "42px", align => "center").Encode(false);
                }
                column.For(c => c.IdServidor).Named("Código").Attributes(width => "80px", align => "right").HeaderAttributes(width => "80px");
                column.For(c => c.DesNomeServidor).Named("Nome").Attributes(width => "100%").HeaderAttributes(width => "100%");
                column.For(c => String.Format(@"{0:000\.000\.000\-00}", c.DesCpfServidor)).Named("CPF").Attributes(width => "100px").HeaderAttributes(width => "100px");
                column.For(c => c.IdFuncional).Named("Id Funcional").Attributes(width => "200px").HeaderAttributes(width => "200px");
                column.For(c => c.Vinculo).Named("Vínculo").Attributes(width => "80px").HeaderAttributes(width => "80px");
            }).Empty("Nenhum registro encontrado")
        }
    </div>                       
}

<script type="text/javascript">

    jQuery(function ($) {

        $("#Cpf").mask("??99999999999", { placeholder: "" });

        $("#Cpf").focusin(function () {
            $('#Cpf').unmask().mask("??99999999999", { placeholder: "" });
            $('#Cpf').focus();
        });

        $("#Cpf").focusout(function () {

            if ($('#Cpf').val() != "") {
                if ($("#Cpf").val().length == 11) {
                    $("#Cpf").unmask().mask("999.999.999-99");
                } else {
                    alert("Cpf inválido");
                    $("#Cpf").val("");
                    $("#Cpf").unmask().mask("??99999999999", { placeholder: "" });
                    $('#Cpf').focus();
                }
            }
        });

    });

</script>