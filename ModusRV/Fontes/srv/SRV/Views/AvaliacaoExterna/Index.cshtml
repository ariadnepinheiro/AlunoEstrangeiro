@model IList<SRV.Models.Domain.AvaliacaoExterna>

@using SRV.Common.Extension
@using MvcContrib.UI.Grid


@using (Html.BeginForm())
{
    using (Html.BeginToolbar())
    {
        @Html.ToolbarItemLink(@Role.IsGranted("Administrador"), "Create", null, null, "btNovo")
    }

    <div class="boxContent">
        @if (TempData["message"] != null)
        {
            <div class="boxInfo">@TempData["message"]</div>
        }

        @Html.ValidationSummary(true)

        <br/>

        @if (Model != null)
        {
            @Html.Grid(Model).Columns(column =>
            {
                if (@Role.IsGranted("Administrador"))
                {
                    column.For(c => Html.ActionLink(" ", "Edit", new { id = @c.IdAvaliacaoExterna }, new { @class = "icoLinkOpen" })).Named("Abrir").Attributes(width => "35px", align => "center").HeaderAttributes(width => "35px", align => "center").Encode(false);
                    column.For(c => Html.ActionLink(" ", "", null, new { href = "#", @class = "icoLinkDelete", onclick = "deleteItem(this, '" + @Url.Action("Delete", "AvaliacaoExterna") + "', " + @c.IdAvaliacaoExterna + ")" })).Named("Excluir").Attributes(width => "42px", align => "center").HeaderAttributes(width => "42px", align => "center").Encode(false);
                }

                column.For(c => c.IdAvaliacaoExterna).Named("Código").Attributes(width => "44px", align => "right").HeaderAttributes(width => "44px");
                column.For(c => c.DesAvaliacaoExterna).Named("Descrição").Attributes(width => "100%").HeaderAttributes(width => "100%");
                column.For(c => c.DesPeriodoAvaliacao).Named("Período").Attributes(width => "300px").HeaderAttributes(width => "300px");
            }).Empty("Nenhum registro encontrado")
        }
    </div>                       
}
