@{
    Layout = null;
}

<div class="boxContent">

    <p>As colunas do arquivo de importação devem ser obrigatoriamente separadas por ponto-e-vírgula.</p>

    <p>Os campos decimais devem utilizar a vírgula (,) como separador.</p>

    <table class="grid">
        
        @* Cabeçalho *@
        <thead>
            <tr>
                <th width="50px">Coluna</th>
                <th width="200px">Campo</th>
                <th width="100%">Descrição</th>
                <th width="120px">Tamanho Máximo</th> 
            </tr>
        </thead>

        @* Corpo *@
        <tbody>
            <tr class="gridrow">        
                <td width="50px">1</td>
                <td width="200px">CICLO</td>
                <td width="100%">Ano Base da ocorrência</td>
                <td width="120px">4</td>
            </tr>

            <tr class="gridrow_alternate">
                <td width="50px">2</td>
                <td width="200px">CENSO_UNIDADE</td>
                <td width="100%">Censo da Unidade</td>
                <td width="120px">8</td>
            </tr>

            <tr class="gridrow">        
                <td width="50px">3</td>
                <td width="200px">UNIDADE_ADMINISTRATIVA</td>
                <td width="100%">Código da Unidade</td>
                <td width="120px">6</td>
            </tr>

			<tr class="gridrow_alternate">
				<td width="50px">4</td>
				<td width="200px">TURMA</td>
				<td width="100%">Turma</td>
				<td width="120px">20</td>
			</tr>

			<tr class="gridrow">
				<td width="50px">5</td>
				<td width="200px">PERÍODO</td>
				<td width="100%">Período da realização da prova</td>
				<td width="120px">1</td>
			</tr>

			<tr class="gridrow_alternate">
				<td width="50px">6</td>
				<td width="200px">MATRÍCULA</td>
				<td width="100%">Matrícula do Docente</td>
				<td width="120px">8</td>
			</tr>
			
			<tr class="gridrow">
				<td width="50px">7</td>
				<td width="200px">DATA</td>
				<td width="100%">Data da Prova</td>
				<td width="120px">10</td>
			</tr>
			
			<tr class="gridrow_alternate">
				<td width="50px">8</td>
				<td width="200px">HORA</td>
				<td width="100%">Hora da Prova</td>
				<td width="120px">5</td>
			</tr>
			
			<tr class="gridrow">
				<td width="50px">9</td>
				<td width="200px">AVALIAÇÃO</td>
				<td width="100%">Código da Avaliação</td>
				<td width="120px">1</td>
			</tr>
        </tbody>
    </table>      
</div>