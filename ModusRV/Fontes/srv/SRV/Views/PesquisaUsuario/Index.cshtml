@model SRV.Models.DTO.PesquisaUsuario

@using SRV.Common.Extension
@using MvcContrib.UI.Grid

@{
    Layout = null;

    AjaxOptions ajaxOpts = new AjaxOptions
    {
        OnSuccess = "OnSuccessUsuario",
        OnFailure = "OnFailureUsuario"
    };
}

@using (Ajax.BeginForm(ajaxOpts))
{
    using (Html.BeginToolbar())
    {
        @Html.ToolbarItemSubmit(true, "btPesquisar")
    }

    <div class="boxContent">

        @Html.ValidationSummary(true)

        <div class="formColumn">
            <table class="tableForm">
                <tr>
                    <td class="labelRight">@Html.LabelFor(m => m.Matricula)</td>
                    <td>
                        @Html.TextBoxFor(m => m.Matricula, new { style = "width:150px;", maxlength = 50  })<br/>
                    </td>
                </tr>
                <tr>
                    <td class="labelRight">@Html.LabelFor(m => m.Nome)</td>
                    <td>
                        @Html.TextBoxFor(m => m.Nome, new { style = "width: 300px", maxlength = "50" })
                    </td>
                </tr>
            </table>
        </div>    
        <div style="clear:both"></div>
    
        @if (Model != null && Model.Usuarios != null)
        {
            @Html.Pager(Model.Usuarios);

            using (@Html.BeginScroller())
            {
                @Html.Grid(Model.Usuarios.Items).Columns(column =>
                {
                    column.For(c => Html.ActionLink(" ", "", null, new { href = "#", onclick = "returnUsuario(" + @c.Id + ", '" + @c.Login + "', '" + @Html.Encode(@c.Nome.Replace("\\", "&#92;")) + "')", @class = "icoLinkSelect" })).Named("Sel.").Attributes(width => "30px").HeaderAttributes(width => "30px");

                    column.For(c => c.Login).Named("Matrícula").Attributes(width => "55px", align => "right").HeaderAttributes(width => "55px");
                    column.For(c => c.Nome).Named("Nome").Attributes(width => "350px").HeaderAttributes(width => "350px");
                }).Empty("Nenhum registro encontrado")
            }
        }
    </div>
}

<script type="text/javascript">

    jQuery(function ($) {

    });

    function returnUsuario(idUsuario, loginUsuario, noUsuario) {
        eval($("#modalButtonHitUsuario").dialog("option", "callback") + "({0}, '{1}', '{2}')".format(idUsuario, loginUsuario, htmlDecode(noUsuario)));

        $("#modalButtonHitUsuario").dialog('close');
    }

    function OnSuccessUsuario(data) {
        $("#modalButtonHitUsuario").empty().append(data);
    }

    function OnFailureUsuario(request, error) {
        alert("Ocorreu um erro na requisição: " + error);
    }

</script>