@model SRV.Models.DTO.Paging<SRV.Models.Domain.Ocorrencia>

@using SRV.Common.Extension
@using MvcContrib.UI.Grid


@using (Html.BeginForm())
{
    using (Html.BeginToolbar())
    {
        @Html.ToolbarItemLink(@Role.IsGranted("Administrador"), "Create", null, null, "btNovo")
    }

    <div class="boxContent">
        @if (TempData["message"] != null)
        {
            <div class="boxInfo">@TempData["message"]</div>
        }

        @Html.ValidationSummary(true)

        <br/>

        @if (Model != null)
        {
            @Html.Pager(Model)

            @Html.Grid(Model.Items).Columns(column =>
            {
                if (@Role.IsGranted("Administrador"))
                {
                    column.For(c => Html.ActionLink(" ", "Edit", new { id = @c.IdOcorrencia }, new { @class = "icoLinkOpen" })).Named("Abrir").Attributes(width => "35px", align => "center").HeaderAttributes(width => "35px", align => "center").Encode(false);
                    column.For(c => Html.ActionLink(" ", "", null, new { href = "#", @class = "icoLinkDelete", onclick = "deleteItem(this, '" + @Url.Action("Delete", "Ocorrencia") + "', " + @c.IdOcorrencia + ")" })).Named("Excluir").Attributes(width => "42px", align => "center").HeaderAttributes(width => "42px", align => "center").Encode(false);
                }
                column.For(c => c.IdOcorrencia).Named("Código").Attributes(width => "44px", align => "right").HeaderAttributes(width => "44px");
                column.For(c => c.DesOcorrencia).Named("Ocorrência").Attributes(width => "100%").HeaderAttributes(width => "100%");
                column.For(c => c.TipoOcorrencia.DesTipoOcorrencia).Named("Tipo Ocorrência").Attributes(width => "300px").HeaderAttributes(width => "300px");
            }).Empty("Nenhum registro encontrado")
        }
    </div>                       
}
