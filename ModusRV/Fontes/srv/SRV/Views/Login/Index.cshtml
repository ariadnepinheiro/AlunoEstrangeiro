@model SRV.Models.DTO.Login

@{
    Layout = null;
}
<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge"/>
    <title>SEEDUC - Remuneração Variável</title>
    <link href="@Url.Content("~/Content/images/favicon.ico")" rel="Shortcut Icon" />
    <link href="@Url.Content("~/Content/Login.css")" rel="stylesheet" type="text/css" />
    
    <!--[if lte IE 7]>
        <style type="text/css">
            img { behavior: url(@Url.Content("~/Content/iepngfix.htc")) }    
        </style>
    <![endif]-->

    <link href="@Url.Content("~/Content/smoothness/jquery-ui-1.8.16.custom.css")" rel="stylesheet" type="text/css" />

    <script src="@Url.Content("~/Scripts/jquery-1.5.1.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/jquery-ui-1.8.11.min.js")" type="text/javascript"></script>

    <script src="@Url.Content("~/Scripts/jquery.unobtrusive-ajax.js")" type="text/javascript"></script>
    
</head>
<body>

    <div class="boxHeaderLogin">
        <img alt="" src="@Url.Content("~/Content/images/topo.png")" />
    </div>

    <div class="boxFormLogin">

        @using (Html.BeginForm())
        {
                
            @Html.ValidationSummary(true)
                            
            <table class="tableForm">
                <tr>
                    <td>@Html.LabelFor(m => m.Usuario)</td>
                    <td>
                        @Html.TextBoxFor(m => m.Usuario, new { style = "width:150px; height: 15px;" })<br/>
                    </td>
                    <td></td>
                    <td>@Html.LabelFor(m => m.Senha)</td>
                    <td>
                        @Html.PasswordFor(m => m.Senha, new { style = "width:150px; height: 15px;" })<br/>
                    </td>
                    <td></td>
                    <td>@Html.LabelFor(m => m.Ciclo)</td>
                    <td>
                        @Html.DropDownListFor(m => m.Ciclo, (IEnumerable<SelectListItem>)@Model.Ciclos ?? new List<SelectListItem>(), "", new { style = "width:100px;" })<br/>
                    </td>
                    <td></td>
                    <td align="left" style="vertical-align: middle">
                        <img id="btEntrar" alt="" style="vertical-align: middle" src="@Url.Content("~/Content/images/bt_entrar.png")" />
                    </td>
                    <td><a href="#" id="showEsqueciSenha">Esqueci minha senha</a> <br /></td>
                </tr>

                <tr>
                    <td></td>
                    <td>
                        @Html.ValidationMessageFor(m => m.Usuario)
                    </td>
                    <td></td>
                    <td></td>
                    <td>
                        @Html.ValidationMessageFor(m => m.Senha)
                    </td>
                    <td></td>
                    <td></td>
                    <td>
                        @Html.ValidationMessageFor(m => m.Ciclo)
                    </td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>

            </table>
            
            if (TempData["message"] != null)
            {
                <div class="boxMessage">@TempData["message"]</div>
            }
        }

    </div>

    <div class="boxFormLoginBottom">
        <img alt="" src="@Url.Content("~/Content/images/fotos_login.png")" />
    
        @{Html.RenderPartial("Version");}
    </div>

    <div id="modalEsqueciSenha" title="Esqueci Minha Senha" style="display:none;"></div>

    <script type="text/javascript">

        jQuery(function ($) {
            @* Desabilita cache para ajax
               Define método tradicional para serialização da url, por causa do envio de array como parâmetro *@
            $.ajaxSetup({ 
                cache: false, 
                traditional: true,
                beforeSend: function() {
                    //openWaiting();
                },
                complete: function(){
                   // closeWaiting();
                }
            });
        });

        $(document).ajaxError(function (event, request, options) {
            if (request.status === 403) {
                alert("Sua sessão expirou. Por favor efetue novo login");
            }
        });

        jQuery(document).ready(function () {
            jQuery("#Usuario").focus();
        });

        jQuery("#btEntrar").click(function (e) {

            $('#btEntrar').closest("form").submit();
        });

        jQuery("#Usuario, #Senha, #Ciclo").keypress(function (e) {
            // if the key pressed is the enter key
            if (e.which == 13) {
                $('#btEntrar').closest("form").submit();
            }
        });

        jQuery('#showEsqueciSenha').click(function () {

            var dlg = $("#modalEsqueciSenha").dialog({
                title: 'Esqueci minha senha',
                height: 'auto',
                width: 400,
                modal: true,
                resizable: false,
                open: function () {
                    $(this).load('@Url.Action("Solicitacao", "NovaSenha")');
                },
                beforeClose: function (event, ui) {
                    $('#modalEsqueciSenha').empty();
                }
            });
        });

    </script>

</body>
</html>
