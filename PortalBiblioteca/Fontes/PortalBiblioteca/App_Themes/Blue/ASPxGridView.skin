<dxwgv:ASPxGridView runat="server"
    CssFilePath="~/App_Themes/Blue/{0}/styles.css" CssPostfix="Office2003_Blue"
	EnableCallbackCompression="true">
	<SettingsPager>
        <NextPageButton>
            <Image AlternateText="Próximo" Url="~/App_Themes/Blue/GridView/ct_next.png" 
                UrlDisabled="~/App_Themes/Blue/GridView/ctd_next.png" />
        </NextPageButton>
        <PrevPageButton>
            <Image AlternateText="Anterior" Url="~/App_Themes/Blue/GridView/ct_back.png" 
                UrlDisabled="~/App_Themes/Blue/GridView/ctd_back.png" />
        </PrevPageButton>
        <Summary AllPagesText="Páginas: {0} - {1} ({2} itens)" Text="Página {0} de {1} ({2} itens)" />
    </SettingsPager>
    <SettingsBehavior ConfirmDelete="true" />
    <SettingsLoadingPanel Text="Carregando" Mode="ShowAsPopup" ShowImage="true" ImagePosition="Left"/>
    <SettingsPager AlwaysShowPager="True">
    </SettingsPager>
    <Settings ShowTitlePanel="True" />
    <SettingsText ConfirmDelete="Confirma a remoção?" EmptyDataRow="Não existem dados." />
	<Images ImageFolder="~/App_Themes/Blue/{0}/">
        <CollapsedButton Height="12px" 
            Url="~/App_Themes/Blue/GridView/gvCollapsedButton.png" 
            Width="11px" />
        <ExpandedButton Height="12px" 
            Url="~/App_Themes/Blue/GridView/gvExpandedButton.png" Width="11px" />
        <DetailCollapsedButton Height="12px" 
            Url="~/App_Themes/Blue/GridView/gvCollapsedButton.png" 
            Width="11px" />
        <DetailExpandedButton Height="12px" 
            Url="~/App_Themes/Blue/GridView/gvExpandedButton.png" Width="11px" />
        <FilterRowButton Height="13px" Width="13px" />
    </Images>	
    <SettingsText Title="&lt;img src='../App_Themes/Blue/GridView/top_r.gif' width='15' height='25' align='right' /&gt;&lt;div class='tab-top_ct' align='center'&gt;&lt;img src='../App_Themes/Blue/GridView/ico_grid.png' width='21' height='20' align=''  /&gt;&lt;/div&gt;&lt;div class='tab-top_dv'&gt;&lt;/div&gt;|Tabela:|" />
    <StylesPager>
        <CurrentPageNumber BackColor="#0353AB">
        </CurrentPageNumber>
        <PageNumber Font-Names="Verdana" Font-Size="10px" ForeColor="White">
        </PageNumber>
        <Summary Font-Names="Verdana" Font-Size="10px" ForeColor="White">
        </Summary>
    </StylesPager>
    <StylesEditors>
                <ProgressBar Height="25px">
                </ProgressBar>
    </StylesEditors>
    <Styles>
        <Header CssClass="tab-lab_c">
        </Header>
        <Row CssClass="tab-mid_c">
        </Row>
        <EditForm CssClass="tab-edit_form"></EditForm>
        <AlternatingRow CssClass="tab-mid_ca">
        </AlternatingRow>
        <FocusedRow BackColor="CornflowerBlue"></FocusedRow>
        <Header SortingImageSpacing="5"></Header>
	    <LoadingPanel ImageSpacing="10px" />
        <FilterRow BackColor="#00528E">
        </FilterRow>
        <PagerBottomPanel CssClass="tab-bas_c">
        </PagerBottomPanel>
          <TitlePanel CssClass="tab-top_c">
        </TitlePanel>
        <CommandColumn CssClass="tab-cell" Wrap="False"></CommandColumn>
        <Cell CssClass="tab-cell"></Cell>
    </Styles>	
</dxwgv:ASPxGridView>

