<dxe:ASPxDateEdit runat="server" Font-Names="Verdana" Font-Size="Smaller" EditFormat="Custom" EditFormatString="dd/MM/yyyy" MinDate="01/01/1900">
<CalendarProperties ClearButtonText="Limpar" TodayButtonText="Hoje" ></CalendarProperties>
<ClientSideEvents ParseDate="function (s, e){ return ASPxDateEditOnParseDate(s, e);}" />
<ClientSideEvents KeyUp="function (s, e){ return ASPxDateEditMaskData(s, e); }" />
<ClientSideEvents KeyPress="function (s, e){ SomentePermitirNumeros(s, e.htmlEvent); }" />
<ClientSideEvents LostFocus="function (s, e){ return ASPxDateEditLostFocus(s, e); }" />
</dxe:ASPxDateEdit>

