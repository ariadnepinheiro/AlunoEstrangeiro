    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" restartOnExternalChanges="true" />
    <section name="seeducInfra" type="Seeduc.Infra.Configuration.SectionHandler, Seeduc.Infra" restartOnExternalChanges="true" />
  </configSections>

  <techne>
    <database>
      <!--Informaçoes para servidor de bando de dados-->
      <!--Desenvolvimento: 10.11.69.201 | Prototipacao (d-1): 10.11.69.197 | Homologação: 10.11.69.200 | Fechamento: 10.11.69.199-->
      <add key="Login" value="Provider=SQLOLEDB.1;Application Name=Techne LyceumWeb;Initial Catalog=Hades;Data Source=10.11.69.201;Connect Timeout=1800" />
      <add key="Hades" value="Provider=SQLOLEDB.1;Application Name=Techne LyceumWeb;Initial Catalog=Hades;Data Source=10.11.69.201;Connect Timeout=1800" />
      <add key="HadesLyc" value="Provider=SQLOLEDB.1;Application Name=Techne LyceumWeb;Initial Catalog=Hades;Data Source=10.11.69.201;Connect Timeout=1800" />
      <add key="Lyceum" value="Provider=SQLOLEDB.1;Application Name=Techne LyceumWeb;Initial Catalog=Lyceum;Data Source=10.11.69.201;Connect Timeout=1800" />
    </database>
  </techne>

  <log4net debug="false">
    <appender name="LogRollingFileAppender" type="log4net.Appender.RollingFileAppender,log4net">
      <file type="log4net.Util.PatternString" value="C:\Logs\Gestao\Seeduc.Infra.Log_" />
      <appendToFile value="true" />
      <rollingStyle value="Date" />
      <staticLogFileName value="false" />
      <datePattern value="yyyy-MM-dd'.txt'" />
      <layout type="log4net.Layout.PatternLayout,log4net">
        <param name="ConversionPattern" value="%newline[%date - %logger]%newline%-5level%newline%message%newline" />
      </layout>
    </appender>
    <root>
      <priority value="ERROR" />
      <appender-ref ref="LogRollingFileAppender" />
    </root>
    <category name="Seeduc.Infra">
      <priority value="ERROR" />
    </category>
  </log4net>

  <seeducInfra>
    <contextQuery executionTimeout="60">
      <bulk enable="true" size="15" />
    </contextQuery>
    <log enable="true" />
  </seeducInfra>

