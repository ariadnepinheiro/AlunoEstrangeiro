  <system.web>
    <httpRuntime enableVersionHeader="false" maxRequestLength="51200" executionTimeout="9000" />
    <httpCookies httpOnlyCookies="true" requireSSL="false" /> <!-- Valores padrão - httpOnlyCookies="false" requireSSL="false" -->
	
    <browserCaps>
      <filter>
        <case match="Opera[/](?'version'(?'major'\d+)(?'minor'\.\d+)(?'letters'\w*))">
          <filter match="[5-9]" with="${major}">
            w3cdomversion=1.0
            tagwriter=System.Web.UI.HtmlTextWriter
          </filter>
        </case>
        <case match="^Mozilla/(?'version'(?'major'\d+)(?'minor'\.\d+)(?'letters'\w*)).*">
          <case match="^[4-9]\." with="${version}">
            <filter match="^[5-9]*" with="${minor}">
              ecmascriptversion=1.3
              tagwriter=System.Web.UI.HtmlTextWriter
              css2=true
              w3cdomversion=1.0
              xml=true
            </filter>
          </case>
        </case>
      </filter>
    </browserCaps>

    <!-- Habilita algumas características para browser IE5 ou superior. Não tem efeito sobre outros browsers -->
    <!-- Não pode ser usado o smartNavigation porque ele provoca múltiplos requests em cada página -->
    <!-- validateRequest setado para false por causa do erro "A potentially dangerous Request.Form value was detected from the client" -->
    <!-- Apesar da mensagem de erro citada no comentário acima, valor "true" de validateRequest foi novamente atribuído (vulnerabilidade) -->
    <pages validateRequest="true" viewStateEncryptionMode="Always" smartNavigation="false" theme="Blue" maintainScrollPositionOnPostBack="true">
      <controls>
        <add tagPrefix="asp" namespace="System.Web.UI" assembly="System.Web.Extensions, Version=3.5.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" />
        <add tagPrefix="asp" namespace="System.Web.UI.WebControls" assembly="System.Web.Extensions, Version=3.5.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" />
        <add tagPrefix="lyweb" namespace="Techne.Lyceum.Web" assembly="Techne.Lyceum.Control" />
        <add tagPrefix="tweb" namespace="Techne.Web" assembly="Techne.Lyceum.Control" />
        <add tagPrefix="techne" namespace="Techne.Controls" assembly="Techne.Lyceum.Infra" />
        <add tagPrefix="dxwgv" namespace="DevExpress.Web.ASPxGridView" assembly="DevExpress.Web.ASPxGridView.v9.2, Version=9.2.13.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" />
        <add tagPrefix="dxe" namespace="DevExpress.Web.ASPxEditors" assembly="DevExpress.Web.ASPxEditors.v9.2, Version=9.2.13.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" />
        <add tagPrefix="dxtc" namespace="DevExpress.Web.ASPxTabControl" assembly="DevExpress.Web.v9.2, Version=9.2.13.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" />
        <add tagPrefix="dxw" namespace="DevExpress.Web.ASPxClasses" assembly="DevExpress.Web.v9.2, Version=9.2.13.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" />
        <add tagPrefix="dxpc" namespace="DevExpress.Web.ASPxPopupControl" assembly="DevExpress.Web.v9.2, Version=9.2.13.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" />
        <add tagPrefix="dxrp" namespace="DevExpress.Web.ASPxRoundPanel" assembly="DevExpress.Web.v9.2, Version=9.2.13.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" />
        <add tagPrefix="dxp" namespace="DevExpress.Web.ASPxPanel" assembly="DevExpress.Web.v9.2, Version=9.2.13.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" />
        <add tagPrefix="rsweb" namespace="Microsoft.Reporting.WebForms" assembly="Microsoft.ReportViewer.WebForms, Version=9.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
      </controls>
    </pages>

    <httpHandlers>
      <remove path="*.asmx" verb="*" />
      <add path="*.asmx" verb="*" type="System.Web.Script.Services.ScriptHandlerFactory, System.Web.Extensions, Version=3.5.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" validate="false" />
      <add path="*_AppService.axd" verb="*" type="System.Web.Script.Services.ScriptHandlerFactory, System.Web.Extensions, Version=3.5.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" validate="false" />
      <add path="ScriptResource.axd" verb="GET,HEAD" type="System.Web.Handlers.ScriptResourceHandler, System.Web.Extensions, Version=3.5.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" validate="false" />
      <add path="Reserved.ReportViewerWebControl.axd" verb="*" type="Microsoft.Reporting.WebForms.HttpHandler, Microsoft.ReportViewer.WebForms, Version=9.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" validate="false" />
    </httpHandlers>

