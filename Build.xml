    <SvnVersion LocalPath="$(LyceumRNDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(LyceumRNAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <MSBuild Projects="$(PortalBibliotecaSolution)" Targets="$(Target)" Properties="Configuration=$(Configuration);OutDir=$(PortalBibliotecaBinDir)\;WebProjectOutputDir=$(PortalBibliotecaPublishDir);" />

    <ItemGroup>
      <Xmls Include="$(PortalBibliotecaBinDir)\*.xml" />
      <Pdbs Include="$(PortalBibliotecaBinDir)\*.pdb" />
    </ItemGroup>
    <Delete Files="@(Xmls)" />
    <Delete Files="@(Pdbs)" />

    <AspNetCompiler VirtualPath="/PortalBiblioteca" PhysicalPath="$(PortalBibliotecaPublishDir)" TargetPath="$(PreCompiledPortalBibliotecaPublishDir)" Force="true" Debug="false" Condition="'$(GeneratePreCompiled)' == 'true'" />

    <ItemGroup Condition="'$(GenerateBuildArchive)' == 'true'">
      <PortalBibliotecaFilesToZip Include="$(PreCompiledPortalBibliotecaPublishDir)\**\*" Exclude="*.zip" />
      <PortalBibliotecaDll Include="$(PortalBibliotecaBinDir)\PortalBiblioteca.dll" />
    </ItemGroup>
    <GetAssemblyIdentity AssemblyFiles="@(PortalBibliotecaDll)" Condition="'$(GenerateBuildArchive)' == 'true'">
      <Output TaskParameter="Assemblies" ItemName="PortalBibliotecaAssembly" />
    </GetAssemblyIdentity>
    <MSBuild.Community.Tasks.Zip Files="@(PortalBibliotecaFilesToZip)" WorkingDirectory="$(PreCompiledPortalBibliotecaPublishDir)" ZipFileName="$(PortalBibliotecaReleaseDir)\PortalBiblioteca %(PortalBibliotecaAssembly.Version) - $(BuildDate).zip" ZipLevel="0" Condition="'$(GenerateBuildArchive)' == 'true'" />

    <Exec Command="$(Quote)$(SvnDir)\svn.exe$(Quote) revert $(Quote)$(PortalBibliotecaAssemblyInfo)$(Quote) $(Quote)$(LyceumRNAssemblyInfo)$(Quote)" />

    <Message Text="PortalBiblioteca built!" />
  </Target>

  <Target Name="UpdateCronos">
    <Message Text="Cleaning Cronos..." />

    <MSBuild Projects="$(CronosSolution)" Targets="Clean" Properties="Configuration=$(Configuration)" />

    <Message Text="Building Cronos..." />

    <SvnVersion LocalPath="$(LyceumCRDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(LyceumCRAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <SvnVersion LocalPath="$(HadesLycCRDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(HadesLycCRAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <MSBuild Projects="$(CronosSolution)" Targets="$(Target)" Properties="Configuration=$(Configuration);DebugSymbols=false;DebugType=None;NoWarn=1572,1573,1591;OutputPath=$(ComponentDir);" />

    <FileUpdate Files="$(LyceumCRAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.0" />
    <FileUpdate Files="$(HadesLycCRAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.0" />

    <Message Text="Removing config files..." />

    <ItemGroup>
      <Configs Include="$(ComponentDir)\*.config" />
    </ItemGroup>
    <Delete Files="@(Configs)" />

    <Message Text="Cronos built!" />
  </Target>

  <Target Name="UpdateCore">
    <Message Text="Cleaning Core..." />

    <MSBuild Projects="$(CoreSolution)" Targets="Clean" Properties="Configuration=$(Configuration)" />

    <Message Text="Building Core..." />

    <SvnVersion LocalPath="$(SeeducInfraDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(SeeducInfraAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <SvnVersion LocalPath="$(TechneLyceumControlDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(TechneLyceumControlAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <SvnVersion LocalPath="$(TechneLyceumInfraDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(TechneLyceumInfraAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <MSBuild Projects="$(CoreSolution)" Targets="$(Target)" Properties="Configuration=$(Configuration);DebugSymbols=false;DebugType=None;NoWarn=1572,1573,1591;OutputPath=$(ComponentDir);" />

    <FileUpdate Files="$(SeeducInfraAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.0" />
    <FileUpdate Files="$(TechneLyceumControlAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.0" />
    <FileUpdate Files="$(TechneLyceumInfraAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.0" />

    <Message Text="Removing config files..." />

    <ItemGroup>
      <Configs Include="$(ComponentDir)\*.config" />
    </ItemGroup>
    <Delete Files="@(Configs)" />

    <Message Text="Core built!" />
  </Target>

  <Target Name="UpdateDLLs">
    <Message Text="Deploying Cronos and Core..." />

    <Message Text="Core built!" />
  </Target>

  <Target Name="UpdateDLLs">
    <Message Text="Deploying Cronos and Core..." />

    <CallTarget Targets="UpdateCronos"></CallTarget>

    <CallTarget Targets="UpdateCore"></CallTarget>

    <Message Text="Cronos and Core deployed!" />
  </Target>

  <Target Name="UpdateRDLs">
    <Message Text="Deploying Reports..." />

    <ItemGroup>
      <RDLs Include="$(ReportServerSourceDir)\**\*.rdl" />
    </ItemGroup>

    <Copy SourceFiles="@(RDLs)" DestinationFolder="$(ReportServerDir)\%(RecursiveDir)"></Copy>

    <Message Text="Reports deployed!" />
  </Target>

  <Target Name="All">
    <Message Text="Deploying all modules..." />

    <CallTarget Targets="UpdateCronos"></CallTarget>

    <CallTarget Targets="UpdateCore"></CallTarget>

    <CallTarget Targets="UpdateCore"></CallTarget>
    
    <CallTarget Targets="UpdateRDLs"></CallTarget>

    <CallTarget Targets="LyceumGov"></CallTarget>

    <CallTarget Targets="LyceumGovAOL"></CallTarget>

    <CallTarget Targets="LyceumGovDOL"></CallTarget>

    <CallTarget Targets="ProcessoSeletivoAluno"></CallTarget>
    
    <CallTarget Targets="PortalBiblioteca"></CallTarget>

    <Message Text="All modules deployed!" />
  </Target>

  <Target Name="Clean">
    <Message Text="Cleaning the deploy directory..." />

    <MSBuild.ExtensionPack.FileSystem.Folder TaskAction="RemoveContent" Path="$(PublishDir)" />

    <Message Text="Deploy directory cleaned!" />
  </Target>

