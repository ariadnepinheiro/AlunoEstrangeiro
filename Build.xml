    <PreCompiledPublishDir>$(PublishDir)\PreCompiled</PreCompiledPublishDir>
    <PreCompiledLyceumGovPublishDir>$(PreCompiledPublishDir)\LyceumGov</PreCompiledLyceumGovPublishDir>
    <PreCompiledLyceumGovAOLPublishDir>$(PreCompiledPublishDir)\LyceumGovAOL</PreCompiledLyceumGovAOLPublishDir>
    <PreCompiledLyceumGovDOLPublishDir>$(PreCompiledPublishDir)\LyceumGovDOL</PreCompiledLyceumGovDOLPublishDir>
