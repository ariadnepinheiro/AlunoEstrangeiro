    <Exec Command="$(Quote)$(SvnDir)\svn.exe$(Quote) revert $(Quote)$(LyceumGovAOLAssemblyInfo)$(Quote) $(Quote)$(LyceumRNAssemblyInfo)$(Quote)" />

    <Message Text="LyceumGovAOL built!" />
  </Target>

