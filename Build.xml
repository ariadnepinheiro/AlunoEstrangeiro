    <GenerateBuildArchive>true</GenerateBuildArchive>
    <GeneratePreCompiled>true</GeneratePreCompiled>
    <PublishDir>C:\Producao</PublishDir>
    <SvnDir>$(programfiles)\Subversion\bin</SvnDir>

    <LyceumGovSolution>$(SolutionDir)\LyceumGov.sln</LyceumGovSolution>
    <LyceumGovAOLSolution>$(SolutionDir)\LyceumGovAOL.sln</LyceumGovAOLSolution>
    <LyceumGovDOLSolution>$(SolutionDir)\LyceumGovDOL.sln</LyceumGovDOLSolution>
    <ProcessoSeletivoAlunoSolution>$(SolutionDir)\ProcessoSeletivoAluno.sln</ProcessoSeletivoAlunoSolution>
    <NovoDocenteOnlineSolution>Proderj.Dol\Proderj.DocenteOnline\DocenteOnline.sln</NovoDocenteOnlineSolution>
    <PortalBibliotecaSolution>$(SolutionDir)\PortalBiblioteca.sln</PortalBibliotecaSolution>
    <CoreSolution>$(SolutionDir)\Core.sln</CoreSolution>
    <CronosSolution>$(SolutionDir)\Cronos.sln</CronosSolution>

    <ReportServerDir>$(PublishDir)\ReportServer</ReportServerDir>
    <ReportServerSourceDir>Relatorios\Producao</ReportServerSourceDir>

    <LyceumGovDir>LyceumGov\Fontes\LyceumGov</LyceumGovDir>
