    <ProcessoSeletivoAlunoDir>ProcessoSeletivoAluno\Fontes\ProcessoSeletivoAluno</ProcessoSeletivoAlunoDir>
    <ProcessoSeletivoAlunoAssemblyInfo>$(ProcessoSeletivoAlunoDir)\Properties\AssemblyInfo.cs</ProcessoSeletivoAlunoAssemblyInfo>
    <NovoDocenteOnlineDir>Proderj.Dol\Proderj.DocenteOnline\Proderj.DOL.WebApp</NovoDocenteOnlineDir>
    <NovoDocenteOnlineAssemblyInfo>$(NovoDocenteOnlineDir)\Properties\AssemblyInfo.cs</NovoDocenteOnlineAssemblyInfo>
