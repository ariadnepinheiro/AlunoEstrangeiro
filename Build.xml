		Force="true" 
		Debug="false" 
		Condition="'$(GeneratePreCompiled)' == 'true'" 
		ToolPath="C:\WINDOWS\Microsoft.NET\Framework\v4.0.30319\" />

    <ItemGroup Condition="'$(GenerateBuildArchive)' == 'true'">
      <NovoDocenteOnlineFilesToZip Include="$(PreCompiledNovoDocenteOnlinePublishDir)\**\*" Exclude="*.zip" />
      <NovoDocenteOnlineDll Include="$(NovoDocenteOnlineBinDir)\Proderj.DOL.WebApp.dll" />
