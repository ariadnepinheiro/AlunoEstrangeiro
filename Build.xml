  <Import Project="$(MSBuildExtensionsPath32)\MSBuildCommunityTasks\MSBuild.Community.Tasks.Targets" />
  <Import Project="$(MSBuildExtensionsPath32)\ExtensionPack\MSBuild.ExtensionPack.tasks" />

  <Target Name="CheckDirectories">
    <Message Text="Creating the directories (if not exists)..." />

    <MakeDir Directories="$(PublishDir)" Condition="!Exists('$(PublishDir)')" />
    <MakeDir Directories="$(LyceumGovPublishDir)" Condition="!Exists('$(LyceumGovPublishDir)')" />
    <MakeDir Directories="$(LyceumGovAOLPublishDir)" Condition="!Exists('$(LyceumGovAOLPublishDir)')" />
    <MakeDir Directories="$(LyceumGovDOLPublishDir)" Condition="!Exists('$(LyceumGovDOLPublishDir)')" />
    <MakeDir Directories="$(ProcessoSeletivoAlunoPublishDir)" Condition="!Exists('$(ProcessoSeletivoAlunoPublishDir)')" />
    <MakeDir Directories="$(NovoDocenteOnlinePublishDir)" Condition="!Exists('$(NovoDocenteOnlinePublishDir)')" />
    <MakeDir Directories="$(PortalBibliotecaPublishDir)" Condition="!Exists('$(PortalBibliotecaPublishDir)')" />

    <MakeDir Directories="$(ReleaseDir)" Condition="!Exists('$(ReleaseDir)')" />
    <MakeDir Directories="$(LyceumGovReleaseDir)" Condition="!Exists('$(LyceumGovReleaseDir)')" />
    <MakeDir Directories="$(LyceumGovAOLReleaseDir)" Condition="!Exists('$(LyceumGovAOLReleaseDir)')" />
    <MakeDir Directories="$(LyceumGovDOLReleaseDir)" Condition="!Exists('$(LyceumGovDOLReleaseDir)')" />
    <MakeDir Directories="$(ProcessoSeletivoAlunoReleaseDir)" Condition="!Exists('$(ProcessoSeletivoAlunoReleaseDir)')" />
    <MakeDir Directories="$(NovoDocenteOnlineReleaseDir)" Condition="!Exists('$(NovoDocenteOnlineReleaseDir)')" />
    <MakeDir Directories="$(PortalBibliotecaReleaseDir)" Condition="!Exists('$(PortalBibliotecaReleaseDir)')" />

    <MakeDir Directories="$(PreCompiledPublishDir)" Condition="!Exists('$(PreCompiledPublishDir)')" />
    <MakeDir Directories="$(PreCompiledLyceumGovPublishDir)" Condition="!Exists('$(PreCompiledLyceumGovPublishDir)')" />
    <MakeDir Directories="$(PreCompiledLyceumGovAOLPublishDir)" Condition="!Exists('$(PreCompiledLyceumGovAOLPublishDir)')" />
    <MakeDir Directories="$(PreCompiledLyceumGovDOLPublishDir)" Condition="!Exists('$(PreCompiledLyceumGovDOLPublishDir)')" />
    <MakeDir Directories="$(PreCompiledProcessoSeletivoAlunoPublishDir)" Condition="!Exists('$(PreCompiledProcessoSeletivoAlunoPublishDir)')" />
    <MakeDir Directories="$(PreCompiledNovoDocenteOnlinePublishDir)" Condition="!Exists('$(PreCompiledNovoDocenteOnlinePublishDir)')" />
    <MakeDir Directories="$(PreCompiledPortalBibliotecaPublishDir)" Condition="!Exists('$(PreCompiledPortalBibliotecaPublishDir)')" />

    <MakeDir Directories="$(ReportServerDir)" Condition="!Exists('$(ReportServerDir)')" />
  </Target>

  <Target Name="GetDate">
    <Time Format="yyyy-MM-dd-HHmmss">
      <Output TaskParameter="FormattedTime" PropertyName="BuildDate" />
    </Time>
  </Target>

  <Target Name="LyceumGov" DependsOnTargets="CheckDirectories; GetDate">
    <Message Text="Removing the existing files from LyceumGov..." />

    <MSBuild.ExtensionPack.FileSystem.Folder TaskAction="RemoveContent" Path="$(LyceumGovPublishDir)" />
    <MSBuild.ExtensionPack.FileSystem.Folder TaskAction="RemoveContent" Path="$(PreCompiledLyceumGovPublishDir)" />

    <Message Text="Cleaning LyceumGov..." />

    <MSBuild Projects="$(LyceumGovSolution)" Targets="Clean" Properties="Configuration=$(Configuration)" />

    <Message Text="Building LyceumGov..." />

    <SvnVersion LocalPath="$(LyceumGovDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(LyceumGovAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <SvnVersion LocalPath="$(LyceumRNDir)" ToolPath="$(SvnDir)">
      <Output TaskParameter="Revision" PropertyName="Revision" />
    </SvnVersion>
    <FileUpdate Files="$(LyceumRNAssemblyInfo)" Regex="(\d+)\.(\d+)\.(\d+)\.(\d+)" ReplacementText="$1.$2.$3.$(Revision)" />

    <MSBuild Projects="$(LyceumGovSolution)" Targets="$(Targets)" Properties="Configuration=$(Configuration);OutDir=$(LyceumGovBinDir)\;WebProjectOutputDir=$(LyceumGovPublishDir);" />

    <ItemGroup>
      <Xmls Include="$(LyceumGovBinDir)\*.xml" />
      <Pdbs Include="$(LyceumGovBinDir)\*.pdb" />
    </ItemGroup>
    <Delete Files="@(Xmls)" />
    <Delete Files="@(Pdbs)" />

    <AspNetCompiler VirtualPath="/LyceumGov" PhysicalPath="$(LyceumGovPublishDir)" TargetPath="$(PreCompiledLyceumGovPublishDir)" Force="true" Debug="false" Condition="'$(GeneratePreCompiled)' == 'true'" />

    <ItemGroup Condition="'$(GenerateBuildArchive)' == 'true'">
      <LyceumGovFilesToZip Include="$(PreCompiledLyceumGovPublishDir)\**\*" Exclude="*.zip" />
      <LyceumGovDll Include="$(LyceumGovBinDir)\LyceumGov.dll" />
    </ItemGroup>
    <GetAssemblyIdentity AssemblyFiles="@(LyceumGovDll)" Condition="'$(GenerateBuildArchive)' == 'true'">
      <Output TaskParameter="Assemblies" ItemName="LyceumGovAssembly" />
    </GetAssemblyIdentity>
    <MSBuild.Community.Tasks.Zip Files="@(LyceumGovFilesToZip)" WorkingDirectory="$(PreCompiledLyceumGovPublishDir)" ZipFileName="$(LyceumGovReleaseDir)\LyceumGov %(LyceumGovAssembly.Version) - $(BuildDate).zip" ZipLevel="0" Condition="'$(GenerateBuildArchive)' == 'true'" />

    <Exec Command="$(Quote)$(SvnDir)\svn.exe$(Quote) revert $(Quote)$(LyceumGovAssemblyInfo)$(Quote) $(Quote)$(LyceumRNAssemblyInfo)$(Quote)" />

    <Message Text="LyceumGov built!" />
  </Target>

