    <SeeducInfraAssemblyInfo>$(SeeducInfraDir)\Properties\AssemblyInfo.cs</SeeducInfraAssemblyInfo>
    <TechneLyceumControlDir>Techne.Lyceum.Control\Fontes\Techne.Lyceum.Control</TechneLyceumControlDir>
    <TechneLyceumControlAssemblyInfo>$(TechneLyceumControlDir)\Properties\AssemblyInfo.cs</TechneLyceumControlAssemblyInfo>
    <TechneLyceumInfraDir>Techne.Lyceum.Infra\Fontes\Techne.Lyceum.Infra</TechneLyceumInfraDir>
    <TechneLyceumInfraAssemblyInfo>$(TechneLyceumInfraDir)\Properties\AssemblyInfo.cs</TechneLyceumInfraAssemblyInfo>

    <LyceumCRDir>LyceumGovCR\Fontes\LyceumCR</LyceumCRDir>
    <LyceumCRAssemblyInfo>$(LyceumCRDir)\Properties\AssemblyInfo.cs</LyceumCRAssemblyInfo>
    <HadesLycCRDir>HadesLycCR\Fontes\HadesLycCR</HadesLycCRDir>
    <HadesLycCRAssemblyInfo>$(HadesLycCRDir)\Properties\AssemblyInfo.cs</HadesLycCRAssemblyInfo>

