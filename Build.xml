    <LyceumGovBinDir>$(PublishDir)\LyceumGov\bin</LyceumGovBinDir>
    <LyceumGovPublishDir>$(PublishDir)\LyceumGov</LyceumGovPublishDir>
    <LyceumGovAOLBinDir>$(PublishDir)\LyceumGovAOL\bin</LyceumGovAOLBinDir>
    <LyceumGovAOLPublishDir>$(PublishDir)\LyceumGovAOL</LyceumGovAOLPublishDir>
    <LyceumGovDOLBinDir>$(PublishDir)\LyceumGovDOL\bin</LyceumGovDOLBinDir>
    <LyceumGovDOLPublishDir>$(PublishDir)\LyceumGovDOL</LyceumGovDOLPublishDir>
    <ProcessoSeletivoAlunoBinDir>$(PublishDir)\ProcessoSeletivoAluno\bin</ProcessoSeletivoAlunoBinDir>
    <ProcessoSeletivoAlunoPublishDir>$(PublishDir)\ProcessoSeletivoAluno</ProcessoSeletivoAlunoPublishDir>
    <NovoDocenteOnlineBinDir>$(PublishDir)\NovoDocenteOnline\bin</NovoDocenteOnlineBinDir>
    <NovoDocenteOnlinePublishDir>$(PublishDir)\NovoDocenteOnline</NovoDocenteOnlinePublishDir>
    <PortalBibliotecaBinDir>$(PublishDir)\PortalBiblioteca\bin</PortalBibliotecaBinDir>
    <PortalBibliotecaPublishDir>$(PublishDir)\PortalBiblioteca</PortalBibliotecaPublishDir>

    <ReleaseDir>$(PublishDir)\Releases</ReleaseDir>
