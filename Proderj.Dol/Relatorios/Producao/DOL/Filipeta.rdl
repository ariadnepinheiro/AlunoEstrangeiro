  <DataSources>
    <DataSource Name="dsFilipeta">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>52e8ca7e-12b6-49ef-8d67-c24f867299e4</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dsFilipeta</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@subperiodo">
            <Value>=Parameters!subperiodo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@disciplina">
            <Value>=Parameters!disciplina.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@turma">
            <Value>=Parameters!turma.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@semestre">
            <Value>=Parameters!semestre.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 
    PE.nome_compl, 
    m.aluno, 
    m.sit_matricula, 
    isnull((SELECT TOP 1 [DESCRICAO] + ' - ' + convert(varchar,[DT_INICIO],103) + ' a ' + convert(varchar,[DT_FIM],103)
      FROM [LY_ALUNO_LICENCA] (NOLOCK)
      where [ALUNO]= m.aluno
          and [DISCIPLINA]= m.disciplina
          and [TURMA]= m.turma
          and [ANO]= m.ano
          and [SEMESTRE] = m.semestre
          and DT_FIM = (select max(DT_FIM) from [LY_ALUNO_LICENCA] 
                          where [ALUNO]= m.aluno
                              and [DISCIPLINA]= m.disciplina
                              and [TURMA]= m.turma
                              and [ANO]= m.ano
                              and [SEMESTRE] = m.semestre)),'') + 
          
          
    isnull((select TOP 1  'Remanejado para a turma ' + TURMA_DESTINO + ' em ' + convert(varchar,DATA,103)
        from dbo.LY_TURMA_TRANSF (NOLOCK)
        where ALUNO=m.ALUNO 
        and ANO=m.ANO 
        and PERIODO = m.SEMESTRE 
        and TURMA_ANT =  m.TURMA
      
        ),'') +
    isnull((select TOP 1 MOTIVO + ' em ' +  convert(varchar,DT_ENCERRAMENTO,103) 
        from dbo.LY_H_CURSOS_CONCL (NOLOCK)
        where ALUNO=m.ALUNO 
        and DT_REABERTURA is null
         ),'')  + 
       ISNULL((SELECT TOP 1
                      ' Transferido para outra unidade da rede estadual em ' + CONVERT(VARCHAR, DT_TRANS, 103)
                 FROM dbo.LY_H_CURR_ALUNO WITH ( NOLOCK )
                INNER JOIN dbo.LY_UNIDADE_ENSINO WITH ( NOLOCK ) ON LY_H_CURR_ALUNO.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
                WHERE ALUNO   = m.ALUNO
                  AND ANO     = m.ANO
                  AND PERIODO = m.SEMESTRE
             ), '') descricao_situacao,

    m.num_chamada, 
    m.disciplina, 
    m.turma, 
    m.ano, 
    m.semestre,         
    CASE m.sit_matricula
              WHEN 'Matriculado' THEN n.conceito
              ELSE NULL
            END AS MÉDIA,
            CASE m.sit_matricula
              WHEN 'Matriculado' THEN CONVERT(INT, f.faltas)
              ELSE NULL
            END AS faltas,
    prova.nome as nome_prova,
    prova.nota_max,
    prova.formula,
    n.notaprova,
    n.notarecuperacao,
     CASE m.sit_matricula
              WHEN 'Matriculado' THEN n.recuperacao_paralela
              ELSE 'N'
            END AS recuperacao_paralela,
     CASE m.sit_matricula
              WHEN 'Matriculado' THEN n.sem_avaliacao
              ELSE 'N'
            END AS sem_avaliacao,
     /*
     CASE m.sit_matricula
              WHEN 'Matriculado' THEN n.justificativa
              ELSE ''
            END AS justificativa
     */
     CASE n.motivosemnotaid
            WHEN 0 THEN 'Aluno em Progressão Parcial (Dependência) não apresentou trabalho'
            WHEN 1 THEN 'Afastamento médico / Maternidade / Serviço  Militar'
            WHEN 2 THEN 'Outros'
     END AS justificativa,
     n.conceito as nota_final_bimestre
     
    from ly_matricula m  WITH(NOLOCK) 
    join ly_aluno a WITH(NOLOCK) on m.aluno = a.aluno
    JOIN LY_PESSOA PE (NOLOCK) ON PE.PESSOA = A.PESSOA
    left join ly_freq freq (NOLOCK) on freq.disciplina = m.disciplina
        and freq.turma = m.turma and freq.ano = m.ano and freq.periodo = m.semestre and freq.subperiodo = @subperiodo --1
    left join LY_FALTA f (NOLOCK) on f.ALUNO = m.ALUNO and f.ANO = m.ANO and f.DISCIPLINA = m.DISCIPLINA 
        and f.PERIODO = m.SEMESTRE and f.TURMA = m.TURMA and freq.freq = f.freq
    left join ly_prova prova (NOLOCK) on prova.disciplina = m.disciplina AND prova.turma = m.turma AND prova.ano = m.ano AND prova.semestre = m.semestre AND prova.subperiodo = @subperiodo --1
    left join LY_NOTA n (NOLOCK) on  n.DISCIPLINA = prova.disciplina and n.turma = prova.TURMA
            and n.ANO = prova.ANO and n.SEMESTRE = prova.SEMESTRE and n.PROVA = prova.PROVA and n.ALUNO = m.ALUNO
    where m.disciplina = @disciplina --'PORT_2_4'
    and m.turma = @turma --'2004-180587'
    and m.ano = @ano --2013
    and m.semestre = @semestre --0
    
    order by m.num_chamada, PE.nome_compl
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>aluno</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome_compl">
          <DataField>nome_compl</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>disciplina</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="sit_matricula">
          <DataField>sit_matricula</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>turma</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ano</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="descricao_situacao">
          <DataField>descricao_situacao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>semestre</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="num_chamada">
          <DataField>num_chamada</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MÉDIA">
          <DataField>MÉDIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="faltas">
          <DataField>faltas</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RECUPERACAO_PARALELA">
          <DataField>recuperacao_paralela</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome_prova">
          <DataField>nome_prova</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEM_AVALIACAO">
          <DataField>sem_avaliacao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="notaprova">
          <DataField>notaprova</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="nota_max">
          <DataField>nota_max</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="JUSTIFICATIVA">
          <DataField>justificativa</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="notarecuperacao">
          <DataField>notarecuperacao</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="formula">
          <DataField>formula</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nota_final_bimestre">
          <DataField>nota_final_bimestre</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MaterialEstudo">
      <Query>
        <DataSourceName>dsFilipeta</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@turma">
            <Value>=Parameters!turma.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@disciplina">
            <Value>=Parameters!disciplina.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@semestre">
            <Value>=Parameters!semestre.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@subperiodo">
            <Value>=Parameters!subperiodo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>DECLARE @desc VARCHAR(max)
SELECT @desc = coalesce(@desc + ', ', '') + DESCRICAO from (

select distinct m.MATERIALESTUDOID, m.DESCRICAO
FROM LYCEUM.LANCAMENTONOTAS.TURMA_MATERIALESTUDO t
	inner join LYCEUM.LancamentoNotas.MATERIALESTUDO m on t.MATERIALESTUDOID = m.MATERIALESTUDOID
WHERE TURMA = @turma
	AND DISCIPLINA = @disciplina
	AND ANO = @ano
	AND SEMESTRE = @semestre
	AND SUBPERIODO = @subperiodo
) q1

select @desc as DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
