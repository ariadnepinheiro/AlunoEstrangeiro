      <ReportItems>
        <Textbox Name="Textbox1">
          <CanGrow>true</CanGrow>
          <KeepTogether>true</KeepTogether>
          <Paragraphs>
            <Paragraph>
              <TextRuns>
                <TextRun>
                  <Value>=First(Fields!DESC_NUCLEO.Value, "ds_Convocacao")</Value>
                  <Style>
                    <FontWeight>Bold</FontWeight>
                  </Style>
                </TextRun>
                <TextRun>
                  <Value xml:space="preserve">  </Value>
                  <Style>
                    <FontWeight>Bold</FontWeight>
                  </Style>
                </TextRun>
                <TextRun>
                  <Value>=iif(Fields!CONCURSO.Value &lt;&gt; "24º Processo", Fields!MUNICIPIO.Value,"")</Value>
                  <Style>
                    <FontWeight>Bold</FontWeight>
                  </Style>
                </TextRun>
              </TextRuns>
              <Style>
                <TextAlign>Center</TextAlign>
              </Style>
            </Paragraph>
          </Paragraphs>
          <rd:DefaultName>Textbox1</rd:DefaultName>
          <Left>0.26459cm</Left>
          <Height>0.6cm</Height>
          <Width>18.49438cm</Width>
          <Style>
            <Border>
              <Style>None</Style>
            </Border>
            <PaddingLeft>2pt</PaddingLeft>
            <PaddingRight>2pt</PaddingRight>
            <PaddingTop>2pt</PaddingTop>
            <PaddingBottom>2pt</PaddingBottom>
          </Style>
        </Textbox>
        <Textbox Name="Textbox2">
          <CanGrow>true</CanGrow>
          <KeepTogether>true</KeepTogether>
          <Paragraphs>
            <Paragraph>
              <TextRuns>
                <TextRun>
                  <Label>CATEGORIA</Label>
                  <Value>=First(Fields!CATEGORIA_NOME.Value, "ds_Convocacao")</Value>
                  <Style />
                </TextRun>
                <TextRun>
                  <Value> - </Value>
                  <Style />
                </TextRun>
                <TextRun>
                  <Label>DISCIPLINA</Label>
                  <Value>=First(Fields!DISCIP_DESC.Value, "ds_Convocacao")</Value>
                  <Style />
                </TextRun>
              </TextRuns>
              <Style>
                <TextAlign>Center</TextAlign>
              </Style>
            </Paragraph>
            <Paragraph>
              <TextRuns>
                <TextRun>
                  <Label>FUNCAO</Label>
                  <Value>=iif(First(Fields!CATEGORIA.Value, "ds_Convocacao") = "DOC I", "PROFESSOR PARA ATUAR NOS ANOS FINAIS DO ENSINO FUNDAMENTAL E/OU ENSINO MÉDIO",
	iif(First(Fields!CATEGORIA.Value, "ds_Convocacao") = "DOC II",  "PROFESSOR PARA ATUAR NOS ANOS INICIAIS DO ENSINO FUNDAMENTAL", First(Fields!CATEGORIA.Value, "ds_Convocacao") &amp; " - " &amp; First(Fields!CATEGORIA_NOME.Value, "ds_Convocacao")))</Value>
                  <Style />
                </TextRun>
              </TextRuns>
              <Style>
                <TextAlign>Center</TextAlign>
              </Style>
            </Paragraph>
            <Paragraph>
              <TextRuns>
                <TextRun>
                  <Value>DATA: </Value>
                  <Style />
                </TextRun>
                <TextRun>
                  <Label>DT_APRESENTACAO</Label>
                  <Value>=iif(First(Fields!DT_APRESENTACAO.Value, "ds_Convocacao") is nothing, "___/___/___", format(First(Fields!DT_APRESENTACAO.Value, "ds_Convocacao"), "dd/MM/yyyy"))</Value>
                  <Style />
                </TextRun>
                <TextRun>
                  <Value> - HORÁRIO: </Value>
                  <Style />
                </TextRun>
                <TextRun>
                  <Label>HORA_APRESENTACAO</Label>
                  <Value>=IIF(First(Fields!HORA_APRESENTACAO.Value, "ds_Convocacao") IS NOTHING, "___:___", FORMAT(First(Fields!HORA_APRESENTACAO.Value, "ds_Convocacao"), "hh:mm"))</Value>
                  <Style />
                </TextRun>
              </TextRuns>
              <Style>
                <TextAlign>Center</TextAlign>
              </Style>
            </Paragraph>
          </Paragraphs>
