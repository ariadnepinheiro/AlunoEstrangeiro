  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
        <Prompt>Especifique um nome de usuário e uma senha para a fonte de dados DataSource1:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>e3260fe9-05ac-4502-a0bf-f9bbe3585271</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MATRICULA">
            <Value>=Parameters!MATRICULA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select  
 DISTINCT 
  ly_docente.MATRICULA,
isnull(LY_DOCENTE.CPF, ly_pessoa.cpf) as CPF,
 
 
 UPPER(ly_docente.NOME_COMPL) NOME_CONTRATADO ,
 
 
CONVERT(VARCHAR(10), ly_docente.DT_NASC, 103) AS NASCIMENTO,
 ly_docente.ENDERECO,
 LY_DOCENTE.END_NUM,
 LY_DOCENTE.END_COMPL,
 LY_DOCENTE.CEP,
 LY_DOCENTE.BAIRRO,
 MUNIC_RES.NOME , 
 --dt_admissao,
 --isnull(CONVERT(VARCHAR(10), DT_INICIO_CONTRATO, 103),'') as DT_INICIO_CONTRATO,
 --isnull(CONVERT(VARCHAR(10), DT_FIM_CONTRATO, 103),'') as DT_FIM_CONTRATO,
 --ly_lotacao.data_desativacao,
 --ly_docente.categoria
 --, LY_FUNCAO.DESCRICAO AS FUNCAO
 --, isnull(CONVERT(VARCHAR(10), DATA_DESATIVACAO, 103),'') as DATA_DEMISSAO,
 --, isnull(convert(varchar(10), VW_INTEG_LICENCA_DOCENTE.DTINI, 103), '') as DATA_INI_SITUACAO
 --, isnull(convert(varchar(10), VW_INTEG_LICENCA_DOCENTE.DTFIM, 103), '') AS DATA_FIM_SITUACAO
 --, LY_LICENCAS.DESCRICAO AS SITUACAO
 
 --LY_FUNCAO.DESCRICAO,
 --LY_GRUPO_HABILITACAO.DESCRICAO
DAY(GETDATE()) AS DIA,
CASE WHEN MONTH(GETDATE())= '1' THEN 'Janeiro'
	WHEN MONTH(GETDATE())= '2' THEN 'Fevereiro'
	WHEN MONTH(GETDATE())= '3' THEN 'Março'
	WHEN MONTH(GETDATE())= '4' THEN 'Abril'
	WHEN MONTH(GETDATE())= '5' THEN 'Maio'
	WHEN MONTH(GETDATE())= '6' THEN 'Junho'
	WHEN MONTH(GETDATE())= '7' THEN 'Julho'
	WHEN MONTH(GETDATE())= '8' THEN 'Agosto'
	WHEN MONTH(GETDATE())= '9' THEN 'Setembro'
	WHEN MONTH(GETDATE())= '10' THEN 'Outubro'
	WHEN MONTH(GETDATE())= '11' THEN 'Novembro'
	WHEN MONTH(GETDATE())= '12' THEN 'Dezembro' END AS MES,
YEAR(GETDATE()) AS ANO,
DAY(DT_ADMISSAO) AS DIA_ADMISSAO,
CASE WHEN MONTH(DT_ADMISSAO)= '1' THEN 'Janeiro'
	WHEN MONTH(DT_ADMISSAO)= '2' THEN 'Fevereiro'
	WHEN MONTH(DT_ADMISSAO)= '3' THEN 'Março'
	WHEN MONTH(DT_ADMISSAO)= '4' THEN 'Abril'
	WHEN MONTH(DT_ADMISSAO)= '5' THEN 'Maio'
	WHEN MONTH(DT_ADMISSAO)= '6' THEN 'Junho'
	WHEN MONTH(DT_ADMISSAO)= '7' THEN 'Julho'
	WHEN MONTH(DT_ADMISSAO)= '8' THEN 'Agosto'
	WHEN MONTH(DT_ADMISSAO)= '9' THEN 'Setembro'
	WHEN MONTH(DT_ADMISSAO)= '10' THEN 'Outubro'
	WHEN MONTH(DT_ADMISSAO)= '11' THEN 'Novembro'
	WHEN MONTH(DT_ADMISSAO)= '12' THEN 'Dezembro' END AS MES_ADMISSAO,
YEAR(DT_ADMISSAO) AS ANO_ADMISSAO,
(SELECT CARGA_HORARIA FROM dbo.LY_CANDIDATO_DOCENTE CD WHERE CD.CANDIDATO=ly_docente.CANDIDATO AND CD.CONCURSO=ly_docente.CONCURSO) AS CH,
COUNT(*) AS TOTAL_AULAS

from  ly_docente
inner join LY_PESSOA on LY_PESSOA.PESSOA = LY_DOCENTE.PESSOA

INNER JOIN LY_AULA_DOCENTE ad WITH(NOLOCK)                    
   ON ad.NUM_FUNC = ly_docente.NUM_FUNC                    
INNER JOIN LY_TURMA tu WITH(NOLOCK)                    
   ON tu.TURMA = ad.TURMA                    
    AND tu.DISCIPLINA = ad.DISCIPLINA                    
    AND tu.SEMESTRE = ad.SEMESTRE                    
    AND tu.DT_FIM  = ad.DATA_FIM 
    and ad.FACULDADE=tu.FACULDADE
    and ad.TURNO=tu.TURNO
    AND tu.SIT_TURMA IN ('ABERTA', 'FINALIZADA')
    and tu.ANO = '2011'
									
inner join LY_LOTACAO on ly_docente.MATRICULA = LY_LOTACAO.MATRICULA
inner join LY_FUNCAO on LY_FUNCAO.FUNCAO = LY_LOTACAO.FUNCAO
inner join HADES..HD_SETOR HD_SETOR on LY_LOTACAO.SETOR = HD_SETOR.SETOR
left JOIN LY_UNIDADE_ENSINO ON LY_UNIDADE_ENSINO.SETOR = LY_LOTACAO.SETOR
/*inner join ly_unidade_ensino_situacao UES on UES.UNIDADE_ENS = LY_UNIDADE_ENSINO.UNIDADE_ENS
											AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
											FROM LY_UNIDADE_ENSINO_SITUACAO LY_UNIDADE_ENSINO_SITUACAO
											WHERE ly_unidade_ensino.UNIDADE_ENS=LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)*/		
LEFT join LY_CANDIDATO_DOC_CONTRATO on LY_CANDIDATO_DOC_CONTRATO.CONCURSO = LY_DOCENTE.CONCURSO
										and LY_CANDIDATO_DOC_CONTRATO.CANDIDATO = LY_DOCENTE.CANDIDATO											
LEFT JOIN MUNICIPIO ON MUNICIPIO.CODIGO = HD_SETOR.MUNICIPIO 														
LEFT JOIN MUNICIPIO MUNIC_RES ON MUNIC_RES.CODIGO = LY_DOCENTE.MUNICIPIO														
LEFT JOIN VW_INTEG_LICENCA_DOCENTE ON VW_INTEG_LICENCA_DOCENTE.MATRICULA = ly_docente.MATRICULA
LEFT JOIN LY_LICENCAS ON LY_LICENCAS.MOTIVO = VW_INTEG_LICENCA_DOCENTE.COD_LICENCA															
where 
--(ly_lotacao.data_desativacao is null or ly_lotacao.data_desativacao &gt; = GETDATE())
--AND year (DT_INICIO_CONTRATO) in ('2011')
 ly_docente.categoria LIKE '%DOC%'
AND (ly_docente.categoria LIKE '% I %' or ly_docente.categoria LIKE '% I')
--AND ISNULL(LY_UNIDADE_ENSINO.SETOR,HD_SETOR.SETOR) &lt;&gt; '187777'
--AND (DT_FIM_CONTRATO &gt; = GETDATE() OR DT_FIM_CONTRATO IS NULL)
AND (ly_docente.MATRICULA LIKE '55%' OR ly_docente.MATRICULA LIKE '33%')
 AND ly_docente.matricula = @MATRICULA
GROUP  BY  ly_docente.MATRICULA,
isnull(LY_DOCENTE.CPF, ly_pessoa.cpf),
 
 
ly_docente.NOME_COMPL,
 
 
CONVERT(VARCHAR(10), ly_docente.DT_NASC, 103),
 ly_docente.ENDERECO,
 LY_DOCENTE.END_NUM,
 LY_DOCENTE.END_COMPL,
 LY_DOCENTE.CEP,
 LY_DOCENTE.BAIRRO,
 MUNIC_RES.NOME ,
 DAY(DT_ADMISSAO),
CASE WHEN MONTH(DT_ADMISSAO)= '1' THEN 'Janeiro'
	WHEN MONTH(DT_ADMISSAO)= '2' THEN 'Fevereiro'
	WHEN MONTH(DT_ADMISSAO)= '3' THEN 'Março'
	WHEN MONTH(DT_ADMISSAO)= '4' THEN 'Abril'
	WHEN MONTH(DT_ADMISSAO)= '5' THEN 'Maio'
	WHEN MONTH(DT_ADMISSAO)= '6' THEN 'Junho'
	WHEN MONTH(DT_ADMISSAO)= '7' THEN 'Julho'
	WHEN MONTH(DT_ADMISSAO)= '8' THEN 'Agosto'
	WHEN MONTH(DT_ADMISSAO)= '9' THEN 'Setembro'
	WHEN MONTH(DT_ADMISSAO)= '10' THEN 'Outubro'
	WHEN MONTH(DT_ADMISSAO)= '11' THEN 'Novembro'
	WHEN MONTH(DT_ADMISSAO)= '12' THEN 'Dezembro' END,
YEAR(DT_ADMISSAO),
ly_docente.CANDIDATO,
ly_docente.CONCURSO
HAVING COUNT (*)&lt;12 or (SELECT CARGA_HORARIA FROM dbo.LY_CANDIDATO_DOCENTE CD WHERE CD.CANDIDATO=ly_docente.CANDIDATO AND CD.CONCURSO=ly_docente.CONCURSO) &lt; 12
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
