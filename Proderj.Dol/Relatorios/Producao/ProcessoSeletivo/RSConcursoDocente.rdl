          <DataField>REMESSA_DOCUMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_REMESSA_DOCUMENTO">
          <DataField>DT_REMESSA_DOCUMENTO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_PROPOSTA">
          <DataField>DT_PROPOSTA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="USULOGIN">
          <DataField>USULOGIN</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="USUSENHA">
          <DataField>USUSENHA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <CommandText>SELECT CD.CONCURSO, CO.DESCRICAO, CO.STATUS STATUS_CONCURSO, CD.CANDIDATO, CD.NOME, CD.DT_NASC, CD.SEXO, CD.NECESSIDADE_ESPECIAL, CD.NOME_MAE, CD.NOME_PAI, CD.ESTADO_CIVIL,
(SELECT NOME FROM PAISES WHERE CODIGO = CD.PAIS_NASC) AS PAIS_NASC, CD.NACIONALIDADE,
(SELECT NOME FROM MUNICIPIO WHERE CODIGO = CD.MUNICIPIO_NASC) AS MUNICIPIO_NASC,
(SELECT UF_SIGLA FROM MUNICIPIO WHERE CODIGO = CD.MUNICIPIO_NASC) AS UF_NASC,
(SELECT NOME FROM PAISES WHERE CODIGO = CD.END_PAIS) AS END_PAIS, CD.CEP,
(SELECT NOME FROM MUNICIPIO WHERE CODIGO = CD.END_MUNICIPIO) AS END_MUNICIPIO,
(SELECT UF_SIGLA FROM MUNICIPIO WHERE CODIGO = CD.END_MUNICIPIO) AS END_UF,
CD.ENDERECO, CD.END_NUM, CD.END_COMPL, CD.BAIRRO, CD.FONE, CD.CELULAR, CD.E_MAIL, CD.RG_TIPO, CD.RG_NUM, CD.RG_EMISSOR, CD.RG_UF, CD.RG_DTEXP,
CD.CPF, CD.PIS_PASEP, CD.CPROF_NUM, CD.CPROF_SERIE, CD.CPROF_UF, CD.CPROF_DTEXP, CD.CATEGORIA, CA.NOME NOME_CATEGORIA,
CD.NUCLEO, NU.DESCRICAO DESCRICAO_NUCLEO, CD.AGRUPAMENTO_INGRESSO, GH.DESCRICAO DESC_AGRUPAMENTO_INGRESSO, 
CD.STATUS, CD.STATUS_OBS, CD.DT_CONVOCACAO, CD.DT_APRESENTACAO, CD.HORA_APRESENTACAO, CD.CDRH, CD.DT_CDRH, CD.CQHI, CD.DT_CQHI, CD.REMESSA_DOCUMENTO,
CD.DT_REMESSA_DOCUMENTO, CD.DT_PROPOSTA, CD.USULOGIN, CD.USUSENHA,Munic.NOME as MUNICIPIO

FROM LY_CANDIDATO_DOCENTE CD
LEFT JOIN MUNICIPIO Munic ON Munic.CODIGO = CD.MUNICIPIO_PROC
, LY_CONCURSO_DOCENTE CO, LY_CATEGORIA_DOCENTE CA, LY_NUCLEO NU, LY_GRUPO_HABILITACAO GH
WHERE CO.CONCURSO = CD.CONCURSO
AND CA.CATEGORIA = CD.CATEGORIA
AND NU.NUCLEO = CD.NUCLEO
AND GH.AGRUPAMENTO = CD.AGRUPAMENTO_INGRESSO
AND CD.CANDIDATO = @P_CANDIDATO
AND CD.CONCURSO = @P_CONCURSO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ds_Titulacao">
      <Fields>
        <Field Name="TITULACAO">
          <DataField>TITULACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PONTU_TIT">
          <DataField>PONTU_TIT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DESCR_TITULAÇÃO">
          <DataField>DESCR_TITULAÇÃO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <CommandText>SELECT CT.TITULACAO, COT.PONTUACAO PONTU_TIT,CCT.DESCRICAO AS DESCR_TITULAÇÃO
FROM LY_CANDIDATO_DOCENTE CD, LY_CANDIDATO_DOC_TITULACOES CT, LY_CONCURSO_DOC_TITULACOES COT,
LY_CONCURSO_TITULACAO CCT
WHERE CT.CANDIDATO = CD.CANDIDATO
AND CT.CONCURSO = CD.CONCURSO
AND COT.CONCURSO = CT.CONCURSO
AND COT.TITULACAO = CT.TITULACAO
AND CCT.TITULACAO = COT.TITULACAO
AND CD.CANDIDATO = @P_CANDIDATO
AND CD.CONCURSO = @P_CONCURSO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ds_Experiencia">
      <Fields>
        <Field Name="EXPERIENCIA">
          <DataField>EXPERIENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PONTU_EXP">
          <DataField>PONTU_EXP</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DESCR_EXPERIENCIA">
          <DataField>DESCR_EXPERIENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <CommandText>SELECT CE.EXPERIENCIA, COE.PONTUACAO PONTU_EXP,CCE.DESCRICAO AS DESCR_EXPERIENCIA
FROM LY_CANDIDATO_DOCENTE CD, LY_CANDIDATO_DOC_EXPERIENCIAS CE, LY_CONCURSO_DOC_EXPERIENCIA COE,LY_CONCURSO_EXPERIENCIA CCE
WHERE CE.CANDIDATO = CD.CANDIDATO
AND CCE.EXPERIENCIA = COE.EXPERIENCIA
AND CE.CANDIDATO = CD.CANDIDATO
AND CE.CONCURSO = CD.CONCURSO
AND COE.CONCURSO = CE.CONCURSO
AND COE.EXPERIENCIA = CE.EXPERIENCIA
AND CD.CANDIDATO = @P_CANDIDATO
AND CD.CONCURSO = @P_CONCURSO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ds_Situacao_Avaliacao">
      <Fields>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CANDIDATO">
          <DataField>CANDIDATO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CONCURSO">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <CommandText>SELECT CA.CANDIDATO, CA.CONCURSO, CA.SITUACAO, CO.DESCRICAO
FROM LY_CONCURSO_DOC_SIT_AVALIACAO CO, LY_CANDIDATO_DOC_SIT_AVALIACAO CA
WHERE CO.SITUACAO = CA.SITUACAO
AND CA.CANDIDATO = @P_CANDIDATO
AND CA.CONCURSO = @P_CONCURSO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ds_Processo_Seletivo">
      <Fields>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DT_APRESENTACAO">
          <DataField>DT_APRESENTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="HORA_APRESENTACAO">
          <DataField>HORA_APRESENTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="CDRH">
          <DataField>CDRH</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CQHI">
          <DataField>CQHI</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REMESSA_DOCUMENTO">
          <DataField>REMESSA_DOCUMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SOMA_PONTUACAO">
          <DataField>SOMA_PONTUACAO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <CommandText>SELECT CD.STATUS, CD.DT_APRESENTACAO, CD.HORA_APRESENTACAO, CD.CDRH, CD.CQHI, CD.REMESSA_DOCUMENTO,
SUM(CTPONT.PONTUACAO) SOMA_PONTUACAO
FROM ((SELECT PONTUACAO, CODE.CONCURSO, CADE.CANDIDATO
	   FROM  LY_CONCURSO_DOC_EXPERIENCIA CODE 
			 JOIN LY_CANDIDATO_DOC_EXPERIENCIAS CADE 
			 ON CODE.CONCURSO = CADE.CONCURSO 
			 AND CODE.EXPERIENCIA = CADE.EXPERIENCIA 
	    WHERE CADE.CANDIDATO = @P_CANDIDATO) 
	    UNION ALL 
	   (SELECT PONTUACAO, CODT.CONCURSO, CADT.CANDIDATO
	    FROM LY_CONCURSO_DOC_TITULACOES CODT 
			 JOIN LY_CANDIDATO_DOC_TITULACOES CADT 
			 ON CODT.CONCURSO = CADT.CONCURSO 
			 AND CODT.TITULACAO = CADT.TITULACAO 
		WHERE CADT.CANDIDATO = @P_CANDIDATO)
) CTPONT INNER JOIN LY_CANDIDATO_DOCENTE CD
					ON CTPONT.CONCURSO = CD.CONCURSO
					AND CTPONT.CANDIDATO = CD.CANDIDATO
WHERE CD.CANDIDATO = @P_CANDIDATO
AND CD.CONCURSO = @P_CONCURSO
GROUP BY CD.STATUS, CD.DT_APRESENTACAO, CD.HORA_APRESENTACAO, CD.CDRH, CD.CQHI, CD.REMESSA_DOCUMENTO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
