		IIF(Fields!STATUS.Value = "3", "Proposta de Contrato Temporário Aguardando Avaliação",
			IIF(Fields!STATUS.Value = "4", "Aguardando Remessa - Proposta Aprovada",
				IIF(Fields!STATUS.Value = "5", "Desistente",
					IIF(Fields!STATUS.Value = "6", "Reprovado",
						IIF(Fields!STATUS.Value = "7", "Aprovado",
							IIF(Fields!STATUS.Value = "8", "Cancelado",
								IIF(Fields!STATUS.Value = "9", "Desativado",
									IIF(Fields!STATUS.Value = "10", "Contrato aguardando rescisão",
										IIF(Fields!STATUS.Value = "11", "Contrato rescindido",
											IIF(Fields!STATUS.Value = "12", "Reprovado pelo RH",
												IIF(Fields!STATUS.Value = "13", "Reprovado pelo QHI", Fields!STATUS.Value)))))))))))))</Value>
