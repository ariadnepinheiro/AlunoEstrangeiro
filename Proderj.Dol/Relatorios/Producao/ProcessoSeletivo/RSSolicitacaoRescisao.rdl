          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="unidade_ens">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_UNIDADE">
          <DataField>NOME_UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="discip_ingresso">
          <DataField>DISCIP_INGRESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="matricula">
          <DataField>MATRICULA</DataField>
