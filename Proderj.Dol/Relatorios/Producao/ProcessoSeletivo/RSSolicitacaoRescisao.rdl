  <DataSources>
    <DataSource Name="DS_Recisao">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>d7e21c2e-bee6-499c-bc95-82876bbe65ee</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_Recisao">
      <Query>
        <DataSourceName>DS_Recisao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CD.CONCURSO AS CONCURSO, CD.CANDIDATO AS CANDIDATO, CD.NOME AS NOME_CANDIDATO,
CD.CPF AS CPF, CD.DT_PROPOSTA AS DT_ADMISSAO, CD.REMESSA_DOCUMENTO AS REMETIDO,
CD.NUCLEO AS NUCLEO, N.DESCRICAO AS DESC_NUCLEO, CD.STATUS AS SITUACAO, 
UE.UNIDADE_ENS AS UNIDADE_ENS, UE.NOME_COMP AS NOME_UNIDADE, UE.SETOR AS UA,
GH.AGRUPAMENTO AS DISCIP_INGRESSO, GH.DESCRICAO AS DISCIP_DESC, L.MATRICULA AS MATRICULA,
CDO.NOME AS CATEGORIA_NOME, CDO.CATEGORIA AS CATEGORIA, CDH.CARGA_HORARIA AS CARGA_HORARIA,
M.CODIGO AS MUNICIPIO, M.NOME AS NOME_MUNICIPIO,
CD.STATUS_OBS AS STATUS_OBS,
	(select count(*)
	from lyceum..LY_CANDIDATO_DOCENTE cdx join lyceum..LY_DOCENTE dx
	on  cdx.CONCURSO = dx.CONCURSO
	and cdx.CANDIDATO = dx.CANDIDATO
	join lyceum..LY_AULA_DOCENTE ax
	on dx.NUM_FUNC = ax.NUM_FUNC
	where ax.DATA_INICIO &lt;= GETDATE()
	and ax.DATA_FIM &gt;= GETDATE()
	and cdx.CANDIDATO = cd.CANDIDATO
	and cdx.CONCURSO = cd.CONCURSO) as aulas_aloc
FROM lyceum..LY_CANDIDATO_DOCENTE CD
left JOIN lyceum..LY_CONCURSO_DOCENTE CO ON CO.CONCURSO = CD.CONCURSO
left JOIN lyceum..LY_NUCLEO N ON N.NUCLEO = CD.NUCLEO
left JOIN lyceum..LY_DOCENTE DO ON DO.CANDIDATO = CD.CANDIDATO
left JOIN lyceum..LY_LOTACAO L ON L.MATRICULA = DO.MATRICULA
left JOIN lyceum..LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = L.UNIDADE_ENS
left JOIN lyceum..MUNICIPIO M ON M.CODIGO = UE.MUNICIPIO
left JOIN lyceum..LY_CATEGORIA_DOCENTE CDO ON CDO.CATEGORIA = DO.CATEGORIA
left JOIN lyceum..LY_GRUPO_HABILITACAO GH ON GH.AGRUPAMENTO = CD.AGRUPAMENTO_INGRESSO
LEFT JOIN lyceum..LY_CONCURSO_DOC_HABILITACAO CDH ON CDH.CONCURSO = CD.CONCURSO 
AND CDH.NUCLEO = CD.NUCLEO AND CDH.CATEGORIA = DO.CATEGORIA
WHERE CD.CONCURSO = @P_CONCURSO
AND CD.CANDIDATO = @P_CANDIDATO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="concurso">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="candidato">
          <DataField>CANDIDATO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome_candidato">
