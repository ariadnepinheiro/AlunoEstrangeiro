  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>dcbc09a8-123d-443d-8b92-a67ada7317ea</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DS_Contrato">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ConcursoDocente">
            <Value>=Parameters!ConcursoDocente.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Inscricao">
            <Value>=Parameters!Inscricao.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        TOP (1) p.NOME_COMPL, CONVERT(varchar(10), p.DT_NASC, 103) AS DT_NASC, RTRIM(p.ENDERECO) + ', ' + p.END_NUM AS Endereco, p.BAIRRO, 
                         mun.NOME AS Municipio, p.RG_NUM, p.RG_EMISSOR, CONVERT(varchar(10), p.RG_DTEXP, 103) AS RG_DTEXP, p.CPF
FROM            LY_PESSOA AS p INNER JOIN
                         LY_DOCENTE AS d ON d.PESSOA = p.PESSOA INNER JOIN
                         MUNICIPIO AS mun ON mun.CODIGO = p.END_MUNICIPIO INNER JOIN
                         LY_CANDIDATO_DOCENTE AS cd ON cd.CANDIDATO = d.CANDIDATO AND cd.CONCURSO = d.CONCURSO
WHERE        (d.MATRICULA LIKE '55%') AND (cd.CONCURSO = @ConcursoDocente) AND (d.matricula = @Inscricao)</CommandText>
      </Query>
      <Fields>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_NASC">
          <DataField>DT_NASC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Endereco">
          <DataField>Endereco</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BAIRRO">
          <DataField>BAIRRO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Municipio">
          <DataField>Municipio</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RG_NUM">
          <DataField>RG_NUM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RG_EMISSOR">
          <DataField>RG_EMISSOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RG_DTEXP">
          <DataField>RG_DTEXP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ConcursoDocente">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>Select CONCURSO, DESCRICAO from LY_CONCURSO_DOCENTE where concurso like '21%' or concurso like '22%'</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CONCURSO">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_Candidato">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@concursodocente">
            <Value>=Parameters!ConcursoDocente.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select d.candidato as Inscricao, d.matricula + ' - ' + d.candidato + ' - ' + ltrim(nome) as Candidato from Ly_candidato_docente
	inner join Ly_docente d
		on d.candidato = Ly_candidato_docente.candidato
where d.concurso = @concursodocente
order by ltrim(nome)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Candidato">
          <DataField>Candidato</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Inscricao">
          <DataField>Inscricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_Candidato_Nome">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@inscricao">
            <Value>=Parameters!Inscricao.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select Nome_Compl from Ly_Docente Where matricula = @inscricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Nome_Compl">
          <DataField>Nome_Compl</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
