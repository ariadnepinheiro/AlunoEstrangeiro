  <DataSources>
    <DataSource Name="DS_PropostaContratoTemp">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>6bee6239-d78c-4a25-9e83-a6799e8b1b5c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_Proposta">
      <Query>
        <DataSourceName>DS_PropostaContratoTemp</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CONCURSO">
            <Value>=Parameters!CONCURSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MATRICULA">
            <Value>=Parameters!MATRICULA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  distinct
--DADOS PESSOAIS
CD.CONCURSO, 
CD.CANDIDATO, 
CD.NOME AS NOME_CANDIDATO,
CD.DT_NASC, 
CD.SEXO, 
CD.NOME_MAE,
CD.NOME_PAI,
CD.NECESSIDADE_ESPECIAL, 
case  CD.ESTADO_CIVIL
	When 'Solteiro' then '1'
	When 'Casado' Then '2'
	When 'Viúvo' Then '3'
	When 'Desquitado' Then '4'
	When 'Divorciado' Then '6'
	Else '5' 
end  as ec_seplag,
(SELECT NOME FROM PAISES WHERE CD.PAIS_NASC = CODIGO) AS PAIS_NASC, 
(select isnull(item,8) from itemtabela  where tab = 'nacional (seplag)' and descr = CD.NACIONALIDADE) nacionalidade_seplag, --nacionalidade
--nivel
(select item from itemtabela  where tab = 'nivel (seplag)' and descr = CD.CARGA_HORARIA) nivel_seplag, --nivel
(select descr from itemtabela  where tab = 'nivel (seplag)' and descr = CD.CARGA_HORARIA) ch_seplag, --ch
CD.gi_seplag, --Grau de instrução

(SELECT ms.munic_sare_cod from MUNIC_LYCEUM ml 
inner join MUNICIPIO_SARE ms on ms.munic_cod = ml.munic_cod
where ml.codlyceum = UE.municipio) municipio_seplag, --municipio

(SELECT NOME FROM MUNICIPIO WHERE CD.MUNICIPIO_NASC = CODIGO) AS NATURALIDADE,
(SELECT UF_SIGLA FROM MUNICIPIO WHERE CD.MUNICIPIO_NASC = CODIGO) AS ESTADO_NASC,
DO.MATRICULA, DO.DT_ADMISSAO, CONVERT (VARCHAR(10), CD.DT_PROPOSTA, 103) AS DT_PROPOSTA, 
PE.CR_NUM, PE.CR_CAT, PE.CR_SERIE, PE.TELEITOR_NUM, PE.TELEITOR_ZONA, PE.TELEITOR_SECAO, PE.COR_RACA, 
--ENDEREÇO
(SELECT NOME FROM PAISES WHERE CD.END_PAIS = CODIGO) AS END_PAIS, 
(SELECT NOME FROM MUNICIPIO WHERE CODIGO = CD.END_MUNICIPIO) AS END_MUNICIPIO, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE CODIGO = CD.END_MUNICIPIO) AS END_UF, 
CD.CEP, CD.ENDERECO, CD.END_NUM, CD.END_COMPL, CD.BAIRRO,
--CONTATO
CD.FONE, CD.CELULAR, CD.E_MAIL,
--DOCUMENTOS
CD.CPF, CD.RG_TIPO, CD.RG_NUM, CD.RG_UF, CD.RG_EMISSOR, CD.RG_DTEXP, CD.PIS_PASEP, CD.CPROF_NUM, CD.CPROF_SERIE, CD.CPROF_DTEXP, CD.CPROF_UF,
--FOLHA DE PAGAMENTO
CD.NUCLEO AS NUCLEO, N.DESCRICAO AS DESC_NUCLEO,CDO.CATEGORIA,CDO.NOME AS CATEGORIA_NOME,GH.AGRUPAMENTO AS DISCIP_INGRESSO, 
GH.DESCRICAO AS DISCIP_DESC,UE.UNIDADE_ENS,UE.NOME_COMP AS NOME_UNIDADE, UE.SETOR as UA,
DO.BANCO, B.NOME AS NOME_BANCO, DO.AGENCIA, A.NOME AS NOME_AGENCIA, DO.CONTA_BANCO
FROM LY_CANDIDATO_DOCENTE CD
JOIN LY_CONCURSO_DOCENTE CO ON CO.CONCURSO = CD.CONCURSO
JOIN LY_NUCLEO N ON N.NUCLEO = CD.NUCLEO
JOIN LY_DOCENTE DO ON DO.CANDIDATO = CD.CANDIDATO AND CD.CONCURSO = DO.CONCURSO
JOIN LY_PESSOA PE ON DO.PESSOA = PE.PESSOA
JOIN LY_LOTACAO L ON L.MATRICULA = DO.MATRICULA
JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = L.UNIDADE_ENS
JOIN MUNICIPIO M ON M.CODIGO = UE.MUNICIPIO
JOIN LY_CATEGORIA_DOCENTE CDO ON CDO.CATEGORIA = DO.CATEGORIA
JOIN LY_GRUPO_HABILITACAO GH ON GH.AGRUPAMENTO = CD.AGRUPAMENTO_INGRESSO
LEFT JOIN LY_CONCURSO_DOC_HABILITACAO CDH ON CDH.CONCURSO = CD.CONCURSO AND CDO.CATEGORIA = CDH.CATEGORIA
AND CDH.NUCLEO = CD.NUCLEO AND CDH.CATEGORIA = DO.CATEGORIA
JOIN BANCOS B ON B.BANCO = DO.BANCO
JOIN AGENCIAS A ON A.AGENCIA = DO.AGENCIA AND A.BANCO = B.BANCO
WHERE DO.CONCURSO =  @CONCURSO
AND DO.MATRICULA= @MATRICULA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
