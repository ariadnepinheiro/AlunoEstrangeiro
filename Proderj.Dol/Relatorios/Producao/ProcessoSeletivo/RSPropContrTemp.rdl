    <DataSet Name="ds_Concurso">
      <Query>
        <DataSourceName>DS_PropostaContratoTemp</DataSourceName>
        <CommandText>Select DISTINCT CONCURSO from LY_CONCURSO_DOCENTE
</CommandText>
      </Query>
      <Fields>
        <Field Name="CONCURSO">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Candidato">
      <Query>
        <DataSourceName>DS_PropostaContratoTemp</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CONCURSO">
            <Value>=Parameters!CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT D.MATRICULA AS MATRICULA from LY_DOCENTE D
	INNER JOIN LY_CANDIDATO_DOCENTE CD
		on D.CANDIDATO = CD.CANDIDATO
where D.CONCURSO = @CONCURSO</CommandText>
      </Query>
      <Fields>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
