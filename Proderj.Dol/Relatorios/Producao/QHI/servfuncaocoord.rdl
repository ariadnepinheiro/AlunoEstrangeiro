        <CommandType>StoredProcedure</CommandType>
        <CommandText>REL_SERV_FUNC_COORD</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
