  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>e3260fe9-05ac-4502-a0bf-f9bbe3585271</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@sit">
            <Value>=Parameters!sit.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@tipo">
            <Value>=Parameters!tipo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--------------------------------------------------------------------------------------------------------------------------------------------------------------------
IF @tipo='1'          
BEGIN
			SELECT 
			SUBSTRING(N1.DESCRICAO,1,35) COORD,
--			(SELECT NOME FROM MUNICIPIO WHERE L1.MUNICIPIO=CODIGO)MUNICIPIO,
			TIPO_CARENCIA,
			SUM(D1.TEMPOS)TOTAL_AULA,
			D1.DISCIPLINA, 
			D1.CLASSIFICACAO
			FROM LY_UNIDADE_ENSINO L1 (NOLOCK)
			JOIN APOLLO..REL_CARENCIA_DETALHE D1 (NOLOCK) ON D1.UNIDADE_ENS=L1.UNIDADE_ENS
		    JOIN (
					SELECT	UNIDADE_ENS,SITUACAO,MAX(ORDEM)ORDEM 
					FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) 
					GROUP BY UNIDADE_ENS,SITUACAO
				 )SS1                
			ON SS1.UNIDADE_ENS=L1.UNIDADE_ENS
			JOIN LY_NUCLEO N1 (NOLOCK) ON N1.NUCLEO=L1.NUCLEO
			WHERE 
			(L1.NUCLEO = ISNULL(@COORD, L1.NUCLEO) OR L1.NUCLEO IS NULL )
			AND 
			 (SS1.situacao=isnull(@sit,SS1.situacao)or SS1.situacao is null)
			AND
			(L1.MUNICIPIO= isnull (@MUNIC,L1.MUNICIPIO)or L1.MUNICIPIO is null)

			AND D1.TIPO_CARENCIA IN ('CARÊNCIA TEMPORÁRIA','CARÊNCIA REAL') 
			GROUP BY N1.DESCRICAO, D1.DISCIPLINA, D1.TIPO_CARENCIA, D1.CLASSIFICACAO --L1.MUNICIPIO,
END
--------------------------------------------------------------------------------------------------------------------------------------------------------------------
IF @tipo='2' --CARÊNCIA TEMP
BEGIN
			SELECT 
			SUBSTRING(N1.DESCRICAO,1,35) COORD,
--			(SELECT NOME FROM MUNICIPIO WHERE L1.MUNICIPIO=CODIGO)MUNICIPIO,
			TIPO_CARENCIA,
			SUM(D1.TEMPOS)TOTAL_AULA,
			D1.DISCIPLINA, 
			D1.CLASSIFICACAO
			FROM LY_UNIDADE_ENSINO L1 (NOLOCK)
			JOIN APOLLO..REL_CARENCIA_DETALHE D1 (NOLOCK) ON D1.UNIDADE_ENS=L1.UNIDADE_ENS
		    JOIN (
					SELECT	UNIDADE_ENS,SITUACAO,MAX(ORDEM)ORDEM 
					FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) 
					GROUP BY UNIDADE_ENS,SITUACAO
				 )SS1                
			ON SS1.UNIDADE_ENS=L1.UNIDADE_ENS
			JOIN LY_NUCLEO N1 (NOLOCK) ON N1.NUCLEO=L1.NUCLEO
			WHERE 
			(L1.NUCLEO = ISNULL(@COORD, L1.NUCLEO) OR L1.NUCLEO IS NULL )
			AND 
			 (SS1.situacao=isnull(@sit,SS1.situacao)or SS1.situacao is null)
			AND
			(L1.MUNICIPIO= isnull (@MUNIC,L1.MUNICIPIO)or L1.MUNICIPIO is null)
			AND D1.TIPO_CARENCIA='CARÊNCIA TEMPORÁRIA'
			GROUP BY N1.DESCRICAO, D1.DISCIPLINA, D1.TIPO_CARENCIA, D1.CLASSIFICACAO --L1.MUNICIPIO,
END
--------------------------------------------------------------------------------------------------------------------------------------------------------------------
IF @tipo='3'
	BEGIN
			SELECT 
			SUBSTRING(N1.DESCRICAO,1,35) COORD,
--			(SELECT NOME FROM MUNICIPIO WHERE L1.MUNICIPIO=CODIGO)MUNICIPIO,
			TIPO_CARENCIA,
			SUM(D1.TEMPOS)TOTAL_AULA,
			D1.DISCIPLINA, 
			D1.CLASSIFICACAO
			FROM LY_UNIDADE_ENSINO L1 (NOLOCK)
			JOIN APOLLO..REL_CARENCIA_DETALHE D1 (NOLOCK) ON D1.UNIDADE_ENS=L1.UNIDADE_ENS
		    JOIN (
					SELECT	UNIDADE_ENS,SITUACAO,MAX(ORDEM)ORDEM 
					FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) 
					GROUP BY UNIDADE_ENS,SITUACAO
				 )SS1                
			ON SS1.UNIDADE_ENS=L1.UNIDADE_ENS
			JOIN LY_NUCLEO N1 (NOLOCK) ON N1.NUCLEO=L1.NUCLEO
			WHERE 
			(L1.NUCLEO = ISNULL(@COORD, L1.NUCLEO) OR L1.NUCLEO IS NULL )
			AND 
			 (SS1.situacao=isnull(@sit,SS1.situacao)or SS1.situacao is null)
			AND
			(L1.MUNICIPIO= isnull (@MUNIC,L1.MUNICIPIO)or L1.MUNICIPIO is null)
			AND D1.TIPO_CARENCIA='CARÊNCIA REAL'
			GROUP BY N1.DESCRICAO, D1.DISCIPLINA, D1.TIPO_CARENCIA, D1.CLASSIFICACAO --L1.MUNICIPIO,
END
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="COORD">
          <DataField>COORD</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO_CARENCIA">
          <DataField>TIPO_CARENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CLASSIFICACAO">
          <DataField>CLASSIFICACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_AULA">
          <DataField>TOTAL_AULA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select 'NULO' nucleo,' Selecione...' descricao 
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DATA_ATUALIZACAO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 2</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
