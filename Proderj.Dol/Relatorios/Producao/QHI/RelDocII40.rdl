  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ca5a0312-59c5-4bc8-ab44-49187c7d5c87</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Rel_carga_hor_livre">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DATA">
            <Value>=Parameters!DATA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT R.REGIONAL, M.NOME MUNICIPIO, UE.SETOR UA, UE.NOME_COMP UNIDADE, 
		D.MATRICULA, P.CPF, D.NOME_COMPL, D.CATEGORIA CARGO, F.DESCRICAO FUNCAO, DBO.f_TotalAulaNormal_Ano (D.MATRICULA, 2012) CH_AULA_MATRICULA, 
		DBO.f_TotalAulaGLP_Ano (D.MATRICULA, YEAR(GETDATE())) CH_AULA_GLP
FROM	LY_DOCENTE D 
JOIN	LY_PESSOA P 
ON		D.PESSOA = P.PESSOA
JOIN	LY_LOTACAO L 
ON		D.MATRICULA = L.MATRICULA
AND		L.DATA_NOMEACAO &lt;= @DATA
AND		(L.DATA_DESATIVACAO IS NULL 
OR		L.DATA_DESATIVACAO &gt; @DATA)
JOIN	LY_UNIDADE_ENSINO UE 
ON		UE.SETOR = L.SETOR
JOIN	TCE_REGIONAL R
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	HADES..TCE_MUNICIPIO M 
ON		M.ID_MUNICIPIO = UE.MUNICIPIO
JOIN	LY_FUNCAO F
ON		F.FUNCAO = L.FUNCAO
WHERE	EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																				(
																				SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																				FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
																				)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND		D.CATEGORIA LIKE '%II%40%'
AND		L.FUNCAO = '107'</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARGO">
          <DataField>CARGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CH_AULA_MATRICULA">
          <DataField>CH_AULA_MATRICULA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CH_AULA_GLP">
          <DataField>CH_AULA_GLP</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
