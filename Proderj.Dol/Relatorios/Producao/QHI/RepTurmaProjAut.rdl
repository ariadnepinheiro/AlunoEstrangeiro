    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:DataSourceID>1ab1af22-d92e-4b6b-8901-8470b7c145a9</rd:DataSourceID>
      <rd:SecurityType>None</rd:SecurityType>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DOCENTE">
          <DataField>DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GLP">
          <DataField>GLP</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MATRICULA_ACUM">
          <DataField>MATRICULA_ACUM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO_MATRIC_ACUM">
          <DataField>FUNCAO_MATRIC_ACUM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GLP_2MAT">
          <DataField>GLP_2MAT</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT     N.DESCRICAO AS COORDENADORIA, M.NOME AS MUNICIPIO, UE.UNIDADE_ENS AS CENSO, UE.NOME_COMP AS UNIDADE, D.MATRICULA, 
                      D.NOME_COMPL AS DOCENTE, L.SETOR AS UA, glp.GLP, G.MATRICULA AS MATRICULA_ACUM, G.DESCRICAO AS FUNCAO_MATRIC_ACUM, G.GLP GLP_2MAT
FROM         LY_LOTACAO AS L INNER JOIN
                      LY_DOCENTE AS D ON L.MATRICULA = D.MATRICULA INNER JOIN
                      LY_UNIDADE_ENSINO AS UE ON UE.SETOR = L.SETOR INNER JOIN
                      MUNICIPIO AS M ON M.CODIGO = UE.MUNICIPIO INNER JOIN
                      LY_NUCLEO AS N ON N.NUCLEO = UE.NUCLEO LEFT OUTER JOIN
                          (SELECT     DOC.MATRICULA, DOC.PESSOA, FF.DESCRICAO, AD1.GLP
                            FROM          LY_DOCENTE AS DOC WITH (NOLOCK) INNER JOIN
                                                   LY_PESSOA AS PES WITH (NOLOCK) ON DOC.PESSOA = PES.PESSOA INNER JOIN
                                                   LY_LOTACAO AS LL WITH (NOLOCK) ON LL.MATRICULA = DOC.MATRICULA INNER JOIN
                                                   LY_FUNCAO AS FF ON FF.FUNCAO = LL.FUNCAO LEFT OUTER JOIN
                                                       (SELECT     AD.NUM_FUNC, COUNT(DISTINCT STR(AD.DIA_SEMANA) + STR(AD.AULA) + AD.DISCIPLINA + AD.TURMA + STR(AD.ANO) 
                                                                                + STR(AD.SEMESTRE)) AS GLP
                                                         FROM          LY_AULA_DOCENTE_TIPO AS AD WITH (NOLOCK) INNER JOIN
                                                                                LY_TURMA AS T WITH (NOLOCK) ON AD.ANO = T.ANO AND AD.SEMESTRE = T.SEMESTRE AND AD.DISCIPLINA = T.DISCIPLINA AND 
                                                                                AD.TURMA = T.TURMA AND AD.DATA_FIM = T.DT_FIM AND AD.TIPO_AULA = 'GLP' AND T.SIT_TURMA = 'ABERTA' AND 
                                                                                T.ANO = YEAR(GETDATE())
                                                         GROUP BY AD.NUM_FUNC) AS AD1 ON AD1.NUM_FUNC = DOC.NUM_FUNC
                            WHERE      (DOC.DT_DEMISSAO IS NULL) AND (LL.DATA_DESATIVACAO &gt;= GETDATE() OR
                                                   LL.DATA_DESATIVACAO IS NULL)) AS G ON G.PESSOA = D.PESSOA AND G.MATRICULA &lt;&gt; D.MATRICULA LEFT OUTER JOIN
                          (SELECT     AD.NUM_FUNC, COUNT(DISTINCT STR(AD.DIA_SEMANA) + STR(AD.AULA) + AD.DISCIPLINA + AD.TURMA + STR(AD.ANO) + STR(AD.SEMESTRE)) 
                                                   AS GLP
                            FROM          LY_AULA_DOCENTE_TIPO AS AD WITH (NOLOCK) INNER JOIN
                                                   LY_TURMA AS T WITH (NOLOCK) ON AD.ANO = T.ANO AND AD.SEMESTRE = T.SEMESTRE AND AD.DISCIPLINA = T.DISCIPLINA AND 
                                                   AD.TURMA = T.TURMA AND AD.DATA_FIM = T.DT_FIM AND AD.TIPO_AULA = 'GLP' AND T.SIT_TURMA = 'ABERTA' AND T.ANO = YEAR(GETDATE())
                            GROUP BY AD.NUM_FUNC) AS glp ON glp.NUM_FUNC = D.NUM_FUNC
WHERE     (L.DATA_DESATIVACAO &gt;= GETDATE() OR
                      L.DATA_DESATIVACAO IS NULL) AND (L.FUNCAO = '10052') AND (N.NUCLEO = ISNULL(@coord, N.NUCLEO) OR
                      N.NUCLEO IS NULL) AND (M.CODIGO = ISNULL(@municipio, M.CODIGO) OR
                      M.CODIGO IS NULL) AND (UE.UNIDADE_ENS = ISNULL(@escola, UE.UNIDADE_ENS) OR
                      UE.UNIDADE_ENS IS NULL) AND EXISTS
                          (SELECT     1 AS Expr1
                            FROM          LY_UNIDADE_ENSINO_SITUACAO AS SU
                            WHERE      (UNIDADE_ENS = UE.UNIDADE_ENS) AND (SITUACAO = 'ESTADUAL'))
ORDER BY COORDENADORIA, UA, DOCENTE</CommandText>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="coordenadoria">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="municipio">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="escola">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
