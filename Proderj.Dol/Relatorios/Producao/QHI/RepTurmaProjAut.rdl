                  <CellContents>
                    <Textbox Name="COORDENADORIA">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=Fields!COORDENADORIA.Value</Value>
