    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ca5a0312-59c5-4bc8-ab44-49187c7d5c87</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Rel_carga_hor_livre">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@SIT_UNIDADE">
            <Value>=Parameters!SIT_UNIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT   NOME_MUNIC,                        
         COORDENADORIA,                        
         NOME_COMPL,                        
         NUM_FUNC,                        
         PESSOA,                        
         MATRICULA,                        
         CATEGORIA,                        
         CENSO,                        
         UA,                        
         NUCLEO,                        
         ESCOLA,                        
         MUNICIPIO,                        
         DISCIPLINA_INGRESSO,                        
         CONVERT(INT,CH_SEMANAL_EFETIVA)CH_SEMANAL_EFETIVA,                        
         ISNULL(ATUACAO, 0)   AS ATUACAO,                        
         ISNULL(RESTANTE, CH_SEMANAL_EFETIVA) AS RESTANTE,                        
         SITUAÇÃO             
      
FROM (                
SELECT DISTINCT       
      
--CAMPOS:      
(SELECT NOME FROM MUNICIPIO AS M (NOLOCK) WHERE CODIGO = EU.MUNICIPIO) AS NOME_MUNIC,                          
(SELECT DESCRICAO FROM LY_NUCLEO AS NA (NOLOCK) WHERE NUCLEO = EU.NUCLEO) AS COORDENADORIA,                          
DD.NOME_COMPL,                          
DD.NUM_FUNC,                          
DD.PESSOA,                          
DD.MATRICULA,                          
DD.CATEGORIA,                          
LT.UNIDADE_ENS AS CENSO,                          
LT.SETOR AS UA,                          
LT.NUCLEO,                          
EU.NOME_COMP AS ESCOLA,                          
EU.MUNICIPIO,           
                     
(SELECT TOP 1 HH.DESCRICAO  FROM  LY_GRUPO_HABILITACAO HH (NOLOCK)  
INNER JOIN LY_GRUPO_HABILITACAO_DOC DF (NOLOCK) ON DF.AGRUPAMENTO = HH.AGRUPAMENTO        
WHERE DF.NUM_FUNC = DD.NUM_FUNC AND DF.AGRUPAMENTO_INGRESSO = 'S') AS DISCIPLINA_INGRESSO,           
                     
ISNULL(CH.CH_SEMANAL_EFETIVA,0)CH_SEMANAL_EFETIVA, ISNULL(SS.ATUACAO,0) ATUACAO,                          
CASE WHEN MT.MOTIVO = '43' THEN CONVERT(INT, ISNULL(CH.CH_SEMANAL_EFETIVA,0)) / 2 - ISNULL(SS.ATUACAO,0)
ELSE CONVERT(INT, ISNULL(CH.CH_SEMANAL_EFETIVA,0)) - ISNULL(SS.ATUACAO,0) END RESTANTE,                                
CASE WHEN MT.MOTIVO = '43' THEN 'CARGA HORÁRIA REDUZIDA' END SITUAÇÃO        
--FROM:                   
FROM  LY_DOCENTE DD (NOLOCK)                          
INNER JOIN LY_LOTACAO LT (NOLOCK) ON DD.MATRICULA = LT.MATRICULA
AND (LT.DATA_NOMEACAO &lt;= CONVERT(DATE, CURRENT_TIMESTAMP) AND (LT.DATA_DESATIVACAO &gt; CONVERT(DATE,CURRENT_TIMESTAMP) OR LT.DATA_DESATIVACAO IS NULL))      
INNER JOIN LY_UNIDADE_ENSINO EU  (NOLOCK) ON LT.SETOR = EU.SETOR
INNER JOIN LY_CH_CATEGORIA CH   (NOLOCK) ON CH.CATEGORIA_DOCENTE = DD.CATEGORIA 
AND CH.FUNCAO = LT.FUNCAO AND CH.GLP = 'N' AND CH.READAPTADO = 'N'  
AND	NR_MATRICULAS = (	SELECT	COUNT(*) 
						FROM	LY_DOCENTE DOC (NOLOCK)  
						JOIN	LY_PESSOA PES (NOLOCK) 
						ON		DOC.PESSOA = PES.PESSOA    
						WHERE	PES.PESSOA = DD.PESSOA
						AND		DOC.DT_DEMISSAO IS NULL
					)                          
LEFT JOIN -- aulas do docente no ano corrente em turma aberta sem contar as GLPs      
(	SELECT	NUM_FUNC, ATUACAO, ANO 
	FROM	APOLLO..REL_CH_LIVRE (NOLOCK)
	WHERE	ANO = @ANO
 ) AS SS
   ON SS.NUM_FUNC = DD.NUM_FUNC           
         
LEFT JOIN (
			SELECT NUM_FUNC, MOTIVO
			FROM LY_LICENCA_DOCENTE WITH(NOLOCK) 
			WHERE MOTIVO = '43' 
			AND DTINI &lt;= CONVERT(DATE, CURRENT_TIMESTAMP) 
			AND DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP) 
			) MT
ON MT.NUM_FUNC = DD.NUM_FUNC

--WHERE                                                    
WHERE         
--LOTAÇÃO EM FUNÇÃO DE REGÊNCIA              
EXISTS (SELECT 1 FROM LY_FUNCAO F1 (nolock) WHERE F1.FUNCAO=LT.FUNCAO AND F1.CAMPO_01 = 'S')       
and NOT exists (SELECT MATRICULA FROM LY_DOCENTE DO WHERE CONCURSO IS NOT NULL AND CANDIDATO IS NOT NULL and DO.MATRICULA = DD.MATRICULA )
      
--TEM CARGA LIVRE SOBRANDO                        
AND CASE WHEN MT.MOTIVO = '43'  THEN (CH.CH_SEMANAL_EFETIVA/2 - isnull(SS.ATUACAO,0))
	ELSE (CH.CH_SEMANAL_EFETIVA- isnull(SS.ATUACAO,0))  END  &gt; 0
      
-- NÃO TEM LICENÇA DE CARGA HORÁRIA REDUZIDA                    
      
AND EXISTS (SELECT 1 FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK)  WHERE  UNIDADE_ENS = EU.UNIDADE_ENS AND SITUACAO = @SIT_UNIDADE)        
      
AND (LT.NUCLEO = @coord or @coord is null)      
AND (EU.MUNICIPIO = @municipio or @municipio is null)        
AND (LT.UNIDADE_ENS = @escola or @escola is null)      

 
) AS S           
      
--NÃO EXISTE LICENÇA DIFERENTE DA CH REDUZIDA (43)      
where      
NOT EXISTS (SELECT 1  FROM LY_LICENCA_DOCENTE (NOLOCK) WHERE S.NUM_FUNC = NUM_FUNC AND MOTIVO &lt;&gt; '43' AND (DTFIM IS NULL OR DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP)))         </CommandText>
      </Query>
      <Fields>
        <Field Name="NOME_MUNIC">
          <DataField>NOME_MUNIC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PESSOA">
          <DataField>PESSOA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUM_FUNC">
          <DataField>NUM_FUNC</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CATEGORIA">
          <DataField>CATEGORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA_INGRESSO">
          <DataField>DISCIPLINA_INGRESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CH_SEMANAL_EFETIVA">
          <DataField>CH_SEMANAL_EFETIVA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ATUACAO">
          <DataField>ATUACAO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RESTANTE">
          <DataField>RESTANTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SITUAÇÃO">
          <DataField>SITUAÇÃO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Data_Hora_Atualizacao">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 1</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
