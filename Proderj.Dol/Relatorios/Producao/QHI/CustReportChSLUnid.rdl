  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ca5a0312-59c5-4bc8-ab44-49187c7d5c87</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Rel_carga_hor_livre">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, 
		MM.NOME MUNICIPIO, 
		UE.SETOR UA, 
		UE.NOME_COMP ESCOLA, 
		ISNULL(SUM(RESTANTE),0) CH_LIVRE,
		QTDE_TURMAS, 
		TOTAL_AULAS,
		AULAS_ALOCADAS, 
		CARENCIA
FROM	LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN	TCE_REGIONAL  R (NOLOCK) 
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	HADES..TCE_MUNICIPIO MM (NOLOCK)
ON		MM.ID_MUNICIPIO = UE.MUNICIPIO
LEFT JOIN (
SELECT	UNIDADE_RESPONSAVEL, 
		COUNT(DISTINCT STR(ANO)+STR(SEMESTRE)+TURMA) QTDE_TURMAS, SUM(TOTAL_AULAS) TOTAL_AULAS, 
		SUM(AULAS_ALOC) AULAS_ALOCADAS, 
		 SUM(CARENCIA) CARENCIA  	
FROM	(
			SELECT	T.UNIDADE_RESPONSAVEL, T.ANO, T.SEMESTRE, T.TURMA, T.DISCIPLINA, 
					CONVERT(INT, REPLACE(DD.AULAS_SEMANAIS,'.0000','')) TOTAL_AULAS, 
					ISNULL(AULAS_ALOC,0) AULAS_ALOC, ISNULL(CA.CARENCIA,0) CARENCIA
			FROM	LY_TURMA T (NOLOCK)
			LEFT	JOIN	
						(
						SELECT	ANO, SEMESTRE, DISCIPLINA, TURMA, DATA_FIM, COUNT(DIA_SEMANA+AULA) AULAS_ALOC
						FROM	LY_AULA_DOCENTE (NOLOCK)
						WHERE	ANO = @ANO 
						AND		NUM_FUNC NOT IN (115451,115460)
						GROUP BY ANO, SEMESTRE, DISCIPLINA, TURMA, DATA_FIM
						) AD
			ON		T.ANO = AD.ANO
			AND		T.SEMESTRE = AD.SEMESTRE
			AND		T.DISCIPLINA = AD.DISCIPLINA
			AND		T.TURMA = AD.TURMA
			AND		T.DT_FIM = AD.DATA_FIM
			JOIN	LY_DISCIPLINA DD (NOLOCK)
			ON		DD.DISCIPLINA = ISNULL(T.DISCIPLINA, T.DISCIPLINA_MULTIPLA)
			LEFT JOIN ( 
						SELECT	ANO, SEMESTRE, TURMA, DISCIPLINA, SUM(TEMPOS) CARENCIA
						FROM	APOLLO..REL_CARENCIA_DETALHE (NOLOCK)
						WHERE	TIPO_CARENCIA LIKE 'CARENCIA%'
						GROUP BY ANO, SEMESTRE, TURMA, DISCIPLINA
						) CA
			ON		CA.ANO = T.ANO
			AND		CA.TURMA = T.TURMA
			AND		CA.SEMESTRE = T.SEMESTRE 
			AND		CA.DISCIPLINA = DD.NOME_COMPL
			WHERE	T.ANO = @ANO
			AND		T.SIT_TURMA = 'ABERTA'
			AND		T.CURSO NOT IN ('9999.92','9999.93','9999.94')
			GROUP BY T.UNIDADE_RESPONSAVEL, T.ANO, T.SEMESTRE, T.TURMA, 
					T.DISCIPLINA, DD.AULAS_SEMANAIS, AD.AULAS_ALOC, CA.CARENCIA					
			) AS A
GROUP BY UNIDADE_RESPONSAVEL
) TT
ON	TT.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS
LEFT JOIN (
			SELECT DISTINCT       
			LT.SETOR AS UA,                          
			DD.MATRICULA, 
			CASE WHEN MT.MOTIVO = '43' THEN CONVERT(INT, ISNULL(CH.CH_SEMANAL_EFETIVA,0)) / 2 - ISNULL(SS.ATUACAO,0)
			ELSE CONVERT(INT, ISNULL(CH.CH_SEMANAL_EFETIVA,0)) - ISNULL(SS.ATUACAO,0) END RESTANTE
			FROM  LY_DOCENTE DD (NOLOCK)                          
			INNER JOIN LY_LOTACAO LT (NOLOCK) ON DD.MATRICULA = LT.MATRICULA
			AND (LT.DATA_NOMEACAO &lt;= CONVERT(DATE, CURRENT_TIMESTAMP) AND (LT.DATA_DESATIVACAO &gt; CONVERT(DATE,CURRENT_TIMESTAMP) OR LT.DATA_DESATIVACAO IS NULL))      
			INNER JOIN LY_CH_CATEGORIA CH   (NOLOCK) ON CH.CATEGORIA_DOCENTE = DD.CATEGORIA 
			AND CH.FUNCAO = LT.FUNCAO AND CH.GLP = 'N' AND CH.READAPTADO = 'N'  
			AND	NR_MATRICULAS = (	SELECT	COUNT(*) 
									FROM	LY_DOCENTE DOC (NOLOCK)  
									JOIN	LY_PESSOA PES (NOLOCK) 
									ON		DOC.PESSOA = PES.PESSOA    
									WHERE	PES.PESSOA = DD.PESSOA
									AND		DOC.DT_DEMISSAO IS NULL
								)                          
LEFT JOIN -- aulas do docente no ano corrente em turma aberta sem contar as GLPs      
(	SELECT	NUM_FUNC, ATUACAO, ANO 
	FROM	APOLLO..REL_CH_LIVRE (NOLOCK)
	WHERE	ANO = @ANO
 ) AS SS
ON SS.NUM_FUNC = DD.NUM_FUNC                  
LEFT JOIN (
			SELECT NUM_FUNC, MOTIVO
			FROM LY_LICENCA_DOCENTE WITH(NOLOCK) 
			WHERE MOTIVO = '43' 
			AND DTINI &lt;= CONVERT(DATE, CURRENT_TIMESTAMP) 
			AND DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP) 
			) MT
ON MT.NUM_FUNC = DD.NUM_FUNC
WHERE    
EXISTS (SELECT 1 FROM LY_FUNCAO F1 (nolock) WHERE F1.FUNCAO=LT.FUNCAO AND F1.CAMPO_01 = 'S')       
AND		CONCURSO IS NULL 
AND		CANDIDATO IS NULL      
AND CASE WHEN MT.MOTIVO = '43'  THEN (CH.CH_SEMANAL_EFETIVA/2 - isnull(SS.ATUACAO,0))
	ELSE (CH.CH_SEMANAL_EFETIVA- isnull(SS.ATUACAO,0))  END  &gt; 0
AND NOT EXISTS (SELECT 1  FROM LY_LICENCA_DOCENTE (NOLOCK) WHERE DD.NUM_FUNC = NUM_FUNC AND MOTIVO &lt;&gt; '43' AND (DTFIM IS NULL OR DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP)))

) A
ON		A.UA = UE.SETOR
WHERE 	EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK) 
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																				(
																				SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																				FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
																				)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
GROUP BY REGIONAL, MM.NOME, UE.SETOR, UE.NOME_COMP, QTDE_TURMAS, AULAS_ALOCADAS, CARENCIA, TOTAL_AULAS
ORDER BY UE.SETOR</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CH_LIVRE">
          <DataField>CH_LIVRE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_TURMAS">
          <DataField>QTDE_TURMAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AULAS_ALOCADAS">
          <DataField>AULAS_ALOCADAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_AULAS">
          <DataField>TOTAL_AULAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CARENCIA">
          <DataField>CARENCIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Data_Hora_atualizacao">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 1</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT ANO 
FROM LY_PERIODO_LETIVO 
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
