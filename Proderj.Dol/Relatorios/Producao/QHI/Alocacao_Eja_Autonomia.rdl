  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.50.12.29;Initial Catalog=LYCEUM</ConnectString>
        <Prompt>Specify a user name and password for data source dblyceum:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>080104a9-852c-4fa1-a82e-8f568367cd21</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null id_regional,' TODAS' regional
union
select  l1.id_regional,SUBSTRING(l1.regional,1,35) from tce_regional L1 (nolock)
join LY_UNIDADE_ENSINO l2 (nolock) on L1.id_regional=l2.id_regional
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj (nolock) on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by regional</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="id_regional">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="regional">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Município">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.id_regional = ISNULL(@REGIONAL,n1.id_regional)or n1.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = UE.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (R.ID_REGIONAL = ISNULL(@REGIONAL,R.ID_REGIONAL) or R.ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, CASE WHEN MODALIDADE = 'PROJETO' THEN 'PROJETO AUTONOMIA' ELSE MODALIDADE END MODALIDADE, 
		COUNT(DISTINCT STR(ANO)+STR(SEMESTRE)+TURMA) QTDE_TURMAS, 
		SUM(CONVERT(DECIMAL(10,4),AULAS_ALOC))/SUM(CONVERT(DECIMAL(10,4),TOTAL_AULAS)) AULAS_ALOCADAS, 
		 SUM(CONVERT(DECIMAL(10,4),CARENCIA))/SUM(CONVERT(DECIMAL(10,4),TOTAL_AULAS)) CARENCIA  	
FROM	(
			SELECT	R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, 
					UE.NOME_COMP UNIDADE, MC.DESCRICAO MODALIDADE, 
					T.ANO, T.SEMESTRE, T.TURMA, T.DISCIPLINA, CONVERT(INT, REPLACE(DD.AULAS_SEMANAIS,'.0000','')) TOTAL_AULAS, 
					ISNULL(AULAS_ALOC,0) AULAS_ALOC, ISNULL(CA.CARENCIA,0) CARENCIA
			FROM	LY_TURMA T (NOLOCK)
			LEFT	JOIN	
						(
						SELECT	ANO, SEMESTRE, DISCIPLINA, TURMA, DATA_FIM, COUNT(DIA_SEMANA+AULA) AULAS_ALOC
						FROM	LY_AULA_DOCENTE (NOLOCK)
						WHERE	ANO = @ANO 
						AND		NUM_FUNC NOT IN (115451,115460)
						GROUP BY ANO, SEMESTRE, DISCIPLINA, TURMA, DATA_FIM
						) AD
			ON		T.ANO = AD.ANO
			AND		T.SEMESTRE = AD.SEMESTRE
			AND		T.DISCIPLINA = AD.DISCIPLINA
			AND		T.TURMA = AD.TURMA
			AND		T.DT_FIM = AD.DATA_FIM
			JOIN	LY_DISCIPLINA DD (NOLOCK)
			ON		DD.DISCIPLINA = ISNULL(T.DISCIPLINA, T.DISCIPLINA_MULTIPLA)
			LEFT JOIN ( 
						SELECT	ANO, SEMESTRE, TURMA, DISCIPLINA, SUM(TEMPOS) CARENCIA
						FROM	APOLLO..REL_CARENCIA_DETALHE (NOLOCK)
						WHERE	TIPO_CARENCIA LIKE 'CARENCIA%'
						GROUP BY ANO, SEMESTRE, TURMA, DISCIPLINA
						) CA
			ON		CA.ANO = T.ANO
			AND		CA.TURMA = T.TURMA
			AND		CA.SEMESTRE = T.SEMESTRE 
			AND		CA.DISCIPLINA = DD.NOME_COMPL
			JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
			ON		T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS
			JOIN	TCE_REGIONAL R (NOLOCK)
			ON		R.ID_REGIONAL = UE.ID_REGIONAL
			JOIN	MUNICIPIO M (NOLOCK)
			ON		M.CODIGO = UE.MUNICIPIO
			JOIN	LY_CURSO C (NOLOCK)
			ON		C.CURSO = T.CURSO
			JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
			ON		MC.MODALIDADE = C.MODALIDADE
			WHERE	T.ANO = @ANO
			AND		T.SIT_TURMA = 'ABERTA'
			AND 	EXISTS (
							SELECT	1
							FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK) 
							WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
							AND		US.SITUACAO = 'ESTADUAL'
							AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																							(
																							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
																							)
							)
			AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
			AND		T.CURSO IN ('0091.29','0092.39','0002.44')
			AND 	 (UE.UNIDADE_ENS = ISNULL(@ESCOLA,UE.UNIDADE_ENS) or UE.UNIDADE_ENS is null)
			AND 	 (UE.ID_REGIONAL = ISNULL(@REGIONAL,UE.ID_REGIONAL) or UE.ID_REGIONAL is null)
			AND 	 (UE.MUNICIPIO = ISNULL(@MUNIC,UE.MUNICIPIO) or UE.MUNICIPIO is null)
			GROUP BY R.REGIONAL, M.NOME, UE.UNIDADE_ENS, 
					UE.NOME_COMP, MC.DESCRICAO, T.ANO, T.SEMESTRE, T.TURMA, 
					T.DISCIPLINA, DD.AULAS_SEMANAIS, AD.AULAS_ALOC, CA.CARENCIA					
			) AS A
GROUP BY REGIONAL, MUNICIPIO, CENSO, UNIDADE, MODALIDADE
</CommandText>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_TURMAS">
          <DataField>QTDE_TURMAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AULAS_ALOCADAS">
          <DataField>AULAS_ALOCADAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARENCIA">
          <DataField>CARENCIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
