  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LyceumGov</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>0499a2cd-569e-4adc-b736-2b86d08b2936</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT     N.NUCLEO AS COORDENADORIA, N.DESCRICAO AS NOME_COORDENADORIA, U.UNIDADE_ENS, U.NOME_COMP AS NOME_UNIDADE_ENSINO, COUNT(*) 
                      AS QTD_MERENDAS
FROM         LY_ALUNO AS A INNER JOIN
                      LY_UNIDADE_ENSINO_CURSOS AS UE ON A.CURSO = UE.CURSO AND A.TURNO = UE.TURNO INNER JOIN
                      LY_UNIDADE_ENSINO AS U ON UE.UNIDADE_ENS = U.UNIDADE_ENS INNER JOIN
                      LY_NUCLEO AS N ON U.NUCLEO = N.NUCLEO INNER JOIN
                      LY_CARTEIRINHA AS C ON A.ALUNO = C.ALUNO INNER JOIN
                      LY_MERENDA AS M ON C.PESSOA = M.PESSOA AND C.VIA_CARTEIRINHA = M.VIA_CARTEIRINHA AND C.ALUNO = M.ALUNO
WHERE N.NUCLEO = ISNULL(@coord, N.NUCLEO)
AND U.UNIDADE_ENS = ISNULL(@ESCOLA, U.UNIDADE_ENS)
GROUP BY N.NUCLEO, N.DESCRICAO, U.UNIDADE_ENS, U.NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NOME_COORDENADORIA">
          <DataField>NOME_COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_UNIDADE_ENSINO">
          <DataField>NOME_UNIDADE_ENSINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTD_MERENDAS">
          <DataField>QTD_MERENDAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Coordenadoria">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@munic,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT l1.CODIGO, l1.NOME
FROM         LY_UNIDADE_ENSINO AS l2 INNER JOIN
                      MUNICIPIO AS l1 ON l1.CODIGO = l2.MUNICIPIO INNER JOIN
                      LY_NUCLEO AS n1 ON n1.NUCLEO = l2.NUCLEO INNER JOIN
                      LY_USUARIO_UNIDADE_FIS AS jj ON jj.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE     (n1.NUCLEO = ISNULL(@COORD, n1.NUCLEO)) OR
                      (n1.NUCLEO IS NULL)
UNION
SELECT     NULL AS codigo, ' TODOS' AS nome
UNION
SELECT     'NULO' AS codigo, ' Selecione...' AS descricao
ORDER BY l1.NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
