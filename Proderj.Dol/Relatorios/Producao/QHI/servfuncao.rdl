  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>14f6c4f5-6443-4849-9415-51a271cb9f30</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SITUACAO">
            <Value>=Parameters!SITUACAO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT      
         LY_NUCLEO.NUCLEO,      
                 LY_NUCLEO.DESCRICAO                            COORDENADORIA,      
                 MUNICIPIO.CODIGO                               COD_MUNIC,      
                 MUNICIPIO.NOME                                 MUNICIPIO,      
                 LY_UNIDADE_ENSINO.SETOR                               UA,      
                 LY_UNIDADE_ENSINO.NOME_COMP                      UA_NOME,      
                 LY_LOTACAO.MATRICULA,      
                 LY_PESSOA.NOME_COMPL,      
                 SR.DESCRICAO                                   CARGO,      
                 LY_FUNCAO.DESCRICAO                            FUNCAO,      
                 REPLACE (LY_LOTACAO.READAPTADO, 'N', '')       READAPTADO,      
         CONVERT(DATE, LY_LOTACAO.DT_INICIO_READAPTACAO)DT_INICIO_READAPTACAO,      
         CONVERT(DATE,      
         LY_LOTACAO.DT_FIM_READAPTACAO)   DT_FIM_READAPTACAO,      
                 LY_LICENCAS.DESCRICAO,      
                 SS.DTINI,      
                 SS.DTFIM,      
                 LY_UNIDADE_ENSINO.UNIDADE_ENS,      
                 FF.SITUACAO, 
                 (SELECT TOP 1 HH.DESCRICAO  FROM  LY_GRUPO_HABILITACAO HH (NOLOCK)  
					JOIN LY_GRUPO_HABILITACAO_DOC DF (NOLOCK) ON DF.AGRUPAMENTO = HH.AGRUPAMENTO        
					WHERE DF.NUM_FUNC = LY_DOCENTE.NUM_FUNC AND DF.AGRUPAMENTO_INGRESSO = 'S') AS DISCIPLINA_INGRESSO,
		'Possui função de ' +(
				SELECT TOP 1 FF1.DESCRICAO FROM LY_LOTACAO LL1 (NOLOCK) JOIN LY_FUNCAO FF1 (NOLOCK) ON LL1.FUNCAO = FF1.FUNCAO 
				WHERE LL1.DATA_NOMEACAO &lt; CONVERT(DATE,GETDATE()) AND (LL1.DATA_DESATIVACAO &gt;= CONVERT(DATE,GETDATE())
				OR LL1.DATA_DESATIVACAO IS NULL) AND LL1.PESSOA = LY_LOTACAO.PESSOA AND LL1.MATRICULA &lt;&gt; LY_LOTACAO.MATRICULA
				AND LL1.FUNCAO IN ('13','14','26')
				) + ' na segunda matrícula' OBS
          FROM   LY_PESSOA WITH (NOLOCK)      
                 JOIN LY_LOTACAO WITH (NOLOCK)      
                   ON LY_PESSOA.PESSOA = LY_LOTACAO.PESSOA      
                 JOIN (SELECT PESSOA,      
                              MATRICULA,      
                              DESCRICAO      
                       FROM   LY_VINCULO VV  WITH(NOLOCK)    
                              LEFT JOIN LY_CARGO GG  WITH(NOLOCK)    
                                ON GG.CARGO = VV.CATEGORIA      
                       UNION      
                       SELECT PESSOA,      
                              MATRICULA,      
                              CATEGORIA DESCRICAO      
                       FROM   LY_DOCENTE WITH(NOLOCK))SR      
                   ON SR.MATRICULA = LY_LOTACAO.MATRICULA      
                 LEFT JOIN LY_DOCENTE  WITH(NOLOCK)    
                   ON LY_DOCENTE.MATRICULA = LY_LOTACAO.MATRICULA
                 JOIN LY_UNIDADE_ENSINO  WITH(NOLOCK)    
                   ON LY_UNIDADE_ENSINO.SETOR = LY_LOTACAO.SETOR      
                 JOIN LY_NUCLEO  WITH(NOLOCK)    
                   ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO      
                 JOIN (SELECT UNIDADE_ENS,      
                              MAX(DT_SITUACAO)ORDEM,      
                              SITUACAO      
                       FROM   LY_UNIDADE_ENSINO_SITUACAO  WITH(NOLOCK)    
                       GROUP  BY UNIDADE_ENS,      
                                 SITUACAO)FF      
                   ON FF.UNIDADE_ENS = LY_UNIDADE_ENSINO.UNIDADE_ENS      
                 LEFT JOIN MUNICIPIO (NOLOCK)     
                   ON LY_UNIDADE_ENSINO.MUNICIPIO = MUNICIPIO.CODIGO      
                 JOIN LY_FUNCAO  (NOLOCK)    
                   ON LY_FUNCAO.FUNCAO = LY_LOTACAO.FUNCAO      
                 LEFT JOIN (SELECT *      
                            FROM   (SELECT DD.PESSOA, DD.MATRICULA,     
                                           LL.NUM_FUNC,      
                                           CONVERT(DATE, DTINI)DTINI,      
                                           CONVERT(DATE, DTFIM)DTFIM,      
                                           MAX(MOTIVO)         MOTIVO      
                                    FROM   LY_LICENCA_DOCENTE LL WITH (NOLOCK)      
                                           JOIN LY_DOCENTE DD WITH (NOLOCK)      
                                             ON DD.NUM_FUNC = LL.NUM_FUNC      
                          WHERE  DTINI &lt;=CONVERT(DATE, CURRENT_TIMESTAMP) AND (DTFIM &gt;  CONVERT(DATE, CURRENT_TIMESTAMP)      
        OR DTFIM IS NULL)    
                                    GROUP  BY DD.PESSOA, DD.MATRICULA,     
                                              LL.NUM_FUNC,      
                       DTINI,      
                                              DTFIM      
                                    UNION      
                                    SELECT LY_LICENCA_PESSOA.PESSOA, VCC.MATRICULA,      
                                           NULL,      
                                           CONVERT(DATE, DTINI)DTINI,      
                                           CONVERT(DATE, DTFIM)DTFIM,      
                                           MAX(MOTIVO)         MOTIVO      
                                    FROM   LY_LICENCA_PESSOA (NOLOCK)     
                                    JOIN LY_VINCULO VCC  (NOLOCK)
                                    ON  VCC.PESSOA = LY_LICENCA_PESSOA.PESSOA  
                                    AND  VCC.DATA_DESATIVACAO IS NULL  
                                    GROUP  BY LY_LICENCA_PESSOA.PESSOA, VCC.MATRICULA ,   
                                              DTINI,      
                                              DTFIM)S      
                            WHERE  DTINI &lt;=CONVERT(DATE, CURRENT_TIMESTAMP) AND ( DTFIM &gt; CONVERT(DATE, CURRENT_TIMESTAMP)      
                                      OR DTFIM IS NULL ))SS      
                   ON SS.PESSOA = LY_PESSOA.PESSOA      
                   AND LY_LOTACAO.MATRICULA = SS.MATRICULA  
                 LEFT JOIN LY_LICENCAS (NOLOCK)     
                   ON LY_LICENCAS.MOTIVO = SS.MOTIVO      
          WHERE      
                 LY_LOTACAO.DATA_NOMEACAO &lt;= GETDATE()      
                 AND ( LY_LOTACAO.DATA_DESATIVACAO &gt; GETDATE()      
                        OR LY_LOTACAO.DATA_DESATIVACAO IS NULL )      
                 AND LY_LOTACAO.FUNCAO NOT IN ( '106', '107', '108', '109',      
                                                '220', '10001', '10052' )                                                          
  AND  (LY_NUCLEO.NUCLEO = ISNULL (@NUCLEO, LY_NUCLEO.NUCLEO)      
            OR LY_NUCLEO.NUCLEO IS NULL )      
         AND ( MUNICIPIO.CODIGO = ISNULL (@MUNIC, MUNICIPIO.CODIGO)      
                OR MUNICIPIO.CODIGO IS NULL )      
         AND ( LY_UNIDADE_ENSINO.UNIDADE_ENS = ISNULL (@ESCOLA, LY_UNIDADE_ENSINO.UNIDADE_ENS)      
                OR LY_UNIDADE_ENSINO.UNIDADE_ENS IS NULL )      
         AND FF.SITUACAO = @SITUACAO </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COD_MUNIC">
          <DataField>COD_MUNIC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
