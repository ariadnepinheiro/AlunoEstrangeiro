  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CRITERIO">
          <DataField>CRITERIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESC_CRIT">
          <DataField>DESC_CRIT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOT_CRITERIO">
          <DataField>TOT_CRITERIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_TURNO">
          <DataField>QTDE_TURNO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_MATRICULAS">
          <DataField>QTDE_MATRICULAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VALOR_PERM_RESOL">
          <DataField>VALOR_PERM_RESOL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT  GERAL.*, CASE WHEN GERAL.FUNCAO = '14' THEN '1'
                           WHEN GERAL.FUNCAO = '13' AND GERAL.TOT_CRITERIO = 'A' THEN '3'
                           WHEN GERAL.FUNCAO = '13' AND GERAL.TOT_CRITERIO = 'B' THEN '2'
                           WHEN GERAL.FUNCAO = '13' AND GERAL.TOT_CRITERIO = 'C' THEN '1'
                           WHEN GERAL.FUNCAO = '5' THEN GERAL.TOT_CRITERIO
                           WHEN GERAL.FUNCAO = '9' AND GERAL.TOT_CRITERIO &gt; 200 THEN RE.VALOR_FUNC_PERM * GERAL.QTDE_TURNO
                           ELSE RE.VALOR_FUNC_PERM END VALOR_PERM_RESOL                           
FROM (
SELECT N.DESCRICAO COORDENADORIA, UE.UNIDADE_ENS CENSO,
             UE.NOME_COMP ESCOLA, M.NOME MUNICIPIO, 
             UE.SETOR UA, LL.FUNCAO, FF.DESCRICAO, 
             CE.CRITERIO, CE.DESC_CRIT, TUR.QTDE_TURNO,
             CASE CE.CRITERIO 
                                        WHEN '1' THEN 
                                               (SELECT LTRIM(RTRIM(STR(COUNT(DISTINCT A.ALUNO)))) FROM LY_ALUNO A (NOLOCK) 
                                                WHERE A.UNIDADE_ENSINO = UE.UNIDADE_ENS 
                                                AND (EXISTS (SELECT 1 FROM LY_MATRICULA M (NOLOCK) 
                                                WHERE ANO = CASE  WHEN CONVERT(DATE,GETDATE()) &gt; CONVERT(DATE, LTRIM(RTRIM(STR(YEAR(GETDATE()))))+'-04-01') THEN @ANO ELSE @ANO-1  END 
                                                AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND M.ALUNO = A.ALUNO)
                                               OR EXISTS (SELECT 1 FROM LY_HISTMATRICULA H (NOLOCK) 
                                                WHERE ANO = CASE  WHEN CONVERT(DATE,GETDATE()) &gt; CONVERT(DATE, LTRIM(RTRIM(STR(YEAR(GETDATE()))))+'-04-01') THEN @ANO ELSE @ANO-1  END                                                 AND SITUACAO_HIST &lt;&gt; 'CANCELADO' AND H.ALUNO = A.ALUNO)))
                                        WHEN '2' THEN 
                                               (SELECT LTRIM(RTRIM(STR(COUNT(DISTINCT TURMA)))) FROM LY_TURMA T (NOLOCK) 
                                                WHERE ANO = @ANO
                                               AND SIT_TURMA &lt;&gt; 'DESATIVADA'
                                               AND EXISTS (SELECT 1 FROM LY_CURSO C (NOLOCK) WHERE C.TIPO = '1' AND C.CURSO = T.CURSO)
                                               AND T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS)
                                        WHEN '3' THEN 
                                               (SELECT LTRIM(RTRIM(STR(COUNT(DISTINCT TURMA)))) FROM LY_TURMA T (NOLOCK) 
                                                WHERE ANO = @ANO
                                               AND SIT_TURMA &lt;&gt; 'DESATIVADA'
                                               AND EXISTS (SELECT 1 FROM LY_CURSO C (NOLOCK) WHERE C.CURSO = T.CURSO
                                               AND (C.TIPO = '2' OR (TIPO = '3' AND MODALIDADE IN ('ED2','RE1'))))
                                               AND T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS)
                                        WHEN '4' THEN 
                                               (SELECT LTRIM(RTRIM(STR(COUNT(DISTINCT TURMA)))) FROM LY_TURMA T (NOLOCK) 
                                                WHERE ANO = @ANO
                                               AND SIT_TURMA &lt;&gt; 'DESATIVADA'
                                               AND EXISTS (SELECT 1 FROM LY_CURSO C (NOLOCK) WHERE C.CURSO = T.CURSO
                                               AND C.TIPO = '3' AND MODALIDADE IN ('ED4','ED5','ED6','IN8'))
                                               AND T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS)
                                        WHEN '5' THEN 
                                               (SELECT LTRIM(RTRIM(STR(COUNT(DISTINCT TURMA)))) FROM LY_TURMA T (NOLOCK) 
                                                WHERE ANO = @ANO
                                               AND SIT_TURMA &lt;&gt; 'DESATIVADA'
                                               AND EXISTS (SELECT 1 FROM LY_CURSO C (NOLOCK) WHERE C.CURSO = T.CURSO
                                               AND C.TIPO = '3' AND MODALIDADE = 'NO9')
                                               AND T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS)
                                        WHEN '6' THEN 
												LTRIM(RTRIM(STR(TUR.QTDE_TURNO)))
                                        WHEN '7' THEN 
                                               UE.CLASSIFICACAO
                                        WHEN '8' THEN 
                                               (SELECT      LTRIM(RTRIM(STR(COUNT(DISTINCT MATRICULA)))) 
                                               FROM   LY_LOTACAO L1 (NOLOCK) 
                                               WHERE  DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE()) AND (DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()) OR DATA_DESATIVACAO IS NULL)
                                               AND          UE.SETOR = L1.SETOR)
                                        END TOT_CRITERIO,
                                        ll.QTDE_MATRICULAS                             
FROM   (
             SELECT FUNCAO, SETOR, SUM(QTDE_MATRICULAS) QTDE_MATRICULAS
             FROM (
					 SELECT FUNCAO, SETOR, COUNT(DISTINCT MATRICULA) QTDE_MATRICULAS
					 FROM   LY_LOTACAO L (NOLOCK) 
					 WHERE  DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE()) AND (DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()) OR DATA_DESATIVACAO IS NULL)
					 AND          EXISTS (SELECT 1 FROM LY_FUNCAO F WHERE F.FUNCAO = L.FUNCAO AND F.CAMPO_02 = 'S')
					 GROUP BY FUNCAO, SETOR
					 UNION	
					 SELECT FUNCAO, SETOR, 0
					 FROM	LY_UNIDADE_ENSINO UE1, APOLLO..REL_CONTROLE_EXTRACLAS
	             ) TT1
             GROUP BY FUNCAO, SETOR
             ) AS LL
LEFT JOIN APOLLO..REL_CONTROLE_EXTRACLAS CE (NOLOCK)
ON           CE.FUNCAO = LL.FUNCAO
JOIN   LY_UNIDADE_ENSINO UE (NOLOCK)
ON           UE.SETOR = LL.SETOR
JOIN   MUNICIPIO M (NOLOCK)
ON           M.CODIGO = UE.MUNICIPIO
JOIN   LY_NUCLEO N (NOLOCK)
ON           N.NUCLEO = UE.NUCLEO
JOIN   LY_FUNCAO FF
ON           FF.FUNCAO = LL.FUNCAO
LEFT JOIN (
		SELECT UNIDADE_RESPONSAVEL, COUNT(DISTINCT EX.TURNO_EQV) QTDE_TURNO
		FROM LY_TURMA T (NOLOCK) 
		JOIN APOLLO..REL_TURNO_EXTRACLAS EX
		ON	EX.TURNO = T.TURNO
		WHERE ANO = @ANO
		AND SIT_TURMA &lt;&gt; 'DESATIVADA'
		GROUP BY UNIDADE_RESPONSAVEL
)TUR
ON TUR.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS
WHERE  EXISTS (
                           SELECT 1 FROM LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK) WHERE US.UNIDADE_ENS = UE.UNIDADE_ENS 
                           AND US.SITUACAO = 'ESTADUAL'
                           )
AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA , UE.UNIDADE_ENS)OR UE.UNIDADE_ENS IS NULL)              
AND (N.NUCLEO = ISNULL(@COORD , N.NUCLEO)OR N.NUCLEO IS NULL)              
AND (UE.MUNICIPIO = ISNULL(@MUNIC , UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)              
) GERAL 
LEFT JOIN APOLLO..REL_RESOL_EXTRACLAS RE (NOLOCK)
ON GERAL.FUNCAO = RE.FUNCAO
AND GERAL.CRITERIO = RE.CRITERIO
AND CONVERT(INT,GERAL.TOT_CRITERIO) BETWEEN RE.VALOR_CRIT AND RE.VALOR_CRIT_FIM
ORDER BY GERAL.COORDENADORIA, GERAL.UA, GERAL.DESCRICAO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@COORD,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@COORD,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
  </DataSets>
