          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT REGIONAL, MUNICIPIO, S1.SETOR, S1.NOME_COMP, SUM(TURMA_INCOMPLETA) TURMA_INCOMPLETA, SUM(TURMA_COMPLETA) TURMA_COMPLETA, 
		SUM(SEM_ALOCACAO) SEM_ALOCACAO, COUNT(*) TOTAL_TURMAS 
FROM (
		SELECT DISTINCT 
		 UE.UNIDADE_ENS,UE.SETOR,UE.NOME_COMP,UE.ID_REGIONAL,R.REGIONAL, M.NOME MUNICIPIO, ANO, SEMESTRE, TURMA, CASE WHEN EM_ELABORACAO = 'S' THEN 1 ELSE 0 END TURMA_INCOMPLETA, 
		 CASE WHEN EM_ELABORACAO = 'N' THEN 1 ELSE 0 END TURMA_COMPLETA, CASE WHEN EM_ELABORACAO IS NULL THEN 1 ELSE 0 END SEM_ALOCACAO
		FROM LY_UNIDADE_ENSINO UE (NOLOCK)
		JOIN TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL=UE.ID_REGIONAL
		JOIN MUNICIPIO M (NOLOCK) ON M.CODIGO = UE.MUNICIPIO
		JOIN LY_TURMA T (NOLOCK)  ON T.ANO = @ANO
		AND		T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS
		AND		T.SIT_TURMA = 'Aberta'
WHERE		EXISTS (
						SELECT	1
						FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
						WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
						AND		US.SITUACAO = 'ESTADUAL'
						AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																						(
																						SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																						FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
																						)
						)
					AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
	 )S1
WHERE (S1.ID_REGIONAL = ISNULL(@REGIONAL, s1.ID_REGIONAL))
GROUP BY REGIONAL, MUNICIPIO, S1.SETOR, S1.NOME_COMP
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA_INCOMPLETA">
          <DataField>TURMA_INCOMPLETA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TURMA_COMPLETA">
          <DataField>TURMA_COMPLETA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_TURMAS">
          <DataField>TOTAL_TURMAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEM_ALOCACAO">
          <DataField>SEM_ALOCACAO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="regional">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null ID_REGIONAL,' TODAS' REGIONAL 
union
select  R.ID_REGIONAL,SUBSTRING(R.REGIONAL,1,35) from LY_UNIDADE_ENSINO  L2
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = L2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM LY_PERIODO_LETIVO (NOLOCK)</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
