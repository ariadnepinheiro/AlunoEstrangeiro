      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>REL_ACGLP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
