    <DataSet Name="Coordenadoria">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT        NULL AS nucleo, ' TODAS' AS descricao
FROM            LY_NUCLEO AS L1 INNER JOIN
                         LY_UNIDADE_ENSINO AS l2 ON L1.NUCLEO = l2.NUCLEO
UNION
SELECT        'NULO' AS nucleo, ' Selecione...' AS descricao
FROM            LY_NUCLEO AS l1 INNER JOIN
                         LY_UNIDADE_ENSINO AS l2 ON l1.NUCLEO = l2.NUCLEO INNER JOIN
                         MUNICIPIO AS m1 ON m1.CODIGO = l2.MUNICIPIO
UNION
SELECT        L1.NUCLEO, SUBSTRING(L1.DESCRICAO, 1, 35) AS Expr1
FROM            LY_NUCLEO AS L1 INNER JOIN
                         LY_UNIDADE_ENSINO AS l2 ON L1.NUCLEO = l2.NUCLEO INNER JOIN
                         MUNICIPIO AS m1 ON m1.CODIGO = l2.MUNICIPIO</CommandText>
      </Query>
    </DataSet>
    <DataSet Name="Município">
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT DISTINCT l1.CODIGO, l1.NOME
FROM            LY_UNIDADE_ENSINO AS l2 INNER JOIN
                         MUNICIPIO AS l1 ON l1.CODIGO = l2.MUNICIPIO INNER JOIN
                         LY_NUCLEO AS n1 ON n1.NUCLEO = l2.NUCLEO
WHERE        (n1.NUCLEO = ISNULL(@nucleo, n1.NUCLEO)) OR
                         (n1.NUCLEO IS NULL)
UNION
SELECT        NULL AS codigo, ' TODOS' AS nome
UNION
SELECT        'NULO' AS codigo, ' Selecione...' AS nome
ORDER BY l1.NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="Escolas">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT        'NULO' AS UNIDADE_ENS, ' Selecione...' AS NOME_COMP
UNION
SELECT        NULL AS UNIDADE_ENS, ' TODAS' AS NOME_COMP
UNION
SELECT        UNIDADE_ENS, SUBSTRING(NOME_COMP, 1, 50) AS NOME_COMP
FROM            LY_UNIDADE_ENSINO AS ue
WHERE        (NUCLEO = ISNULL(@nucleo, NUCLEO) OR
                         NUCLEO IS NULL) AND (MUNICIPIO = ISNULL(@municipio, MUNICIPIO) OR
                         MUNICIPIO IS NULL)
ORDER BY NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="Mês">
      <Fields>
        <Field Name="mes">
          <DataField>mes</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select distinct mes from LY_DOCENTE_FUNCAO_GLP order by MES desc</CommandText>
      </Query>
    </DataSet>
  </DataSets>
