  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>5e1607f2-9160-4e68-98dc-03a372be382f</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DT_INICIO">
            <Value>=Parameters!DT_INICIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DT_FIM">
            <Value>=Parameters!DT_FIM.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
TR.REGIONAL AS REGIONAL,
MM.NOME AS MUNICIPIO,
CA.DISCIPLINA AS DISCIPLINA,
UE.SETOR UA,
UPPER(UE.NOME_COMP) ESCOLA,
LEFT(LY_TURMA.TURMA, LEN(LY_TURMA.TURMA) - CHARINDEX('-', REVERSE(LY_TURMA.TURMA))) TURMA,
ISNULL(CA.CARENCIA, 0) CARENCIA,
CA.TIPO_CARENCIA,
--D.MATRICULA AS MAT
CONVERT(VARCHAR, AL.DATA_INICIO, 103) AS DATA_INICIO,
CONVERT(VARCHAR,AL.DATA_FIM, 103) AS DATA_FIM

FROM LY_TURMA (NOLOCK)
JOIN LY_AULA_DOCENTE AL (NOLOCK) ON AL.TURMA = LY_TURMA.TURMA    
								AND AL.DISCIPLINA=LY_TURMA.DISCIPLINA 
								AND AL.FACULDADE=LY_TURMA.FACULDADE
								AND AL.SEMESTRE=LY_TURMA.SEMESTRE
								AND AL.TURMA=LY_TURMA.TURMA
								AND AL.TURNO=LY_TURMA.TURNO
								AND AL.DATA_FIM=LY_TURMA.DT_FIM
								AND AL.DATA_INICIO &gt;= @DT_INICIO 
								AND AL.DATA_FIM &lt;= @DT_FIM
								
JOIN LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.UNIDADE_ENS = LY_TURMA.FACULDADE
JOIN TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = UE.ID_REGIONAL
LEFT JOIN HADES..MUNICIPIO MM (NOLOCK) ON MM.CODIGO = UE.MUNICIPIO  
--JOIN LY_DOCENTE D ON D.NUM_FUNC = AL.NUM_FUNC
		--AND D.MATRICULA = '99999999'
JOIN (SELECT  TURMA, DISCIPLINA, ANO, SEMESTRE, TIPO_CARENCIA,
					SUM(TEMPOS) CARENCIA
			FROM    APOLLO..REL_CARENCIA_DETALHE (NOLOCK)
			WHERE   TIPO_CARENCIA IN ('CARÊNCIA REAL')
			GROUP BY TURMA, DISCIPLINA, ANO, SEMESTRE, TIPO_CARENCIA
		  ) CA ON CA.TURMA = LY_TURMA.TURMA
          
WHERE EXISTS (SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
									(
									SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
									FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
									)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')     </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARENCIA">
          <DataField>CARENCIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_INICIO">
          <DataField>DATA_INICIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO_CARENCIA">
          <DataField>TIPO_CARENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_FIM">
          <DataField>DATA_FIM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
