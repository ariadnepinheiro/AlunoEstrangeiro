  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>14f6c4f5-6443-4849-9415-51a271cb9f30</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@SETOR">
            <Value>=Parameters!SETOR.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>  SELECT DISTINCT  
  MUNICIPIO.CODIGO								COD_MUNIC,  
  ISNULL(MUNICIPIO.NOME, 'NÃO INFORMADO')       MUNICIPIO,  
  LY_LOTACAO.SETOR                               UA,  
  SETOR.NOMESETOR                                UA_NOME,  
  LY_LOTACAO.MATRICULA,  
  LY_PESSOA.NOME_COMPL,  
  SR.DESCRICAO                                   CARGO,  
  LY_FUNCAO.DESCRICAO                            FUNCAO,  
  REPLACE (LY_LOTACAO.READAPTADO, 'N', '')       READAPTADO,  
  CONVERT(DATE, LY_LOTACAO.DT_INICIO_READAPTACAO)DT_INICIO_READAPTACAO,  
  CONVERT(DATE, LY_LOTACAO.DT_FIM_READAPTACAO)   DT_FIM_READAPTACAO,  
  LY_LICENCAS.DESCRICAO,  
  SS.DTINI,  
  SS.DTFIM  
  FROM   LY_PESSOA WITH (NOLOCK)  
         JOIN LY_LOTACAO WITH (NOLOCK)  
           ON LY_PESSOA.PESSOA = LY_LOTACAO.PESSOA  
         -- SERVIDORES E CARGOS        
         JOIN (SELECT PESSOA,  
                      MATRICULA,  
                      DESCRICAO  
               FROM   LY_VINCULO VV  (NOLOCK)
                      LEFT JOIN LY_CARGO GG  (NOLOCK)
                        ON GG.CARGO = VV.CATEGORIA  
               UNION  
               SELECT PESSOA,  
                      MATRICULA,  
                      CATEGORIA DESCRICAO  
               FROM   LY_DOCENTE (NOLOCK) )SR  
           ON SR.MATRICULA = LY_LOTACAO.MATRICULA  
         JOIN SETOR  (NOLOCK)
           ON SETOR.SETOR = LY_LOTACAO.SETOR  
         LEFT JOIN MUNICIPIO (NOLOCK) 
           ON SETOR.MBAIRRO_MUNICIPIO_CODIGO = MUNICIPIO.CODIGO  
         JOIN LY_FUNCAO  (NOLOCK)
           ON LY_FUNCAO.FUNCAO = LY_LOTACAO.FUNCAO  
         --LICENCAS        
         LEFT JOIN (SELECT *  
                    FROM   (SELECT DD.PESSOA,  
                                   LL.NUM_FUNC,  
                                   CONVERT(DATE, DTINI)DTINI,  
                                   CONVERT(DATE, DTFIM)DTFIM,  
                                   MAX(MOTIVO)         MOTIVO  
                            FROM   LY_LICENCA_DOCENTE LL (NOLOCK)  
                                   JOIN LY_DOCENTE DD (NOLOCK)  
                                     ON DD.NUM_FUNC = LL.NUM_FUNC  
                            WHERE  DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP)  
                            GROUP  BY DD.PESSOA,  
                                      LL.NUM_FUNC,  
                                      DTINI,  
                                      DTFIM  
                            UNION  
                            SELECT PESSOA,  
                                   NULL,  
                                   CONVERT(DATE, DTINI)DTINI,  
                                   CONVERT(DATE, DTFIM)DTFIM,  
                                   MAX(MOTIVO)         MOTIVO  
                            FROM   LY_LICENCA_PESSOA  (NOLOCK) 
                            GROUP  BY PESSOA,  
                                      DTINI,  
                                      DTFIM)S  
                    WHERE  ( DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP)  
                              OR DTFIM IS NULL ))SS  
           ON SS.PESSOA = LY_PESSOA.PESSOA  
         LEFT JOIN LY_LICENCAS  
           ON LY_LICENCAS.MOTIVO = SS.MOTIVO  
  WHERE  LY_LOTACAO.MATRICULA NOT IN (SELECT DISTINCT DD.MATRICULA  
                                      FROM   LY_DOCENTE DD (NOLOCK)  
                                             JOIN LY_AULA_DOCENTE DR (NOLOCK)  
                                               ON DD.NUM_FUNC = DR.NUM_FUNC  
                                             JOIN LY_TURMA TT (NOLOCK)  
                                               ON TT.ANO = DR.ANO  
                                                  AND TT.SEMESTRE = DR.SEMESTRE  
                                                  AND TT.FACULDADE = DR.FACULDADE  
                                                  AND TT.DISCIPLINA = DR.DISCIPLINA  
                                                  AND TT.TURMA = DR.TURMA  
                                                  AND TT.ANO = YEAR(CURRENT_TIMESTAMP)  
                                                  AND TT.DT_FIM = DR.DATA_FIM)  
         AND LY_LOTACAO.DATA_NOMEACAO &lt; CONVERT(DATE, GETDATE())
         AND ( LY_LOTACAO.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE())
                OR LY_LOTACAO.DATA_DESATIVACAO IS NULL )  
         AND NOT EXISTS (SELECT 1  
                         FROM   LY_UNIDADE_ENSINO EE  (NOLOCK)
                         WHERE  EE.SETOR = SETOR.SETOR)  
		 AND NOT EXISTS	(SELECT 1 
						 FROM	LY_NUCLEO N (NOLOCK) 
						 WHERE	N.NUCLEO = SETOR.SETOR
						 )                         
		AND SETOR.SETOR NOT IN ('189998', '187777')
        AND (SETOR.SETOR = ISNULL (@SETOR, SETOR.SETOR)  
                OR SETOR.SETOR IS NULL ) </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="COD_MUNIC">
          <DataField>COD_MUNIC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_NOME">
          <DataField>UA_NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARGO">
          <DataField>CARGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="READAPTADO">
          <DataField>READAPTADO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_INICIO_READAPTACAO">
          <DataField>DT_INICIO_READAPTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_FIM_READAPTACAO">
          <DataField>DT_FIM_READAPTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DTINI">
          <DataField>DTINI</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DTFIM">
          <DataField>DTFIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="coordenadoria">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 'NULO' setor,' Selecione...' descricao 
union
select null setor,' TODAS' nomesetor from SETOR L1
union
select  l1.SETOR,NOMESETOR from SETOR L1
where  NOT EXISTS (SELECT 1  
                         FROM   LY_UNIDADE_ENSINO EE  (NOLOCK)
                         WHERE  EE.SETOR = L1.SETOR)  
 AND NOT EXISTS	(SELECT 1 
						 FROM	LY_NUCLEO N (NOLOCK) 
						 WHERE	N.NUCLEO = L1.SETOR
						 )                         
		AND L1.SETOR NOT IN ('189998', '187777')
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="setor">
          <DataField>setor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
