  <DataSources>
    <DataSource Name="DS_Solicitacao">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>8fbf2656-28b1-4c3e-8b25-1c2892bd6378</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DS_COORDENADORIA">
      <Query>
        <DataSourceName>DS_Solicitacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT     'NULO' AS NUCLEO, ' Selecione...' AS COORDENADORIA
UNION
SELECT     NULL AS NUCLEO, ' TODAS' AS COORDENADORIA
FROM         LY_NUCLEO AS L1 INNER JOIN
                      LY_UNIDADE_ENSINO AS l2 ON L1.NUCLEO = l2.NUCLEO
UNION
SELECT     L1.NUCLEO, SUBSTRING(L1.DESCRICAO, 1, 35) AS Expr1
FROM         LY_NUCLEO AS L1 INNER JOIN
                      LY_UNIDADE_ENSINO AS l2 ON L1.NUCLEO = l2.NUCLEO INNER JOIN
                      MUNICIPIO AS m1 ON m1.CODIGO = l2.MUNICIPIO INNER JOIN
                      LY_USUARIO_UNIDADE_FIS AS jj ON jj.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE     (jj.USUARIO = ISNULL(@usuario, jj.USUARIO)) OR
                      (jj.USUARIO IS NULL)
ORDER BY COORDENADORIA</CommandText>
      </Query>
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_MUNICIPIO">
      <Query>
        <DataSourceName>DS_Solicitacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORDENADORIA">
            <Value>=Parameters!COORDENADORIA.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT l2.MUNICIPIO AS COD_MUNICIPIO, l1.NOME AS MUNICIPIO
FROM         LY_UNIDADE_ENSINO AS l2 INNER JOIN
                      MUNICIPIO AS l1 ON l1.CODIGO = l2.MUNICIPIO INNER JOIN
                      LY_NUCLEO AS n1 ON n1.NUCLEO = l2.NUCLEO
WHERE     (n1.NUCLEO = ISNULL(@COORDENADORIA, n1.NUCLEO)) OR
                      (n1.NUCLEO IS NULL)
UNION
SELECT     NULL AS codigo, ' TODOS' AS nome
UNION
SELECT     'NULO' AS codigo, ' Selecione...' AS nome
ORDER BY MUNICIPIO</CommandText>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="COD_MUNICIPIO">
          <DataField>COD_MUNICIPIO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_ESCOLA">
      <Query>
        <DataSourceName>DS_Solicitacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORDENADORIA">
            <Value>=Parameters!COORDENADORIA.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT     'NULO' AS UNIDADE_ENSINO, ' Selecione...' AS UNIDADE
UNION
SELECT     NULL AS UNIDADE_ENSINO, ' TODAS' AS UNIDADE
UNION
SELECT     UNIDADE_ENS AS UNIDADE_ENSINO, SUBSTRING(NOME_COMP, 1, 50) AS UNIDADE
FROM         LY_UNIDADE_ENSINO AS ue
WHERE     (NUCLEO = ISNULL(@COORDENADORIA, NUCLEO) OR
                      NUCLEO IS NULL) AND (MUNICIPIO = ISNULL(@MUNICIPIO, MUNICIPIO) OR
                      MUNICIPIO IS NULL)
ORDER BY UNIDADE</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENSINO">
          <DataField>UNIDADE_ENSINO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_SOLICITACAO_HABILITACAO">
      <Query>
        <DataSourceName>DS_Solicitacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORDENADORIA">
            <Value>=Parameters!COORDENADORIA.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@SITUACAO">
            <Value>=Parameters!SITUACAO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT     shd.ID_SOLICITACAO_HABILITACAO_DOCENTE AS 'CODIGO', n.DESCRICAO AS 'COORDENADORIA', M.NOME AS 'MUNICIPIO', 
                      ue.NOME_COMP AS 'ESCOLA', ue.SETOR AS 'UA', d.MATRICULA, d.NOME_COMPL AS 'NOME', d.CATEGORIA AS 'CARGO', ISNULL(F.DESCRICAO, '') 
                      AS 'FUNCAO', gh2.DESCRICAO AS 'DISCIPLINA_HABILITAR', shd.TIPO_SUBSTITUICAO, CASE WHEN HABILITACAO_MATRICULA = 'N' AND 
                      HABILITACAO_GLP = 'S' THEN 'GLP' WHEN HABILITACAO_MATRICULA = 'S' AND 
                      HABILITACAO_GLP = 'N' THEN 'Matricula' WHEN HABILITACAO_MATRICULA = 'S' AND 
                      HABILITACAO_GLP = 'S' THEN 'Matricula / GLP' END AS 'HABILITACAO_PARA', d2.MATRICULA AS 'MATRICULA_SUBSTITUIDA', 
                      shd.STATUS AS 'SITUACAO', shd.DATA_CADASTRO, shd.DATA_ANALISE, shd.MOTIVO
FROM         TCE_SOLICITACAO_HABILITACAO_DOCENTE AS shd WITH (NOLOCK) INNER JOIN
                      LY_UNIDADE_ENSINO AS ue WITH (NOLOCK) ON shd.UNIDADE_ENS = ue.UNIDADE_ENS INNER JOIN
                      LY_NUCLEO AS n WITH (NOLOCK) ON ue.NUCLEO = n.NUCLEO INNER JOIN
                      MUNICIPIO AS M WITH (NOLOCK) ON ue.MUNICIPIO = M.CODIGO INNER JOIN
                      LY_DOCENTE AS d WITH (NOLOCK) ON shd.NUM_FUNC = d.NUM_FUNC LEFT OUTER JOIN
                      LY_LOTACAO AS l WITH (NOLOCK) ON d.MATRICULA = l.MATRICULA AND (l.DATA_DESATIVACAO IS NULL OR
                      l.DATA_DESATIVACAO &gt; GETDATE()) INNER JOIN
                      LY_GRUPO_HABILITACAO_DOC AS ghd WITH (NOLOCK) ON d.NUM_FUNC = ghd.NUM_FUNC INNER JOIN
                      LY_GRUPO_HABILITACAO AS gh WITH (NOLOCK) ON ghd.AGRUPAMENTO = gh.AGRUPAMENTO LEFT OUTER JOIN
                      LY_FUNCAO AS F WITH (NOLOCK) ON F.FUNCAO = l.FUNCAO INNER JOIN
                      LY_GRUPO_HABILITACAO AS gh2 WITH (NOLOCK) ON shd.AGRUPAMENTO = gh2.AGRUPAMENTO LEFT OUTER JOIN
                      LY_DOCENTE AS d2 WITH (NOLOCK) ON shd.NUM_FUNC_SUBSTITUIDO = d2.NUM_FUNC
WHERE     (ghd.AGRUPAMENTO_INGRESSO = 'S')
 AND (ue.NUCLEO = ISNULL(@COORDENADORIA, ue.NUCLEO) OR
                      ue.NUCLEO IS NULL) 
AND (ue.MUNICIPIO = ISNULL(@MUNICIPIO, ue.MUNICIPIO) OR
                      ue.MUNICIPIO IS NULL)
AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) OR
                      UE.UNIDADE_ENS IS NULL)
AND (STATUS = ISNULL(@SITUACAO, STATUS) OR
                      STATUS IS NULL)</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="CARGO">
          <DataField>CARGO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="DISCIPLINA_HABILITAR">
          <DataField>DISCIPLINA_HABILITAR</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="HABILITACAO_PARA">
          <DataField>HABILITACAO_PARA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="TIPO_SUBSTITUICAO">
          <DataField>TIPO_SUBSTITUICAO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="MATRICULA_SUBSTITUIDA">
          <DataField>MATRICULA_SUBSTITUIDA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="DATA_CADASTRO">
          <DataField>DATA_CADASTRO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="DATA_ANALISE">
          <DataField>DATA_ANALISE</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="MOTIVO">
          <DataField>MOTIVO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
