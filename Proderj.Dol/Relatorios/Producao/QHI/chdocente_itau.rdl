        <Field Name="TOL_GLP">
          <DataField>TOL_GLP</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DIS_INGRESS">
          <DataField>DIS_INGRESS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LOTE">
          <DataField>LOTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
