      <Subreport Name="Subreport1">
        <ReportName>ch_docente_relsub</ReportName>
        <Parameters>
          <Parameter Name="MATRICULA">
            <Value>=Parameters!matricula.Value</Value>
          </Parameter>
          <Parameter Name="ANO">
            <Value>=Parameters!ano.Value</Value>
          </Parameter>
        </Parameters>
        <Top>13.30311cm</Top>
        <Left>1.36737cm</Left>
        <Height>6.51521cm</Height>
        <Width>7.5cm</Width>
        <ZIndex>3</ZIndex>
        <Style>
          <Border>
            <Style>None</Style>
          </Border>
        </Style>
      </Subreport>
    </ReportItems>
    <Height>7.92749in</Height>
    <Style />
  </Body>
  <Width>9.00684in</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin>
    <RightMargin>2cm</RightMargin>
    <TopMargin>2cm</TopMargin>
    <BottomMargin>2cm</BottomMargin>
    <ColumnSpacing>0.13cm</ColumnSpacing>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="dsProfessores">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ebcb1bc0-5edc-4d2a-900b-1783fac154a0</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ch_servidor">
      <Query>
        <DataSourceName>dsProfessores</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MATRICULA">
            <Value>=Parameters!matricula.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SET DATEFORMAT DMY
SELECT  *
FROM    (
         SELECT NULL SEGUNDA_MATRICULA,
                V1.MATRICULA,
                PP.NOME_COMPL,
                PP.CPF,
                (
                 SELECT DESCRICAO
                 FROM   LY_FUNCAO FF
                 WHERE  FF.FUNCAO = LL.FUNCAO
                ) FUNCAO,
                (
                 SELECT DESCRICAO
                 FROM   LY_CARGO CC
                 WHERE  CC.CARGO = V1.CATEGORIA
                ) CARGO,
                (CONVERT(INT, V1.CH_CATEGORIA)) [CH_INGRESSO],
                LL.SETOR [UNIDADE ADMINISTRATIVA],
                (
                 SELECT S1.NOMESETOR
                 FROM   SETOR S1
                 WHERE  S1.SETOR = LL.SETOR
                ) [UA DE LOTACAO],
                (
                 SELECT N1.DESCRICAO
                 FROM   LY_NUCLEO N1
                 WHERE  N1.NUCLEO = LL.NUCLEO
                ) COORDENADORIA,
                (
                 SELECT MM.NOME
                 FROM   MUNICIPIO MM
                 WHERE  MM.CODIGO = DD.MUNICIPIO
                ) MUNICIPIO,
                '0' HOR_TUR,
                '0' TOL_NORMAL,
                '0' TOL_GLP,
                NULL DIS_INGRESS,
                (
                 SELECT TOP 1
                        D3.DESCRICAO
                 FROM   LY_LICENCA_PESSOA D1
                        JOIN LY_LICENCAS D3
                        ON D1.MOTIVO = D3.MOTIVO
                        JOIN LY_VINCULO VM
                        ON VM.PESSOA = D1.PESSOA
                 WHERE  (
                         D1.DTFIM &gt; CONVERT(DATE, CURRENT_TIMESTAMP)
                         OR D1.DTFIM IS NULL
                        )
                        AND VM.MATRICULA = V1.MATRICULA
                ) SITUACAO,
                pit.LOTE
         FROM   LY_PESSOA PP
                JOIN LY_VINCULO V1
                ON V1.PESSOA = PP.PESSOA
                LEFT JOIN LY_LOTACAO LL
                ON LL.MATRICULA = V1.MATRICULA
                LEFT JOIN LY_UNIDADE_ENSINO DD
                ON DD.SETOR = LL.SETOR
                INNER JOIN dbo.TCE_PROFESSORES_ITAU pit
                ON LL.MATRICULA = pit.MATRICULA
         WHERE  V1.DATA_DESATIVACAO IS NULL
                AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                AND (
                     LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE())
                     OR LL.DATA_DESATIVACAO IS NULL
                    )
         UNION
         SELECT (
                 SELECT (
                         SELECT MAX(MM.MATRICULA)
                         FROM   LY_DOCENTE MM WITH (NOLOCK)
                         WHERE  MM.MATRICULA &lt;&gt; DD.MATRICULA
                                AND DD.PESSOA = MM.PESSOA
                                AND EXISTS ( SELECT 1
                                             FROM   LY_LOTACAO WITH (NOLOCK)
                                             WHERE  LY_LOTACAO.MATRICULA = MM.MATRICULA
                                                    AND DATA_DESATIVACAO IS NULL )
                        )
                 FROM   LY_DOCENTE DD WITH (NOLOCK)
                 WHERE  DD.MATRICULA = VV.MATRICULA
                ) SEGUNDA_MATRICULA,
                VV.MATRICULA,
                PP.NOME_COMPL,
                PP.CPF,
                CASE (
                      SELECT DISTINCT
                                '1'
                      FROM      LY_AULA_DOCENTE D1 WITH (NOLOCK)
                                JOIN LY_TURMA TT WITH (NOLOCK)
                                ON D1.ANO = TT.ANO
                                   AND D1.DISCIPLINA = TT.DISCIPLINA
                                   AND D1.FACULDADE = TT.FACULDADE
                                   AND D1.SEMESTRE = TT.SEMESTRE
                                   AND D1.TURMA = TT.TURMA
                                   AND D1.TURNO = TT.TURNO
                                   AND D1.DATA_FIM = TT.DT_FIM
                      WHERE     D1.ANO = 2011
                                AND D1.NUM_FUNC = VV.NUM_FUNC
                                AND NOT EXISTS ( SELECT 1
                                                 FROM   LY_AULA_DOCENTE_TIPO TP WITH (NOLOCK)
                                                 WHERE  D1.FACULDADE = TP.FACULDADE
                                                        AND D1.SEMESTRE = TP.SEMESTRE
                                                        AND D1.TURMA = TP.TURMA
                                                        AND D1.TURNO = TP.TURNO
                                                        AND D1.AULA = TP.AULA
                                                        AND D1.DISCIPLINA = TP.DISCIPLINA
                                                        AND D1.DIA_SEMANA = TP.DIA_SEMANA
                                                        AND D1.NUM_FUNC = TP.NUM_FUNC
                                                        AND D1.ANO = TP.ANO
                                                        AND TP.TIPO_AULA = 'GLP' )
                     )
                  WHEN '1' THEN CASE LL.FUNCAO
                                  WHEN '10052' THEN 'REGENTE DO PROJETO AUTONOMIA'
                                  ELSE 'REGENTE'
                                END
                  ELSE (
                        SELECT  DESCRICAO
                        FROM    LY_FUNCAO FF
                        WHERE   FF.FUNCAO = LL.FUNCAO
                       )
                END,
                VV.WINUSUARIO CARGO,
                VV.REGIME_TRABALHO [CH_INGRESSO],
                LL.SETOR [UNIDADE ADMINISTRATIVA],
                (
                 SELECT S1.NOMESETOR
                 FROM   SETOR S1
                 WHERE  S1.SETOR = LL.SETOR
                ) [UA DE LOTACAO],
                (
                 SELECT N1.DESCRICAO
                 FROM   LY_NUCLEO N1
                 WHERE  N1.NUCLEO = LL.NUCLEO
                ) COORDENADORIA,
                (
                 SELECT MM.NOME
                 FROM   MUNICIPIO MM
                 WHERE  MM.CODIGO = DD.MUNICIPIO
                ) MUNICIPIO,
                (dbo.f_TotalAulaNormal_Ano(@MATRICULA, 2011) + dbo.f_TotalAulaGLP_Ano(@MATRICULA, 2011)) HOR_TUR,
                dbo.f_TotalAulaNormal_Ano(@MATRICULA, 2011) TOL_NORMAL,
                dbo.f_TotalAulaGLP_Ano(@MATRICULA, 2011) TOL_GLP,
                (
                 SELECT HH.DESCRICAO
                 FROM   LY_GRUPO_HABILITACAO HH
                        JOIN LY_GRUPO_HABILITACAO_DOC JJ
                        ON JJ.AGRUPAMENTO = HH.AGRUPAMENTO
                 WHERE  JJ.NUM_FUNC = VV.NUM_FUNC
                        AND JJ.AGRUPAMENTO_INGRESSO = 'S'
                ) DIS_INGRESS,
                (
                 SELECT TOP 1
                        DESCRICAO
                 FROM   LY_LICENCAS L1
                        JOIN LY_LICENCA_DOCENTE D1
                        ON L1.MOTIVO = D1.MOTIVO
                        JOIN LY_DOCENTE D3
                        ON D3.NUM_FUNC = D1.NUM_FUNC
                 WHERE  (
                         DTFIM &gt; CONVERT(DATE, CURRENT_TIMESTAMP)
                         OR DTFIM IS NULL
                        )
                        AND D3.MATRICULA = VV.MATRICULA
                ) SITUACAO,
                pit.LOTE
         FROM   LY_PESSOA PP
                JOIN LY_DOCENTE VV
                ON VV.PESSOA = PP.PESSOA
                LEFT JOIN LY_LOTACAO LL
                ON LL.MATRICULA = VV.MATRICULA
                LEFT JOIN LY_UNIDADE_ENSINO DD
                ON DD.SETOR = LL.SETOR
                LEFT JOIN LY_CH_CATEGORIA AS CH
                ON CH.CATEGORIA_DOCENTE = VV.CATEGORIA
                   AND CH.FUNCAO = Ll.FUNCAO
                   AND CH.GLP = 'N'
                   AND CH.READAPTADO = 'N'
                   AND NR_MATRICULAS = (
                                        SELECT  COUNT(*)
                                        FROM    LY_DOCENTE DOC (NOLOCK)
                                                JOIN LY_PESSOA PES
                                                ON DOC.PESSOA = PES.PESSOA
                                        WHERE   PES.PESSOA = PP.PESSOA
                                       )
                INNER JOIN dbo.TCE_PROFESSORES_ITAU pit
                ON LL.MATRICULA = pit.MATRICULA
         WHERE  LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                AND (
                     LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE())
                     OR LL.DATA_DESATIVACAO IS NULL
                    )
                AND LL.FUNCAO NOT IN ('10028', '10029', '10030', '10031', '10032', '10033', '10034', '10035', '10036', '10037', '10038', '10039', '10040', '10041', '10042', '10043')
         UNION
         SELECT (
                 SELECT (
                         SELECT MAX(MM.MATRICULA)
                         FROM   LY_DOCENTE MM WITH (NOLOCK)
                         WHERE  MM.MATRICULA &lt;&gt; DD.MATRICULA
                                AND DD.PESSOA = MM.PESSOA
                                AND EXISTS ( SELECT 1
                                             FROM   LY_LOTACAO WITH (NOLOCK)
                                             WHERE  LY_LOTACAO.MATRICULA = MM.MATRICULA
                                                    AND DATA_DESATIVACAO IS NULL )
                        )
                 FROM   LY_DOCENTE DD WITH (NOLOCK)
                 WHERE  DD.MATRICULA = VV.MATRICULA
                ) SEGUNDA_MATRICULA,
                VV.MATRICULA,
                PP.NOME_COMPL,
                PP.CPF,
                (
                 SELECT DESCRICAO
                 FROM   LY_FUNCAO FF
                 WHERE  FF.FUNCAO = LL.FUNCAO
                ),
                VV.WINUSUARIO CARGO,
                VV.REGIME_TRABALHO [CH_INGRESSO],
                LL.SETOR [UNIDADE ADMINISTRATIVA],
                (
                 SELECT S1.NOMESETOR
                 FROM   SETOR S1
                 WHERE  S1.SETOR = LL.SETOR
                ) [UA DE LOTACAO],
                (
                 SELECT N1.DESCRICAO
                 FROM   LY_NUCLEO N1
                 WHERE  N1.NUCLEO = LL.NUCLEO
                ) COORDENADORIA,
                (
                 SELECT MM.NOME
                 FROM   MUNICIPIO MM
                 WHERE  MM.CODIGO = DD.MUNICIPIO
                ) MUNICIPIO,
                (dbo.f_TotalAulaNormal_Ano(@MATRICULA, 2011) + dbo.f_TotalAulaGLP_Ano(@MATRICULA, 2011)) HOR_TUR,
                dbo.f_TotalAulaNormal_Ano(@MATRICULA, 2011) TOL_NORMAL,
                dbo.f_TotalAulaGLP_ano(@MATRICULA, 2011) TOL_GLP,
                (
                 SELECT HH.DESCRICAO
                 FROM   LY_GRUPO_HABILITACAO HH
                        JOIN LY_GRUPO_HABILITACAO_DOC JJ
                        ON JJ.AGRUPAMENTO = HH.AGRUPAMENTO
                 WHERE  JJ.NUM_FUNC = VV.NUM_FUNC
                        AND JJ.AGRUPAMENTO_INGRESSO = 'S'
                ) DIS_INGRESS,
                (
                 SELECT TOP 1
                        DESCRICAO
                 FROM   LY_LICENCAS L1
                        JOIN LY_LICENCA_DOCENTE D1
                        ON L1.MOTIVO = D1.MOTIVO
                        JOIN LY_DOCENTE D3
                        ON D3.NUM_FUNC = D1.NUM_FUNC
                 WHERE  (
                         DTFIM &gt; CONVERT(DATE, CURRENT_TIMESTAMP)
                         OR DTFIM IS NULL
                        )
                        AND D3.MATRICULA = VV.MATRICULA
                ) SITUACAO,
                pit.LOTE
         FROM   LY_PESSOA PP
                JOIN LY_DOCENTE VV
                ON VV.PESSOA = PP.PESSOA
                LEFT JOIN LY_LOTACAO LL
                ON LL.MATRICULA = VV.MATRICULA
                LEFT JOIN LY_UNIDADE_ENSINO DD
                ON DD.SETOR = LL.SETOR
                LEFT JOIN LY_CH_CATEGORIA AS CH
                ON CH.CATEGORIA_DOCENTE = VV.CATEGORIA
                   AND CH.FUNCAO = Ll.FUNCAO
                   AND CH.GLP = 'N'
                   AND CH.READAPTADO = 'N'
                   AND NR_MATRICULAS = (
                                        SELECT  COUNT(*)
                                        FROM    LY_DOCENTE DOC (NOLOCK)
                                                JOIN LY_PESSOA PES
                                                ON DOC.PESSOA = PES.PESSOA
                                        WHERE   PES.PESSOA = PP.PESSOA
                                       )
                INNER JOIN dbo.TCE_PROFESSORES_ITAU pit
                ON LL.MATRICULA = pit.MATRICULA
         WHERE  LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                AND (
                     LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE())
                     OR LL.DATA_DESATIVACAO IS NULL
                    )
                AND LL.FUNCAO IN ('10028', '10029', '10030', '10031', '10032', '10033', '10034', '10035', '10036', '10037', '10038', '10039', '10040', '10041', '10042', '10043')
        ) S1
WHERE   S1.MATRICULA = @MATRICULA </CommandText>
      </Query>
      <Fields>
        <Field Name="SEGUNDA_MATRICULA">
          <DataField>SEGUNDA_MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
