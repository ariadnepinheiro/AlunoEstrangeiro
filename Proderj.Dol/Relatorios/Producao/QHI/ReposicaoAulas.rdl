          <DataField>PROFESSOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO_AULA">
          <DataField>TIPO_AULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="INÍCIO">
          <DataField>INÍCIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="FIM">
          <DataField>FIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="VALOR">
          <DataField>VALOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dsReposicao</DataSourceName>
        <CommandText>SELECT  n.DESCRICAO AS 'COORDENADORIA',
        m.NOME AS 'MUNICIPIO',
        ue.NOME_COMP AS 'ESCOLA',
        ue.SETOR AS 'UA',
        ue.UNIDADE_ENS AS 'CENSO',
        adg.ANO,
        adg.SEMESTRE AS 'PERIODO',
        adg.TURMA,
        t.TURNO,
        CASE adg.DIA_SEMANA
          WHEN 2 THEN 'Segunda'
          WHEN 3 THEN 'Terça'
          WHEN 4 THEN 'Quarta'
          WHEN 5 THEN 'Quinta'
          WHEN 6 THEN 'Sexta'
          WHEN 7 THEN 'Sábado'
        END AS 'DIA',
        CONVERT(CHAR(5), o.HORAINI_AULA, 108) AS 'ENTRADA',
        CONVERT(CHAR(5), o.HORAFIM_AULA, 108) AS 'SAIDA',
        di.NOME_COMPL AS 'DISCIPLINA',
        d.MATRICULA as 'MATRICULA',
        D.NOME_COMPL AS 'NOME',
        adg.MATRICULA_SUBSTITUTO AS 'MATRICULA_SUBSTITUICAO',
        D2.NOME_COMPL AS 'PROFESSOR',
        adg.TIPO AS 'TIPO_AULA',
        adg.DATA_INICIO_SUBSTITUICAO as 'INÍCIO',
        adg.DATA_FIM_SUBSTITUICAO AS 'FIM',
        cast(replace(adg.VALOR_GLP,',','.') as money) AS 'VALOR'
FROM    dbo.LY_AULA_DOCENTE ad WITH (NOLOCK)
        LEFT JOIN dbo.LY_AULA_DOCENTE_TIPO adt WITH (NOLOCK)
        ON adt.ANO = ad.ANO
           AND adt.AULA = ad.AULA
           AND adt.DATA_INICIO = ad.DATA_INICIO
           AND adt.DIA_SEMANA = ad.DIA_SEMANA
           AND adt.DISCIPLINA = ad.DISCIPLINA
           AND adt.FACULDADE = ad.FACULDADE
           AND adt.NUM_FUNC = ad.NUM_FUNC
           AND adt.SEMESTRE = ad.SEMESTRE
           AND adt.TURMA = ad.TURMA
           AND adt.TURNO = ad.TURNO
           AND adt.TIPO_AULA = 'GLP'
        INNER JOIN dbo.LY_DOCENTE d WITH (NOLOCK)
        ON ad.NUM_FUNC = d.NUM_FUNC
        INNER JOIN LY_DISCIPLINA di (NOLOCK)
        ON di.DISCIPLINA = ad.DISCIPLINA
        INNER JOIN LY_HOR_OPER o (NOLOCK)
        ON ad.AULA = o.AULA
           AND ad.DIA_SEMANA = o.DIA_SEMANA
           AND ad.FACULDADE = o.FACULDADE
           AND ad.TURNO = o.TURNO
        INNER JOIN dbo.TCE_AULA_DOCENTE_GREVE adg
        ON ad.ANO = adg.ANO
           AND ad.AULA = adg.AULA
           AND ad.DATA_INICIO = adg.DATA_INICIO
           AND ad.DIA_SEMANA = adg.DIA_SEMANA
           AND ad.DISCIPLINA = adg.DISCIPLINA
           AND ad.FACULDADE = adg.FACULDADE
           AND ad.NUM_FUNC = adg.NUM_FUNC
           AND ad.SEMESTRE = adg.SEMESTRE
           AND ad.TURMA = adg.TURMA
           AND ad.TURNO = adg.TURNO
        INNER JOIN dbo.LY_TURMA t
        ON adg.ANO = t.ANO
           AND adg.SEMESTRE = t.SEMESTRE
           AND adg.TURMA = t.TURMA
           AND adg.DISCIPLINA = t.DISCIPLINA
        INNER JOIN dbo.LY_UNIDADE_ENSINO ue
        ON t.FACULDADE = ue.UNIDADE_ENS
        INNER JOIN dbo.MUNICIPIO m
        ON ue.MUNICIPIO = m.CODIGO
        INNER JOIN dbo.LY_NUCLEO n
        ON ue.NUCLEO = n.NUCLEO
        INNER JOIN LY_DOCENTE d2
        ON adg.MATRICULA_SUBSTITUTO = d2.matricula</CommandText>
      </Query>
    </DataSet>
  </DataSets>
