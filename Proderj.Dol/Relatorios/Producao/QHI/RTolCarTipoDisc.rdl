  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>0543612e-1cc2-4902-a759-80fa55315639</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@tipo">
            <Value>=Parameters!tipo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT                                 
 NN.DESCRICAO,                
 SQL1.TIPO_CARENCIA,                
 SQL1.DISCIPLINA,              
 SQL1.CLASSIFICACAO,               
 SUM(SQL1.TEMPOS) TOTAL_CARENCIA,    
 SITUACAO,    
 MM.NOME MUNICIPIO                
FROM APOLLO..REL_CARENCIA_DETALHE SQL1                
JOIN LY_UNIDADE_ENSINO EE ON EE.UNIDADE_ENS=SQL1.UNIDADE_ENS 
JOIN LY_NUCLEO NN ON NN.NUCLEO=EE.NUCLEO        
left JOIN MUNICIPIO MM ON MM.CODIGO=EE.MUNICIPIO            
WHERE SITUACAO = @tipo
GROUP BY NN.DESCRICAO,SQL1.TIPO_CARENCIA,                
 SQL1.DISCIPLINA,              
 SQL1.CLASSIFICACAO,    
 SQL1.SITUACAO,    
 MM.NOME
ORDER BY NN.DESCRICAO,CLASSIFICACAO,DISCIPLINA,TIPO_CARENCIA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO_CARENCIA">
          <DataField>TIPO_CARENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CLASSIFICACAO">
          <DataField>CLASSIFICACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_CARENCIA">
          <DataField>TOTAL_CARENCIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DATA_ATUALIZACAO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 2</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
