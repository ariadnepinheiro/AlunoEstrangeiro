  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>0543612e-1cc2-4902-a759-80fa55315639</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@TIPO">
            <Value>=Parameters!tipo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT COORDENADORIA, MUNICIPIO, DISCIPLINA, CLASSIFICACAO, SUM(CARENCIA_REAL) CARENCIA_REAL, SUM(PROF_CAR_REAL) PROF_CAR_REAL, SUM(CARENCIA_TEMP) CARENCIA_TEMP, SUM(PROF_CAR_TEMP) PROF_CAR_TEMP, 
SUM(GLP_REAL) GLP_REAL, SUM(PROF_GLP_REAL) PROF_GLP_REAL, SUM(GLP_TEMP) GLP_TEMP, SUM(PROF_GLP_TEMP) PROF_GLP_TEMP, SUM(CONTRATO) CONTRATO, SUM(PROF_CONTRATO) PROF_CONTRATO
FROM (
SELECT N.DESCRICAO COORDENADORIA, MU.NOME MUNICIPIO, 
CASE WHEN DISCIPLINA = 'LINGUA ESTRANGEIRA OPTATIVA' THEN 'LÍNGUA ESTRANGEIRA - ESPANHOL' 
WHEN DISCIPLINA = 'LÍNGUA PORTUGUESA' THEN 'LÍNGUA PORTUGUESA/LITERATURA' 
WHEN DISCIPLINA = 'LITERATURA' THEN 'LÍNGUA PORTUGUESA/LITERATURA' ELSE DISCIPLINA END DISCIPLINA, 
CC.CLASSIFICACAO, CARENCIA_REAL, PROF_CAR_REAL, CARENCIA_TEMP, PROF_CAR_TEMP, 
GLP_REAL, PROF_GLP_REAL, GLP_TEMP, PROF_GLP_TEMP, CONTRATO, PROF_CONTRATO
FROM 	APOLLO..REL_CARENCIA_CONS CC (NOLOCK)
JOIN LY_UNIDADE_ENSINO UE (NOLOCK) 
ON UE.UNIDADE_ENS = CC.UNIDADE_ENS 
JOIN LY_NUCLEO N (NOLOCK)
ON N.NUCLEO = UE.NUCLEO
JOIN MUNICIPIO MU 
ON MU.CODIGO = UE.MUNICIPIO
WHERE 	SITUACAO = @TIPO
AND 	CC.CLASSIFICACAO = 'BASE NACIONAL COMUM'
 AND ( MU.NOME = ISNULL(@munic, MU.NOME)              
        OR MU.NOME IS NULL )              
)  C
GROUP BY COORDENADORIA,  DISCIPLINA, CLASSIFICACAO, MUNICIPIO
UNION 
SELECT N.DESCRICAO COORDENADORIA, MU.NOME MUNICIPIO,
'ATIVIDADES INTEGRADAS (1o. ao 5o. ano)', C.CLASSIFICACAO, SUM(CARENCIA_REAL) CARENCIA_REAL, SUM(PROF_CAR_REAL) PROF_CAR_REAL, SUM(CARENCIA_TEMP) CARENCIA_TEMP, SUM(PROF_CAR_TEMP) PROF_CAR_TEMP, 
SUM(GLP_REAL) GLP_REAL, SUM(PROF_GLP_REAL) PROF_GLP_REAL, SUM(GLP_TEMP) GLP_TEMP, SUM(PROF_GLP_TEMP) PROF_GLP_TEMP, SUM(CONTRATO) CONTRATO, SUM(PROF_CONTRATO) PROF_CONTRATO
FROM 	APOLLO..REL_CARENCIA_CONS C (NOLOCK)
JOIN LY_UNIDADE_ENSINO UE (NOLOCK) 
ON UE.UNIDADE_ENS = C.UNIDADE_ENS 
JOIN LY_NUCLEO N (NOLOCK)
ON N.NUCLEO = UE.NUCLEO
JOIN MUNICIPIO MU 
ON MU.CODIGO = UE.MUNICIPIO
WHERE 	SITUACAO = @TIPO
AND 	C.CLASSIFICACAO = 'BASE NACIONAL COMUM-DOC II'
 AND ( MU.NOME = ISNULL(@munic, MU.NOME)              
        OR MU.NOME IS NULL )              
GROUP BY C.CLASSIFICACAO, N.DESCRICAO, MU.NOME
UNION 
SELECT 	N.DESCRICAO COORDENADORIA, MU.NOME MUNICIPIO,
'Formação Profissional e Curso Normal', C.CLASSIFICACAO, SUM(CARENCIA_REAL) CARENCIA_REAL, SUM(PROF_CAR_REAL) PROF_CAR_REAL, SUM(CARENCIA_TEMP) CARENCIA_TEMP, SUM(PROF_CAR_TEMP) PROF_CAR_TEMP, 
SUM(GLP_REAL) GLP_REAL, SUM(PROF_GLP_REAL) PROF_GLP_REAL, SUM(GLP_TEMP) GLP_TEMP, SUM(PROF_GLP_TEMP) PROF_GLP_TEMP, SUM(CONTRATO) CONTRATO, SUM(PROF_CONTRATO) PROF_CONTRATO
FROM 	APOLLO..REL_CARENCIA_CONS C (NOLOCK)
JOIN LY_UNIDADE_ENSINO UE (NOLOCK) 
ON UE.UNIDADE_ENS = C.UNIDADE_ENS 
JOIN LY_NUCLEO N (NOLOCK)
ON N.NUCLEO = UE.NUCLEO
JOIN MUNICIPIO MU 
ON MU.CODIGO = UE.MUNICIPIO
WHERE 	SITUACAO = @TIPO
AND 	C.CLASSIFICACAO = 'FORMAÇÃO PROFISSIONAL'
 AND ( MU.NOME = ISNULL(@munic, MU.NOME)              
        OR MU.NOME IS NULL )              
GROUP BY C.CLASSIFICACAO, N.DESCRICAO, MU.NOME
UNION 
SELECT 	N.DESCRICAO COORDENADORIA, MU.NOME MUNICIPIO,
'Ens.Religioso/Projeto/Oficinas/Estudo e Pesquisa', C.CLASSIFICACAO, SUM(CARENCIA_REAL) CARENCIA_REAL, SUM(PROF_CAR_REAL) PROF_CAR_REAL, SUM(CARENCIA_TEMP) CARENCIA_TEMP, SUM(PROF_CAR_TEMP) PROF_CAR_TEMP, 
SUM(GLP_REAL) GLP_REAL, SUM(PROF_GLP_REAL) PROF_GLP_REAL, SUM(GLP_TEMP) GLP_TEMP, SUM(PROF_GLP_TEMP) PROF_GLP_TEMP, SUM(CONTRATO) CONTRATO, SUM(PROF_CONTRATO) PROF_CONTRATO
FROM 	APOLLO..REL_CARENCIA_CONS C (NOLOCK)
JOIN LY_UNIDADE_ENSINO UE (NOLOCK) 
ON UE.UNIDADE_ENS = C.UNIDADE_ENS 
JOIN LY_NUCLEO N (NOLOCK)
ON N.NUCLEO = UE.NUCLEO
JOIN MUNICIPIO MU 
ON MU.CODIGO = UE.MUNICIPIO
WHERE 	SITUACAO = @TIPO
AND 	C.CLASSIFICACAO = 'PARTE DIVERSIFICADA'
 AND ( MU.NOME = ISNULL(@munic, MU.NOME)              
        OR MU.NOME IS NULL )              
GROUP BY C.CLASSIFICACAO, N.DESCRICAO, MU.NOME
ORDER BY COORDENADORIA, MUNICIPIO, CLASSIFICACAO, DISCIPLINA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
