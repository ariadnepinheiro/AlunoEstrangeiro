  <Description>Relatório de Auxílio p/ Alocação de Servidor</Description>
  <Author>Alexandre Fonseca</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="S_AUX_ALOC_SERV">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ee7e2c46-bbca-41f2-bca0-5688878f583a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>S_AUX_ALOC_SERV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@sit">
            <Value>=Parameters!sit.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT   NN.NUCLEO,                  
         NN.DESCRICAO COORDENADORIA,                  
         MM.CODIGO,                  
         MM.NOME,                  
         UE.UNIDADE_ENS,                  
         UE.NOME_COMP ESCOLA,                  
         UE.SETOR UA,                  
         D.DISCIPLINA,					
		 D.DIA_SEMANA, 
		 D.TURNO,                  
         SUM(D.TEMPOS) TOTAL_TEMPOS,                  
   	     CASE TIPO_CARENCIA WHEN 'GLP TEMPORÁRIA' THEN 'GLP' 
							WHEN 'GLP REAL' THEN 'GLP' 
							ELSE D.TIPO_CARENCIA END TIPO_CARENCIA,  
         CASE TIPO_CARENCIA WHEN 'GLP TEMPORÁRIA' THEN 'CARÊNCIA TEMPORÁRIA' 
							WHEN 'GLP REAL' THEN 'CARÊNCIA REAL' 
							ELSE NULL END CARENCIA_ANT,
         UPPER(D.CLASSIFICACAO) CLASSIFICACAO
FROM	APOLLO..REL_CARENCIA_DETALHE D (NOLOCK) 
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		UE.UNIDADE_ENS = D.UNIDADE_ENS
JOIN	LY_NUCLEO NN (NOLOCK) 
ON		NN.NUCLEO = UE.NUCLEO
JOIN	MUNICIPIO MM (NOLOCK)
ON		MM.CODIGO = UE.MUNICIPIO
WHERE   ( UE.NUCLEO = ISNULL(@coord, UE.NUCLEO)                  
            OR UE.NUCLEO IS NULL )         
         AND ( UE.MUNICIPIO = ISNULL(@munic, UE.MUNICIPIO)                  
                OR UE.MUNICIPIO IS NULL )                  
         AND ( UE.UNIDADE_ENS = ISNULL(@escola, UE.UNIDADE_ENS)                  
                OR UE.UNIDADE_ENS IS NULL )                  
         AND ( D.SITUACAO = @sit)   
GROUP BY NN.NUCLEO,                  
         NN.DESCRICAO,                  
         MM.CODIGO,                  
         MM.NOME,                  
         UE.UNIDADE_ENS,                  
         UE.NOME_COMP,                  
         UE.SETOR,                  
         D.DISCIPLINA,					
		 D.DIA_SEMANA, 
		 D.TURNO,                  
		 D.TIPO_CARENCIA,
		 D.CLASSIFICACAO
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DIA_SEMANA">
          <DataField>DIA_SEMANA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_TEMPOS">
          <DataField>TOTAL_TEMPOS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TIPO_CARENCIA">
          <DataField>TIPO_CARENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARENCIA_ANT">
          <DataField>CARENCIA_ANT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CLASSIFICACAO">
          <DataField>CLASSIFICACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="coordenadoria">
      <Query>
        <DataSourceName>S_AUX_ALOC_SERV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' NUCLEO,' Selecione...' DESCRICAO 
union
select null NUCLEO,' TODAS' DESCRICAO 
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
left join LY_USUARIO_UNIDADE_FIS ff on ff.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(ff.USUARIO = ISNULL(@usuario,ff.USUARIO)or ff.USUARIO is null)
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="municipio">
      <Query>
        <DataSourceName>S_AUX_ALOC_SERV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY nome</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="escola">
      <Query>
        <DataSourceName>S_AUX_ALOC_SERV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS ff on ff.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = isnull(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = isnull(@munic,ue.municipio)or ue.MUNICIPIO is null)
and (ff.USUARIO = isnull(@usuario,ff.USUARIO)or ff.USUARIO is null)
order by NOME_COMP </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DATA_ATUALIZACAO">
      <Query>
        <DataSourceName>S_AUX_ALOC_SERV</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 2</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
