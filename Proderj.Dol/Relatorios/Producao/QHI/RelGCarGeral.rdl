  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:DataSourceID>f59afa00-a1a1-484e-986f-12c6ca146d41</rd:DataSourceID>
      <rd:SecurityType>None</rd:SecurityType>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="CARÊNCIA_REAL">
          <DataField>CARÊNCIA REAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CARÊNCIA_TEMPORÁRIA">
          <DataField>CARÊNCIA TEMPORÁRIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NORMAL">
          <DataField>normal</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="GLP_REAL">
          <DataField>GLP REAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONTRATO">
          <DataField>contrato</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="GLP_TEMPORÁRIA">
          <DataField>GLP TEMPORÁRIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="C_DATA">
          <DataField>C_DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT        TOP (7) ISNULL(SUM(LY_REL_CAR.NORMAL), 0) AS normal, ISNULL(SUM(LY_REL_CAR.CONTRATO), 0) AS contrato, ISNULL(SUM(LY_REL_CAR.C_REAL), 0) 
                         AS [CARÊNCIA REAL], ISNULL(SUM(LY_REL_CAR.C_TEMP), 0) AS [CARÊNCIA TEMPORÁRIA], ISNULL(SUM(LY_REL_CAR.GLP_REAL), 0) AS [GLP REAL], 
                         ISNULL(SUM(LY_REL_CAR.GLP_TEMP), 0) AS [GLP TEMPORÁRIA], LY_REL_CAR.C_DATA
FROM            LY_REL_CAR INNER JOIN
                         LY_UNIDADE_ENSINO ON LY_UNIDADE_ENSINO.UNIDADE_ENS = LY_REL_CAR.UNIDADE_ENS INNER JOIN
                         LY_NUCLEO ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO INNER JOIN
                         MUNICIPIO ON MUNICIPIO.CODIGO = LY_UNIDADE_ENSINO.MUNICIPIO INNER JOIN
                         LY_DISCIPLINA ON LY_DISCIPLINA.DISCIPLINA = LY_REL_CAR.DISCIPLINA
WHERE        (LY_DISCIPLINA.COMPONENTE IN (@base))
GROUP BY LY_REL_CAR.C_DATA
ORDER BY LY_REL_CAR.C_DATA DESC</CommandText>
        <QueryParameters>
          <QueryParameter Name="@base">
            <Value>=Parameters!base.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="DataSet2">
      <Fields>
        <Field Name="TOTAL">
          <DataField>TOTAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="C_DATA">
          <DataField>C_DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT        TOP (7) ISNULL(COUNT( DISTINCT LY_REL_CHL.MATRICULA), 0) TOTAL, LY_REL_CHL.C_DATA
FROM            LY_REL_CHL
                      
GROUP BY LY_REL_CHL.C_DATA
ORDER BY LY_REL_CHL.C_DATA DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
