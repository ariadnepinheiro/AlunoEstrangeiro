          <DataField>NUMEROLOG</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="COMPLEMENTO">
          <DataField>COMPLEMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CEP">
          <DataField>CEP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FONE">
          <DataField>FONE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FAX">
          <DataField>FAX</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ATIVO">
          <DataField>ATIVO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MBAIRRO_CODIGO">
          <DataField>MBAIRRO_CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MBAIRRO_MUNICIPIO_CODIGO">
          <DataField>MBAIRRO_MUNICIPIO_CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 'NULO' SETOR,' Selecione...' NOME
union
select null SETOR,' TODAS' NOME from setor
where
	setor in (select setor from LY_LOTACAO 
	where FUNCAO in (10058,10059))
union

select  SETOR , SETOR + ' - ' + NOMESETOR AS NOME
from setor
where
	setor in (select setor from LY_LOTACAO 
	where FUNCAO in (10058,10059))
ORDER BY NOME
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
