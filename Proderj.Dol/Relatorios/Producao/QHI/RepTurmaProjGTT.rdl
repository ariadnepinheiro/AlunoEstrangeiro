          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATAINI">
          <DataField>DATAINI</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATAFIM">
          <DataField>DATAFIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
