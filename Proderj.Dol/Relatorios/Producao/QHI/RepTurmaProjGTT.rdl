          <DataField>TIPOLOG</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOMELOG">
          <DataField>NOMELOG</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
