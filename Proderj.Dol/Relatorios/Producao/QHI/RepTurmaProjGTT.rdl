    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
        <Prompt>Specify a user name and password for data source DataSource1.</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>4358dad7-d5ec-4f0f-b91f-5e058edb8f3e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DOCENTE">
          <DataField>DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNÇÃO">
          <DataField>FUNÇÃO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
CASE WHEN LY_NUCLEO.DESCRICAO IS NULL THEN SETOR.NOME ELSE LY_NUCLEO.DESCRICAO END COORDENADORIA  
, MUNICIPIO_SETOR.NOME AS MUNICIPIO  
,L.SETOR UA
,S.NOMESETOR SETOR
,D.MATRICULA
,D.NOME_COMPL DOCENTE 
,LY_FUNCAO.DESCRICAO AS FUNÇÃO
FROM 	LY_LOTACAO L
JOIN 	LY_DOCENTE D
ON 	L.MATRICULA = D.MATRICULA
JOIN 	SETOR S
ON 	S.SETOR = L.SETOR

INNER JOIN HADES..HD_SETOR  SETOR   
  ON SETOR.SETOR = L.SETOR     
INNER JOIN MUNICIPIO MUNICIPIO_SETOR    
  ON MUNICIPIO_SETOR.CODIGO = SETOR.MUNICIPIO  
INNER JOIN lyceum..LY_FUNCAO LY_FUNCAO   
  ON LY_FUNCAO.FUNCAO = L.FUNCAO  
LEFT  JOIN lyceum..LY_UNIDADE_ENSINO   
  ON LY_UNIDADE_ENSINO.SETOR = L.SETOR  
LEFT JOIN lyceum..LY_NUCLEO   
  ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO  

WHERE 	(L.DATA_DESATIVACAO &gt;= GETDATE() OR L.DATA_DESATIVACAO IS NULL)  AND L.FUNCAO IN ('10058','10059')
AND  ( S.SETOR = ISNULL(@setor, S.SETOR )    
            OR S.SETOR  IS NULL )    

ORDER BY
CASE WHEN LY_NUCLEO.DESCRICAO IS NULL THEN SETOR.NOME ELSE LY_NUCLEO.DESCRICAO END   
, MUNICIPIO_SETOR.NOME
 ,S.NOMESETOR, L.SETOR, D.NOME_COMPL</CommandText>
        <QueryParameters>
          <QueryParameter Name="@setor">
            <Value>=Parameters!setor.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Setor">
      <Fields>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
