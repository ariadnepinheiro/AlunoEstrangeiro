  <Description>Rel Lotacao Situacao de Servidores</Description>
  <Author>Techne</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="SelectServidores">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>36d7814d-e9db-497b-a7ec-5fb4665bd103</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>SelectServidores</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@sit_escola">
            <Value>=Parameters!sit_escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT SQL1.*,
       CASE SQL1.FUNCAO
         WHEN 'DOC II' THEN NULL
         WHEN 'DOC I' THEN NULL
         WHEN 'DOC II - 40' THEN NULL
         WHEN 'MERENDEIRA' THEN NULL
         WHEN 'AGENTE DE PORTARIA' THEN NULL
         WHEN 'EM EXERCÍCIO  NO MUNICÍPIO' THEN NULL
         WHEN 'DOC I - 40' THEN NULL
         WHEN 'SERVENTE' THEN NULL
         ELSE SQL1.FUNCAO
       END AS DESC_FUNCAO
FROM   (
       /* docentes alocados */
       SELECT DISTINCT DD.MATRICULA,
                       DD.NOME_COMPL,
                       CH.CATEGORIA_DOCENTE CARGO,
                       SQL2.DISC_INGRESSO,
                       DD.REGIME_TRABALHO CH,
                       'REGENTE' FUNCAO,
                       dbo.f_TotalAulaNormal_Ano (dd.MATRICULA,YEAR(GETDATE()))AULA_ALOCADAS,
                       dbo.f_TotalAulaGLP_Ano(dd.MATRICULA,YEAR(GETDATE())) AULA_ALOCADAS_GLP,
                       LL.READAPTADO READAPTADO,
                       LL.DT_INICIO_READAPTACAO DT_INICIO_READAPTACAO,
                       LL.DT_FIM_READAPTACAO DT_FIM_READAPTACAO,
                       SQL1.DESCRICAO,
                       SQL1.DTINI,
                       SQL1.DTFIM,
                       SQL1.MOTIVO,
                       (SELECT DESCRICAO
                        FROM   LY_NUCLEO N1 (NOLOCK)
                        WHERE  N1.NUCLEO = LL.NUCLEO) COORDENADORIA,
                       JJ.NOME_COMP ESCOLA,
                       SS.SETOR,
                       LL.NUCLEO,
                       LL.UNIDADE_ENS,
                       (SELECT M2.NOME
                        FROM   MUNICIPIO M2 (NOLOCK)
                        WHERE  M2.CODIGO = JJ.MUNICIPIO)MUNICIPIO,
                       ST.SITUACAO
       FROM   LY_DOCENTE DD (NOLOCK)
              JOIN LY_LOTACAO LL (NOLOCK)
                ON LL.MATRICULA = DD.MATRICULA
              LEFT JOIN LY_CH_CATEGORIA CH (NOLOCK)
                ON CH.CATEGORIA_DOCENTE = DD.CATEGORIA
              LEFT JOIN LY_UNIDADE_ENSINO JJ (NOLOCK)
                ON JJ.UNIDADE_ENS = LL.UNIDADE_ENS
              LEFT JOIN LY_UNIDADE_ENSINO_SITUACAO ST (NOLOCK)
                ON ST.UNIDADE_ENS = LL.UNIDADE_ENS
              LEFT JOIN SETOR SS (NOLOCK)
                ON SS.SETOR = LL.SETOR
              --licença docente
              LEFT JOIN (SELECT MAX(DE.DTFIM) AS DTFIM,
                                DE.NUM_FUNC,
                                DE.MOTIVO,
                                DE.DTINI,
                                LC.DESCRICAO
                         FROM   LY_LICENCA_DOCENTE AS DE (NOLOCK)
                                INNER JOIN LY_LICENCAS AS LC (NOLOCK)
                                  ON LC.MOTIVO = DE.MOTIVO
                         WHERE  ( DE.DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP) )
                                 OR ( DE.DTFIM IS NULL )
                         GROUP  BY DE.NUM_FUNC,
                                   DE.MOTIVO,
                                   DE.DTINI,
                                   LC.DESCRICAO)SQL1
                ON SQL1.NUM_FUNC = DD.NUM_FUNC
              -- disciplina de ingresso
              LEFT JOIN (SELECT H1.DESCRICAO DISC_INGRESSO,
                                H2.NUM_FUNC
                         FROM   LY_GRUPO_HABILITACAO H1 (NOLOCK)
                                JOIN LY_GRUPO_HABILITACAO_DOC H2 (NOLOCK)
                                  ON H1.AGRUPAMENTO = H2.AGRUPAMENTO
                         WHERE  H2.AGRUPAMENTO_INGRESSO = 'S')SQL2
                ON SQL2.NUM_FUNC = DD.NUM_FUNC
             
       WHERE  LL.DATA_NOMEACAO &lt;= CONVERT(DATE,GETDATE()) AND 
					(LL.DATA_DESATIVACAO &gt;= CONVERT(DATE,GETDATE()) OR LL.DATA_DESATIVACAO IS NULL) 
              AND ST.SITUACAO = @sit_escola
              AND ( JJ.UNIDADE_ENS = ISNULL (@escola, JJ.UNIDADE_ENS)
                     OR JJ.UNIDADE_ENS IS NULL )
              AND ( JJ.NUCLEO = ISNULL (@coord, JJ.NUCLEO)
                     OR JJ.NUCLEO IS NULL )
              AND ( JJ.MUNICIPIO = ISNULL (@municipio, JJ.MUNICIPIO)
                     OR JJ.MUNICIPIO IS NULL )
			AND EXISTS (SELECT 1
                              FROM   LY_AULA_DOCENTE D1 (NOLOCK)
                              WHERE  EXISTS (SELECT 1
                                             FROM   LY_TURMA TT (NOLOCK)
                                             WHERE  TT.ANO = D1.ANO
                                                    AND TT.SEMESTRE =
                                                        D1.SEMESTRE
                                                    AND TT.DT_FIM = D1.DATA_FIM
                                                    AND D1.DATA_FIM&gt;=CONVERT(DATE,CURRENT_TIMESTAMP)
                                                    AND TT.DISCIPLINA=D1.DISCIPLINA
                                                    AND TT.TURMA = D1.TURMA)
                                     AND D1.ANO = YEAR(GETDATE())
                                     AND D1.NUM_FUNC = DD.NUM_FUNC)
       UNION
       /* docentes não alocados */
       SELECT DISTINCT DD.MATRICULA,
                       DD.NOME_COMPL,
                       CH.CATEGORIA_DOCENTE CARGO,
                       SQL2.DISC_INGRESSO,
                       DD.REGIME_TRABALHO CH,
                       (SELECT DESCRICAO
                        FROM   LY_FUNCAO FR (NOLOCK)
                        WHERE  FR.FUNCAO = LL.FUNCAO)   FUNCAO,
                       NULL AULA_ALOCADAS,
                       NULL AULA_ALOCADAS_GLP,
                       LL.READAPTADO READAPTADO,
                       LL.DT_INICIO_READAPTACAO DT_INICIO_READAPTACAO,
                       LL.DT_FIM_READAPTACAO DT_FIM_READAPTACAO,
                       SQL1.DESCRICAO,
                       SQL1.DTINI,
                       SQL1.DTFIM,
                       SQL1.MOTIVO,
                       (SELECT DESCRICAO
                        FROM   LY_NUCLEO N1 (NOLOCK)
                        WHERE  N1.NUCLEO = LL.NUCLEO) COORDENADORIA,
                       JJ.NOME_COMP ESCOLA,
                       SS.SETOR,
                       LL.NUCLEO,
                       LL.UNIDADE_ENS,
                       (SELECT M2.NOME
                        FROM   MUNICIPIO M2 (NOLOCK)
                        WHERE  M2.CODIGO = JJ.MUNICIPIO)MUNICIPIO,
                       ST.SITUACAO
       FROM   LY_DOCENTE DD (NOLOCK)
              JOIN LY_LOTACAO LL (NOLOCK)
                ON LL.MATRICULA = DD.MATRICULA
              LEFT JOIN LY_CH_CATEGORIA CH (NOLOCK)
                ON CH.CATEGORIA_DOCENTE = DD.CATEGORIA
              LEFT JOIN LY_UNIDADE_ENSINO JJ (NOLOCK)
                ON JJ.UNIDADE_ENS = LL.UNIDADE_ENS
              LEFT JOIN LY_UNIDADE_ENSINO_SITUACAO ST (NOLOCK)
                ON ST.UNIDADE_ENS = LL.UNIDADE_ENS
              LEFT JOIN SETOR SS (NOLOCK)
                ON SS.SETOR = LL.SETOR
              --licença docente
              LEFT JOIN (SELECT MAX(DE.DTFIM) AS DTFIM,
                                DE.NUM_FUNC,
                                DE.MOTIVO,
                                DE.DTINI,
                                LC.DESCRICAO
                         FROM   LY_LICENCA_DOCENTE AS DE (NOLOCK)
                                INNER JOIN LY_LICENCAS AS LC (NOLOCK)
                                  ON LC.MOTIVO = DE.MOTIVO
                         WHERE  ( DE.DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP) )
                                 OR ( DE.DTFIM IS NULL )
                         GROUP  BY DE.NUM_FUNC,
                                   DE.MOTIVO,
                                   DE.DTINI,
                                   LC.DESCRICAO)SQL1
                ON SQL1.NUM_FUNC = DD.NUM_FUNC
              -- disciplina de ingresso
              LEFT JOIN (SELECT H1.DESCRICAO DISC_INGRESSO,
                                H2.NUM_FUNC
                         FROM   LY_GRUPO_HABILITACAO H1 (NOLOCK)
                                JOIN LY_GRUPO_HABILITACAO_DOC H2 (NOLOCK)
                                  ON H1.AGRUPAMENTO = H2.AGRUPAMENTO
                         WHERE  H2.AGRUPAMENTO_INGRESSO = 'S')SQL2
                ON SQL2.NUM_FUNC = DD.NUM_FUNC
       WHERE  LL.DATA_NOMEACAO &lt;= CONVERT(DATE,GETDATE()) AND 
					(LL.DATA_DESATIVACAO &gt;= CONVERT(DATE,GETDATE()) OR LL.DATA_DESATIVACAO IS NULL) 
              AND NOT EXISTS (SELECT 1
                              FROM   LY_AULA_DOCENTE D1 (NOLOCK)
                              WHERE  EXISTS (SELECT 1
                                             FROM   LY_TURMA TT (NOLOCK)
                                             WHERE  TT.ANO = D1.ANO
                                                    AND TT.SEMESTRE =
                                                        D1.SEMESTRE
                                                    AND TT.DT_FIM = D1.DATA_FIM
                                                    AND D1.DATA_FIM&gt;=CONVERT(DATE,CURRENT_TIMESTAMP)
                                                    AND TT.DISCIPLINA=D1.DISCIPLINA
                                                    AND TT.TURMA = D1.TURMA)
                                     AND D1.ANO = YEAR(GETDATE())
                                     AND D1.NUM_FUNC = DD.NUM_FUNC)
              AND ST.SITUACAO = @sit_escola
              AND ( JJ.UNIDADE_ENS = ISNULL (@escola, JJ.UNIDADE_ENS)
                     OR JJ.UNIDADE_ENS IS NULL )
              AND ( JJ.NUCLEO = ISNULL (@coord, JJ.NUCLEO)
                     OR JJ.NUCLEO IS NULL )
              AND ( JJ.MUNICIPIO = ISNULL (@municipio, JJ.MUNICIPIO)
                     OR JJ.MUNICIPIO IS NULL )
        UNION
        /* servidores não docentes */
        SELECT DISTINCT LL.MATRICULA,
                        UPPER(PP.NOME_COMPL) NOME_COMPL,
                        (SELECT I.DESCR
                         FROM   ITEMTABELA I
                         WHERE  I.TAB = 'CategoriaServidor'
                                AND I.ITEM = VV.CATEGORIA) CARGO,
                        NULL DISC_INGRESSO,
                        ISNULL(CONVERT(INT, VV.CH_CATEGORIA), 0)CH,
                        (SELECT F1.DESCRICAO
                         FROM   LY_FUNCAO F1
                         WHERE  F1.FUNCAO = LL.FUNCAO) FUNCAO,
                        NULL AULA_ALOCADAS,
                        NULL
                        AULA_ALOCADAS_GLP,
                        LL.READAPTADO,
                        LL.DT_INICIO_READAPTACAO,
                        LL.DT_FIM_READAPTACAO,
                        SQLR.DESCRICAO,
                        SQLR.DTINI,
                        SQLR.DTFIM,
                        SQLR.MOTIVO,
                        (SELECT N2.DESCRICAO
                         FROM   LY_NUCLEO N2 (NOLOCK)
                         WHERE  N2.NUCLEO = LL.NUCLEO) COORDENADORIA,
                        JJ.NOME_COMP ESCOLA,
                        SS.SETOR,
                        LL.NUCLEO,
                        LL.UNIDADE_ENS,
                        (SELECT M2.NOME
                         FROM   MUNICIPIO M2 (NOLOCK)
                         WHERE  M2.CODIGO = JJ.MUNICIPIO) MUNICIPIO,
                        ST.SITUACAO
        FROM   LY_PESSOA PP (NOLOCK)
               JOIN LY_VINCULO VV (NOLOCK)
                 ON VV.PESSOA = PP.PESSOA
               JOIN LY_LOTACAO LL (NOLOCK)
                 ON LL.MATRICULA = VV.MATRICULA
               LEFT JOIN LY_UNIDADE_ENSINO JJ (NOLOCK)
                 ON JJ.UNIDADE_ENS = LL.UNIDADE_ENS
               LEFT JOIN LY_UNIDADE_ENSINO_SITUACAO ST (NOLOCK)
                 ON ST.UNIDADE_ENS = LL.UNIDADE_ENS
               LEFT JOIN SETOR SS (NOLOCK)
                 ON SS.SETOR = LL.SETOR
               -- licença servidor
               LEFT JOIN (SELECT MAX(DE.DTFIM) AS DTFIM,
                                 DE.PESSOA,
                                 DE.MOTIVO,
                                 DE.DTINI,
                                 LC.DESCRICAO
                          FROM   LY_LICENCA_PESSOA AS DE (NOLOCK)
                                 INNER JOIN LY_LICENCAS AS LC (NOLOCK)
                                   ON LC.MOTIVO = DE.MOTIVO
                          WHERE  ( DE.DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP)
                                 )
                                  OR ( DE.DTFIM IS NULL )
                          GROUP  BY DE.PESSOA,
                                    DE.MOTIVO,
                                    DE.DTINI,
                                    LC.DESCRICAO)SQLR
                 ON SQLR.PESSOA = PP.PESSOA
        WHERE  LL.DATA_NOMEACAO &lt;= CONVERT(DATE,GETDATE()) AND 
					(LL.DATA_DESATIVACAO &gt;= CONVERT(DATE,GETDATE()) OR LL.DATA_DESATIVACAO IS NULL) 
               AND VV.DATA_DESATIVACAO IS NULL
               AND ST.SITUACAO = @sit_escola
               AND ( JJ.UNIDADE_ENS = ISNULL (@escola, JJ.UNIDADE_ENS)
                      OR JJ.UNIDADE_ENS IS NULL )
               AND ( JJ.NUCLEO = ISNULL (@coord, JJ.NUCLEO)
                      OR JJ.NUCLEO IS NULL )
               AND ( JJ.MUNICIPIO = ISNULL (@municipio, JJ.MUNICIPIO)
                      OR JJ.MUNICIPIO IS NULL ))SQL1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
