          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>Município</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>MUNICIPIO</DataSetName>
          <ValueField>codigo</ValueField>
          <LabelField>nome</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="escola">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>Escola</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>ESCOLA</DataSetName>
          <ValueField>UNIDADE_ENS</ValueField>
          <LabelField>NOME_COMP</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="sit_escola">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>ESTADUAL</Value>
        </Values>
      </DefaultValue>
      <Prompt>Situação Escola</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>ESTADUAL</Value>
            <Label>ESTADUAL</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>FEDERAL</Value>
            <Label>FEDERAL</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>MUNICIPALIZADA</Value>
            <Label>MUNICIPALIZADA</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>PRIVADA</Value>
            <Label>PRIVADA</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Conveniada</Value>
            <Label>CONVENIADA</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Extinta</Value>
            <Label>EXTINTA</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Paralisada</Value>
            <Label>PARALISADA</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Desativada</Value>
            <Label>DESATIVADA</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
  </ReportParameters>
