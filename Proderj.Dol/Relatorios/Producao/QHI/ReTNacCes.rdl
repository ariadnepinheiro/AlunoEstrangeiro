    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:DataSourceID>2282c4e7-5d17-4140-9d8c-bf882a826454</rd:DataSourceID>
      <rd:SecurityType>None</rd:SecurityType>
    </DataSource>
