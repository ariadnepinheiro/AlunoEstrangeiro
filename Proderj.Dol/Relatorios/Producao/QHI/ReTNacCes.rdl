  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE_CENSO">
          <DataField>UE_CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NORMAL">
          <DataField>NORMAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONTRATO">
          <DataField>CONTRATO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CARÊNCIA_REAL">
          <DataField>CARÊNCIA REAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CARÊNCIA_TEMPORÁRIA">
          <DataField>CARÊNCIA TEMPORÁRIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="GLP_REAL">
          <DataField>GLP REAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="GLP_TEMPORÁRIA">
          <DataField>GLP TEMPORÁRIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT MUNICIPIO.CODIGO,
       MUNICIPIO.NOME MUNICIPIO,
       LY_NUCLEO.NUCLEO,
       LY_NUCLEO.DESCRICAO COORDENADORIA,
       LY_UNIDADE_ENSINO.SETOR UA,
       LY_UNIDADE_ENSINO.UNIDADE_ENS  UE_CENSO,
       LY_UNIDADE_ENSINO.NOME_COMP ESCOLA,
       UPPER(LY_DISCIPLINA.NOME_COMPL)DISCIPLINA,
       LY_REL_CAR.TURMA,
       ISNULL(LY_REL_CAR.NORMAL, 0) NORMAL,
       ISNULL(LY_REL_CAR.CONTRATO, 0) CONTRATO,
       ISNULL(LY_REL_CAR.C_REAL, 0) [CARÊNCIA REAL],
       ISNULL(LY_REL_CAR.C_TEMP, 0) [CARÊNCIA TEMPORÁRIA],
       ISNULL(LY_REL_CAR.GLP_REAL, 0) [GLP REAL],
       ISNULL(LY_REL_CAR.GLP_TEMP, 0) [GLP TEMPORÁRIA]
FROM   LY_REL_CAR
       JOIN LY_DISCIPLINA
         ON LY_DISCIPLINA.DISCIPLINA = LY_REL_CAR.DISCIPLINA
       JOIN LY_UNIDADE_ENSINO
         ON LY_UNIDADE_ENSINO.UNIDADE_ENS = LY_REL_CAR.UNIDADE_ENS
       JOIN LY_NUCLEO
         ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO
       JOIN MUNICIPIO
         ON MUNICIPIO.CODIGO = LY_UNIDADE_ENSINO.MUNICIPIO
WHERE  LY_REL_CAR.C_DATA = (SELECT MAX(C_DATA)
                            FROM   LY_REL_CAR)
       AND ( LY_REL_CAR.TURMA LIKE 'CEJAS%'
              OR LY_REL_CAR.TURMA LIKE 'NACEJAS%' )
       AND EXISTS (SELECT 1
                   FROM   LY_TURMA TT WITH(NOLOCK)
                   WHERE  TT.TURMA = LY_REL_CAR.TURMA
                          AND ANO = YEAR(CURRENT_TIMESTAMP)
                          AND SIT_TURMA = 'ABERTA')
AND 
	(LY_NUCLEO.NUCLEO = ISNULL(@coord, LY_NUCLEO.NUCLEO) OR LY_NUCLEO.NUCLEO IS NULL)
AND
	(LY_UNIDADE_ENSINO.MUNICIPIO = ISNULL(@munic, LY_UNIDADE_ENSINO.MUNICIPIO) OR LY_UNIDADE_ENSINO.MUNICIPIO IS NULL)
AND
	(LY_UNIDADE_ENSINO.UNIDADE_ENS = ISNULL(@escola, LY_UNIDADE_ENSINO.UNIDADE_ENS) OR LY_UNIDADE_ENSINO.UNIDADE_ENS IS NULL)
ORDER  BY LY_NUCLEO.DESCRICAO,
          MUNICIPIO.NOME,
          LY_UNIDADE_ENSINO.UNIDADE_ENS</CommandText>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="coordenadoria">
      <Fields>
        <Field Name="NUCLEO">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="município">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Escola">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@munic,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
