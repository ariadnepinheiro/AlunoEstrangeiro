      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT        N.DESCRICAO, N.SETOR, N.ENDERECO, N.FONE, P.NOME_COMPL
FROM            LY_NUCLEO AS N INNER JOIN
                         LY_PESSOA AS P ON P.PESSOA = N.PESSOA</CommandText>
      </Query>
    </DataSet>
  </DataSets>
