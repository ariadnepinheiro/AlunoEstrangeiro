  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>0d5a5086-0517-491b-bf6d-411e7a3de62e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@NIVEL">
            <Value>=Parameters!NIVEL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MATRIZ">
            <Value>=Parameters!MATRIZ.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SERIE">
            <Value>=Parameters!SERIE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT MC.DESCRICAO MODALIDADE, TC.DESCRICAO SEGMENTO, CC.NOME CURSO, L3.SERIE,L3.DESCRICAO,L2.DISCIPLINA,D.NOME,CONVERT(INT,D.AULAS_SEMANAIS)AULAS_SEMANAIS
,CONVERT(INT,D.HORAS_AULA)HORAS_AULA,L2.TURNO FROM LY_CURRICULO L1
JOIN LY_GRADE L2 ON L1.CURSO=L2.CURSO
	AND L1.TURNO=L2.TURNO 
	AND L1.CURRICULO=L2.CURRICULO
JOIN LY_SERIE L3 ON L3.SERIE=L2.SERIE_IDEAL
	AND L3.CURSO=L2.CURSO AND L3.CURRICULO=L2.CURRICULO 
	AND L3.TURNO=L2.TURNO
JOIN LY_DISCIPLINA D ON D.DISCIPLINA=L2.DISCIPLINA
JOIN LY_CURSO C1 ON C1.CURSO=L2.CURSO
JOIN LY_CURSO CC
ON	 CC.CURSO = L1.CURSO
JOIN LY_MODALIDADE_CURSO MC 
ON	 MC.MODALIDADE = CC.MODALIDADE
JOIN LY_TIPO_CURSO TC
ON	 TC.TIPO = CC.TIPO
WHERE C1.MODALIDADE=@MODALIDADE 
		AND C1.TIPO=@NIVEL 
		AND C1.CURSO=@ESCOLARIDADE 
		AND L2.CURRICULO=@MATRIZ
		AND (L2.TURNO = ISNULL(@TURNO,L2.TURNO) OR L2.TURNO IS NULL)
AND (L3.SERIE = ISNULL(@SERIE,L3.SERIE) OR L3.SERIE IS NULL)
ORDER BY L2.CURRICULO,L2.TURNO,L2.SERIE_IDEAL,D.NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AULAS_SEMANAIS">
          <DataField>AULAS_SEMANAIS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="HORAS_AULA">
          <DataField>HORAS_AULA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MODALIDADE">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NIVEL">
            <Value>=Parameters!NIVEL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT C.MODALIDADE,C.DESCRICAO FROM LY_MODALIDADE_CURSO C
JOIN LY_CURSO B ON B.MODALIDADE=C.MODALIDADE
WHERE B.TIPO=@NIVEL
UNION 
SELECT  'NULO', ' Selecione...' 
order by DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="NIVEL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT T.TIPO,T.DESCRICAO FROM LY_CURSO C
JOIN LY_TIPO_CURSO T
ON T.TIPO=C.TIPO
UNION 
SELECT  'NULO', ' Selecione...' 
order by DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TIPO">
          <DataField>TIPO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLARIDADE">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NIVEL">
            <Value>=Parameters!NIVEL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CURSO,NOME DESCRICAO FROM LY_CURSO 
WHERE TIPO=@NIVEL AND MODALIDADE=@MODALIDADE
UNION 
SELECT  'NULO', ' Selecione...' 
order by DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MATRIZ">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@NIVEL">
            <Value>=Parameters!NIVEL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT CC.CURRICULO MATRIZ FROM LY_GRADE G1 
JOIN LY_CURSO C1 ON C1.CURSO=G1.CURSO
JOIN LY_CURRICULO CC ON CC.CURRICULO = G1.CURRICULO
AND CC.CURSO = G1.CURSO
AND CC.TURNO = G1.TURNO
WHERE C1.MODALIDADE=@MODALIDADE AND C1.TIPO=@NIVEL AND C1.CURSO=@ESCOLARIDADE AND CC.ANO_INI = @ANO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MATRIZ">
          <DataField>MATRIZ</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@NIVEL">
            <Value>=Parameters!NIVEL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MATRIZ">
            <Value>=Parameters!MATRIZ.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT 
	(SELECT DESCRICAO FROM LY_TURNO WHERE C1.TURNO=TURNO)DESCRICAO,C1.TURNO
FROM LY_CURRICULO C1
JOIN LY_CURSO C2 ON C1.CURSO=C2.CURSO
WHERE  C2.MODALIDADE=@MODALIDADE AND C2.TIPO=@NIVEL AND C2.CURSO=@ESCOLARIDADE AND C1.CURRICULO=@MATRIZ
UNION
SELECT ' Selecione...' DESCRICAO, 'NULO'
UNION
SELECT ' TODOS' DESCRICAO, NULL TURNO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SERIE">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MATRIZ">
            <Value>=Parameters!MATRIZ.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT  SERIE,CONVERT(VARCHAR(10),SERIE) AS DESCRICAO FROM LY_SERIE
WHERE CURSO=@ESCOLARIDADE AND CURRICULO=@MATRIZ 
AND (TURNO = ISNULL(@TURNO,TURNO) OR TURNO IS NULL)
UNION
SELECT NULL , 'TODAS' DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
