  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1e588d25-ddbc-4eff-80a8-b229eeb406ef</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT REGIONAL,
       UE.SETOR,
       UE.NOME_COMP,
       T.ANO, 
       T.SEMESTRE,
       T.TURMA,
       CASE T.EM_ELABORACAO
         WHEN 'S' THEN 'INCOMPLETA'
         ELSE 'SEM ALOCACAO'
       END  EM_ELABORACAO,
      (SELECT COUNT(DISTINCT ALUNO) FROM LY_MATRICULA M (NOLOCK)
     WHERE T.ANO = M.ANO
     AND  T.SEMESTRE = M.SEMESTRE
     AND T.TURMA = M.TURMA
     AND M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
     ) ALUNOS_MATRICULADOS, 
		MM.NOME MUNICIPIO
FROM   LY_UNIDADE_ENSINO UE (NOLOCK)
       JOIN TCE_REGIONAL R (NOLOCK)
         ON R.ID_REGIONAL = UE.ID_REGIONAL
       JOIN LY_TURMA T (NOLOCK)
         ON T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS
         AND T.ANO = @ANO
       JOIN MUNICIPIO MM (NOLOCK)
		 ON MM.CODIGO = UE.MUNICIPIO
WHERE		EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
					WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
					AND		US.SITUACAO = 'ESTADUAL'
					AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																					(
																					SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																					FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
																					)
					)
				AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')

       AND ( T.EM_ELABORACAO = 'S' OR EM_ELABORACAO IS NULL )
       AND ( R.ID_REGIONAL = ISNULL(@coord, R.ID_REGIONAL)
              OR R.ID_REGIONAL IS NULL )
       AND ( UE.MUNICIPIO = ISNULL(@municipio, UE.MUNICIPIO)
              OR UE.MUNICIPIO IS NULL )
		AND T.SIT_TURMA='ABERTA'
GROUP  BY R.REGIONAL,
          UE.SETOR,
          UE.NOME_COMP,
          T.TURMA,
          T.EM_ELABORACAO, 
          T.ANO, 
          T.SEMESTRE, 
	MM.NOME
ORDER  BY R.REGIONAL,
          UE.NOME_COMP,
          T.TURMA
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="EM_ELABORACAO">
          <DataField>EM_ELABORACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ALUNOS_MATRICULADOS">
          <DataField>ALUNOS_MATRICULADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="regional">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null ID_REGIONAL,' TODAS' REGIONAL 
union
select  R.ID_REGIONAL,SUBSTRING(R.REGIONAL,1,35) from LY_UNIDADE_ENSINO  L2
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = L2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL R on R.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(R.ID_REGIONAL = ISNULL(@coord,R.ID_REGIONAL)or R.ID_REGIONAL is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
