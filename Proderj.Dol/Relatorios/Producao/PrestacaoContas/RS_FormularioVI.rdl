  <DataSets>
    <DataSet Name="ds_Cabecalho">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select fr.CODIGO_FORMULARIO,upper(fr.NOME) NOME
from LY_PC_CONTABANCO cb
inner join  LY_PC_FONTERECURSO fr on cb.ID_FONTERECURSO=fr.ID
where cb.ID=@ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO_FORMULARIO">
          <DataField>CODIGO_FORMULARIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco1">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select cb.titular,
	cb.cnpj,
	pr.DATAINIAPLICACAO,
	pr.DATAFIMAPLICACAO,
	pr.PERIODOLY,
	pr.ANOLY,
	b.NOME as NOME_BANCO, 
	cb.BANCO, 
	ag.NOME as NOME_AGENCIA, 
	cb.AGENCIA, 
	cb.CONTA, 
	cb.ID as ID_CONTABANCO,
	pc.DATA_INICIO,
	pc.DATA_FIM
from LY_PC_CONTABANCO cb
inner join LY_PC_PRESTACAOCONTAS PC on cb.ID_PRESTADOR = PC.ID_PRESTADOR
inner join LY_PC_PERIODOREF pr on pr.ID = PC.ID_PERIODOREF
left outer join BANCOS b on cb.BANCO = b.BANCO
left outer join AGENCIAS ag on cb.AGENCIA = ag.AGENCIA and cb.BANCO = ag.BANCO
where PC.ID = @ID_PRESTCONTAS and cb.ID = @ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="titular">
          <DataField>titular</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cnpj">
          <DataField>cnpj</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATAINIAPLICACAO">
          <DataField>DATAINIAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATAFIMAPLICACAO">
          <DataField>DATAFIMAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="PERIODOLY">
          <DataField>PERIODOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ANOLY">
          <DataField>ANOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME_BANCO">
          <DataField>NOME_BANCO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BANCO">
          <DataField>BANCO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME_AGENCIA">
          <DataField>NOME_AGENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AGENCIA">
          <DataField>AGENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CONTA">
          <DataField>CONTA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_CONTABANCO">
          <DataField>ID_CONTABANCO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA_INICIO">
          <DataField>DATA_INICIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATA_FIM">
          <DataField>DATA_FIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2_Campo10">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CBS.SALDO_INICIAL
FROM LY_PC_CONTABANCO_SALDO CBS
WHERE CBS.ID_PRESTCONTAS=@ID_PRESTCONTAS and CBS.ID_CONTABANCO=@ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SALDO_INICIAL">
          <DataField>SALDO_INICIAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco3">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT ch.DATA_EMISSAO, 
	ch.NUMERO, 
	ch.VALOR
FROM LY_PC_CHEQUE ch
INNER JOIN LY_PC_COMPRA co ON ch.ID_COMPRA = co.ID
INNER JOIN LY_PC_PRESTACAOCONTAS pc ON pc.ID = co.ID_PRESTCONTAS
INNER JOIN LY_PC_PERIODOREF pr ON pc.ID_PERIODOREF = pr.ID
WHERE co.ID_PRESTCONTAS = @ID_PRESTCONTAS 
	AND ch.ID_CONTABANCO = @ID_CONTABANCO
	AND (ch.DATA_APRESENTACAO IS NULL OR ch.DATA_APRESENTACAO &gt; pr.DATAFIMAPLICACAO)
ORDER BY ch.DATA_EMISSAO </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DATA_EMISSAO">
          <DataField>DATA_EMISSAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR">
          <DataField>VALOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco4">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT ch.DATA_APRESENTACAO,  co.ID_PRESTCONTAS,
	ch.NUMERO, 
	ch.VALOR
FROM LY_PC_CHEQUE ch
LEFT OUTER JOIN LY_PC_COMPRA co ON ch.ID_COMPRA = co.ID,
LY_PC_PRESTACAOCONTAS pc 
INNER JOIN LY_PC_PERIODOREF pr ON pc.ID_PERIODOREF = pr.ID
WHERE pc.ID = @ID_PRESTCONTAS 
	AND ch.ID_CONTABANCO = @ID_CONTABANCO 
	AND (co.ID_PRESTCONTAS IS NULL OR co.ID_PRESTCONTAS &lt;&gt; pc.ID)	
	AND ch.DATA_EMISSAO &lt; pr.DATAINIAPLICACAO 
	AND (ch.DATA_APRESENTACAO &gt;= pr.DATAINIAPLICACAO AND ch.DATA_APRESENTACAO &lt;= pr.DATAFIMAPLICACAO)
ORDER BY ch.DATA_APRESENTACAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DATA_APRESENTACAO">
          <DataField>DATA_APRESENTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ID_PRESTCONTAS">
          <DataField>ID_PRESTCONTAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR">
          <DataField>VALOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2_Campo11">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select SUM(mb.VALOR) VALOR_TOTAL
from LY_PC_MOVBANCO mb
inner join LY_PC_TIPOMOVBANC tm on tm.ID=mb.ID_TIPOMOV
where tm.TIPO='R' and
mb.ID_PRESTCONTAS=@ID_PRESTCONTAS and mb.ID_CONTABANCO=@ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="valor_total">
          <DataField>VALOR_TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2_Campo12">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select SUM(mb.VALOR) VALOR_TOTAL
from LY_PC_MOVBANCO mb
inner join LY_PC_TIPOMOVBANC tm on tm.ID=mb.ID_TIPOMOV
where tm.TIPO='A' and
mb.ID_PRESTCONTAS=@ID_PRESTCONTAS and mb.ID_CONTABANCO=@ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="VALOR_TOTAL">
          <DataField>VALOR_TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2_Campo13">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT SUM(ch.VALOR) AS VALOR_TOTAL
FROM LY_PC_CHEQUE ch
INNER JOIN LY_PC_COMPRA co ON ch.ID_COMPRA = co.ID
WHERE co.ID_PRESTCONTAS = @ID_PRESTCONTAS 
	AND ch.ID_CONTABANCO = @ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="VALOR_TOTAL">
          <DataField>VALOR_TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2_Campo14">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select SUM(mb.VALOR) VALOR_TOTAL
from LY_PC_MOVBANCO mb
inner join LY_PC_TIPOMOVBANC tm on tm.ID=mb.ID_TIPOMOV
where tm.TIPO='D' and
mb.ID_PRESTCONTAS=@ID_PRESTCONTAS and mb.ID_CONTABANCO=@ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="VALOR_TOTAL">
          <DataField>VALOR_TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2_Campo15">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT SUM(ch.VALOR) AS VALOR_TOTAL
FROM LY_PC_CHEQUE ch
INNER JOIN LY_PC_COMPRA co ON ch.ID_COMPRA = co.ID
INNER JOIN LY_PC_PRESTACAOCONTAS pc ON pc.ID = co.ID_PRESTCONTAS
INNER JOIN LY_PC_PERIODOREF pr ON pc.ID_PERIODOREF = pr.ID
WHERE co.ID_PRESTCONTAS = @ID_PRESTCONTAS 
	AND ch.ID_CONTABANCO = @ID_CONTABANCO
	AND (ch.DATA_APRESENTACAO IS NULL OR ch.DATA_APRESENTACAO &gt; pr.DATAFIMAPLICACAO)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="VALOR_TOTAL">
          <DataField>VALOR_TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2_Campo16">
      <Query>
        <DataSourceName>DS_FormularioVI</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT SUM(ch.VALOR) AS VALOR_TOTAL
FROM LY_PC_CHEQUE ch
LEFT OUTER JOIN LY_PC_COMPRA co ON ch.ID_COMPRA = co.ID,
LY_PC_PRESTACAOCONTAS pc
INNER JOIN LY_PC_PERIODOREF pr ON pc.ID_PERIODOREF = pr.ID
WHERE pc.ID = @ID_PRESTCONTAS 
	AND ch.ID_CONTABANCO = @ID_CONTABANCO 	
	AND (co.ID_PRESTCONTAS IS NULL OR co.ID_PRESTCONTAS &lt;&gt; pc.ID)
	AND ch.DATA_EMISSAO &lt; pr.DATAINIAPLICACAO 
	AND (ch.DATA_APRESENTACAO &gt;= PR.DATAINIAPLICACAO AND ch.DATA_APRESENTACAO &lt;= pr.DATAFIMAPLICACAO)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="VALOR_TOTAL">
          <DataField>VALOR_TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
