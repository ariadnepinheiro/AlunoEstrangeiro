    <DataSet Name="ds_Cabecalho">
      <Query>
        <DataSourceName>DS_FormularioIV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select fr.CODIGO_FORMULARIO, upper(fr.NOME) NOME
from LY_PC_CONTABANCO cb
inner join  LY_PC_FONTERECURSO fr on cb.ID_FONTERECURSO=fr.ID
where cb.ID=@ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CODIGO_FORMULARIO">
          <DataField>CODIGO_FORMULARIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2">
      <Query>
        <DataSourceName>DS_FormularioIV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT it.NOME AS NOME_ITEM,
	ISNULL(fo.NOME,'FDR') AS NOME_FORNECEDOR, 
	co.VALOR AS VALOR_COMPRA,
	ide.VALOR_TOTAL AS VALOR_ITEM,
	ide.DESCONTO AS DESCONTO_ITEM,
	(ide.VALOR_TOTAL - ide.DESCONTO) AS VALOR,
	ch.NUMERO as NUMERO_CHEQUE, 
	ch.DATA_EMISSAO,
	de.TIPO_COMPROV, 
	de.NUM_COMPROV, 
	MONTH(ch.DATA_EMISSAO) as MES, 
	ide.ID_FINALIDADE,
	fn.CODIGO,	
	(ISNULL((
		SELECT DISTINCT SUM(ISNULL(idex.VALOR_TOTAL,0) - ISNULL(idex.DESCONTO,0)) AS SOMA_VALOR
		FROM LY_PC_ITEMDESPESA idex
		INNER JOIN LY_PC_DESPESA dex ON idex.ID_DESPESA = dex.ID
		INNER JOIN LY_PC_COMPRA cox ON dex.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		LEFT OUTER JOIN LY_SM_FORNECEDOR fox ON cox.ID_FORNECEDOR = fox.ID
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO
	),0) +	ISNULL((
		SELECT DISTINCT SUM(ISNULL(cox.VALOR,0) - ISNULL(cox.DESCONTO,0)) AS SOMA_VALOR
		FROM LY_PC_PEQUENA_DESPESA pdx
		INNER JOIN LY_PC_COMPRA cox ON pdx.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO
	),0)) AS TOTAL_ACUMULADO,
	(
		SELECT SUM(ISNULL(sfx.SALDO,0)) AS SALDO_FINALIDADE
		FROM LY_PC_CBS_FINALIDADE sfx
		INNER JOIN LY_PC_CONTABANCO_SALDO cbs ON sfx.ID_CONTABANCO_SALDO = cbs.ID
		WHERE cbs.ID_PRESTCONTAS = @ID_PRESTCONTAS 
			AND cbs.ID_CONTABANCO = @ID_CONTABANCO
			AND sfx.ID_FINALIDADE = fn.ID_FINALIDADE			
	) AS SALDO_FINALIDADE,
	(
		select SUM(ISNULL(mb.VALOR,0)) as VALOR_RECEBIDO
		from LY_PC_MOVBANCO mb
		inner join LY_PC_TIPOMOVBANC tmb on mb.id_tipomov = tmb.id
		where mb.ID_PRESTCONTAS = @ID_PRESTCONTAS 
			and mb.ID_CONTABANCO = @ID_CONTABANCO
			and tmb.TIPO = 'R'
			and mb.ID_FINALIDADE = fn.ID_FINALIDADE
	) as VALOR_RECEBIDO_FINALIDADE,	
	(ISNULL((
		SELECT SUM(ISNULL(idex.VALOR_TOTAL,0) - ISNULL(idex.DESCONTO,0)) AS SOMA_VALOR
		FROM LY_PC_ITEMDESPESA idex
		INNER JOIN LY_PC_DESPESA dex ON idex.ID_DESPESA = dex.ID
		INNER JOIN LY_PC_COMPRA cox ON dex.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		LEFT OUTER JOIN LY_SM_FORNECEDOR fox ON cox.ID_FORNECEDOR = fox.ID
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO
			AND idex.ID_FINALIDADE = fn.ID_FINALIDADE
	),0) +	ISNULL((
		SELECT SUM(ISNULL(pdx.VALOR,0) - ISNULL(pdx.DESCONTO,0)) AS SOMA_VALOR
		FROM LY_PC_PEQUENA_DESPESA pdx
		INNER JOIN LY_PC_COMPRA cox ON pdx.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO
			AND pdx.ID_FINALIDADE = fn.ID_FINALIDADE
	),0)) AS TOTAL_ACUMULADO_FINALIDADE
FROM LY_PC_ITEMDESPESA ide
INNER JOIN LY_PC_DESPESA de ON ide.ID_DESPESA = de.ID
INNER JOIN LY_PC_COMPRA co ON de.ID_COMPRA = co.ID
INNER JOIN LY_PC_CHEQUE ch ON co.ID = ch.ID_COMPRA
LEFT OUTER JOIN LY_SM_FORNECEDOR fo ON co.ID_FORNECEDOR = fo.ID
INNER JOIN LY_PC_FINALIDADE fn ON ide.ID_FINALIDADE = fn.ID_FINALIDADE
INNER JOIN LY_SM_ITENS it ON ide.ID_ITEM = it.ID
WHERE co.ID_PRESTCONTAS = @ID_PRESTCONTAS 
	AND ch.ID_CONTABANCO = @ID_CONTABANCO
UNION
SELECT 'Pequenas Despesas' AS NOME_ITEM,
	NULL AS NOME_FORNECEDOR, 
	co.VALOR AS VALOR_COMPRA,
	pd.VALOR AS VALOR_ITEM,
	ISNULL(pd.DESCONTO,0) AS DESCONTO_ITEM,
	(ISNULL(pd.VALOR,0) - ISNULL(pd.DESCONTO,0)) AS VALOR,
	ch.NUMERO as NUMERO_CHEQUE, 
	ch.DATA_EMISSAO,
	NULL AS TIPO_COMPROV, 
	'S/Nº' AS NUM_COMPROV, 
	MONTH(ch.DATA_EMISSAO) as MES, 
	pd.ID_FINALIDADE,
	fn.CODIGO,
	(ISNULL((
		SELECT (SUM(ISNULL(cox.VALOR,0) - ISNULL(cox.DESCONTO,0))) AS SOMA_VALOR
		FROM LY_PC_PEQUENA_DESPESA pdx
		INNER JOIN LY_PC_COMPRA cox ON pdx.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO			
	),0) + ISNULL((
		SELECT SUM(ISNULL(idex.VALOR_TOTAL,0) - ISNULL(idex.DESCONTO,0)) AS SOMA_VALOR
		FROM LY_PC_ITEMDESPESA idex
		INNER JOIN LY_PC_DESPESA dex ON idex.ID_DESPESA = dex.ID
		INNER JOIN LY_PC_COMPRA cox ON dex.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		LEFT OUTER JOIN LY_SM_FORNECEDOR fox ON cox.ID_FORNECEDOR = fox.ID
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO
	),0)) AS TOTAL_ACUMULADO,
	(
		SELECT SUM(ISNULL(sfx.SALDO,0)) AS SALDO_FINALIDADE
		FROM LY_PC_CBS_FINALIDADE sfx
		INNER JOIN LY_PC_CONTABANCO_SALDO cbs ON sfx.ID_CONTABANCO_SALDO = cbs.ID
		WHERE cbs.ID_PRESTCONTAS = @ID_PRESTCONTAS 
			AND cbs.ID_CONTABANCO = @ID_CONTABANCO
			AND sfx.ID_FINALIDADE = fn.ID_FINALIDADE	
	) AS SALDO_FINALIDADE,
	(
		SELECT SUM(ISNULL(mb.VALOR,0)) AS VALOR_RECEBIDO
		FROM LY_PC_MOVBANCO mb
		INNER JOIN LY_PC_TIPOMOVBANC tmb ON mb.id_tipomov = tmb.id
		WHERE mb.ID_PRESTCONTAS = @ID_PRESTCONTAS 
			AND mb.ID_CONTABANCO = @ID_CONTABANCO
			AND tmb.TIPO = 'R'
			AND mb.ID_FINALIDADE = fn.ID_FINALIDADE
	) AS VALOR_RECEBIDO_FINALIDADE,	 
	(ISNULL((
		SELECT SUM(ISNULL(pdx.VALOR,0) - ISNULL(pdx.DESCONTO,0)) AS SOMA_VALOR
		FROM LY_PC_PEQUENA_DESPESA pdx
		INNER JOIN LY_PC_COMPRA cox ON pdx.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO
			AND pdx.ID_FINALIDADE = fn.ID_FINALIDADE
	),0) + ISNULL((
		SELECT SUM(ISNULL(idex.VALOR_TOTAL,0) - ISNULL(idex.DESCONTO,0)) AS SOMA_VALOR
		FROM LY_PC_ITEMDESPESA idex
		INNER JOIN LY_PC_DESPESA dex ON idex.ID_DESPESA = dex.ID
		INNER JOIN LY_PC_COMPRA cox ON dex.ID_COMPRA = cox.ID
		INNER JOIN LY_PC_CHEQUE chx ON cox.ID = chx.ID_COMPRA
		LEFT OUTER JOIN LY_SM_FORNECEDOR fox ON cox.ID_FORNECEDOR = fox.ID
		WHERE MONTH(chx.DATA_EMISSAO) &lt;= MONTH(ch.DATA_EMISSAO)
			AND YEAR(chx.DATA_EMISSAO) = YEAR(ch.DATA_EMISSAO)
			AND cox.ID_PRESTCONTAS = @ID_PRESTCONTAS
			AND chx.ID_CONTABANCO = @ID_CONTABANCO
			AND idex.ID_FINALIDADE = fn.ID_FINALIDADE
	),0)) AS TOTAL_ACUMULADO_FINALIDADE
FROM LY_PC_PEQUENA_DESPESA pd
INNER JOIN LY_PC_COMPRA co ON pd.ID_COMPRA = co.ID
INNER JOIN LY_PC_CHEQUE ch ON co.ID = ch.ID_COMPRA
INNER JOIN LY_PC_FINALIDADE fn ON pd.ID_FINALIDADE = fn.ID_FINALIDADE
WHERE co.ID_PRESTCONTAS = @ID_PRESTCONTAS 
	AND ch.ID_CONTABANCO = @ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NOME_FORNECEDOR">
          <DataField>NOME_FORNECEDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_ITEM">
          <DataField>NOME_ITEM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VALOR">
          <DataField>VALOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_COMPRA">
          <DataField>VALOR_COMPRA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NUMERO_CHEQUE">
          <DataField>NUMERO_CHEQUE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA_EMISSAO">
          <DataField>DATA_EMISSAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="VALOR_ITEM">
          <DataField>VALOR_ITEM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TIPO_COMPROV">
          <DataField>TIPO_COMPROV</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCONTO_ITEM">
          <DataField>DESCONTO_ITEM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NUM_COMPROV">
          <DataField>NUM_COMPROV</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MES">
          <DataField>MES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ACUMULADO">
          <DataField>TOTAL_ACUMULADO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ID_FINALIDADE">
          <DataField>ID_FINALIDADE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SALDO_FINALIDADE">
          <DataField>SALDO_FINALIDADE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_RECEBIDO_FINALIDADE">
          <DataField>VALOR_RECEBIDO_FINALIDADE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ACUMULADO_FINALIDADE">
          <DataField>TOTAL_ACUMULADO_FINALIDADE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco3">
      <Query>
        <DataSourceName>DS_FormularioIV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
(	
	select sum(mb.VALOR) as VALOR_RECEBIDO
	from LY_PC_MOVBANCO mb
	inner join LY_PC_TIPOMOVBANC tmb on mb.id_tipomov = tmb.id
	where mb.ID_PRESTCONTAS = @ID_PRESTCONTAS 
		and mb.ID_CONTABANCO = @ID_CONTABANCO
		and tmb.TIPO = 'R'
) as VALOR_RECEBIDO,
(
	select sum(mb.VALOR) as RENDIMENTO_BANCARIO
	from LY_PC_MOVBANCO mb
	inner join LY_PC_TIPOMOVBANC tmb on mb.id_tipomov = tmb.id
	where mb.ID_PRESTCONTAS = @ID_PRESTCONTAS 
		and mb.ID_CONTABANCO = @ID_CONTABANCO
		and tmb.TIPO = 'A'
) as RENDIMENTO_BANCARIO,
(
	select sum(mb.VALOR) as DESPESA_BANCARIA
	from LY_PC_MOVBANCO mb
	inner join LY_PC_TIPOMOVBANC tmb on mb.id_tipomov = tmb.id
	where mb.ID_PRESTCONTAS = @ID_PRESTCONTAS 
		and mb.ID_CONTABANCO = @ID_CONTABANCO
		and tmb.TIPO = 'D'
) as DESPESA_BANCARIA,
(
	select cbs.SALDO_INICIAL
	from ly_pc_contabanco_saldo cbs
	where cbs.ID_PRESTCONTAS = @ID_PRESTCONTAS 
		and cbs.ID_CONTABANCO = @ID_CONTABANCO
) as SALDO_INICIAL,
(
	select sum(ch.valor)
	from ly_pc_cheque ch
	where ch.ID_CONTABANCO = @ID_CONTABANCO
		and ch.DATA_APRESENTACAO IS NULL
) as SALDO_PARCIAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="VALOR_RECEBIDO">
          <DataField>VALOR_RECEBIDO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="RENDIMENTO_BANCARIO">
          <DataField>RENDIMENTO_BANCARIO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DESPESA_BANCARIA">
          <DataField>DESPESA_BANCARIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SALDO_INICIAL">
          <DataField>SALDO_INICIAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
