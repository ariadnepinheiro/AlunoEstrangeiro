  <DataSources>
    <DataSource Name="SeeducDataSource">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>691004f1-5dbf-4484-aaf6-ef50c9b14190</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsRelatorioPequenaDespesa">
      <Query>
        <DataSourceName>SeeducDataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@p_PequenaDespesa">
            <Value>=Parameters!PequenaDespesa.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT pc.NUMERO_PROCESSO,
	nuc.DESCRICAO AS NOME_COORDENADORIA,
	ue.NOME_COMP AS NOME_UNIDADE,
	pd.VALOR,
	dbo.Extenso(pd.VALOR) AS VALOR_EXTENSO,
	ch.NUMERO,
	pd.DATA,	
	pd.MATRICULA AS MATRICULA_SERVIDOR,
	p.NOME_COMPL AS NOME_SERVIDOR,
	pd.OBSERVACOES AS OBSERVACOES	
FROM LY_PC_PEQUENA_DESPESA pd
INNER JOIN LY_PC_COMPRA co ON pd.ID_COMPRA = co.ID
INNER JOIN LY_PC_CHEQUE ch ON co.ID = ch.ID_COMPRA
INNER JOIN LY_PC_PRESTACAOCONTAS pc ON co.ID_PRESTCONTAS = pc.ID
INNER JOIN LY_PC_PRESTADOR pr ON pc.ID_PRESTADOR = pr.ID
LEFT OUTER JOIN LY_VINCULO v ON pd.MATRICULA = v.MATRICULA
LEFT OUTER JOIN LY_PESSOA p ON  v.PESSOA = p.PESSOA
LEFT OUTER JOIN LY_NUCLEO nuc ON pr.NUCLEOLY = nuc.NUCLEO
LEFT OUTER JOIN LY_UNIDADE_ENSINO ue ON pr.UNIDADELY = ue.UNIDADE_ENS
WHERE pd.ID = @p_PequenaDespesa</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NUMERO_PROCESSO">
          <DataField>NUMERO_PROCESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="NOME_COORDENADORIA">
          <DataField>NOME_COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_UNIDADE">
          <DataField>NOME_UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VALOR">
          <DataField>VALOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_EXTENSO">
          <DataField>VALOR_EXTENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_SERVIDOR">
          <DataField>NOME_SERVIDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA_SERVIDOR">
          <DataField>MATRICULA_SERVIDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OBSERVACOES">
          <DataField>OBSERVACOES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
