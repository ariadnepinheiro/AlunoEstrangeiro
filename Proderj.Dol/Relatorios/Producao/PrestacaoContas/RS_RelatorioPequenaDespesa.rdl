                        <Textbox Name="txtDadosCheque">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>="Recebi dos Gestores do(a) " &amp; IIF(Fields!NOME_UNIDADE.Value is nothing, Fields!NOME_COORDENADORIA.Value, Fields!NOME_UNIDADE.Value) &amp; ", " &amp; 
"a importância de " &amp; FormatCurrency(Fields!VALOR.Value, 2) &amp; " (" &amp; Trim(Fields!VALOR_EXTENSO.Value) &amp; "), através do cheque de nº " &amp; Fields!NUMERO.Value &amp; ". " &amp;
chr(13) &amp; chr(10) &amp; 
"Para as quais não houve obtenção de notas fiscais."</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Top>3.5cm</Top>
                          <Height>1.5cm</Height>
                          <Width>18cm</Width>
                          <ZIndex>2</ZIndex>
                          <Style>
