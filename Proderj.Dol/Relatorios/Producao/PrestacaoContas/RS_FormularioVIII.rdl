    <DataSet Name="ds_Bloco2_Campo5A">
      <Query>
        <DataSourceName>DS_FormularioVIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT SUM(CBS.SALDO_INICIAL) SALDO_INICIAL
FROM LY_PC_CONTABANCO_SALDO CBS
WHERE CBS.ID_PRESTCONTAS=@ID_PRESTCONTAS 
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SALDO_INICIAL">
          <DataField>SALDO_INICIAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
