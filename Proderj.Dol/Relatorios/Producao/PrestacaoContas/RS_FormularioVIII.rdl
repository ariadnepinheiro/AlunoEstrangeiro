        </QueryParameters>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>SP_FORMULARIO_VIII</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MES">
          <DataField>MES</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_TOTAL_RECEITA">
          <DataField>VALOR_TOTAL_RECEITA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
