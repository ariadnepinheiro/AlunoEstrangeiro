  <DataSources>
    <DataSource Name="DS_FormularioVIII">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>b4d77adf-3fd1-4d84-a1c9-94555ce5deb8</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_Bloco1">
      <Query>
        <DataSourceName>DS_FormularioVIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select cb.TITULAR,
	cb.CNPJ,
	pr.DATAINIAPLICACAO,
	pr.DATAFIMAPLICACAO,
	pr.PERIODOLY,
	pr.ANOLY,
	pc.DATA_INICIO,
	pc.DATA_FIM
from LY_PC_PRESTACAOCONTAS PC
inner join LY_PC_PERIODOREF pr on pr.ID = PC.ID_PERIODOREF
left outer join LY_PC_CONTABANCO cb on PC.ID_PRESTADOR = cb.ID_PRESTADOR
left outer join LY_PC_FONTERECURSO fr on fr.ID = cb.ID_FONTERECURSO
where PC.ID = @ID_PRESTCONTAS
order by fr.CODIGO_FORMULARIO asc</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TITULAR">
          <DataField>TITULAR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CNPJ">
          <DataField>CNPJ</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATAINIAPLICACAO">
          <DataField>DATAINIAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATAFIMAPLICACAO">
          <DataField>DATAFIMAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="PERIODOLY">
          <DataField>PERIODOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ANOLY">
          <DataField>ANOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA_INICIO">
          <DataField>DATA_INICIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATA_FIM">
          <DataField>DATA_FIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2">
      <Query>
        <DataSourceName>DS_FormularioVIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@INICIO_MES">
            <Value>=Parameters!INICIO_MES.Value</Value>
          </QueryParameter>
