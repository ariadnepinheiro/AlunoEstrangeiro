  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>86c52f8c-2e98-4034-adf0-72ff6971ce88</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@TURMA">
            <Value>=Parameters!TURMA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT AA.ALUNO,AA.NOME_COMPL,MM.TURMA,MM.ANO,LS.UNIDADE_ENS,LS.NUCLEO 
FROM	LY_ALUNO AA (NOLOCK)
JOIN	LY_MATRICULA MM (NOLOCK) ON MM.ALUNO=AA.ALUNO
JOIN	LY_TURMA TR (NOLOCK) ON TR.TURMA=MM.TURMA AND TR.ANO=MM.ANO AND TR.DISCIPLINA=MM.DISCIPLINA AND TR.SEMESTRE=MM.SEMESTRE
JOIN	LY_UNIDADE_ENSINO LS (NOLOCK) ON LS.UNIDADE_ENS=TR.UNIDADE_RESPONSAVEL
WHERE	MM.TURMA=@TURMA AND MM.ANO=@ANO 
AND		MM.SEMESTRE = @SEMESTRE
AND		LS.UNIDADE_ENS=@ESCOLA
AND		MM.SIT_MATRICULA &lt;&gt; 'CANCELADO'
ORDER BY AA.NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="coord">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT R.ID_REGIONAL CODIGO,REGIONAL DESCRICAO
FROM TCE_REGIONAL R (NOLOCK)
JOIN LY_UNIDADE_ENSINO UE (NOLOCK)
ON R.ID_REGIONAL = UE.ID_REGIONAL
GROUP BY R.ID_REGIONAL,REGIONAL
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="munic">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select DISTINCT  mm.ID_MUNICIPIO codigo,mm.nome municipio from HADES..TCE_municipio mm
join ly_unidade_ensino s1 on s1.MUNICIPIO=mm.ID_MUNICIPIO
join TCE_REGIONAL n1 on n1.ID_REGIONAL=s1.ID_REGIONAL
where s1.ID_REGIONAL=@NUCLEO
ORDER BY MM.NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="municipio">
          <DataField>municipio</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select UNIDADE_ENS,nome_comp escola 
from ly_unidade_ensino UE
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where 
	ID_REGIONAL=@NUCLEO
and 	MUNICIPIO=@MUNIC
AND (gg.USUARIO = ISNULL(@usuario, gg.USUARIO) OR  gg.USUARIO IS NULL) 
GROUP BY UNIDADE_ENS,NOME_COMP
ORDER BY NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="escola">
          <DataField>escola</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ano">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct ano from LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ano">
          <DataField>ano</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="turma">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT 
	T1.TURMA 
FROM 
LY_TURMA T1 WITH (NOLOCK) 
JOIN LY_UNIDADE_ENSINO LL (NOLOCK) ON LL.UNIDADE_ENS=T1.UNIDADE_RESPONSAVEL
WHERE T1.UNIDADE_RESPONSAVEL=@ESCOLA
AND T1.ANO = @ANO
AND T1.SEMESTRE = @SEMESTRE
AND SIT_TURMA = 'ABERTA'
order by t1.turma</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
