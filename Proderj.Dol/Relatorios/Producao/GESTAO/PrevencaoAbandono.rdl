  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=Metas</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>eadb33a5-a61e-4cce-bfaa-dbe8e4847baf</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CENSO">
            <Value>=Parameters!CENSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  A.*,UE.NOME_COMP AS ESCOLA
FROM    [Metas].[dbo].ABANDONO A
        INNER JOIN LYCEUM.DBO.LY_UNIDADE_ENSINO UE ON A.CENSO = UE.UNIDADE_ENS
WHERE   ANO = YEAR(GETDATE()) - 1
        AND CENSO = @CENSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNO">
          <DataField>TOT_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOT_ABANDONO">
          <DataField>TOT_ABANDONO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERC_PERMANENCIA">
          <DataField>PERC_PERMANENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
