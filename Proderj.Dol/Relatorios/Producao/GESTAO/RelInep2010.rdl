  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <Transaction>true</Transaction>
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>541d2d57-1ca6-4cdf-9211-09c7bdf37b73</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT * FROM (      
SELECT DISTINCT LY_UNIDADE_ENSINO.SETOR      
                ,LY_UNIDADE_ENSINO.UNIDADE_ENS      
                ,LY_UNIDADE_ENSINO.NOME_COMP ESCOLA      
                ,LY_ALUNO.ALUNO      
                ,UPPER(LY_ALUNO.NOME_COMPL)NOME_COMPL      
                ,LY_CURSO.NOME  MODALIDADE      
                ,LY_TURNO.DESCRICAO TURNO      
                ,CONVERT(VARCHAR(30),LY_ALUNO.SERIE) ANO_ESCOLARIDADE      
                ,LY_SERIE.DESCRICAO DSC_SERIE      
				,'ATUALIZAR DADOS CADASTRAIS E ENTURMAR ALUNO' SITUACAO      
                ,LY_NUCLEO.DESCRICAO COORDENADORIA      
                ,LY_NUCLEO.NUCLEO      
                ,MUNICIPIO.CODIGO       
                ,MUNICIPIO.NOME NOME_MUNIC,      
  'ATUALIZAR DADOS CADASTRAIS' [ATUALIZAR DADOS CADASTRAIS]            
FROM   LY_ALUNO WITH(NOLOCK)      
         JOIN LY_PESSOA WITH(NOLOCK)  
            ON LY_PESSOA.PESSOA = LY_ALUNO.PESSOA  
       JOIN LY_CURSO WITH(NOLOCK)      
         ON LY_CURSO.CURSO = LY_ALUNO.CURSO      
       JOIN LY_MODALIDADE_CURSO  WITH(NOLOCK)      
         ON LY_MODALIDADE_CURSO.MODALIDADE = LY_CURSO.MODALIDADE      
       JOIN LY_UNIDADE_ENSINO WITH(NOLOCK)         
         ON LY_UNIDADE_ENSINO.UNIDADE_ENS = LY_ALUNO.UNIDADE_ENSINO      
       JOIN LY_TURNO  WITH(NOLOCK)        
   ON LY_TURNO.TURNO = LY_ALUNO.TURNO      
       JOIN LY_SERIE  WITH(NOLOCK)         
         ON LY_SERIE.CURSO = LY_ALUNO.CURSO      
       AND  LY_SERIE.CURRICULO = LY_ALUNO.CURRICULO      
       AND LY_SERIE.TURNO = LY_ALUNO.TURNO      
       AND  LY_SERIE.SERIE = LY_ALUNO.SERIE      
      JOIN LY_NUCLEO WITH(NOLOCK)       
      ON LY_NUCLEO.NUCLEO=LY_UNIDADE_ENSINO.NUCLEO      
      JOIN MUNICIPIO WITH(NOLOCK)      
      ON MUNICIPIO.CODIGO=LY_UNIDADE_ENSINO.MUNICIPIO      
LEFT	JOIN LY_FL_PESSOA  FL (NOLOCK) 
ON		FL.PESSOA = LY_PESSOA.PESSOA
WHERE  NOT EXISTS (
					SELECT	1 
					FROM	LY_H_CURSOS_CONCL WITH(NOLOCK)      
					WHERE	LY_ALUNO.ALUNO = LY_H_CURSOS_CONCL.ALUNO      
					AND		LY_H_CURSOS_CONCL.DT_REABERTURA IS NULL 
					AND		LY_H_CURSOS_CONCL.DT_ENCERRAMENTO &lt;= '2011-05-25'
					)                  
		AND (  
               LY_PESSOA.NOME_MAE IS NULL  
            OR LY_PESSOA.DT_NASC &lt; '1900-01-01' 
            OR LY_PESSOA.DT_NASC IS NULL 
            OR LY_PESSOA.SEXO IS NULL
            OR LY_PESSOA.EST_CIVIL IS NULL  
            OR LY_PESSOA.PAIS_NASC IS NULL  
            OR LY_PESSOA.NACIONALIDADE IS NULL  
            OR CASE WHEN ISNULL(LY_PESSOA.NACIONALIDADE,'BRASILEIRA') = 'BRASILEIRA' THEN ISNULL(LY_PESSOA.MUNICIPIO_NASC,'S')  END = 'S'
            --OR LY_PESSOA.END_PAIS IS NULL  
            OR LY_PESSOA.CEP IS NULL   
            OR LY_PESSOA.CEP LIKE '0000%'  
            OR LY_PESSOA.END_MUNICIPIO IS NULL  
            OR LY_PESSOA.ENDERECO IS NULL  
            OR LY_PESSOA.END_NUM IS NULL  
            OR LY_PESSOA.BAIRRO IS NULL          
            OR FL.FL_FIELD_01 IS NULL
            OR FL.FL_FIELD_03 IS NULL
            OR FL.FL_FIELD_04 IS NULL
            OR (FL.FL_FIELD_10 IS NULL AND FL.FL_FIELD_04 = 'S')
		)                            
AND		EXISTS (
				SELECT	1 
				FROM	LY_MATRICULA M (NOLOCK)
				WHERE	M.ALUNO = LY_ALUNO.ALUNO 
				AND		M.ANO = YEAR(GETDATE())
				AND		M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
				)
)SQL1                                
WHERE       
(SQL1.nucleo = ISNULL(@coord, SQL1.nucleo) OR SQL1.nucleo IS NULL)       
AND (SQL1.CODIGO = ISNULL(@municipio,  SQL1.CODIGO) OR   SQL1.CODIGO IS NULL)       
AND (SQL1.UNIDADE_ENS = ISNULL(@escola,SQL1.UNIDADE_ENS) OR SQL1.UNIDADE_ENS IS NULL)       
ORDER BY SQL1.MODALIDADE, SQL1.TURNO, SQL1.ANO_ESCOLARIDADE,SQL1.NOME_COMPL  </CommandText>
      </Query>
      <Fields>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO_ESCOLARIDADE">
          <DataField>ANO_ESCOLARIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DSC_SERIE">
          <DataField>DSC_SERIE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_MUNIC">
          <DataField>NOME_MUNIC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ATUALIZAR_DADOS_CADASTRAIS">
          <DataField>ATUALIZAR DADOS CADASTRAIS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Coordenadoria">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municpio">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
