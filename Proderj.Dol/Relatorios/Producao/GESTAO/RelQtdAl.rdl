  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="QTD_ALUNO">
          <DataField>QTD_ALUNO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTD_FUND">
          <DataField>QTD_FUND</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTD_MEDIO">
          <DataField>QTD_MEDIO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTD_ESPECIAL">
          <DataField>QTD_ESPECIAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTD_UNID_PRISIONAIS">
          <DataField>QTD_UNID_PRISIONAIS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTD_INDIGENA">
          <DataField>QTD_INDIGENA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT  DISTINCT QTD_ALUNO, QTD_FUND, QTD_MEDIO, QTD_ESPECIAL, QTD_UNID_PRISIONAIS, QTD_INDIGENA--, QTD_ALUNOS_MUNICIPIO, QTD_ESCOLAS_MUNICIPIO

FROM (
SELECT 

(select COUNT (DISTINCT A.ALUNO) FROM LY_ALUNO A
INNER JOIN LY_MATRICULA on A.ALUNO = LY_MATRICULA.ALUNO 
INNER join LY_TURMA on LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE
INNER JOIN LY_UNIDADE_ENSINO LL ON LL.UNIDADE_ENS=LY_TURMA.FACULDADE
INNER JOIN LY_UNIDADE_ENSINO_SITUACAO UES ON UES.UNIDADE_ENS=LL.UNIDADE_ENS
					AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
											FROM LY_UNIDADE_ENSINO_SITUACAO LY_UNIDADE_ENSINO_SITUACAO
											WHERE LL.UNIDADE_ENS=LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
WHERE A.ALUNO not in (select ALUNO FROM LY_H_CURSOS_CONCL where DT_REABERTURA is null) 
AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND LY_TURMA.SIT_TURMA IN ('ABERTA') AND LY_TURMA.ANO = '2011' AND SITUACAO = 'ESTADUAL') AS QTD_ALUNO,

(select COUNT (DISTINCT A.ALUNO) FROM LY_ALUNO A
INNER JOIN LY_MATRICULA on A.ALUNO = LY_MATRICULA.ALUNO 
INNER join LY_TURMA on LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE
WHERE A.ALUNO not in (select ALUNO FROM LY_H_CURSOS_CONCL where DT_REABERTURA is null) 
AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND LY_TURMA.SIT_TURMA IN ('ABERTA') AND LY_TURMA.ANO = '2011'
AND A.CURSO IN ('0001.11', '0001.16', '0001.21', '0001.51')) AS QTD_FUND,

(select COUNT (DISTINCT A.ALUNO) FROM LY_ALUNO A
INNER JOIN LY_MATRICULA on A.ALUNO = LY_MATRICULA.ALUNO 
INNER join LY_TURMA on LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE
WHERE A.ALUNO not in (select ALUNO FROM LY_H_CURSOS_CONCL where DT_REABERTURA is null) 
AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND LY_TURMA.SIT_TURMA IN ('ABERTA') AND LY_TURMA.ANO = '2011'
AND A.CURSO IN ('0002.31')) AS QTD_MEDIO,

(select COUNT (DISTINCT A.ALUNO) FROM LY_ALUNO A
INNER JOIN LY_MATRICULA on A.ALUNO = LY_MATRICULA.ALUNO 
INNER join LY_TURMA on LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE
INNER JOIN LY_SERIE ON LY_SERIE.CURSO = LY_TURMA.CURSO
			AND LY_SERIE.TURNO = LY_TURMA.TURNO						
			AND LY_SERIE.CURRICULO = LY_TURMA.CURRICULO	
			AND LY_SERIE.SERIE = LY_TURMA.SERIE
INNER JOIN LY_CURSO ON LY_CURSO.CURSO = LY_SERIE.CURSO
INNER JOIN LY_MODALIDADE_CURSO ON LY_MODALIDADE_CURSO.MODALIDADE = LY_CURSO.MODALIDADE
WHERE A.ALUNO not in (select ALUNO FROM LY_H_CURSOS_CONCL where DT_REABERTURA is null) 
AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND LY_TURMA.SIT_TURMA IN ('ABERTA') AND LY_TURMA.ANO = '2011'
AND LY_MODALIDADE_CURSO.MODALIDADE = 'ES7') AS QTD_ESPECIAL,

(select COUNT (DISTINCT A.ALUNO) FROM LY_ALUNO A
INNER JOIN LY_MATRICULA on A.ALUNO = LY_MATRICULA.ALUNO 
INNER join LY_TURMA on LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE
INNER JOIN LY_UNIDADE_ENSINO LL ON LL.UNIDADE_ENS=LY_TURMA.FACULDADE  
inner join LY_NUCLEO N on N.NUCLEO=LL.NUCLEO
WHERE A.ALUNO not in (select ALUNO FROM LY_H_CURSOS_CONCL where DT_REABERTURA is null) 
AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND LY_TURMA.SIT_TURMA IN ('ABERTA') AND LY_TURMA.ANO = '2011'
AND N.NUCLEO = '31') AS QTD_UNID_PRISIONAIS,

(select COUNT (DISTINCT A.ALUNO) FROM LY_ALUNO A
INNER JOIN LY_MATRICULA on A.ALUNO = LY_MATRICULA.ALUNO 
INNER join LY_TURMA on LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE
INNER JOIN LY_SERIE ON LY_SERIE.CURSO = LY_TURMA.CURSO
			AND LY_SERIE.TURNO = LY_TURMA.TURNO						
			AND LY_SERIE.CURRICULO = LY_TURMA.CURRICULO	
			AND LY_SERIE.SERIE = LY_TURMA.SERIE
INNER JOIN LY_CURSO ON LY_CURSO.CURSO = LY_SERIE.CURSO
INNER JOIN LY_MODALIDADE_CURSO ON LY_MODALIDADE_CURSO.MODALIDADE = LY_CURSO.MODALIDADE
WHERE A.ALUNO not in (select ALUNO FROM LY_H_CURSOS_CONCL where DT_REABERTURA is null) 
AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND LY_TURMA.SIT_TURMA IN ('ABERTA') AND LY_TURMA.ANO = '2011'
AND LY_MODALIDADE_CURSO.MODALIDADE = 'ED3') AS QTD_INDIGENA

/*(select MUNICIPIO.NOME, COUNT (DISTINCT A.ALUNO) FROM LY_ALUNO A
INNER JOIN LY_MATRICULA on A.ALUNO = LY_MATRICULA.ALUNO 
INNER join LY_TURMA on LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE
INNER JOIN LY_UNIDADE_ENSINO LL ON LL.UNIDADE_ENS=LY_TURMA.FACULDADE  
inner join ly_unidade_ensino_situacao UES on UES.UNIDADE_ENS = LL.UNIDADE_ENS
			AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
				FROM LY_UNIDADE_ENSINO_SITUACAO LY_UNIDADE_ENSINO_SITUACAO
				WHERE LL.UNIDADE_ENS=LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
INNER JOIN MUNICIPIO ON MUNICIPIO.CODIGO = LL.MUNICIPIO	
WHERE A.ALUNO not in (select ALUNO FROM LY_H_CURSOS_CONCL where DT_REABERTURA is null) 
AND SIT_MATRICULA &lt;&gt; 'CANCELADO' AND LY_TURMA.SIT_TURMA IN ('ABERTA') AND LY_TURMA.ANO = '2011' AND SITUACAO = 'ESTADUAL'
GROUP BY MUNICIPIO.NOME) AS QTD_ALUNOS_MUNICIPIO,

(select MUNICIPIO.NOME, COUNT (DISTINCT LL.UNIDADE_ENS) FROM LY_UNIDADE_ENSINO LL
join LY_TURMA T ON T.FACULDADE = LL.UNIDADE_ENS
inner join ly_unidade_ensino_situacao UES on UES.UNIDADE_ENS = LL.UNIDADE_ENS
			AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
				FROM LY_UNIDADE_ENSINO_SITUACAO LY_UNIDADE_ENSINO_SITUACAO
				WHERE LL.UNIDADE_ENS=LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
INNER JOIN MUNICIPIO ON MUNICIPIO.CODIGO = LL.MUNICIPIO	
where T.SIT_TURMA IN ('ABERTA') AND T.ANO = '2011' AND SITUACAO = 'estadual' 
GROUP BY MUNICIPIO.NOME) AS QTD_ESCOLAS_MUNICIPIO*/

FROM LY_TURMA
--INNER JOIN LY_UNIDADE_ENSINO ON LY_UNIDADE_ENSINO.UNIDADE_ENS = LY_TURMA.FACULDADE
--INNER JOIN LY_UNIDADE_ENSINO_SITUACAO UES ON UES.UNIDADE_ENS=ly_unidade_ensino.UNIDADE_ENS
--					AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
--											FROM LY_UNIDADE_ENSINO_SITUACAO LY_UNIDADE_ENSINO_SITUACAO
--											WHERE ly_unidade_ensino.UNIDADE_ENS=LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
--WHERE SITUACAO = 'ESTADUAL'

)SQL
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="coord">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
