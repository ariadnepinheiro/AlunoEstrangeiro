  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02d43a91-490f-46e8-8bb4-6c98a61e102f</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT SUBSTRING(N.DESCRICAO,1,35)COORDENADORIA,
          N.NUCLEO,
          UE.UNIDADE_ENS,
          UE.SETOR,
          UE.MUNICIPIO,
          (select nome from municipio where ue.municipio=municipio.codigo)nome_munic,
          UE.NOME_COMP,
          (
          SELECT	COUNT(LISTA_FREQ+COMP_LISTA)
          FROM	LY_INTEG_PRESENCA (NOLOCK)
          WHERE	UNIDADE_ENS = UE.UNIDADE_ENS
          AND		year(CONVERT(DATE,DT_AULA)) = @ano
          AND		PRESENCA = '2'
          ) AS PRESENCA_SEM_CARTAO_ANO,
          (
          SELECT	COUNT(LISTA_FREQ+COMP_LISTA)
          FROM	LY_INTEG_PRESENCA (NOLOCK)
          WHERE	UNIDADE_ENS = UE.UNIDADE_ENS
          AND		year(CONVERT(DATE,DT_AULA)) = @ano
          AND		PRESENCA = '1'
          ) AS PRESENCA_CARTAO_ANO
          --SUM(S_ANO.QTDE) PRESENCA_SEM_CARTAO_ANO,
          --SUM(ANO.QTDE)   PRESENCA_CARTAO_ANO
          FROM	LY_UNIDADE_ENSINO UE
          JOIN LY_NUCLEO N
          ON N.NUCLEO = UE.NUCLEO
          WHERE EXISTS (SELECT 1
          FROM   LY_UNIDADE_ENSINO_SITUACAO US
          WHERE  SITUACAO = 'ESTADUAL'
          AND US.UNIDADE_ENS = UE.UNIDADE_ENS)
          AND (UE.UNIDADE_ENS=isnull(@escola,UE.UNIDADE_ENS)or UE.UNIDADE_ENS is null)
          GROUP  BY N.DESCRICAO,
          N.NUCLEO,
          UE.UNIDADE_ENS,
          UE.SETOR,
          UE.MUNICIPIO,
          UE.NOME_COMP
        </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
