  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null id_regional,' TODAS' regional 
union
select  l1.id_regional,SUBSTRING(l1.regional,1,35) from tce_regional L1
join LY_UNIDADE_ENSINO l2 on L1.id_regional=l2.id_regional
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by regional</CommandText>
      </Query>
      <Fields>
        <Field Name="id_regional">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="regional">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join tce_regional r on r.id_regional = l2.id_regional
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(r.id_regional = ISNULL(@coord,r.id_regional)or r.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' descricao 
union
select null codigo,' TODOS' nome  
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
order by NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CURSO">
            <Value>=Parameters!CURSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@serie">
            <Value>=Parameters!serie.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@bimestre">
            <Value>=Parameters!bimestre.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@habilidade">
            <Value>=Parameters!habilidade.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@disc">
            <Value>=Parameters!disc.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	N.REGIONAL, MM.NOME MUNICIPIO, 
		UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, MC.DESCRICAO MODALIDADE, 
		C.NOME CURSO, M3.SERIE, M3.ANO, M3.SEMESTRE, M3.TURMA, D.NOME DISCIPLINA, M3.GRUPO, M3.COMPETENCIA_HABILIDADE, M3.BIMESTRE, CASE WHEN M3.ITEM_CM_CUMPRIDO = 1 THEN 'S' ELSE 'N' END ITEM_CM_CUMPRIDO,
		M3.MATRICULA, M3.NOME_DOCENTE
FROM	LY_UNIDADE_ENSINO UE
JOIN	TCE_REGIONAL N 
ON		N.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO MM 
ON		MM.CODIGO = UE.MUNICIPIO
JOIN	APOLLO..REL_CURRICULO_MINIMO M3
ON		M3.UNIDADE_ENS = UE.UNIDADE_ENS
JOIN	LY_CURSO C
ON		C.CURSO = M3.CURSO 
JOIN	LY_MODALIDADE_CURSO MC 
ON		MC.MODALIDADE = C.MODALIDADE
JOIN	LY_DISCIPLINA D
ON		D.DISCIPLINA = M3.DISCIPLINA
WHERE	EXISTS (
					SELECT 1
					FROM LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
					WHERE US.UNIDADE_ENS = UE.UNIDADE_ENS
					AND  US.SITUACAO = 'ESTADUAL'
					AND  US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
									(
									SELECT UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
									FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
									)
			    )
AND  (UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND (N.ID_REGIONAL = ISNULL(@coord, N.ID_REGIONAL) OR N.ID_REGIONAL IS NULL)       
AND (MM.CODIGO = ISNULL(@municipio,  MM.CODIGO) OR   MM.CODIGO IS NULL)       
AND (UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
AND (M3.CURSO = ISNULL(@CURSO,M3.CURSO) OR M3.CURSO IS NULL)
AND (CONVERT(VARCHAR(1), M3.SERIE) = ISNULL(@serie,CONVERT(VARCHAR(1), M3.SERIE)) OR CONVERT(VARCHAR(1), M3.SERIE) IS NULL)
AND (CONVERT(VARCHAR(1), M3.BIMESTRE) = ISNULL(@bimestre,CONVERT(VARCHAR(1), M3.BIMESTRE)) OR CONVERT(VARCHAR(1), M3.BIMESTRE) IS NULL)
AND (M3.COMPETENCIA_HABILIDADE = ISNULL(@habilidade,M3.COMPETENCIA_HABILIDADE) OR M3.COMPETENCIA_HABILIDADE IS NULL)
AND (D.NOME_COMPL = ISNULL(@disc, D.NOME_COMPL) OR D.NOME_COMPL IS NULL)
AND	M3.ANO = @ANO
</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GRUPO">
          <DataField>GRUPO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMPETENCIA_HABILIDADE">
          <DataField>COMPETENCIA_HABILIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BIMESTRE">
          <DataField>BIMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ITEM_CM_CUMPRIDO">
          <DataField>ITEM_CM_CUMPRIDO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Modalidade">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT MC.MODALIDADE CD_MODALIDADE, MC.DESCRICAO MODALIDADE
FROM LY_MODALIDADE_CURSO MC (NOLOCK) 
union
select 'NULO' CD_MODALIDADE,' Selecione...' MODALIDADE 
union
select null CD_MODALIDADE,' TODAS' MODALIDADE 
ORDER BY DESCRICAO</CommandText>
      </Query>
      <Fields>
        <Field Name="CD_MODALIDADE">
          <DataField>CD_MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Curso">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@modalidade">
            <Value>=Parameters!modalidade.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT C.CURSO CD_CURSO, C.NOME CURSO
FROM LY_CURSO C (NOLOCK) 
WHERE (C.MODALIDADE= ISNULL(@modalidade,C.MODALIDADE) OR  C.MODALIDADE IS NULL) 
union
select 'NULO' CD_CURSO,' Selecione...' CURSO
union
select null CD_CURSO,' TODOS' CURSO
ORDER BY C.CURSO</CommandText>
      </Query>
      <Fields>
        <Field Name="CD_CURSO">
          <DataField>CD_CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SERIE">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CURSO">
            <Value>=Parameters!CURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT CONVERT(VARCHAR(1), SERIE) SERIE, CONVERT(VARCHAR(1), SERIE) DS_SERIE
FROM LY_SERIE  M (NOLOCK)
JOIN LY_CURRICULO C
ON 	C.CURSO = M.CURSO
AND 	C.CURRICULO = M.CURRICULO
AND 	C.TURNO = M.TURNO
AND 	C.DT_EXTINCAO IS NULL
WHERE (M.CURSO= ISNULL(@CURSO,M.CURSO) OR  M.CURSO IS NULL) 
union
select 'NULO' SERIE,' Selecione...' DS_SERIE
union
select null SERIE,' TODAS' DS_SERIE
ORDER BY CONVERT(VARCHAR(1), SERIE)</CommandText>
      </Query>
      <Fields>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DS_SERIE">
          <DataField>DS_SERIE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="HABILIDADE">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CURSO">
            <Value>=Parameters!CURSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@serie">
            <Value>=Parameters!serie.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@bimestre">
            <Value>=Parameters!bimestre.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT COMPETENCIA_HABILIDADE ID_ITEM, COMPETENCIA_HABILIDADE
FROM TCE_COMPETENCIA_HABILIDADE_ITEM  M (NOLOCK)
JOIN TCE_COMPETENCIA_HABILIDADE_GRUPO G (NOLOCK) 
ON G.ID_COMPETENCIA_HABILIDADE_GRUPO = M.ID_COMPETENCIA_HABILIDADE_GRUPO
WHERE (G.CURSO= ISNULL(@CURSO,G.CURSO) OR  G.CURSO IS NULL) 
AND (G.SERIE= ISNULL(@serie,G.SERIE) OR  G.SERIE IS NULL) 
AND (G.SUBPERIODO= ISNULL(@bimestre,G.SUBPERIODO) OR  G.SUBPERIODO IS NULL) 
union
select 'NULO' ID_ITEM,' Selecione...' COMPETENCIA_HABILIDADE
union
select null ID_ITEM,' TODAS' COMPETENCIA_HABILIDADE
ORDER BY COMPETENCIA_HABILIDADE</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_ITEM">
          <DataField>ID_ITEM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMPETENCIA_HABILIDADE">
          <DataField>COMPETENCIA_HABILIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DISCIPLINA">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT	DISTINCT D.NOME_COMPL DISCIPLINA, D.NOME_COMPL DS_DISCIPLINA
FROM	TCE_COMPETENCIA_HABILIDADE_GRUPO G
JOIN	LY_DISCIPLINA D 
ON		G.DISCIPLINA = D.DISCIPLINA
WHERE	G.ANO = YEAR(GETDATE())
union
select ' NULO' DISCIPLINA,' Selecione...' DS_DISCIPLINA
union
select null DISCIPLINA,' TODAS' DS_DISCIPLINA
ORDER BY DISCIPLINA</CommandText>
      </Query>
      <Fields>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DS_DISCIPLINA">
          <DataField>DS_DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
