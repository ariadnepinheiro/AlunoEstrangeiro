  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, CENSO, UNIDADE, SEGMENTO, CURSO, SERIE MODULO, SUM(QTDE_ALUNO) QTDE_ALUNO, SUM(QTDE_ALUNOS_ATIVOS) QTDE_ALUNOS_ENT,
		SUM(APROVADOS) APROVADOS, SUM(REPROVADOS) REPROVADOS, SUM(ABANDONO) ABANDONO, 
		SUM(OUTROS) OUTROS, SUM(CONCLUINTE) CONCLUINTE
FROM (
		SELECT	REGIONAL, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
				TC.DESCRICAO SEGMENTO, C.NOME CURSO, T.SERIE, B.ALUNO, 1 QTDE_ALUNO, 
				CASE WHEN B.SITUACAO &lt;&gt; 'CANCELADO' THEN 1 ELSE 0 END QTDE_ALUNOS_ATIVOS,
				CASE WHEN S.SITUACAO_FINAL LIKE 'APROV%' THEN 1  ELSE 0 END APROVADOS,
				CASE WHEN S.SITUACAO_FINAL LIKE 'REP%' THEN 1 ELSE 0 END REPROVADOS, 
				CASE WHEN H.MOTIVO IN ('PROV_DES','ABANDONO') THEN 1 ELSE 0 END ABANDONO, 
				CASE WHEN H.MOTIVO NOT IN ('PROV_DES','ABANDONO','CONCLUSAO') AND H.MOTIVO IS NOT NULL THEN 1 ELSE 0 END OUTROS, 
				CASE WHEN H.MOTIVO IN ('CONCLUSAO') THEN 1 ELSE 0 END CONCLUINTE
		FROM	LY_UNIDADE_ENSINO UE (NOLOCK)
		JOIN	TCE_REGIONAL R (NOLOCK)
		ON		UE.ID_REGIONAL = R.ID_REGIONAL
		JOIN	LY_TURMA T (NOLOCK)
		ON		UE.UNIDADE_ENS = T.UNIDADE_RESPONSAVEL
		AND		T.ANO = @ANO
		JOIN	(
				SELECT	ANO, SEMESTRE, TURMA, ALUNO, MAX(SITUACAO_HIST) SITUACAO
				FROM	LY_HISTMATRICULA (NOLOCK)
				GROUP BY ANO, SEMESTRE, TURMA, ALUNO
				UNION	
				SELECT	ANO, SEMESTRE, TURMA, ALUNO, MAX(SIT_MATRICULA) SITUACAO
				FROM	LY_MATRICULA (NOLOCK)
				GROUP BY ANO, SEMESTRE, TURMA, ALUNO
				) B
		ON		T.ANO = B.ANO
		AND		T.SEMESTRE = B.SEMESTRE
		AND		T.TURMA = B.TURMA		
		LEFT	JOIN (
					SELECT	ANO, PERIODO, TURMA, ALUNO, MAX(SITUACAO_FINAL) SITUACAO_FINAL
					FROM	TCE_SITUACAO_FINAL_ALUNO  (NOLOCK)
					GROUP BY ANO, PERIODO, TURMA, ALUNO
					) S
		ON		S.ANO = B.ANO
		AND		S.PERIODO = B.SEMESTRE
		AND		S.TURMA = B.TURMA
		AND		S.ALUNO = B.ALUNO
		JOIN	LY_CURSO C (NOLOCK)
		ON		C.CURSO = T.CURSO
		JOIN	LY_TIPO_CURSO TC (NOLOCK)
		ON		TC.TIPO = C.TIPO
		LEFT	JOIN (
						SELECT	ALUNO, ANO_ENCERRAMENTO, MAX(MOTIVO) MOTIVO
						FROM	LY_H_CURSOS_CONCL (NOLOCK)
						WHERE	DT_REABERTURA IS NULL
						GROUP BY ALUNO, ANO_ENCERRAMENTO
						) H
		ON		H.ALUNO = B.ALUNO
		AND		H.ANO_ENCERRAMENTO = B.ANO
		WHERE	T.CURSO IN ('0091.29','0092.39')
		GROUP BY REGIONAL, UE.UNIDADE_ENS, UE.NOME_COMP, 
				TC.DESCRICAO, C.NOME, B.ALUNO, S.SITUACAO_FINAL, H.MOTIVO, B.SITUACAO, T.SERIE
) A 
GROUP BY REGIONAL, CENSO, UNIDADE, SEGMENTO, CURSO, SERIE
</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS_ENT">
          <DataField>QTDE_ALUNOS_ENT</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MODULO">
          <DataField>MODULO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="APROVADOS">
          <DataField>APROVADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REPROVADOS">
          <DataField>REPROVADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNO">
          <DataField>QTDE_ALUNO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ABANDONO">
          <DataField>ABANDONO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="OUTROS">
          <DataField>OUTROS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONCLUINTE">
          <DataField>CONCLUINTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
