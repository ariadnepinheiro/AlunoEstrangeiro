  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>86c52f8c-2e98-4034-adf0-72ff6971ce88</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@parametro_turma">
            <Value>=Parameters!parametro_turma.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT   DISTINCT ly_nucleo.descricao AS COORDENADORIA, M.NOME AS MUNICIPIO, LY_UNIDADE_ENSINO.UNIDADE_ENS AS CENSO, LY_UNIDADE_ENSINO.NOME_COMP AS ESCOLA, LY_ALUNO.ALUNO AS MATRICULA, LY_ALUNO.NOME_COMPL AS ALUNO, ly_matricula.TURMA                           
                  FROM     LY_ALUNO (NOLOCK)
		 INNER JOIN LY_UNIDADE_ENSINO (NOLOCK) ON LY_ALUNO.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS 
		JOIN LY_NUCLEO  WITH (NOLOCK) ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO
		JOIN HADES..TCE_MUNICIPIO M  WITH (NOLOCK) ON M.ID_MUNICIPIO = LY_UNIDADE_ENSINO.MUNICIPIO
                JOIN LY_MATRICULA WITH (NOLOCK) ON LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_MATRICULA.ANO = @ANO
                           AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                           AND NOT EXISTS (SELECT 1
                                           FROM   LY_FOTO_PESSOA WITH (NOLOCK)
                                           WHERE  LY_FOTO_PESSOA.PESSOA = LY_ALUNO.PESSOA)
						   AND LY_UNIDADE_ENSINO.MUNICIPIO=@MUNIC 
						   AND LY_UNIDADE_ENSINO.UNIDADE_ENS=@ESCOLA
						   AND LY_UNIDADE_ENSINO.NUCLEO=@NUCLEO
						   AND LY_MATRICULA.TURMA=ISNULL(@parametro_turma, LY_MATRICULA.TURMA)
AND NOT EXISTS (SELECT 1 FROM LY_H_CURSOS_CONCL H
				WHERE H.ALUNO = LY_ALUNO.ALUNO 
				AND H.DT_REABERTURA IS NULL
				)
order by ly_matricula.TURMA, LY_ALUNO.NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="coord">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT NUCLEO,SUBSTRING(DESCRICAO,1,35)DESCRICAO FROM LY_NUCLEO 
ORDER BY DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="munic">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select DISTINCT  mm.id_municipio codigo,mm.nome municipio from hades..tce_municipio mm
join ly_unidade_ensino s1 on s1.MUNICIPIO=mm.id_municipio
join LY_NUCLEO n1 on n1.NUCLEO=s1.NUCLEO
where s1.NUCLEO=@NUCLEO
ORDER BY MM.NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="municipio">
          <DataField>municipio</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select UNIDADE_ENS,substring(NOME_COMP,1,40) escola from ly_unidade_ensino
where 
	NUCLEO=@NUCLEO
and 	MUNICIPIO=@MUNIC
ORDER BY NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="escola">
          <DataField>escola</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="turma">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null as parametro_turma, ' Todas' as turma
union
SELECT DISTINCT 
	T1.TURMA as parametro_turma, T1.TURMA as turma
FROM 
LY_TURMA T1 (NOLOCK) 
WHERE T1.UNIDADE_RESPONSAVEL=@ESCOLA
AND ANO = @ANO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TURMA">
          <DataField>turma</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="parametro_turma">
          <DataField>parametro_turma</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
