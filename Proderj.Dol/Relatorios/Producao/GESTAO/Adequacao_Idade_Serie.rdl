        <CommandText>SELECT     D.CENSO, D.MF_1_ANO, D.ATE7_1_ANO, D.ATE8_1_ANO, D.ATE9_1_ANO, D.ATE10_1_ANO, D.ATE11_1_ANO, D.ATE12_1_ANO, D.ATE13_1_ANO, 
                      D.ATE14_1_ANO, D.ATE15_1_ANO, D.MAIS15_1_ANO, D.IDADE_SUP_SERIE_1_ANO, D.TX_DISTORCAO_1_ANO, D.MF_2_ANO, D.ATE7_2_ANO, 
                      D.ATE8_2_ANO, D.ATE9_2_ANO, D.ATE10_2_ANO, D.ATE11_2_ANO, D.ATE12_2_ANO, D.ATE13_2_ANO, D.ATE14_2_ANO, D.ATE15_2_ANO, 
                      D.MAIS15_2_ANO, D.IDADE_SUP_SERIE_2_ANO, D.TX_DISTORCAO_2_ANO, D.MF_3_ANO, D.ATE7_3_ANO, D.ATE8_3_ANO, D.ATE9_3_ANO, 
                      D.ATE10_3_ANO, D.ATE11_3_ANO, D.ATE12_3_ANO, D.ATE13_3_ANO, D.ATE14_3_ANO, D.ATE15_3_ANO, D.MAIS15_3_ANO, 
                      D.IDADE_SUP_SERIE_3_ANO, D.TX_DISTORCAO_3_ANO, D.MF_4_ANO, D.ATE7_4_ANO, D.ATE8_4_ANO, D.ATE9_4_ANO, D.ATE10_4_ANO, 
                      D.ATE11_4_ANO, D.ATE12_4_ANO, D.ATE13_4_ANO, D.ATE14_4_ANO, D.ATE15_4_ANO, D.MAIS15_4_ANO, D.IDADE_SUP_SERIE_4_ANO, 
                      D.TX_DISTORCAO_4_ANO, D.MF_5_ANO, D.ATE7_5_ANO, D.ATE8_5_ANO, D.ATE9_5_ANO, D.ATE10_5_ANO, D.ATE11_5_ANO, D.ATE12_5_ANO, 
                      D.ATE13_5_ANO, D.ATE14_5_ANO, D.ATE15_5_ANO, D.MAIS15_5_ANO, D.IDADE_SUP_SERIE_5_ANO, D.TX_DISTORCAO_5_ANO, D.MF_6_ANO, 
                      D.ATE7_6_ANO, D.ATE8_6_ANO, D.ATE9_6_ANO, D.ATE10_6_ANO, D.ATE11_6_ANO, D.ATE12_6_ANO, D.ATE13_6_ANO, D.ATE14_6_ANO, 
                      D.ATE15_6_ANO, D.MAIS15_6_ANO, D.IDADE_SUP_SERIE_6_ANO, D.TX_DISTORCAO_6_ANO, D.MF_7_ANO, D.ATE7_7_ANO, D.ATE8_7_ANO, 
                      D.ATE9_7_ANO, D.ATE10_7_ANO, D.ATE11_7_ANO, D.ATE12_7_ANO, D.ATE13_7_ANO, D.ATE14_7_ANO, D.ATE15_7_ANO, D.MAIS15_7_ANO, 
                      D.IDADE_SUP_SERIE_7_ANO, D.TX_DISTORCAO_7_ANO, D.MF_8_ANO, D.ATE7_8_ANO, D.ATE8_8_ANO, D.ATE9_8_ANO, D.ATE10_8_ANO, 
                      D.ATE11_8_ANO, D.ATE12_8_ANO, D.ATE13_8_ANO, D.ATE14_8_ANO, D.ATE15_8_ANO, D.MAIS15_8_ANO, D.IDADE_SUP_SERIE_8_ANO, 
                      D.TX_DISTORCAO_8_ANO, D.MF_9_ANO, D.ATE7_9_ANO, D.ATE8_9_ANO, D.ATE9_9_ANO, D.ATE10_9_ANO, D.ATE11_9_ANO, D.ATE12_9_ANO, 
                      D.ATE13_9_ANO, D.ATE14_9_ANO, D.ATE15_9_ANO, D.MAIS15_9_ANO, D.IDADE_SUP_SERIE_9_ANO, D.TX_DISTORCAO_9_ANO, UE.UNIDADE_ENS, 
                      UE.NOME_COMP, UE.NOME_ABREV, UE.ENDERECO, UE.END_NUM, UE.END_COMPL, UE.BAIRRO, UE.MUNICIPIO, UE.CEP, UE.CAIXA_POSTAL, 
                      UE.FONE, UE.FAX, UE.CGC, UE.E_MAIL, UE.TURMAPREF, UE.CCM, UE.MNEMONICO, UE.OUTRA_FACULDADE, UE.BANCO, UE.AGENCIA, 
                      UE.CONTA_BANCO, UE.TITULAR, UE.WEB_SITE, UE.INEP_FACULDADE, UE.INSCR_ESTADUAL, UE.MARCA, UE.GRUPO, UE.STAMP_ATUALIZACAO, 
                      UE.NUCLEO, UE.SETOR, UE.TIPO, UE.DEPENDENCIA_ADM, UE.CLASSIFICACAO, UE.EXTRACLASSE, NOME_COMP AS ESCOLA
FROM         DISTORCAO_IDADE_SERIE AS D INNER JOIN
                      LYCEUM.dbo.LY_UNIDADE_ENSINO AS UE ON UE.UNIDADE_ENS = D.CENSO
WHERE     (D.CENSO = @CENSO)</CommandText>
