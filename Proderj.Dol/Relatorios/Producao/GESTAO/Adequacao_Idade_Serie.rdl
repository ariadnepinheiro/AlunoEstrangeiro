        <CommandText>SELECT     TOP (200) COD_COORDENADORIA, COORDENADORIA, COD_MUNICIPIO, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, NIVEL, CURSO, SERIE, 
                      MATRICULA_FINAL, NAO_INFORMADO, [12131415], [16], [17], [18], [19202122], TOTAL_ALUNOS_SUPERIOR, TAXA_DISTORCAO, REPLACE (SERIE, 'ª Série', '') AS COD_SERIE
FROM         QTD_ALUNOS_SERIE_IDADE_2010_FINAL_EM
WHERE CENSO = @CENSO
order by serie</CommandText>
