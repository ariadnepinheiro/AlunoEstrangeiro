  <DataSources>
    <DataSource Name="DS_LYCEUM">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>70af6d3c-89b3-416e-a5e2-9f2e77395dfe</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DADOS_ESCOLARES">
      <Query>
        <DataSourceName>DS_LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@matricula">
            <Value>=Parameters!matricula.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	A.ALUNO, A.NOME_COMPL, P.DT_NASC, P.NOME_MAE, 
	C.NOME CURSO, A.SERIE, A.TURNO, 
	ISNULL((SELECT 	TOP 1 MOTIVO 
	FROM 	LY_H_CURSOS_CONCL H (NOLOCK)
	WHERE 	H.ALUNO = A.ALUNO 
	AND 	H.DT_REABERTURA IS NULL
	),'Ativo') ENCERRAMENTO, 
	(SELECT 	TOP 1 TURMA 
	FROM 	LY_MATRICULA M (NOLOCK) 
	WHERE 	M.ALUNO = A.ALUNO 
	AND 	M.ANO = YEAR(GETDATE())
	AND 	M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
	) TURMA_ATUAL	
FROM 	LY_ALUNO A (NOLOCK) 
JOIN 	LY_CURSO C (NOLOCK)
ON 	A.CURSO = C.CURSO 
JOIN 	LY_PESSOA P (NOLOCK) 
ON 	P.PESSOA = A.PESSOA 
WHERE 	ALUNO = @matricula</CommandText>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_NASC">
          <DataField>DT_NASC</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="NOME_MAE">
          <DataField>NOME_MAE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ENCERRAMENTO">
          <DataField>ENCERRAMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA_ATUAL">
          <DataField>TURMA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SOLICITACOES">
      <Query>
        <DataSourceName>DS_LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@matricula">
            <Value>=Parameters!matricula.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	R.NOMEARQUIVO LOTE, RA.DATA, 
	CASE TIPOMOVIMENTACAO WHEN '1001' THEN '1a. Via'
	WHEN '1002' THEN 'Alteração (escola, turno, segmento, série)'
	WHEN '1003' THEN 'Alteração de Cadastro (mãe, pai, endereço, telefone)'
	WHEN '3' THEN '2a. Via - Cancelamento por perda'
	WHEN '4' THEN '2a. Via - Cancelamento por roubo'
	WHEN '6' THEN '2a. Via - Alteracao de nome e/ou data de nascimento'
	WHEN '18' THEN '2a. Via - Cancelamento por cartão danificado'
	WHEN '19' THEN '2a. Via - Cancelamento por foto trocada'
	WHEN '49' THEN 'Cancelamento por bloqueio'
	WHEN '99' THEN 'Descancelar'
	WHEN '66' THEN 'Solicitação de 2a. via com substituição de matrícula' END TIPO_SOLICITACAO, 
	R.codigocenso CENSO, 
	UE.NOME_COMP ESCOLA, 
	CASE CONVERT(VARCHAR(50), RR.STATUS) WHEN '1' THEN 'Processamento OK' ELSE CONVERT(VARCHAR(50), RR.status) +'-'+RR.descricao END  PROC_RIOCARD
FROM 	RIOCARD_REMESSA R (NOLOCK)
LEFT JOIN TR_STATUS_ARQUIVO_REGISTRO RR (NOLOCK)
ON 		RR.NomeArquivo = R.nomearquivo
AND		RR.MATRICULA = R.matriculanova
LEFT JOIN LY_UNIDADE_ENSINO UE (NOLOCK)
ON		UE.UNIDADE_ENS = R.codigocenso
JOIN	RIOCARD_ARQUIVOREMESSA RA (nolock)
ON		RA.arquivo = R.nomearquivo
WHERE	R.matriculanova = @matricula
ORDER BY RA.DATA DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="LOTE">
          <DataField>LOTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="TIPO_SOLICITACAO">
          <DataField>TIPO_SOLICITACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROC_RIOCARD">
          <DataField>PROC_RIOCARD</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CARTAO">
      <Query>
        <DataSourceName>DS_LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@matricula">
            <Value>=Parameters!matricula.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	VIA_CARTEIRINHA, COD_BARRAS_CARTEIRINHA, SIT_CARTEIRINHA, DT_IMPRESSAO
FROM 	LY_CARTEIRINHA (nolock)
WHERE  	ALUNO = @matricula
ORDER BY DT_IMPRESSAO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="VIA_CARTEIRINHA">
          <DataField>VIA_CARTEIRINHA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="COD_BARRAS_CARTEIRINHA">
          <DataField>COD_BARRAS_CARTEIRINHA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SIT_CARTEIRINHA">
          <DataField>SIT_CARTEIRINHA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_IMPRESSAO">
          <DataField>DT_IMPRESSAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="GRATUIDADE">
      <Query>
        <DataSourceName>DS_LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@matricula">
            <Value>=Parameters!matricula.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT TOP 5 CONVERT(DATE, DATA_HORA) DATA, 
		SUBSTRING(CONVERT(VARCHAR(20), CONVERT(TIME, DATA_HORA)),1,5) HORA, 
		cod_barras_carteirinha
FROM	LY_INTEG_GRATUIDADE with(nolock)
WHERE	aluno = @matricula 
AND MSG_ID = '0'
GROUP BY DATA_HORA, cod_barras_carteirinha
ORDER BY data_hora DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cod_barras_carteirinha">
          <DataField>cod_barras_carteirinha</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="matricula">
      <DataType>String</DataType>
      <Prompt>Matrícula do aluno:</Prompt>
    </ReportParameter>
    <ReportParameter Name="usuario">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <Prompt>usuario</Prompt>
      <Hidden>true</Hidden>
    </ReportParameter>
