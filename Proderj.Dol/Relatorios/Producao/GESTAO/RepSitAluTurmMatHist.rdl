        </Field>
        <Field Name="TOTAL_ALUNO_ANTIGOS_COM_FOTO_SEM_CART">
          <DataField>TOTAL_ALUNO_ANTIGOS_COM_FOTO_SEM_CART</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
