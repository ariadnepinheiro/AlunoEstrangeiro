      <Fields>
        <Field Name="TOTAL_ALUNO_ANTIGOS_LOT">
          <DataField>TOTAL_ALUNO_ANTIGOS_LOT</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ENCERRADOS_ANTIGOS">
          <DataField>TOTAL_ENCERRADOS_ANTIGOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ALUNO_ANTIGOS_MAT">
          <DataField>TOTAL_ALUNO_ANTIGOS_MAT</DataField>
