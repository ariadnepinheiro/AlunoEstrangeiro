        </Field>
        <Field Name="TOTAL_ENCERRADOS_NOV">
          <DataField>TOTAL_ENCERRADOS_NOV</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ALUNO_NOV_MAT">
          <DataField>TOTAL_ALUNO_NOV_MAT</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ALUNO_NOVOS_S_FOTO">
          <DataField>TOTAL_ALUNO_NOVOS_S_FOTO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_AL_NOV_CONF_N_ENT">
          <DataField>TOTAL_AL_NOV_CONF_N_ENT</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ALUNO_NOVO_N_MAT_S_FT">
          <DataField>TOTAL_ALUNO_NOVO_N_MAT_S_FT</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UE_CENSO">
          <DataField>UE_CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_MUNICIPIO">
          <DataField>NOME_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_ESCOLA">
          <DataField>NOME_ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
		 SQL1.TOTAL_ALUNO_ANTIGOS_LOT --[TOTAL DE ALUNOS ANTIGOS LOTADOS]
		,SQL2.TOTAL_ENCERRADOS_ANTIGOS --[TOTAL DE ALUNOS ANTIGOS ENCERRADOS]
		,SQL3.TOTAL_ALUNO_ANTIGOS_MAT --[TOTAL DE ALUNOS ANTIGOS MATRICULADOS]
        ,SQL4.TOTAL_ALUNO_ANTIGOS_S_FOTO --[TOTAL DE ALUNOS ANTIGOS SEM FOTO]
		,SQL5.TOTAL_ALUNO_ANTIGOS_COM_FOTO_SEM_CART --[TOTAL DE ALUNOS ANTIGOS COM FOTO SEM CARTAO]        
		,SQL6.TOTAL_ALUNOS_ANT_P_ENTRUM --[TOTAL DE ALUNOS ANTIGOS PARA ENTURMACAO]
		,SQL7.TOTAL_AL_ANT_C_CART_SEM_ENT --[TOTAL DE ALUNOS ANTIGOS COM CARTAO SEM ENTURMACAO]        
		,SQL13.TOTAL_ALUNO_ANTIG_N_MAT_S_FT --[TOTAL DE ALUNOS ANTIGOS NAO MATRICULADOS SEM FOTO]
		,SQL8.TOTAL_ALUNO_NOV_LOT --[TOTAL DE ALUNOS NOVOS LOTADOS]
		,SQL9.TOTAL_ENCERRADOS_NOV --[TOTAL DE ALUNOS ANTIGOS ENCERRADOS]
		,SQL10.TOTAL_ALUNO_NOV_MAT --[TOTAL DE ALUNOS ANTIGOS MATRICULADOS]
		,SQL11.TOTAL_ALUNO_NOVOS_S_FOTO --[TOTAL DE ALUNOS NOVOS SEM FOTO]       
		,SQL12.TOTAL_AL_NOV_CONF_N_ENT --[TOTAL DE ALUNOS NOVOS PARA ENTURMACAO]		
		,SQL14.TOTAL_ALUNO_NOVO_N_MAT_S_FT --[TOTAL DE ALUNOS NOVOS NAO MATRICULADO SEM FOTO]
		,LY_UNIDADE_ENSINO.UNIDADE_ENS UE_CENSO
        ,LY_UNIDADE_ENSINO.SETOR UA
        ,LY_UNIDADE_ENSINO.MUNICIPIO
        ,MUNICIPIO.NOME NOME_MUNICIPIO
        ,LY_NUCLEO.NUCLEO 
        ,SUBSTRING(LY_NUCLEO.DESCRICAO,1,35)COORDENADORIA
        ,LY_UNIDADE_ENSINO.NOME_COMP NOME_ESCOLA
FROM   LY_UNIDADE_ENSINO
       JOIN LY_NUCLEO
         ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO
       JOIN MUNICIPIO
         ON MUNICIPIO.CODIGO = LY_UNIDADE_ENSINO.MUNICIPIO
       JOIN LY_UNIDADE_ENSINO_SITUACAO
         ON LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS = LY_UNIDADE_ENSINO.UNIDADE_ENS
            AND LY_UNIDADE_ENSINO_SITUACAO.SITUACAO = 'ESTADUAL'
/*=====================================================================
 == TOTAL ALUNOS ANTIGOS LOTADOS POR ESCOLA
=======================================================================*/

LEFT JOIN (SELECT   COUNT(LY_ALUNO.ALUNO)  TOTAL_ALUNO_ANTIGOS_LOT
                   ,LY_ALUNO.UNIDADE_ENSINO
          FROM     LY_ALUNO WITH (NOLOCK)
			WHERE LY_ALUNO.ALUNO NOT LIKE '2010%' 
          GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL1
 ON SQL1.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
 
/*=====================================================================
 == TOTAL ALUNOS ANTIGOS  ENCERRADOS
=======================================================================*/

       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_ENCERRADOS_ANTIGOS
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_H_CURSOS_CONCL
                             ON LY_H_CURSOS_CONCL.ALUNO = LY_ALUNO.ALUNO
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL2
                  ON SQL2.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS

 /*=====================================================================
 == TOTAL ALUNOS ANTIGOS  MATRICULADOS
=======================================================================*/

       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_ALUNO_ANTIGOS_MAT
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_MATRICULA WITH (NOLOCK)
                             ON LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_MATRICULA.ANO = 2010
                           AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                           AND LY_ALUNO.ALUNO NOT LIKE '2010%'
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL3
         ON SQL3.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS

/*=====================================================================
 == TOTAL DE ALUNOS ANTIGO SEM FOTO
=======================================================================*/         
       
       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_ALUNO_ANTIGOS_S_FOTO
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_MATRICULA WITH (NOLOCK)
                             ON LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_MATRICULA.ANO = 2010
                           AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                           AND LY_ALUNO.ALUNO NOT LIKE '2010%'
                           AND NOT EXISTS (SELECT 1
                                           FROM   LY_FOTO_PESSOA WITH (NOLOCK)
                                           WHERE  LY_FOTO_PESSOA.PESSOA = LY_ALUNO.PESSOA)
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL4
         ON SQL4.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
         
/*=====================================================================
 == TOTAL DE ALUNOS ANTIGOS COM FOTO SEM CARTAO
=======================================================================*/         

       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO) TOTAL_ALUNO_ANTIGOS_COM_FOTO_SEM_CART
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_MATRICULA WITH (NOLOCK)
                             ON LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_MATRICULA.ANO = 2010
                           AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                           AND LY_ALUNO.ALUNO NOT LIKE '2010%'
                           AND EXISTS (SELECT 1
                                       FROM   LY_FOTO_PESSOA WITH (NOLOCK)
                                       WHERE  LY_FOTO_PESSOA.PESSOA = LY_ALUNO.PESSOA)
                           AND NOT EXISTS (SELECT 1
                                           FROM   LY_CARTEIRINHA
                                           WHERE  LY_CARTEIRINHA.SIT_CARTEIRINHA = 'ATIVA'
                                                  AND LY_CARTEIRINHA.ALUNO = LY_ALUNO.ALUNO)
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL5
         ON SQL5.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS

         
/*=====================================================================
 == TOTAL DE ALUNOS ANTIGOS PARA ENTURMACAO
=======================================================================*/         
       
       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_ALUNOS_ANT_P_ENTRUM
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                  WHERE    NOT EXISTS (SELECT 1
                                       FROM   LY_MATRICULA WITH (NOLOCK)
                                       WHERE  LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                                              AND LY_MATRICULA.ANO = 2010
                                              AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO')
                           AND LY_ALUNO.ALUNO LIKE '2009%'
                           AND NOT EXISTS (SELECT 1
                                           FROM   LY_H_CURSOS_CONCL
                                           WHERE  LY_ALUNO.ALUNO = LY_H_CURSOS_CONCL.ALUNO)
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL6
         ON SQL6.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS

/*=====================================================================
 == TOTAL ALUNOS ANTIGOS COM CARTAO SEM ENTURMACAO
=======================================================================*/         
       
       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_AL_ANT_C_CART_SEM_ENT
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_CARTEIRINHA
                             ON LY_CARTEIRINHA.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_CARTEIRINHA.SIT_CARTEIRINHA = 'ATIVA'
                           AND NOT EXISTS (SELECT 1
                                           FROM   LY_MATRICULA
                                           WHERE  LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                                                  AND LY_MATRICULA.ANO = 2010
                                                  AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO')
                           AND LY_ALUNO.ALUNO LIKE '2009%'
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL7
         ON SQL7.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
         
/*=====================================================================
  == TOTAL ALUNOS NOVOS LOTADOS POR ESCOLA
=======================================================================*/         
         
/* TOTAL ALUNOS NOVOS  POR ESCOLA*/
       LEFT JOIN (SELECT   COUNT(LY_ALUNO.ALUNO)  TOTAL_ALUNO_NOV_LOT
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
					WHERE LY_ALUNO.ALUNO LIKE '2010%' 
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL8
         ON SQL8.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
         
/*=====================================================================
  == TOTAL ALUNOS NOVOS ENCERRADOS
=======================================================================*/         
       
              LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_ENCERRADOS_NOV
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_H_CURSOS_CONCL
                             ON LY_H_CURSOS_CONCL.ALUNO = LY_ALUNO.ALUNO
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL9
         ON SQL9.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS  
         
/*=====================================================================
  == TOTAL ALUNOS NOVOS MATRICULADOS EM 2010
=======================================================================*/                  
       
       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_ALUNO_NOV_MAT
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_MATRICULA WITH (NOLOCK)
                             ON LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_MATRICULA.ANO = 2010
                           AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                           AND LY_ALUNO.ALUNO LIKE '2010%'
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL10
         ON SQL10.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
         
/*=====================================================================
  == TOTAL ALUNOS NOVOS SEM FOTO POR ESCOLA
=======================================================================*/                  
       
       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_ALUNO_NOVOS_S_FOTO
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_MATRICULA WITH (NOLOCK)
                             ON LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_MATRICULA.ANO = 2010
                           AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                           AND LY_ALUNO.ALUNO LIKE '2010%'
                           AND NOT EXISTS (SELECT 1
                                           FROM   LY_FOTO_PESSOA WITH (NOLOCK)
                                           WHERE  LY_FOTO_PESSOA.PESSOA = LY_ALUNO.PESSOA)
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL11
         ON SQL11.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
         
/*=====================================================================
  == TOTAL ALUNOS NOVOS CONFIRMADOS SEM ENTURMACAO POR ESCOLA
=======================================================================*/                  
  
       LEFT JOIN (SELECT   COUNT(DISTINCT LY_ALUNO.ALUNO)  TOTAL_AL_NOV_CONF_N_ENT
                           ,LY_ALUNO.UNIDADE_ENSINO
                  FROM     LY_ALUNO WITH (NOLOCK)
                           JOIN LY_CONTRATO_ALUNO
                             ON LY_CONTRATO_ALUNO.ALUNO = LY_ALUNO.ALUNO
                  WHERE    LY_CONTRATO_ALUNO.CONTRATO_ACEITO = 'S'
                           AND NOT EXISTS (SELECT 1
                                           FROM   LY_MATRICULA
                                           WHERE  LY_ALUNO.ALUNO = LY_MATRICULA.ALUNO
                                                  AND LY_MATRICULA.ANO = 2010
                                                  AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO')
                           AND LY_ALUNO.ALUNO LIKE '2010%'
                  GROUP BY LY_ALUNO.UNIDADE_ENSINO) SQL12
         ON SQL12.UNIDADE_ENSINO = LY_UNIDADE_ENSINO.UNIDADE_ENS
         
/*=====================================================================
  == TOTAL DE ALUNO ANTIGO NAO MATRICULADO SEM FOTO 
=======================================================================*/                  
LEFT JOIN (  SELECT COUNT(DISTINCT LY_ALUNO.ALUNO)TOTAL_ALUNO_ANTIG_N_MAT_S_FT,LY_ALUNO.UNIDADE_ENSINO
      FROM LY_ALUNO
      WHERE
        NOT EXISTS (SELECT 1 FROM LY_MATRICULA WHERE LY_MATRICULA.SIT_MATRICULA&lt;&gt;'CANCELADO' AND LY_MATRICULA.ALUNO=LY_ALUNO.ALUNO)
      AND
        NOT EXISTS (SELECT 1 FROM LY_H_CURSOS_CONCL WHERE LY_H_CURSOS_CONCL.ALUNO=LY_ALUNO.ALUNO)
      AND
        LY_ALUNO.ALUNO NOT LIKE '2010%'
      AND
        NOT EXISTS (SELECT 1 FROM LY_FOTO_PESSOA WHERE LY_FOTO_PESSOA.PESSOA=LY_ALUNO.PESSOA)
      GROUP BY LY_ALUNO.UNIDADE_ENSINO )SQL13 ON SQL13.UNIDADE_ENSINO=LY_UNIDADE_ENSINO.UNIDADE_ENS 

			
/*=====================================================================
  == TOTAL DE ALUNO NOVOS NAO MATRICULADO SEM FOTO 
=======================================================================*/                  
LEFT JOIN (SELECT COUNT(DISTINCT LY_ALUNO.ALUNO)TOTAL_ALUNO_NOVO_N_MAT_S_FT,LY_ALUNO.UNIDADE_ENSINO
      FROM LY_ALUNO
      WHERE
        NOT EXISTS (SELECT 1 FROM LY_MATRICULA WHERE LY_MATRICULA.SIT_MATRICULA&lt;&gt;'CANCELADO' AND LY_MATRICULA.ALUNO=LY_ALUNO.ALUNO)
      AND
        NOT EXISTS (SELECT 1 FROM LY_H_CURSOS_CONCL WHERE LY_H_CURSOS_CONCL.ALUNO=LY_ALUNO.ALUNO)
      AND
        LY_ALUNO.ALUNO LIKE '2010%'
      AND
        NOT EXISTS (SELECT 1 FROM LY_FOTO_PESSOA WHERE LY_FOTO_PESSOA.PESSOA=LY_ALUNO.PESSOA)
      AND
        EXISTS (SELECT 1 FROM LY_CONTRATO_ALUNO WHERE LY_CONTRATO_ALUNO.ALUNO=LY_ALUNO.ALUNO AND LY_CONTRATO_ALUNO.CONTRATO_ACEITO='S')
      GROUP BY LY_ALUNO.UNIDADE_ENSINO )SQL14 ON SQL14.UNIDADE_ENSINO=LY_UNIDADE_ENSINO.UNIDADE_ENS</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
