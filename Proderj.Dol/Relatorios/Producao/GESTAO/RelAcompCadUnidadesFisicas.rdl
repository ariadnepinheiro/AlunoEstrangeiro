  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="UNIDADES_PEND">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT	DISTINCT R.REGIONAL, 
		M.NOME MUNICIPIO, 
		UE.UNIDADE_ENS CENSO, 
		UE.NOME_COMP UNIDADE, 
		CASE WHEN UF.UNIDADE_FIS IS NULL THEN 0 ELSE 1 END PROB, 
1 UNID
FROM	LY_UNIDADE_ENSINO UE (NOLOCK)
JOIN	TCE_REGIONAL R (NOLOCK)
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	HADES..TCE_MUNICIPIO M (NOLOCK)
ON		M.ID_MUNICIPIO = UE.MUNICIPIO
JOIN	LY_UNIDADES_ASSOCIADAS UA (NOLOCK)
ON		UA.UNIDADE_ENS = UE.UNIDADE_ENS
LEFT JOIN	LY_UNIDADE_FISICA UF (NOLOCK)
ON		UF.UNIDADE_FIS = UA.UNIDADE_FIS
AND	 (UF.NOME_COMP IS NULL
OR		UF.FORMA_OCUPACAO IS NULL
OR		UF.LOCAL_FUNCIONAMENTO IS NULL
OR		UF.CEP IS NULL
OR		UF.ENDERECO IS NULL
OR		UF.MUNICIPIO IS NULL
OR		UF.BAIRRO IS NULL
OR		UF.END_NUM IS NULL
OR		NOT EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_FISICA_CONCESSIONARIA UC (NOLOCK)
					WHERE	UC.UNIDADE_FIS = UF.UNIDADE_FIS
					AND		UC.EE_TIPO_ABASTECIMENTO IS NULL
					)
OR		NOT EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_FISICA_CONCESSIONARIA UC (NOLOCK)
					WHERE	UC.UNIDADE_FIS = UF.UNIDADE_FIS
					AND		UC.AG_OUTROS_ABASTECIMENTOS IS NULL
					)
OR		NOT EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_FISICA_CONCESSIONARIA UC (NOLOCK)
					WHERE	UC.UNIDADE_FIS = UF.UNIDADE_FIS
					AND		UC.EL_DESTINACAO_LIXO IS NULL
					)
OR		NOT EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_FISICA_CONCESSIONARIA UC (NOLOCK)
					WHERE	UC.UNIDADE_FIS = UF.UNIDADE_FIS
					AND		UC.EL_ESGOTO_SANITARIO IS NULL
					)
) 
WHERE		EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																				(
																				SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																				FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
																				)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROB">
          <DataField>PROB</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UNID">
          <DataField>UNID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
