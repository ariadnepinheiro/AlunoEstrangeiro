  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=Metas</ConnectString>
        <Prompt>Specify a user name and password for data source DataSource1:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>41fba76f-4c89-4ddb-b510-4274e134c9de</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CENSO">
            <Value>=Parameters!CENSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select A.*, NOME_COMP AS ESCOLA
 from LOTACAO_COMPLETA_PROFESSORES A
        INNER JOIN LYCEUM.DBO.LY_UNIDADE_ENSINO UE ON A.CENSO = UE.UNIDADE_ENS
where CENSO=@CENSO
AND ANO=YEAR(GETDATE()) - 1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROFESSORES_NECESSARIOS">
          <DataField>PROFESSORES_NECESSARIOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROFESSORES_ALOCADOS">
          <DataField>PROFESSORES_ALOCADOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
