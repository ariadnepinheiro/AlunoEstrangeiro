  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CENSO">
            <Value>=Parameters!CENSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  CENSO,ESCOLA,NECESSIDADE_PROF_QTDE
,round(AULAS_COM_PROF_QTDE,2) AS AULAS_COM_PROF_QTDE
--CAST(round(NECESSIDADE_PROF_QTDE,0) AS int  ) AS 
--, CAST(round(AULAS_COM_PROF_QTDE,0) AS INT) AS 
FROM NEC_PROF_FEV2010
where censo = @CENSO
AND ANO=YEAR(GETDATE())</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NECESSIDADE_PROF_QTDE">
          <DataField>NECESSIDADE_PROF_QTDE</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="AULAS_COM_PROF_QTDE">
          <DataField>AULAS_COM_PROF_QTDE</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
