  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Coordenadoria">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null nucleo,' TODOS' descricao
order by descricao</CommandText>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' nome
union
select null codigo,' TODOS' nome
order by nome</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
union
select null unidade_ens,' TODOS' nome_comp
order by nome_comp  
</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	N.DESCRICAO COORDENADORIA, MM.NOME MUNICIPIO, 
		UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, 
		SUM(T.QTDE_ALUNOS) ALUNOS_TURMA, SUM(t.QTDE_SAV) ALUNOS_SA
FROM	LY_UNIDADE_ENSINO UE (NOLOCK)
JOIN	LY_NUCLEO N (NOLOCK)
ON		N.NUCLEO = UE.NUCLEO
JOIN	MUNICIPIO MM (NOLOCK)
ON		MM.CODIGO = UE.MUNICIPIO
JOIN	APOLLO..REL_TURMAS_ALUNOS T (NOLOCK)
ON		T.UNIDADE_ENS = UE.UNIDADE_ENS
WHERE	T.ANO = @ano
AND (N.nucleo = ISNULL(@coord, N.nucleo) OR N.nucleo IS NULL)       
AND (MM.CODIGO = ISNULL(@municipio,  MM.CODIGO) OR   MM.CODIGO IS NULL)       
AND (UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
GROUP BY N.DESCRICAO, MM.NOME, UE.UNIDADE_ENS, UE.NOME_COMP
</CommandText>
      </Query>
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNOS_TURMA">
          <DataField>ALUNOS_TURMA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALUNOS_SA">
          <DataField>ALUNOS_SA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Ano">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO 
FROM 	LY_PERIODO_LETIVO
WHERE 	ANO &lt;= YEAR(GETDATE())
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Data_Hora_Atualizacao">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 4</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
