    <DataSet Name="DtBiologia">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CENSO">
            <Value>=Parameters!CENSO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>  SELECT  T.*
FROM    CURRICULO_COMPETENCIAS_HABILIDADES T
WHERE   ANO = YEAR(GETDATE()) - 1
AND CENSO=@CENSO
AND DISCIPLINA='BIOLOGIA'</CommandText>
      </Query>
