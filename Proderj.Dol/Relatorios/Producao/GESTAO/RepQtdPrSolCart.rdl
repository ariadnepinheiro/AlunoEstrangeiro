  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MES">
          <DataField>MES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SOLICITACAO">
          <DataField>SOLICITACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SOLICITACOES">
          <DataField>SOLICITACOES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT N.DESCRICAO COORDENADORIA, MM.NOME MUNICIPIO,

             U.SETOR UA, U.UNIDADE_ENS CENSO, U.NOME_COMP, YEAR(S.DATA) ANO, MONTH(S.DATA) MES,

             CASE SI.SERVICO WHEN '1VIACARTAO' THEN 'PRIMEIRA VIA' ELSE 'SEGUNDA VIA' END SOLICITACAO, COUNT(S.SOLICITACAO) SOLICITACOES

FROM   LY_SOLICITACAO_SERV S

JOIN   LY_ITENS_SOLICIT_SERV SI

ON           S.SOLICITACAO = SI.SOLICITACAO

JOIN   LY_ALUNO A

ON           A.ALUNO = S.ALUNO

JOIN   LY_UNIDADE_ENSINO U

ON           A.UNIDADE_ENSINO = U.UNIDADE_ENS

JOIN   LY_NUCLEO N

ON           U.NUCLEO = N.NUCLEO

JOIN   MUNICIPIO MM

ON           MM.CODIGO = U.MUNICIPIO

WHERE  EXISTS (

                           SELECT 1

                           FROM   LY_USUARIO_UNIDADE_FIS UF

                           WHERE   U.UNIDADE_ENS = UF.UNIDADE_FIS

--                         AND          UF.USUARIO = @usuario

                           )

AND        (N.NUCLEO = ISNULL(@nucleo, N.NUCLEO) OR N.NUCLEO IS NULL )

AND        (U.MUNICIPIO= isnull (@municipio,U.MUNICIPIO)or U.MUNICIPIO is null)

AND        (U.UNIDADE_ENS= isnull(@escola,U.UNIDADE_ENS) or U.UNIDADE_ENS is null)

AND        SI.SERVICO in (@SERVICO)

AND        YEAR(s.data) IN (@ANO)

AND        MONTH(s.data) IN  (@MES)

GROUP BY     N.DESCRICAO, MM.NOME,

                    U.SETOR, U.UNIDADE_ENS, U.NOME_COMP, YEAR(S.DATA), MONTH(S.DATA), SI.SERVICO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SERVICO">
            <Value>=Parameters!SERVICO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MES">
            <Value>=Parameters!MES.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Coordenadoria">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select 'NULO' nucleo,' Selecione...' descricao from ly_nucleo l1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
union
select  l1.NUCLEO,substring(l1.descricao,1,35)descricao from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Municipio">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
where 
	(n1.NUCLEO = ISNULL(@nucleo,n1.NUCLEO)or n1.NUCLEO is null)
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="DataSet2">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.NUCLEO = ISNULL(@nucleo,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP </CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
