  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@matricula">
            <Value>=Parameters!matricula.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT VW_INTEG_LANC_NOTAS_DIR.*
FROM   VW_INTEG_LANC_NOTAS_DIR
       JOIN LY_UNIDADE_ENSINO
         ON LY_UNIDADE_ENSINO.UNIDADE_ENS = VW_INTEG_LANC_NOTAS_DIR.CENSO
WHERE  ( LY_UNIDADE_ENSINO.UNIDADE_ENS = @escola)
       and(VW_INTEG_LANC_NOTAS_DIR.matricula=@matricula)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
