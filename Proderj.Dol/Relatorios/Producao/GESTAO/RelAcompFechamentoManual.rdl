  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@regional">
            <Value>=Parameters!regional.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, COUNT(TURMA) QTDE_TURMAS_FEC, SUM(ALUNO) QTDE_ALUNOS_SEM_FEC, SUM(SITUACAO) TURMAS_PENDENTES
FROM (	
		SELECT	DISTINCT R.REGIONAL, MM.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
				T.ANO, T.SEMESTRE, T.TURMA, ISNULL(M.ALUNO,0) ALUNO, CASE WHEN T.SIT_TURMA = 'ABERTA' THEN 1 ELSE 0 END SITUACAO
		FROM	LY_UNIDADE_ENSINO UE (NOLOCK)
		JOIN	TCE_REGIONAL R (NOLOCK)
		ON		UE.ID_REGIONAL = R.ID_REGIONAL
		JOIN	LY_TURMA T (NOLOCK)
		ON		T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS
		JOIN	MUNICIPIO MM (NOLOCK) 
		ON		MM.CODIGO = UE.MUNICIPIO
		LEFT JOIN	(
					SELECT	ANO, SEMESTRE, TURMA, COUNT(DISTINCT ALUNO) ALUNO
					FROM	LY_MATRICULA (NOLOCK)
					WHERE	ANO = @ANO
					AND		SIT_MATRICULA &lt;&gt; 'CANCELADO'
					GROUP BY ANO, SEMESTRE, TURMA
					) M 
		ON		M.ANO = T.ANO
		AND		M.SEMESTRE = T.SEMESTRE
		AND		M.TURMA = T.TURMA
		WHERE	T.SIT_TURMA &lt;&gt; 'DESATIVADA'
		AND		T.ANO = @ANO
		AND		EXISTS (
						SELECT	1
						FROM	LY_GRADE_SERIE GS
						WHERE	GS.ANO = T.ANO
						AND		GS.SEMESTRE = T.SEMESTRE
						AND		GS.GRADE = T.TURMA
						AND		GS.FECHAMENTO_MANUAL = 'S'
						)
		AND		T.TURMA NOT LIKE 'ER%'
		AND		T.TURMA NOT LIKE 'LE%'
		AND		(R.ID_REGIONAL = ISNULL(@regional, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)           
		) A
GROUP BY REGIONAL, MUNICIPIO, CENSO, UNIDADE
</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_TURMAS_FEC">
          <DataField>QTDE_TURMAS_FEC</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS_SEM_FEC">
          <DataField>QTDE_ALUNOS_SEM_FEC</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TURMAS_PENDENTES">
          <DataField>TURMAS_PENDENTES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO_LETIVO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL ID_REGIONAL, ' TODAS' REGIONAL
UNION
SELECT DISTINCT R.ID_REGIONAL, R.REGIONAL 
FROM TCE_REGIONAL R (nolock)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.ID_REGIONAL = R.ID_REGIONAL
WHERE 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = @usuario
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY REGIONAL</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
