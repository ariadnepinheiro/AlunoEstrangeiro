        </Field>
        <Field Name="CEP">
          <DataField>CEP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ENDERECO">
          <DataField>ENDERECO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BAIRRO">
          <DataField>BAIRRO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE">
          <DataField>UE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NIVEL">
          <DataField>NIVEL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT  u.MATRICULA,
        u.NOME,
        a.NOME_COMPL AS ALUNO,
        a.ALUNO AS MAT_ALUNO,
        p.NOME_MAE,
        CONVERT (VARCHAR (20), p.DT_NASC, 103) AS NASCIMENTO,
        p.CEP,
        p.ENDERECO,
        p.BAIRRO,
        mu.NOME AS MUNICIPIO,
        ue.NOME_COMP AS UE,
        t.TURMA,
         case 
    when t.TURNO = 'M' then 'MANHÃ'
    when t.TURNO = 'T' then 'TARDE'
    when t.TURNO = 'N' then 'NOITE'
    when t.TURNO = 'I' then 'INTEGRAL'
    when t.TURNO = 'A' then 'AMPLIADO'
   END AS TURNO,
        tc.DESCRICAO AS NIVEL,
        mc.DESCRICAO AS MODALIDADE
FROM    dbo.LY_ALUNO a WITH (NOLOCK)
        INNER JOIN dbo.LY_MATRICULA m WITH (NOLOCK)
        ON a.ALUNO = m.ALUNO
        INNER JOIN dbo.LY_TURMA t WITH (NOLOCK)
        ON m.DISCIPLINA = t.DISCIPLINA
           AND m.TURMA = t.TURMA
           AND m.ANO = t.ANO
           AND m.SEMESTRE = t.SEMESTRE
        INNER JOIN dbo.LY_UNIDADE_ENSINO ue WITH (NOLOCK)
        ON a.UNIDADE_ENSINO = ue.UNIDADE_ENS
        INNER JOIN LY_DISCIPLINA D WITH (NOLOCK)
        ON D.DISCIPLINA = t.DISCIPLINA
        INNER JOIN LY_SERIE s WITH (NOLOCK)
        ON s.CURSO = t.CURSO
           AND s.TURNO = t.TURNO
           AND s.CURRICULO = t.CURRICULO
           AND s.SERIE = t.SERIE
        INNER JOIN LY_CURSO c WITH (NOLOCK)
        ON c.CURSO = s.CURSO
        INNER JOIN LY_TIPO_CURSO tc WITH (NOLOCK)
        ON tc.TIPO = c.TIPO
        INNER JOIN LY_MODALIDADE_CURSO mc WITH (NOLOCK)
        ON mc.MODALIDADE = c.MODALIDADE
        INNER JOIN LY_USUARIO_UNIDADE_FIS uf WITH (NOLOCK)
        ON uf.UNIDADE_FIS = a.UNIDADE_ENSINO
        INNER JOIN HADES.dbo.HD_USUARIO u WITH (NOLOCK)
        ON u.USUARIO = uf.USUARIO
        INNER JOIN dbo.LY_PESSOA p WITH (NOLOCK)
        ON a.PESSOA = p.PESSOA
        INNER JOIN dbo.MUNICIPIO mu WITH (NOLOCK)
        ON p.END_MUNICIPIO = mu.CODIGO
WHERE   uf.USUARIO = @usuario
        AND m.SIT_MATRICULA = 'Matriculado'
       AND (M.ALUNO = @MAT_ALUNO) AND (M.ANO = YEAR(GETDATE())) 
         </CommandText>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MAT_ALUNO">
            <Value>=Parameters!MAT_ALUNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
