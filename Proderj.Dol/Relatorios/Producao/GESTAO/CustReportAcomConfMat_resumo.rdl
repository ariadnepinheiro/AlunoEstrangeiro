  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>846a0706-a34d-422f-af64-8b66b975e2df</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT N.REGIONAL, UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, 
	MC.DESCRICAO MODALIDADE, 
	C.NOME CURSO, V.SERIE, V.TURNO, V.VAGAS,
	V.ALOCADOS, 
	V.CONFIRMADOS, 
	V.NAO_CONFIRMADOS,
	V.NAO_COMPARECERAM
FROM 	APOLLO..SISMAT_VAGAS V (NOLOCK)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 		V.ESCOLA = UE.UNIDADE_ENS
JOIN 	LY_CURSO C (NOLOCK)
ON 		C.CURSO = V.MODALIDADE
JOIN 	LY_MODALIDADE_CURSO MC (NOLOCK)
ON 		MC.MODALIDADE = C.MODALIDADE
JOIN	TCE_REGIONAL N (NOLOCK)
ON		N.ID_REGIONAL = UE.ID_REGIONAL
WHERE     (N.ID_REGIONAL = ISNULL(@COORD, N.ID_REGIONAL) OR
N.ID_REGIONAL IS NULL) AND (UE.MUNICIPIO = ISNULL(@MUNIC, UE.MUNICIPIO) OR
UE.MUNICIPIO IS NULL) AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) OR
UE.UNIDADE_ENS IS NULL)
ORDER BY N.REGIONAL, UE.NOME_COMP,
		MC.DESCRICAO,C.NOME, V.TURNO, V.SERIE</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VAGAS">
          <DataField>VAGAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALOCADOS">
          <DataField>ALOCADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONFIRMADOS">
          <DataField>CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_CONFIRMADOS">
          <DataField>NAO_CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_COMPARECERAM">
          <DataField>NAO_COMPARECERAM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null nucleo,' TODAS' descricao 
union
select 0 nucleo,' Selecione...' descricao 
union
select  l1.ID_REGIONAL,SUBSTRING(l1.REGIONAL,1,35) from TCE_REGIONAL L1
join LY_UNIDADE_ENSINO l2 on L1.ID_REGIONAL=l2.ID_REGIONAL
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS UF 
ON UF.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE UF.USUARIO = @usuario
order by descricao</CommandText>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
where 
	(n1.NUCLEO = ISNULL(@COORD,n1.NUCLEO)or n1.NUCLEO is null)
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS UF 
ON UF.UNIDADE_FIS = ue.UNIDADE_ENS
WHERE UF.USUARIO = @usuario
AND (ue.ID_REGIONAL = ISNULL(@COORD,ue.ID_REGIONAL) or ue.ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP </CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
