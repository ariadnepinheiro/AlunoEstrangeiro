  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=Metas</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>17e6723b-0329-4415-b021-b240dd09fd2f</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CENSO">
            <Value>=Parameters!CENSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  A.*
,ROUND(CAST(REPLACE(frequencia,',','.') AS FLOAT), 2) as FREQUENCIA_FINAL

, NOME_COMP AS ESCOLA
  FROM [Metas].[dbo].[FREQUENCIA_ALUNOS] A
      INNER JOIN LYCEUM.DBO.LY_UNIDADE_ENSINO UE ON A.CENSO = UE.UNIDADE_ENS
WHERE CENSO=@CENSO
AND ANO=YEAR(GETDATE()) - 1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AULAS_DADAS">
          <DataField>AULAS_DADAS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FALTAS">
          <DataField>FALTAS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FREQUENCIA">
          <DataField>FREQUENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FREQUENCIA_FINAL">
          <DataField>FREQUENCIA_FINAL</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
