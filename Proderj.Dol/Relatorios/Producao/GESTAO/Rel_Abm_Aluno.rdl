  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>5c8142ab-9107-4312-bc29-09672ecd1c75</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@p_coordenadoria">
            <Value>=Parameters!p_coordenadoria.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_unidade">
            <Value>=Parameters!p_unidade.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_dt_ini">
            <Value>=Parameters!p_dt_ini.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_dt_fim">
            <Value>=Parameters!p_dt_fim.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select se.ALUNO, sum(FALTAS)faltas, sum(AULAS_DADAS) AULAS_DADAS, NOME_COMPL
from SE_DIAS_FALTA se (nolock), LY_ALUNO a (nolock), LY_UNIDADE_ENSINO u (nolock),SE_DIAS_PERIODO pp
where se.ALUNO = a.ALUNO 
and
a.UNIDADE_ENSINO = u.UNIDADE_ENS 
and pp.ID_DIAS_PERIODO=se.ID_DIAS_PERIODO
 AND (@p_coordenadoria IS NULL OR u.NUCLEO = @p_coordenadoria)
  and (@P_MUNICIPIO IS NULL OR u.municipio = @P_MUNICIPIO)
  and (@p_unidade IS NULL OR u.unidade_ens = @p_unidade)
    and  convert(date,pp.DT_AULA)&gt;=@p_dt_ini 
  and  convert(date,pp.DT_AULA)&lt;=@p_dt_fim
  group by se.ALUNO, NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="faltas">
          <DataField>faltas</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="AULAS_DADAS">
          <DataField>AULAS_DADAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_coordenadoria">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null nucleo,' TODAS'descricao 
union
select 'NULO' nucleo,' Selecione...'descricao
union
select distinct  l1.NUCLEO,SUBSTRING(l1.descricao,1,35)descricao from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_municipio">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@p_coordenadoria">
            <Value>=Parameters!p_coordenadoria.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@p_coordenadoria,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@p_coordenadoria">
            <Value>=Parameters!p_coordenadoria.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_municipio">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@p_coordenadoria,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@p_municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_ab_r1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@p_coordenadoria">
            <Value>=Parameters!p_coordenadoria.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_unidade">
            <Value>=Parameters!p_unidade.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select u.UNIDADE_ENS, u.NOME_COMP,(SUM(se.FALTAS)*100/sum(se.AULAS_DADAS))tol
from SE_DIAS_FALTA se (nolock), LY_ALUNO a (nolock), LY_UNIDADE_ENSINO u (nolock),SE_DIAS_PERIODO pp 
where se.ALUNO = a.ALUNO 
and 
	se.ID_DIAS_PERIODO=pp.ID_DIAS_PERIODO
and 
a.UNIDADE_ENSINO = u.UNIDADE_ENS 
 AND (@p_coordenadoria IS NULL OR u.NUCLEO = @p_coordenadoria)
  and (@P_MUNICIPIO IS NULL OR u.municipio = @P_MUNICIPIO)
  and (@p_unidade IS NULL OR u.unidade_ens = @p_unidade)
  group by u.UNIDADE_ENS, u.NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="tol">
          <DataField>tol</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_ab_r2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@p_coordenadoria">
            <Value>=Parameters!p_coordenadoria.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_unidade">
            <Value>=Parameters!p_unidade.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_dt_ini">
            <Value>=Parameters!p_dt_ini.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_dt_fim">
            <Value>=Parameters!p_dt_fim.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select  distinct TURMA, FALTAS, AULAS_DADAS,  a.CURSO, a.SERIE , TURNO  
from SE_DIAS_FALTA se (nolock), LY_ALUNO a (nolock), LY_UNIDADE_ENSINO u (nolock),SE_DIAS_PERIODO ss
where se.ALUNO = a.ALUNO 
and se.ID_DIAS_PERIODO=ss.ID_DIAS_PERIODO
and 
a.UNIDADE_ENSINO = u.UNIDADE_ENS 
 AND (@p_coordenadoria IS NULL OR u.NUCLEO = @p_coordenadoria)
  and (@P_MUNICIPIO IS NULL OR u.municipio = @P_MUNICIPIO)
  and (@p_unidade IS NULL OR u.unidade_ens = @p_unidade)
  and  ss.DT_AULA&gt;=@p_dt_ini 
  and  ss.DT_AULA&lt;=@p_dt_fim</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FALTAS">
          <DataField>FALTAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="AULAS_DADAS">
          <DataField>AULAS_DADAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
