  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=Metas</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>736270c3-2a5b-44f5-99a4-b934b74fd986</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CENSO">
            <Value>=Parameters!CENSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT A.*,RTRIM(SEM_FECHAMENTO) as semFechamento, NOME_COMP AS ESCOLA
  FROM [Metas].[dbo].[APROVADOS_3ANO_EF] A
  INNER JOIN [LYCEUM].dbo.LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.CENSO
  WHERE A.CENSO = @CENSO
AND A.ANO=YEAR(GETDATE()) -1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNO">
          <DataField>QTDE_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_APROVADOS">
          <DataField>QTDE_APROVADOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEM_FECHAMENTO">
          <DataField>SEM_FECHAMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="semFechamento">
          <DataField>semFechamento</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
