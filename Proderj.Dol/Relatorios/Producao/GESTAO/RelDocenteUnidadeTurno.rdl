<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.50.12.29;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>86c52f8c-2e98-4034-adf0-72ff6971ce88</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="desc_turno">
          <DataField>desc_turno</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>Select distinct  n.DESCRICAO , ue.SETOR, ue.UNIDADE_ENS, ue.NOME_COMP, t.descricao as desc_turno, 
d.MATRICULA, d.NOME_COMPL, d.CPF

from LY_DOCENTE d
	inner join LY_AULA_DOCENTE au
		on au.NUM_FUNC = d.NUM_FUNC
	inner join LY_UNIDADE_ENSINO ue
		on au.FACULDADE = ue.UNIDADE_ENS
	inner join LY_NUCLEO n
		on n.NUCLEO = ue.NUCLEO
	inner join Ly_turno t
		on t.turno = au.turno
Where au.FACULDADE = @ESCOLA
And au.turno = isnull(@turno, au.turno)
and MATRICULA not in ('00000000', '99999999', '66666666' )
Order by n.DESCRICAO , ue.SETOR, ue.UNIDADE_ENS, ue.NOME_COMP, t.descricao,d.NOME_COMPL</CommandText>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@turno">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="coord">
      <Fields>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT NUCLEO,SUBSTRING(DESCRICAO,1,35)DESCRICAO FROM LY_NUCLEO 
ORDER BY DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="munic">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="municipio">
          <DataField>municipio</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>

select DISTINCT  mm.codigo,mm.nome as municipio 
from municipio mm
	join ly_unidade_ensino s1 
		on s1.MUNICIPIO = mm.CODIGO
	join LY_NUCLEO n1 
		on n1.NUCLEO=s1.NUCLEO
where s1.NUCLEO= @NUCLEO
ORDER BY MM.NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="escola">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="escola">
          <DataField>escola</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select UNIDADE_ENS,substring(NOME_COMP,1,40) escola from ly_unidade_ensino
where 
	NUCLEO=@NUCLEO
and 	MUNICIPIO=@MUNIC
ORDER BY NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ano">
      <Fields>
        <Field Name="ano">
          <DataField>ano</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct ano from ly_turma</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Turno">
      <Fields>
        <Field Name="cod_turno">
          <DataField>cod_turno</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="desc_turno">
          <DataField>desc_turno</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null cod_turno,' TODOS' desc_turno
union
select 'NULO' cod_turno,' Selecione...'  desc_turno
union
Select Mnemonico cod_turno, Descricao  desc_turno
from Ly_turno
Order by desc_turno</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
