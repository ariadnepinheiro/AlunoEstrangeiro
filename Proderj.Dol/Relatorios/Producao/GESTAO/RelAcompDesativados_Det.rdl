  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Coordenadoria">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' descricao 
union
select null codigo,' TODOS' nome  
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
order by NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DESATIVADOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT N.DESCRICAO COORDENADORIA, 
		M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, 
		MC.DESCRICAO MODALIDADE, TC.DESCRICAO SEGMENTO, C.NOME CURSO, 
		A.SERIE, A.ALUNO, A.NOME_COMPL NOME_ALUNO, 
		H.DT_ENCERRAMENTO DATA_ENCERRAMENTO_ORIGINAL, 
		CASE WHEN QTDE &gt; 1 THEN 'S' ELSE 'N' END HOUVE_REATIVACAO_QUEDA, 
		CASE WHEN A.SIT_ALUNO = 'ATIVO' THEN 'ATIVO' ELSE 
		CASE WHEN HA.MOTIVO = 'PROV_DES' AND DATEDIFF(DAY,HA.DT_ENCERRAMENTO, GETDATE()) &lt;= 7  
		AND		HA.MOTIVOREABERTURA = 'Ajuste de Lançamentos Anteriores' THEN 'Ajuste de lançamentos anteriores pendente'
		WHEN    HA.MOTIVO = 'PROV_DES' AND DATEDIFF(DAY,HA.DT_ENCERRAMENTO, GETDATE()) &gt; 7  
		AND		HA.MOTIVOREABERTURA = 'Ajuste de Lançamentos Anteriores' THEN 'Ajuste de lançamentos anteriores'
		WHEN    HA.MOTIVO = 'PROV_DES' 
		AND		HA.MOTIVOREABERTURA = 'Reabertura de matrícula' THEN 'Reabertura de matrícula'
		ELSE	HA.DESCRICAO END END SITUACAO_ATUAL					
FROM	LY_UNIDADE_ENSINO UE (NOLOCK)
JOIN	LY_NUCLEO N (NOLOCK)
ON		N.NUCLEO = UE.NUCLEO
JOIN	MUNICIPIO M (NOLOCK)
ON		M.CODIGO = UE.MUNICIPIO
JOIN	LY_ALUNO A (NOLOCK) 
ON		A.UNIDADE_ENSINO = UE.UNIDADE_ENS
JOIN	(
		SELECT	ALUNO, MOTIVO,  MIN(CONVERT(DATE,DT_ENCERRAMENTO)) DT_ENCERRAMENTO, 
		COUNT(DISTINCT ALUNO+CONVERT(VARCHAR(20), DT_ENCERRAMENTO)) QTDE
		FROM	LY_H_CURSOS_CONCL (NOLOCK)
		WHERE	MOTIVO = 'PROV_DES'
		AND	YEAR(DT_ENCERRAMENTO) = @ano
		GROUP BY ALUNO, MOTIVO
		) H
ON		A.ALUNO = H.ALUNO
LEFT	JOIN (
		SELECT	DISTINCT ALUNO, MOTIVO, CONVERT(DATE, DT_ENCERRAMENTO) DT_ENCERRAMENTO, MOTIVOREABERTURA, MM.DESCRICAO
		FROM	LY_H_CURSOS_CONCL H2 (NOLOCK)
		JOIN	LY_MOTIVOSAIDA MM (NOLOCK)
		ON		MM.MOTIVOSAIDA = H2.MOTIVO
		WHERE	H2.ALUNO + CONVERT(VARCHAR(20), (H2.DT_ENCERRAMENTO)) IN (
														SELECT	ALUNO + CONVERT(VARCHAR(20), MAX(DT_ENCERRAMENTO))
														FROM	LY_H_CURSOS_CONCL HJ (NOLOCK)
														GROUP BY ALUNO
														)
		) HA
ON		HA.ALUNO = A.ALUNO
JOIN	LY_CURSO C (NOLOCK)
ON		C.CURSO = A.CURSO
JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
ON		MC.MODALIDADE = C.MODALIDADE
JOIN	LY_TIPO_CURSO TC (NOLOCK)
ON		TC.TIPO = C.TIPO
WHERE	(N.nucleo = ISNULL(@coord, N.nucleo) OR N.nucleo IS NULL)       
AND (M.CODIGO = ISNULL(@municipio,  M.CODIGO) OR   M.CODIGO IS NULL)       
AND (UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
ORDER BY N.DESCRICAO, M.NOME, UE.UNIDADE_ENS, MC.DESCRICAO, TC.DESCRICAO, C.NOME, A.SERIE, A.NOME_COMPL</CommandText>
      </Query>
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_ALUNO">
          <DataField>NOME_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_ENCERRAMENTO_ORIGINAL">
          <DataField>DATA_ENCERRAMENTO_ORIGINAL</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="HOUVE_REATIVACAO_QUEDA">
          <DataField>HOUVE_REATIVACAO_QUEDA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO_ATUAL">
          <DataField>SITUACAO_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT  DISTINCT ANO 
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
