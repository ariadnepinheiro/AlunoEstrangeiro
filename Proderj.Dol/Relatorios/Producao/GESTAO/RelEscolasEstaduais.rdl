  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ENDERECO">
          <DataField>ENDERECO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BAIRRO">
          <DataField>BAIRRO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CEP">
          <DataField>CEP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FONE">
          <DataField>FONE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT distinct
	LY_NUCLEO.DESCRICAO AS COORDENADORIA, MUNICIPIO.NOME AS MUNICIPIO
	,LY_UNIDADE_ENSINO.UNIDADE_ENS AS CENSO,
	 LY_UNIDADE_ENSINO.NOME_COMP AS ESCOLA,
	 LY_UNIDADE_ENSINO.SETOR AS UA,
	LY_UNIDADE_ENSINO.ENDERECO AS ENDERECO,
	LY_UNIDADE_ENSINO.END_NUM AS NUMERO,
	LY_UNIDADE_ENSINO.BAIRRO,
	LY_UNIDADE_ENSINO.CEP,
	LY_UNIDADE_ENSINO.FONE
FROM       LY_UNIDADE_ENSINO
INNER JOIN LY_NUCLEO ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO
inner JOIN MUNICIPIO ON MUNICIPIO.CODIGO = LY_UNIDADE_ENSINO.MUNICIPIO
INNER JOIN LY_UNIDADE_ENSINO_SITUACAO UES ON UES.UNIDADE_ENS=ly_unidade_ensino.UNIDADE_ENS
											AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
																FROM LY_UNIDADE_ENSINO_SITUACAO LY_UNIDADE_ENSINO_SITUACAO
																WHERE ly_unidade_ensino.UNIDADE_ENS=LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
WHERE	
 LY_UNIDADE_ENSINO.UNIDADE_ENS NOT in ('99999999','33334444','33335555','33335556')
 AND SITUACAO = 'ESTADUAL'
and LY_NUCLEO.NUCLEO = ISNULL(@NUCLEO, LY_NUCLEO.NUCLEO)
and MUNICIPIO.CODIGO = ISNULL(@MUNIC, MUNICIPIO.CODIGO)
and LY_UNIDADE_ENSINO.UNIDADE_ENS = ISNULL(@ESCOLA, LY_UNIDADE_ENSINO.UNIDADE_ENS)
order by LY_NUCLEO.DESCRICAO, MUNICIPIO.NOME,
	LY_UNIDADE_ENSINO.UNIDADE_ENS</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="coord">
      <Fields>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select *
from (select null as NUCLEO, ' Todas' as DESCRICAO
union SELECT NUCLEO,SUBSTRING(DESCRICAO,1,35)DESCRICAO FROM LY_NUCLEO )coord
ORDER BY DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="munic">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="municipio">
          <DataField>municipio</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select *
from (select null as codigo, ' Todas' as municipio
union
select DISTINCT  mm.codigo,mm.nome municipio from municipio mm
join ly_unidade_ensino s1 on s1.MUNICIPIO=mm.CODIGO
join LY_NUCLEO n1 on n1.NUCLEO=s1.NUCLEO
where s1.NUCLEO=@NUCLEO) municipio
ORDER BY municipio</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="escola">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>unidade_ens</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="escola">
          <DataField>escola</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select *
from (select null as unidade_ens, ' Todas' as escola
union
select UNIDADE_ENS,substring(NOME_COMP,1,40)  as escola from ly_unidade_ensino
where 
	NUCLEO=@NUCLEO
and 	MUNICIPIO=@MUNIC) escola
order by escola</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCLEO">
            <Value>=Parameters!NUCLEO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
