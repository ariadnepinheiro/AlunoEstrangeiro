  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT R.ID_REGIONAL, R.REGIONAL 
FROM TCE_REGIONAL R (nolock)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.ID_REGIONAL = R.ID_REGIONAL
WHERE 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = @usuario
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY REGIONAL</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	DISTINCT CODIGO, NOME 
FROM 	MUNICIPIO M (NOLOCK)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.MUNICIPIO = M.CODIGO
WHERE 	UE.ID_REGIONAL = @COORD
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = @usuario
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	UNIDADE_ENS, NOME_COMP
FROM 	LY_UNIDADE_ENSINO UE (NOLOCK)
WHERE 	UE.MUNICIPIO = @municipio
AND 	UE.ID_REGIONAL = @coord
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = @usuario
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	R.REGIONAL, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, A.ALUNO, P.NOME_COMPL, P.DT_NASC, 
		P.NOME_MAE, MC.DESCRICAO MODALIDADE, C.NOME CURSO, CM.SERIE, CM.TURNO, CM.ANO ANO_CONFIRMACAO, 
		CM.PERIODO PERIODO_CONFIRMACAO, CM.DT_ALTERACAO DATA_CONFIRMACAO, LF.DATAIMPRESSAO DATA_IMPRESSAO, 
		LF.MATRICULA MATRICULA_IMPRESSAO
FROM	LY_ALUNO A (NOLOCK)
JOIN	LY_PESSOA P (NOLOCK)
ON		P.PESSOA = A.PESSOA
JOIN	TCE_CONFIRMACAO_MATRICULA CM (NOLOCK)
ON		CM.ALUNO = A.ALUNO
AND		CM.STATUS = 'CONFIRMADO'
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		UE.UNIDADE_ENS = CM.CENSO
JOIN	LY_CURSO C (NOLOCK)
ON		C.CURSO = CM.CURSO
JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
ON		MC.MODALIDADE = C.MODALIDADE
JOIN	TCE_REGIONAL R 
ON		R.ID_REGIONAL = UE.ID_REGIONAL
LEFT JOIN (
			SELECT	CONFIRMACAOMATRICULAID, MAX(DATAIMPRESSAO) DATAIMPRESSAO, MAX(MATRICULA) MATRICULA
			FROM LOGIMPRESSAOFICHAMATRICULA (NOLOCK)
GROUP BY CONFIRMACAOMATRICULAID
			)LF 
ON		LF.CONFIRMACAOMATRICULAID = CM.ID_CONFIRMACAO_MATRICULA
WHERE	UE.UNIDADE_ENS = @escola
AND		CM.ANO = @ANO
ORDER BY MC.DESCRICAO, C.NOME, CM.TURNO, CM.SERIE, P.NOME_COMPL</CommandText>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_NASC">
          <DataField>DT_NASC</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_MAE">
          <DataField>NOME_MAE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO_CONFIRMACAO">
          <DataField>ANO_CONFIRMACAO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PERIODO_CONFIRMACAO">
          <DataField>PERIODO_CONFIRMACAO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA_CONFIRMACAO">
          <DataField>DATA_CONFIRMACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATA_IMPRESSAO">
          <DataField>DATA_IMPRESSAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MATRICULA_IMPRESSAO">
          <DataField>MATRICULA_IMPRESSAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO 
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
