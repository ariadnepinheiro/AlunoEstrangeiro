      <Query>
        <DataSourceName>lua</DataSourceName>
        <CommandText>SELECT  
convert(varchar(10),a.data, 103),
a.PROCESSADO
	   ,R.nomearquivo
      ,R.quantidaderegistros
     -- ,[tipomovimentacao]
      ,[matriculanova]
      ,[nomealuno]
      ,[alunodatanascimento]
      ,[painome]
      ,[maenome]
      ,[alunocpf]
      ,[alunorg]
      ,[alunorgufexpedicao]
      ,[alunorgorgaoexpedicao]
      ,[alunorgdataexpedicao]
      ,[enderecocep]
      ,[enderecotipologradouro]
      ,[endereconomelogradouro]
      ,[endereconumero]
      ,[enderecocomplemento]
      ,[enderecobairro]
      ,[enderecomunicipio]
      ,[codigocenso]
      ,[qhiturma]
      --,[alunofoto]
      ,[gratuidade]
      ,[modalTREM]
      ,[modalONIBUS]
      ,[modalMETRO]
      ,[modalBARCAS]
      ,[QHITurno]
      ,[SOLICITACAO] 

,Case 
when r.alunofoto is null  then 'N'
when r.alunofoto is not null  then 'S'
end Fotos,

Case 
when st.status = 1 then  'Processado OK'
when st.status = 2 then  'Processado com Erro'
when st.status = 4 then  'Escola Pertence Salineira'
when st.status = 5 then  'Bloqueado Para Emissão de Cartão'
when st.status = 6 then  'Arquivo Cancelado - Dados Inválidos'
when st.status = 9 then  'Em Processamento'
when st.status not in (1,2,4,5,6,9) then 'Status Novo Contactar a Informática'
end Status,
st.descricao

FROM 
 RIOCARD_ARQUIVOREMESSA a  join RIOCARD_REMESSA r on  a.arquivo = r.NomeArquivo
 left join TR_STATUS_ARQUIVO_REGISTRO st  on   st.NomeArquivo = r.nomearquivo  and  r.matriculanova = st.matricula


where
--a.arquivo = 'SEEDUC2010060801'
a.data  between @dateinicio and @datefim


order by a.data, nomealuno</CommandText>
        <QueryParameters>
          <QueryParameter Name="@dateinicio">
            <Value>=Parameters!dateinicio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@datefim">
            <Value>=Parameters!datefim.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
  </DataSets>
