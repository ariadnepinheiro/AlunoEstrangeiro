  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>229031ba-5c11-4e90-a47d-c1621f78e578</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SIT_CONF">
            <Value>=Parameters!SIT_CONF.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT     ALUNO, INSCRICAO, NOME_COMPL, CURSO, TURNO, ID_REGIONAL, REGIONAL, MUNICÍPIO, COD_MUN, UE_CENSO, SIT_CONF, ESCOLA, LOTE, DATA_CONFIRMACAO
FROM         RELCONFMAT (NOLOCK)
WHERE     (ID_REGIONAL = ISNULL(@COORD, ID_REGIONAL) OR
                      ID_REGIONAL IS NULL) AND (COD_MUN = ISNULL(@MUNIC, COD_MUN) OR
                      COD_MUN IS NULL) AND (UE_CENSO = ISNULL(@ESCOLA, UE_CENSO) OR
                      UE_CENSO IS NULL) AND (SIT_CONF = ISNULL(@SIT_CONF, SIT_CONF) OR
                      SIT_CONF IS NULL) AND (TURNO = ISNULL(@TURNO, TURNO) OR
                      TURNO IS NULL)</CommandText>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="INSCRICAO">
          <DataField>INSCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICÍPIO">
          <DataField>MUNICÍPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COD_MUN">
          <DataField>COD_MUN</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE_CENSO">
          <DataField>UE_CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SIT_CONF">
          <DataField>SIT_CONF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LOTE">
          <DataField>LOTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DATA_CONFIRMACAO">
          <DataField>DATA_CONFIRMACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null nucleo,' TODAS' descricao 
union
select 0 nucleo,' Selecione...' descricao 
union
select  l1.ID_REGIONAL,SUBSTRING(l1.REGIONAL,1,35) from TCE_REGIONAL L1
join LY_UNIDADE_ENSINO l2 on L1.ID_REGIONAL=l2.ID_REGIONAL
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS UF 
ON UF.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE UF.USUARIO = @usuario
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join tce_regional r on r.id_regional = l2.id_regional
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(r.id_regional = ISNULL(@coord,r.id_regional)or r.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' descricao 
union
select null codigo,' TODOS' nome  
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS UF 
ON UF.UNIDADE_FIS = ue.UNIDADE_ENS
WHERE UF.USUARIO = @usuario
and (ue.ID_REGIONAL = ISNULL(@COORD,ue.ID_REGIONAL) or ue.ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
