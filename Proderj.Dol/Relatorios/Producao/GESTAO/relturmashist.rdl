<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LyceumGov</DataSourceReference>
      <rd:DataSourceID>77317388-9fb8-46ad-bb47-2a296b530d24</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="rel1">
      <Fields>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA_ANTERIOR">
          <DataField>TURMA_ANTERIOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA_ATUAL">
          <DataField>TURMA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO_HIST">
          <DataField>SITUACAO_HIST</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE_CENSO">
          <DataField>UE_CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_COD">
          <DataField>UA_COD</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT 
                      AL.ALUNO, AL.NOME_COMPL, HT.TURMA AS TURMA_ANTERIOR, MM.TURMA AS TURMA_ATUAL, HT.SITUACAO_HIST, 
                      SS.UNIDADE_ENS AS UE_CENSO, SS.NOME_COMP AS ESCOLA, SS.SETOR AS UA_COD, SS.NUCLEO,
                          (SELECT     NOME
                            FROM          MUNICIPIO
                            WHERE      (CODIGO = SS.MUNICIPIO)) AS MUNICIPIO, NN.DESCRICAO AS COORDENADORIA
FROM         LY_HISTMATRICULA AS HT INNER JOIN
                      LY_ALUNO AS AL WITH (NOLOCK) ON AL.ALUNO = HT.ALUNO LEFT OUTER JOIN
                      LY_MATRICULA AS MM WITH (NOLOCK) ON MM.ALUNO = HT.ALUNO INNER JOIN
                      LY_TURMA AS TT WITH (NOLOCK) ON TT.TURMA = HT.TURMA AND HT.ANO = TT.ANO AND HT.SEMESTRE = TT.SEMESTRE AND 
                      HT.SERIE = TT.SERIE AND HT.DISCIPLINA = TT.DISCIPLINA INNER JOIN
                      LY_UNIDADE_ENSINO AS SS ON SS.UNIDADE_ENS = TT.FACULDADE INNER JOIN
                      LY_NUCLEO AS NN ON NN.NUCLEO = SS.NUCLEO
WHERE     (NN.NUCLEO = @NUCL) AND (SS.MUNICIPIO = @MUNIC) AND (SS.UNIDADE_ENS = @ESCOLA) AND (HT.TURMA = @TURMA)
ORDER BY AL.NOME_COMPL</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCL">
            <Value>=Parameters!NUCL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURMA">
            <Value>=Parameters!TURMA.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="search_nucleo">
      <Fields>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT NUCLEO,SUBSTRING(DESCRICAO,1,35)DESCRICAO FROM LY_NUCLEO 
ORDER BY DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="search_municipio">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="municipio">
          <DataField>municipio</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select DISTINCT  mm.codigo,mm.nome municipio from municipio mm
join ly_unidade_ensino s1 on s1.MUNICIPIO=mm.CODIGO
join LY_NUCLEO n1 on n1.NUCLEO=s1.NUCLEO
where s1.NUCLEO=@NUCL
ORDER BY MM.MUNICIPIO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCL">
            <Value>=Parameters!NUCL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="search_escola">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="escola">
          <DataField>escola</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select UNIDADE_ENS,substring(NOME_COMP,1,40) escola from ly_unidade_ensino
where 
	NUCLEO=@NUCL
and 	MUNICIPIO=@MUNIC
ORDER BY NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@NUCL">
            <Value>=Parameters!NUCL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="search_turma">
      <Fields>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT 
	H1.TURMA 
FROM LY_HISTMATRICULA H1  WITH (NOLOCK)
JOIN LY_TURMA T1 WITH (NOLOCK) 
	ON T1.TURMA=H1.TURMA 
	AND T1.SEMESTRE=H1.SEMESTRE 
	AND T1.ANO=H1.ANO 
	AND T1.DISCIPLINA=H1.DISCIPLINA
JOIN LY_UNIDADE_ENSINO LL ON LL.UNIDADE_ENS=T1.FACULDADE
WHERE T1.FACULDADE=@ESCOLA</CommandText>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
