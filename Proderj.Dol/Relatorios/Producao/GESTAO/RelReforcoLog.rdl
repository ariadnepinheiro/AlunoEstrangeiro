  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Data_Ini">
            <Value>=Parameters!Data_Ini.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Data_fim">
            <Value>=Parameters!Data_fim.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	R.REGIONAL, M.NOME MUNICIPIO, L.UA, UE.NOME_COMP UNIDADE, 
		LOTE, DATA_ENVIO, DATA_PROCESSAMENTO, CH_SOLICITADA, L.MATRICULA, 
		D.NOME_COMPL NOME_DOCENTE, STATUS
FROM 	APOLLO..REL_REFORCO_LOG L
LEFT	JOIN LY_UNIDADE_ENSINO UE
ON		UE.SETOR = L.UA
LEFT	JOIN HADES..TCE_MUNICIPIO M 
ON		M.ID_MUNICIPIO = UE.MUNICIPIO
LEFT	JOIN TCE_REGIONAL R 
ON		R.ID_REGIONAL = UE.ID_REGIONAL
LEFT	JOIN LY_DOCENTE D
ON		D.MATRICULA = L.MATRICULA
WHERE 	DATA_ENVIO BETWEEN @Data_Ini AND @Data_fim</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LOTE">
          <DataField>LOTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DATA_ENVIO">
          <DataField>DATA_ENVIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATA_PROCESSAMENTO">
          <DataField>DATA_PROCESSAMENTO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="CH_SOLICITADA">
          <DataField>CH_SOLICITADA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
