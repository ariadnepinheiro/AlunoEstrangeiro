<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:DataSourceID>8e833c7e-d130-40c7-820b-e0d5cacfe1dc</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_DOCENTE">
          <DataField>TOTAL_DOCENTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
	SUBSTRING((SELECT DESCRICAO FROM LY_NUCLEO WHERE LL.NUCLEO=NUCLEO),1,35)COORDENADORIA,
	(SELECT DS.NOME_COMP FROM LY_UNIDADE_ENSINO DS WHERE DS.SETOR=LL.SETOR 
					AND LL.DATA_DESATIVACAO IS NULL)ESCOLA,
	COUNT(distinct DD.MATRICULA)TOTAL_DOCENTE,
	SS.DESCRICAO,
	DD.CATEGORIA FUNCAO,
	(SELECT NOME FROM MUNICIPIO M1 WHERE S2.MUNICIPIO=M1.CODIGO)MUNICIPIO		
	FROM LY_DOCENTE DD
JOIN LY_LOTACAO LL ON LL.MATRICULA=DD.MATRICULA
JOIN 
	(SELECT NUM_FUNC,DESCRICAO FROM LY_GRUPO_HABILITACAO H1,LY_GRUPO_HABILITACAO_DOC H2
				WHERE H1.AGRUPAMENTO=H2.AGRUPAMENTO
				AND H2.AGRUPAMENTO_INGRESSO='S') SS ON SS.NUM_FUNC=DD.NUM_FUNC
JOIN LY_AULA_DOCENTE DR ON DR.NUM_FUNC=DD.NUM_FUNC
JOIN LY_TURMA TT	ON TT.ANO=DR.ANO
						AND TT.TURMA=DR.TURMA
						AND TT.SEMESTRE=DR.SEMESTRE
						AND TT.DT_FIM=DR.DATA_FIM		
						AND TT.TURNO=DR.TURNO
						AND TT.DISCIPLINA=DR.DISCIPLINA
						AND TT.FACULDADE=DR.FACULDADE				
JOIN (SELECT UNIDADE_ENS,MUNICIPIO,NUCLEO,SETOR FROM LY_UNIDADE_ENSINO KK 
					JOIN MUNICIPIO MM ON MM.CODIGO=KK.MUNICIPIO)S2 ON S2.NUCLEO=LL.NUCLEO
WHERE
	LL.DATA_DESATIVACAO IS NULL
AND 
	NOT EXISTS (SELECT 1 FROM LY_LICENCA_DOCENTE DF WHERE DF.NUM_FUNC=DD.NUM_FUNC AND (DF.DTFIM IS NULL OR DF.DTFIM&gt;=CURRENT_TIMESTAMP))
AND 
	DR.ANO IN (@ANO)  AND DR.SEMESTRE IN (@PERIODO)
and
	(LL.NUCLEO= isnull (@nucleo,LL.nucleo)or LL.nucleo is null)
	AND
		(S2.MUNICIPIO= isnull (@MUNICIPIO,S2.MUNICIPIO)or S2.MUNICIPIO is null)

and 
	(S2.UNIDADE_ENS= isnull (@escola,S2.UNIDADE_ENS)or S2.UNIDADE_ENS is null)
	AND S2.SETOR=LL.SETOR

GROUP BY LL.NUCLEO,LL.setor,SS.DESCRICAO,DD.CATEGORIA,S2.MUNICIPIO,LL.DATA_DESATIVACAO
ORDER BY SS.DESCRICAO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PERIODO">
            <Value>=Parameters!PERIODO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="coordenadoria">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null nucleo,' TODAS'descricao 
union
select 'NULO' nucleo,' Selecione...'descricao
union
select distinct  l1.NUCLEO,SUBSTRING(l1.descricao,1,35)descricao from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
where 
	(n1.NUCLEO = ISNULL(@nucleo,n1.NUCLEO)or n1.NUCLEO is null)

union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="escola">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
where (ue.NUCLEO = ISNULL(@nucleo,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.MUNICIPIO is null)

order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nucleo">
            <Value>=Parameters!nucleo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
