          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DS_SERIE">
          <DataField>DS_SERIE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO_SEGUINTE">
