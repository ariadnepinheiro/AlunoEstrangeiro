  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT	DISTINCT C.ANO_INI, C.SEM_INI, MC.DESCRICAO MODALIDADE, TC.DESCRICAO, 
		CC.CURSO COD_CURSO, CC.NOME CURSO, C.TURNO, S.SERIE, S.DESCRICAO DS_SERIE, 
		S.CURSO_SEGUINTE, S.SERIE_SEGUINTE, S.ANO_SERIE_CONCLUINTE
FROM	LY_CURRICULO C
JOIN	LY_SERIE S 
ON		C.CURSO = S.CURSO
AND		C.CURRICULO = S.CURRICULO
AND		C.TURNO = S.TURNO
JOIN	LY_CURSO CC
ON		CC.CURSO = C.CURSO
JOIN	LY_MODALIDADE_CURSO MC 
ON		MC.MODALIDADE = CC.MODALIDADE
JOIN	LY_TIPO_CURSO TC
ON		TC.TIPO = CC.TIPO
WHERE	C.DT_EXTINCAO IS NULL
OR		C.DT_EXTINCAO &gt;= CONVERT(DATE, GETDATE())
</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO_INI">
          <DataField>ANO_INI</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEM_INI">
          <DataField>SEM_INI</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
