          <DataField>MEDIO_REGULAR</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MEDIO_NORMAL">
          <DataField>MEDIO_NORMAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="EJA_MEDIO">
          <DataField>EJA_MEDIO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MEDIO_PROF">
          <DataField>MEDIO_PROF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MEDIO_INTEGRAL">
          <DataField>MEDIO_INTEGRAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MEDIO_AUTONOMIA">
          <DataField>MEDIO_AUTONOMIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_MEDIO">
          <DataField>TOTAL_MEDIO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ENSINO_ESPECIAL">
          <DataField>ENSINO_ESPECIAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UNID_PRISIONAIS">
          <DataField>UNID_PRISIONAIS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ENSINO_INDIGENA">
          <DataField>ENSINO_INDIGENA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT MUNICIPIO, QTD_ESCOLAS, QTD_ALUNOS, FUND_ANOS_INICIAIS, FUND_ANOS_FINAIS, EJA_FUND_ANOS_INICIAIS, EJA_FUND_ANOS_FINAIS, FUND_AUTONOMIA,
(FUND_ANOS_INICIAIS + FUND_ANOS_FINAIS + EJA_FUND_ANOS_INICIAIS + EJA_FUND_ANOS_FINAIS + FUND_AUTONOMIA) AS TOTAL_FUNDAMENTAL, 
MEDIO_REGULAR, MEDIO_NORMAL, EJA_MEDIO, MEDIO_PROF, MEDIO_INTEGRAL, MEDIO_AUTONOMIA, 
(MEDIO_REGULAR + MEDIO_NORMAL + EJA_MEDIO + MEDIO_PROF + MEDIO_INTEGRAL + MEDIO_AUTONOMIA) AS TOTAL_MEDIO,
ENSINO_ESPECIAL, UNID_PRISIONAIS, ENSINO_INDIGENA
FROM 
(SELECT MUNICIPIO,
ISNULL (COUNT (DISTINCT QTD_ESCOLA), '') AS QTD_ESCOLAS,
ISNULL (COUNT (DISTINCT QTD_ALUNO), '') AS QTD_ALUNOS,  
ISNULL (COUNT (CASE WHEN ESCOLARIDADE='ENSINO FUNDAMENTAL' AND NIVEL='1' THEN QTD_ALUNO END), '') AS FUND_ANOS_INICIAIS,
ISNULL (COUNT (CASE WHEN ESCOLARIDADE='ENSINO FUNDAMENTAL' AND NIVEL='2' THEN QTD_ALUNO END), '') AS FUND_ANOS_FINAIS,
ISNULL (COUNT (CASE WHEN ESCOLARIDADE='EJA ENSINO FUNDAMENTAL' AND NIVEL='6' THEN QTD_ALUNO END), '') AS EJA_FUND_ANOS_INICIAIS,
ISNULL (COUNT (CASE WHEN ESCOLARIDADE='EJA ENSINO FUNDAMENTAL' AND NIVEL='2' THEN QTD_ALUNO END), '') AS EJA_FUND_ANOS_FINAIS,
ISNULL (COUNT (CASE WHEN PROJETO = '0091.29' THEN QTD_ALUNO END), '') AS FUND_AUTONOMIA,
ISNULL (COUNT (CASE WHEN ESCOLARIDADE='ENSINO MEDIO' AND MODALIDADE='RE1' THEN QTD_ALUNO END), '') AS MEDIO_REGULAR,
ISNULL (COUNT (CASE WHEN ESCOLARIDADE='CURSO NORMAL' AND MODALIDADE='NO9' AND NIVEL='3' THEN QTD_ALUNO END), '') AS MEDIO_NORMAL,
ISNULL (COUNT (CASE WHEN ESCOLARIDADE='EJA ENSINO MÉDIO' AND NIVEL='3' THEN QTD_ALUNO END), '') AS EJA_MEDIO,
ISNULL (COUNT (CASE WHEN MODALIDADE IN ('ED4', 'ED5', 'ED6') AND NIVEL='3' THEN QTD_ALUNO END), '') AS MEDIO_PROF,
ISNULL (COUNT (CASE WHEN MODALIDADE='IN8' AND NIVEL='3' THEN QTD_ALUNO END), '') AS MEDIO_INTEGRAL,
ISNULL (COUNT (CASE WHEN PROJETO = '0092.39' AND NIVEL='3' THEN QTD_ALUNO END), '') AS MEDIO_AUTONOMIA,
ISNULL (COUNT (CASE WHEN MODALIDADE = 'ES7' THEN QTD_ALUNO END), '') AS ENSINO_ESPECIAL,
ISNULL (COUNT (CASE WHEN COORDENADORIA = '31' THEN QTD_ALUNO END), '') AS UNID_PRISIONAIS,
ISNULL (COUNT (CASE WHEN QTD_ESCOLA IN ('33098018', '33135738', '33135720') THEN QTD_ALUNO END), '') AS ENSINO_INDIGENA

FROM (
SELECT N.NUCLEO AS COORDENADORIA,
 --LL.NOME_COMP AS ESCOLA,
 --M.CODIGO AS CODIGO,
 M.NOME AS MUNICIPIO,
 LY_CURSO.NOME AS ESCOLARIDADE,
 LY_TIPO_CURSO.TIPO AS NIVEL,
 LY_MODALIDADE_CURSO.MODALIDADE AS MODALIDADE,
 LY_SERIE.CURSO AS PROJETO,
 AA.ALUNO AS QTD_ALUNO,
 LL.UNIDADE_ENS AS QTD_ESCOLA

 FROM LY_PESSOA PP WITH (NOLOCK)   

 INNER JOIN LY_ALUNO AA WITH (NOLOCK) ON AA.PESSOA = PP.PESSOA
			AND NOT EXISTS (SELECT 1 FROM   LY_H_CURSOS_CONCL
							WHERE  AA.ALUNO = LY_H_CURSOS_CONCL.ALUNO
							AND DT_REABERTURA is null)
 INNER JOIN LY_MATRICULA WITH (NOLOCK) on AA.ALUNO = LY_MATRICULA.ALUNO 
			AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
 INNER join LY_TURMA WITH (NOLOCK) ON LY_TURMA.TURMA = ly_matricula.TURMA
			AND	LY_TURMA.DISCIPLINA = ly_matricula.DISCIPLINA
			AND	LY_TURMA.ANO = ly_matricula.ANO
			AND	LY_TURMA.SEMESTRE = ly_matricula.SEMESTRE 
			AND LY_TURMA.SIT_TURMA IN ('ABERTA')
			AND LY_TURMA.ANO = YEAR (GETDATE())		
INNER JOIN LY_SERIE WITH (NOLOCK) ON LY_SERIE.CURSO = LY_TURMA.CURSO
			AND LY_SERIE.TURNO = LY_TURMA.TURNO						
			AND LY_SERIE.CURRICULO = LY_TURMA.CURRICULO	
			AND LY_SERIE.SERIE = LY_TURMA.SERIE
INNER JOIN LY_CURSO WITH (NOLOCK) ON LY_CURSO.CURSO = LY_SERIE.CURSO
INNER JOIN LY_TIPO_CURSO WITH (NOLOCK) ON LY_TIPO_CURSO.TIPO = LY_CURSO.TIPO
INNER JOIN LY_MODALIDADE_CURSO WITH (NOLOCK) ON LY_MODALIDADE_CURSO.MODALIDADE = LY_CURSO.MODALIDADE				
INNER JOIN LY_UNIDADE_ENSINO LL WITH (NOLOCK) ON LL.UNIDADE_ENS=LY_TURMA.FACULDADE  
inner join LY_UNIDADE_ENSINO_SITUACAO UES WITH (NOLOCK) ON UES.UNIDADE_ENS = LL.UNIDADE_ENS
			AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
				FROM LY_UNIDADE_ENSINO_SITUACAO LY_UNIDADE_ENSINO_SITUACAO
				WHERE LL.UNIDADE_ENS = LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
				AND UES.SITUACAO = 'ESTADUAL'
INNER JOIN LY_USUARIO_UNIDADE_FIS UF WITH (NOLOCK) ON UF.UNIDADE_FIS = AA.UNIDADE_ENSINO
INNER JOIN HADES.dbo.HD_USUARIO U WITH (NOLOCK) ON U.USUARIO = UF.USUARIO
INNER JOIN LY_NUCLEO N WITH (NOLOCK) ON N.NUCLEO=LL.NUCLEO
INNER JOIN MUNICIPIO M WITH (NOLOCK) ON M.CODIGO = LL.MUNICIPIO

WHERE 
UF.USUARIO = @usuario
 
GROUP BY  N.NUCLEO, M.NOME, LY_CURSO.NOME, LY_TIPO_CURSO.TIPO, LY_MODALIDADE_CURSO.MODALIDADE, LY_SERIE.CURSO, AA.ALUNO, LL.UNIDADE_ENS

)SQL1

GROUP BY  MUNICIPIO

)SQL2

GROUP BY  MUNICIPIO, QTD_ESCOLAS, QTD_ALUNOS, FUND_ANOS_INICIAIS, FUND_ANOS_FINAIS, EJA_FUND_ANOS_INICIAIS, EJA_FUND_ANOS_FINAIS, FUND_AUTONOMIA,
MEDIO_REGULAR, MEDIO_NORMAL, EJA_MEDIO, MEDIO_PROF, MEDIO_INTEGRAL, MEDIO_AUTONOMIA, ENSINO_ESPECIAL, UNID_PRISIONAIS, ENSINO_INDIGENA</CommandText>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
