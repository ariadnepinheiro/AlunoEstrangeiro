  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@matricula">
            <Value>=Parameters!matricula.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@censo">
            <Value>=Parameters!censo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select VW_INTEG_LANC_NOTAS_TUR.* 
from  VW_INTEG_LANC_NOTAS_TUR
where VW_INTEG_LANC_NOTAS_TUR.matricula=@matricula
and   VW_INTEG_LANC_NOTAS_TUR.censo =@censo</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
