  <DataSets>
    <DataSet Name="DOCENTES">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT		UE.SETOR      
                ,UE.UNIDADE_ENS      
                ,UE.NOME_COMP ESCOLA      
                ,LY_NUCLEO.DESCRICAO COORDENADORIA      
                ,LY_NUCLEO.NUCLEO      
                ,MUNICIPIO.CODIGO       
                ,MUNICIPIO.NOME NOME_MUNIC
                ,A.MATRICULA
                ,A.NOME_COMPL NOME_DOCENTE
FROM   LY_DOCENTE A WITH(NOLOCK)      
         JOIN LY_PESSOA WITH(NOLOCK)  
            ON LY_PESSOA.PESSOA = A.PESSOA  
       JOIN	LY_LOTACAO L (NOLOCK) 
       ON	L.MATRICULA = A.MATRICULA
		AND		L.DATA_NOMEACAO &lt;= CONVERT(DATE,GETDATE())
		AND		(L.DATA_DESATIVACAO IS NULL
		OR		L.DATA_DESATIVACAO &gt;= CONVERT(DATE,GETDATE()))
       JOIN LY_UNIDADE_ENSINO UE WITH(NOLOCK)         
         ON UE.SETOR = L.SETOR
      JOIN LY_NUCLEO WITH(NOLOCK)       
      ON LY_NUCLEO.NUCLEO=UE.NUCLEO      
      JOIN MUNICIPIO WITH(NOLOCK)      
      ON MUNICIPIO.CODIGO=UE.MUNICIPIO      
	JOIN LY_FUNCAO FF
	ON	FF.FUNCAO = L.FUNCAO
	AND		FF.CAMPO_01 = 'S'
WHERE  NOT EXISTS (
					SELECT	1 
					FROM	LY_LICENCA_DOCENTE LD WITH(NOLOCK)      
					WHERE	LD.NUM_FUNC = A.NUM_FUNC
					AND		LD.DTFIM IS NULL
					)                  
		AND (  
            LY_PESSOA.DT_NASC &lt; '1900-01-01' 
            OR LY_PESSOA.DT_NASC IS NULL
            OR LY_PESSOA.NOME_COMPL IS NULL 
            OR LY_PESSOA.SEXO IS NULL
            OR LY_PESSOA.NECESSIDADE_ESPECIAL IS NULL
            OR LY_PESSOA.COR_RACA IS NULL
            OR LY_PESSOA.EST_CIVIL IS NULL
            OR LY_PESSOA.PAIS_NASC IS NULL  
            OR LY_PESSOA.NACIONALIDADE IS NULL  
            OR LY_PESSOA.MUNICIPIO_NASC IS NULL 
            OR LY_PESSOA.ENDERECO IS NULL
            OR LY_PESSOA.END_MUNICIPIO IS NULL
            OR LY_PESSOA.CEP IS NULL
            OR A.ZONA_RESIDENCIAL IS NULL 
            OR LY_PESSOA.CPF IS NULL
            OR 	NOT EXISTS (
							SELECT	1
							FROM	TCE_FORMACAO_PESSOAL FP 
							WHERE	FP.PESSOA = LY_PESSOA.PESSOA				
							)
		)    
AND		EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US 
				WHERE	US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN (
													SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO))
													FROM	LY_UNIDADE_ENSINO_SITUACAO
													GROUP BY UNIDADE_ENS
													)															                        
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EmAtividade')				
AND (LY_NUCLEO.nucleo = ISNULL(@coord, LY_NUCLEO.nucleo) OR LY_NUCLEO.nucleo IS NULL)       
AND (MUNICIPIO.CODIGO = ISNULL(@municipio,  MUNICIPIO.CODIGO) OR   MUNICIPIO.CODIGO IS NULL)       
AND (UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
GROUP BY UE.SETOR      
                ,UE.UNIDADE_ENS      
                ,UE.NOME_COMP
                ,LY_NUCLEO.DESCRICAO
                ,LY_NUCLEO.NUCLEO      
                ,MUNICIPIO.CODIGO       
                ,MUNICIPIO.NOME
                ,UE.SETOR
                ,A.MATRICULA
                ,A.NOME_COMPL
</CommandText>
      </Query>
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_MUNIC">
          <DataField>NOME_MUNIC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Coordenadoria">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' descricao 
union
select null codigo,' TODOS' nome  
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
order by NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="usuario">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>usuario</Prompt>
      <Hidden>true</Hidden>
    </ReportParameter>
    <ReportParameter Name="coord">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>Coordenadoria</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Coordenadoria</DataSetName>
          <ValueField>nucleo</ValueField>
          <LabelField>descricao</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="municipio">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <Prompt>Município</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Municipio</DataSetName>
          <ValueField>codigo</ValueField>
          <LabelField>nome</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="escola">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>Unidade</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Escola</DataSetName>
          <ValueField>UNIDADE_ENS</ValueField>
          <LabelField>NOME_COMP</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
  </ReportParameters>
