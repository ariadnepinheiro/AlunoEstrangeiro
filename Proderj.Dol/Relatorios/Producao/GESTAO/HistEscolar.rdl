    <DataSet Name="dsDadosUnidade">
      <Fields>
        <Field Name="nome_comp">
          <DataField>nome_comp</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="endereco">
          <DataField>endereco</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandText>select nome_comp, endereco + ', ' + end_num + ' Bairro ' + bairro + ' - ' + uf_sigla + ' CEP.: ' + ly_unidade_ensino.cep + ' Tel. ' + fone + ' - ' + fax endereco
from ly_aluno, ly_curso, ly_unidade_ensino, municipio
where ly_aluno.curso = ly_curso.curso
and ly_unidade_ensino.unidade_ens = ly_curso.faculdade
and municipio.codigo = ly_unidade_ensino.municipio
and aluno = @p_aluno</CommandText>
        <QueryParameters>
          <QueryParameter Name="@p_aluno">
            <Value>=Parameters!p_aluno.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
