  <DataSources>
    <DataSource Name="dbLyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
        <Prompt>Especifique um nome de usuário e uma senha para a fonte de dados dbLyceum:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>e570dad1-841d-4a87-8327-43cd8adcf261</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsFichaMatricula">
      <Query>
        <DataSourceName>dbLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONFIRMACAO_MATRICULA">
            <Value>=Parameters!Id_Confirmacao_Matricula.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
	--DADOS PESSOAIS
	A.NOME_COMPL,
	P.DT_NASC,
	CASE P.SEXO WHEN 'M' THEN 'Masculino' ELSE 'Feminino' END SEXO,
	P.QT_FILHOS,
	P.TIPO_SANGUINEO,
	P.ETNIA COR_RACA,
	P.EST_CIVIL,
	PS.NOME PAISNASCIMENTO,
	P.NACIONALIDADE,
	TM.UF UFNASCIMENTO,
	TM.NOME MUNICIPIONASCIMENTO,
	P.CREDO,
	P.NECESSIDADE_ESPECIAL,

	-- ESCOLARIDADE
	A.ALUNO MATRICULA,
	UEA.NOME_COMP UNIDADEESCOLARIDADE,
	MCA.DESCRICAO MODALIDADE,
	TCA.DESCRICAO SEGMENTO,
	A.CURSO,
	CA.NOME NOMECURSO,
	CASE A.TURNO
	  WHEN 'A' THEN 'Ampliado'
	  WHEN 'T' THEN 'Tarde'
	  WHEN 'M' THEN 'Manhã'
	  WHEN 'N' THEN 'Noite'
	  WHEN 'I' THEN 'Integral'
	END TURNO,
	A.SERIE,
	A.TIPO_INGRESSO,
	A.REDE_ENSINO_ORIGEM,
	IT.DESCR RECEBEESCOLARIZACAOOUTROESPACAO,
	
	--FILIAÇÃO
	P.NOME_MAE,
	CASE P.MAE_FALECIDA
	  WHEN 'N' THEN 'Não'
	  WHEN 'S' THEN 'Sim'
	  ELSE P.MAE_FALECIDA
	END MAE_FALECIDA,
	P.MAE_TELEFONE,
	P.MAE_CPF,
	P.NOME_PAI,
	CASE P.PAI_FALECIDO
	  WHEN 'N' THEN 'Não'
	  WHEN 'S' THEN 'Sim'
	  ELSE P.PAI_FALECIDO
	END PAI_FALECIDO,
	P.PAI_TELEFONE,
	P.PAI_CPF,
	P.RESPONSAVEL,
	P.RESP_NOME_COMPL NOMERESPONSAVEL,
	P.RESP_FONE,
	P.RESP_CPF,
	
	--ENDEREÇO
	P.ENDERECO,
	P.END_NUM,
	P.END_COMPL,
	P.BAIRRO,
	TMA.NOME MUNICIPIOALUNO,
	TMA.UF UFALUNO,
	P.CEP,
	FP.FL_FIELD_01 LOCALIZACAORESIDENCIA,
	
	--CONTATO
	P.FONE,
	P.CELULAR,
	P.E_MAIL,
	
	--DOCUMENTOS
	P.CPF,
	P.RG_TIPO,
	P.RG_NUM,
	FP.FL_FIELD_07 COMPLEMENTOIDENTIDADE,
	P.RG_UF,
	P.RG_EMISSOR,
	P.RG_DTEXP,
	A.RGDETRANRJ,
	A.DATAEMISSAORGDETRANRJ,

	--OUTRAS INFORMAÇÕES
	P.ID_CENSO NUMEROINEP,
	FP.FL_FIELD_08 NUMERONIS,

	--CERTIDÃO NASCIMENTO
	FP.FL_FIELD_02 TIPOCERTIDAOCIVIL,
	FP.FL_FIELD_09 CERTIDAOCIVIL,
	CT.UF CARTORIOUF, --CARTORIO UF
	CT.MUNICIPIO CARTORIOMUNICIPIO, --CARTORIO MUNICIPIO
	P.CERT_NASC_CARTORIO_EXPED, --CARTORIO NOME
	P.CERT_NASC_NUM, --NUMERO DO TERMO
	P.CERT_NASC_EMISSAO, --DATA EMISSAO
	P.CERT_NASC_CARTORIO_UF CERTIDAOUF, --ESTADO
	P.CERT_NASC_FOLHA, --FOLHA
	P.CERT_NASC_LIVRO, --LIVRO
	P.CERT_NUMERO_MATRICULA, --MATRÍCULA DA CERTIDÃO

	--TRANSPORTE
	CASE FP.FL_FIELD_04
	  WHEN 'N' THEN 'Não'
	  WHEN 'S' THEN 'Sim'
	  ELSE FP.FL_FIELD_04
	END UTILIZATRANSPORTE,
	FP.FL_FIELD_10 PODERRESPONSAVEL,
	--FP.FL_FIELD_05 MODAISTRANSPORTE,
	ISNULL((SELECT DESCR + ', ' FROM ITEMTABELA WHERE TAB = 'TransporteModal' AND CHARINDEX(ITEM, FP.FL_FIELD_05) &lt;&gt; 0 ORDER BY DESCR FOR XML PATH('') ), ',') AS MODAISTRANSPORTE,

	--CONFIRMAÇÃO RENOVAÇÃO DE MATRÍCULA
	CM.ID_CONFIRMACAO_MATRICULA, 
	CM.ANO,
	CM.PERIODO,
	UE.NOME_COMP UNIDADEENSINOCONF,
	MC.DESCRICAO MODALIDADECONF,
	TC.DESCRICAO SEGMENTOCONF, 
	C.NOME NOMECURSOCONF,
	CM.SERIE SERIECONF,
	
	CASE CM.TURNO
	  WHEN 'A' THEN 'Ampliado'
	  WHEN 'T' THEN 'Tarde'
	  WHEN 'M' THEN 'Manhã'
	  WHEN 'N' THEN 'Noite'
	  WHEN 'I' THEN 'Integral'
	END TURNOCONF,
	CM.DT_SUGERIDA,
	CASE WHEN ISNULL(CM.ENSINO_RELIGIOSO, 0) = 1 THEN 'Sim' ELSE 'Não' END ENSINO_RELIGIOSO,
	CASE WHEN ISNULL(CM.LINGUA_ESTRANGEIRA_FACULTATIVA, 0) = 1 THEN 'Sim' ELSE 'Não' END LINGUA_ESTRANGEIRA_FACULTATIVA,
	CM.[STATUS] SITUACAO,
	CM.DT_CADASTRO DATASITUACAO,
	
	--FOTO
	FA.FOTO
	
FROM TCE_CONFIRMACAO_MATRICULA CM
	INNER JOIN LY_UNIDADE_ENSINO UE
		ON (CM.CENSO = UE.UNIDADE_ENS)
	INNER JOIN LY_CURSO C
		ON (CM.CURSO = C.CURSO)
	INNER JOIN LY_MODALIDADE_CURSO MC
		ON (C.MODALIDADE = MC.MODALIDADE)
	INNER JOIN LY_TIPO_CURSO TC
		ON (C.TIPO = TC.TIPO)
	INNER JOIN LY_ALUNO A
		ON (CM.ALUNO = A.ALUNO)
	INNER JOIN LY_UNIDADE_ENSINO UEA
		ON (A.UNIDADE_ENSINO = UEA.UNIDADE_ENS)
	INNER JOIN LY_CURSO CA
		ON (A.CURSO = CA.CURSO)
	INNER JOIN LY_MODALIDADE_CURSO MCA
		ON (CA.MODALIDADE = MCA.MODALIDADE)
	INNER JOIN LY_TIPO_CURSO TCA
		ON (CA.TIPO = TCA.TIPO)
	INNER JOIN LY_PESSOA P
		ON (A.PESSOA = P.PESSOA)
	LEFT JOIN PAISES PS
		ON (P.PAIS_NASC = PS.CODIGO)
	LEFT OUTER JOIN CARTORIO CT
		ON (CT.COD_CARTORIO = P.ID_CARTORIO)
	LEFT OUTER JOIN LY_FL_PESSOA FP
		ON (P.PESSOA = FP.PESSOA)
	LEFT OUTER JOIN ITEMTABELA IT
		ON (FP.FL_FIELD_03 = IT.ITEM
		AND IT.TAB = 'EscolarizacaoExterna')
	LEFT OUTER JOIN LY_FOTO_PESSOA FA
		ON (A.PESSOA = FA.PESSOA)
	LEFT OUTER JOIN HADES.dbo.TCE_MUNICIPIO TMA
		ON (P.END_MUNICIPIO = TMA.ID_MUNICIPIO)
	LEFT OUTER JOIN HADES.dbo.TCE_MUNICIPIO TM
		ON (P.MUNICIPIO_NASC = TM.ID_MUNICIPIO)

WHERE        (CM.ID_CONFIRMACAO_MATRICULA = @ID_CONFIRMACAO_MATRICULA)</CommandText>
      </Query>
