  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:DataSourceID>7045aa6a-7004-4a44-ba2d-836c76f0bc76</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_docente">
      <Fields>
        <Field Name="FACULDADE">
          <DataField>FACULDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUM_FUNC">
          <DataField>NUM_FUNC</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AULAS_PREVISTA">
          <DataField>AULAS_PREVISTA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT distinct  FACULDADE,NUM_FUNC,TURMA,DISCIPLINA,COUNT(AGENDA) AULAS_PREVISTA,XX.DATA 
FROM SE_AGENDA_AUX XX
WHERE	
	 EXISTS (SELECT 1 FROM LY_LISTA_FREQ FF 
					WHERE FF.ANO=XX.ANO
						AND FF.SEMESTRE=XX.SEMESTRE
						AND FF.TURMA=XX.TURMA
						AND FF.DISCIPLINA=XX.DISCIPLINA
						AND FF.AULA=XX.AULA
						AND FF.DIA_SEMANA=XX.DIA_SEMANA
						AND FF.DT_AULA=XX.DATA
						AND FF.FACULDADE=XX.FACULDADE
						AND FF.TURNO=XX.TURNO)
AND XX.NUM_FUNC=@p_matricula AND XX.DATA&gt;=@p_dt_ini AND XX.DATA&lt;=@p_dt_fim
and XX.FACULDADE=@p_unidade
GROUP BY FACULDADE,NUM_FUNC,TURMA,DISCIPLINA,XX.DATA</CommandText>
        <QueryParameters>
          <QueryParameter Name="@p_dt_ini">
            <Value>=Parameters!p_dt_ini.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_dt_fim">
            <Value>=Parameters!p_dt_fim.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_matricula">
            <Value>=Parameters!p_matricula.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_unidade">
            <Value>=Parameters!p_unidade.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
