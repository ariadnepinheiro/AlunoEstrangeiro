      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
	SS.NUCLEO
	,SUBSTRING(NN.DESCRICAO,1,35)COORDENADORIA
	,SS.MUNICIPIO
	,MI.NOME NOME_MUNICIPIO
	,SS.UNIDADE_ENS
	,SS.SETOR
	,SS.NOME_COMP
	,SQL0.TOTAL_ENTURM [TOTAL DE ALUNOS ENTURMADOS ATÉ MARÇO]
	,SQL1.TOTAL_ENT_1
	,SQL2.TOTAL_ENT_2
	,SQL3.TOTAL_ENT_3
	,SQL4.TOTAL_ENT_4
	,SQL5.TOTAL_ENT_5
	,SQL6.TOTAL_ENT_6
	,SQL7.TOTAL_ENT_7
	,SQL8.TOTAL_ENT_8
	,SQL9.TOTAL_ENT_9
	,SQL10.TOTAL_ENT_10
	,SQL11.TOTAL_ENT_11
	,SQL12.TOTAL_ENT_12
	,SQL13.TOTAL_ENT_13
	,SQL14.TOTAL_ENT_14
	,SQL15.TOTAL_ENT_15
	,SQL16.TOTAL_ENT_16
FROM LY_UNIDADE_ENSINO SS
JOIN LY_NUCLEO NN ON NN.NUCLEO=SS.NUCLEO
JOIN MUNICIPIO MI ON MI.CODIGO=SS.MUNICIPIO
JOIN 
	(SELECT MAX(ORDEM)ORDEM,SITUACAO,UNIDADE_ENS 
			FROM LY_UNIDADE_ENSINO_SITUACAO 
			GROUP BY SITUACAO,UNIDADE_ENS)MM ON MM.UNIDADE_ENS=SS.UNIDADE_ENS AND MM.SITUACAO='ESTADUAL'
LEFT JOIN 
--TOTAL DE ALUNOS ENTURMADOS EM MARÇO
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENTURM
	,LY_ALUNO.UNIDADE_ENSINO 
FROM LY_MATRICULA
JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
WHERE   
	LY_MATRICULA.DT_INSERCAO BETWEEN '20100101' and '20100331'
AND
	LY_MATRICULA.SIT_MATRICULA='MATRICULADO'
GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL0 ON SQL0.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_1
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100401'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL1 ON SQL1.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_2
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100402'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL2 ON SQL2.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT  JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_3
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100403'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL3 ON SQL3.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT  JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_4
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100404'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL4 ON SQL4.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_5
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100405'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL5 ON SQL5.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_6
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100406'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL6 ON SQL6.UNIDADE_ENSINO=SS.UNIDADE_ENS	
	
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_7
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100407'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL7 ON SQL7.UNIDADE_ENSINO=SS.UNIDADE_ENS	
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_8
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100408'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL8 ON SQL8.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_9
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100409'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL9 ON SQL9.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_10
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100410'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL10 ON SQL10.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_11
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100411'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL11 ON SQL10.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_12
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100412'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL12 ON SQL10.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_13
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100413'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL13 ON SQL13.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_14
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100414'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL14 ON SQL14.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_15
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100415'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL15 ON SQL15.UNIDADE_ENSINO=SS.UNIDADE_ENS
LEFT JOIN 
(SELECT 
	COUNT(DISTINCT LY_MATRICULA.ALUNO)TOTAL_ENT_16
	,LY_ALUNO.UNIDADE_ENSINO
	FROM LY_MATRICULA
	JOIN LY_ALUNO ON LY_ALUNO.ALUNO=LY_MATRICULA.ALUNO
	WHERE DT_INSERCAO='20100416'
	AND SIT_MATRICULA='MATRICULADO'
	GROUP BY LY_ALUNO.UNIDADE_ENSINO)SQL16 ON SQL16.UNIDADE_ENSINO=SS.UNIDADE_ENS

ORDER BY NN.DESCRICAO,MI.NOME,SS.NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
