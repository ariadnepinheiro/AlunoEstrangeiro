  <DataSets>
    <DataSet Name="dsFichaAtaMatricula">
      <Fields>
        <Field Name="SEXO">
          <DataField>SEXO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_NASC">
          <DataField>DT_NASC</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="NATURALIDADE">
          <DataField>NATURALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RESIDENCIA">
          <DataField>RESIDENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_PAI">
          <DataField>NOME_PAI</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_MAE">
          <DataField>NOME_MAE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NACIONALIDADE">
          <DataField>NACIONALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROFISSAO_PAI">
          <DataField>PROFISSAO_PAI</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROFISSAO_MAE">
          <DataField>PROFISSAO_MAE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>Relat_FichaAtaMatricula</CommandText>
        <QueryParameters>
          <QueryParameter Name="@CURSO">
            <Value>=Parameters!p_curso.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!p_turno.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURMA">
            <Value>=Parameters!p_turma.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="dsRestricaoAcesso">
      <Fields>
        <Field Name="USUARIO">
          <DataField>USUARIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>Relat_RestricaoAcesso</CommandText>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="dsCoordenadoria">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCR">
          <DataField>DESCR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandText>SELECT DISTINCT NUCLEO  AS CODIGO, (NUCLEO + ' - ' + DESCRICAO) AS DESCR
FROM LY_NUCLEO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="dsUnidadeEnsino">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCR">
          <DataField>DESCR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandText>SELECT UNIDADE_ENS AS CODIGO, UNIDADE_ENS + ' - ' + NOME_COMP AS DESCR
FROM LY_UNIDADE_ENSINO
WHERE NUCLEO = @p_coordenadoria</CommandText>
        <QueryParameters>
          <QueryParameter Name="@p_coordenadoria">
            <Value>=Parameters!p_coordenadoria.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="dsCurso">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCR">
          <DataField>DESCR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandText>SELECT LY_UNIDADE_ENSINO_CURSOS.CURSO AS CODIGO, LY_UNIDADE_ENSINO_CURSOS.CURSO + '-' + LY_CURSO.NOME AS DESCR FROM LY_UNIDADE_ENSINO_CURSOS, LY_CURSO
WHERE LY_UNIDADE_ENSINO_CURSOS.CURSO=LY_CURSO.CURSO AND
UNIDADE_ENS = @p_unidade_ensino</CommandText>
        <QueryParameters>
          <QueryParameter Name="@p_unidade_ensino">
            <Value>=Parameters!p_unidade_ensino.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="dsTipoIngresso">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCR">
          <DataField>DESCR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandText>SELECT DISTINCT TIPO_INGRESSO AS CODIGO, TIPO_INGRESSO AS DESCR
FROM LY_ALUNO
UNION
SELECT NULL AS CODIGO, 'TODOS' AS DESCR
ORDER BY TIPO_INGRESSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="dsTurno">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCR">
          <DataField>DESCR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandText>SELECT TURNO AS CODIGO, TURNO + '-'+ DESCRICAO AS DESCR FROM LY_TURNO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="dsTurma">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCR">
          <DataField>DESCR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LyceumDataSource</DataSourceName>
        <CommandText>SELECT DISTINCT TURMA AS CODIGO, TURMA AS DESCR FROM LY_TURMA
WHERE (CURSO = @p_curso OR CURSO IS NULL) AND
             (TURNO = @p_turno OR TURNO IS NULL)
UNION
SELECT NULL AS CODIGO, 'TODAS' AS DESCR</CommandText>
        <QueryParameters>
          <QueryParameter Name="@p_curso">
            <Value>=Parameters!p_curso.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@p_turno">
            <Value>=Parameters!p_turno.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
