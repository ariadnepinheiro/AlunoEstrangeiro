  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>229031ba-5c11-4e90-a47d-c1621f78e578</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT REGIONAL, 
  MM.NOME,
  UE.UNIDADE_ENS,
  UE.NOME_COMP,   
  @ANO ANO,
  A.ALUNO, 
  A.NOME_COMPL NOME_ALUNO
FROM LY_ALUNO A (NOLOCK)
JOIN LY_UNIDADE_ENSINO UE (NOLOCK)
ON  UE.UNIDADE_ENS = A.UNIDADE_ENSINO
JOIN TCE_REGIONAL N (NOLOCK)
ON  N.ID_REGIONAL = UE.ID_REGIONAL
JOIN MUNICIPIO MM (NOLOCK)
ON  MM.CODIGO = UE.MUNICIPIO
WHERE NOT EXISTS (
					 SELECT 1
					 FROM LY_H_CURSOS_CONCL H WITH (NOLOCK)
					 WHERE H.ALUNO = A.ALUNO
					 AND  H.DT_REABERTURA IS NULL
					 )
AND  EXISTS (
    SELECT 1
    FROM LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
    WHERE US.UNIDADE_ENS = UE.UNIDADE_ENS
    AND  US.SITUACAO = 'ESTADUAL'
    AND  US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
                    (
                    SELECT UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
                    FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
                    )
    )
AND  (UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND  A.ANO_INGRESSO &lt; @ANO
AND  NOT EXISTS (
				 SELECT 1
				 FROM LY_SERIE S (NOLOCK)
				 WHERE S.CURSO = A.CURSO
				 AND  S.CURRICULO = A.CURRICULO
				 AND  S.TURNO = A.TURNO
				 AND  S.SERIE = A.SERIE
				 AND  S.ANO_SERIE_CONCLUINTE = 'S' 
				 )
AND		UE.UNIDADE_ENS = @ESCOLA
AND		NOT EXISTS (
					SELECT	1
					FROM	TCE_CONFIRMACAO_MATRICULA C WITH (NOLOCK) 
					WHERE	A.ALUNO = C.ALUNO
					AND		C.ANO = @ANO
					)
</CommandText>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Object</rd:TypeName>
        </Field>
        <Field Name="NOME_ALUNO">
          <DataField>NOME_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 0 nucleo,' Selecione...' descricao 
union
select  l1.ID_REGIONAL,SUBSTRING(l1.REGIONAL,1,35) from TCE_REGIONAL L1
join LY_UNIDADE_ENSINO l2 on L1.ID_REGIONAL=l2.ID_REGIONAL
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS UF 
ON UF.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE UF.USUARIO = @usuario
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
where 
	(n1.ID_REGIONAL = ISNULL(@COORD,n1.ID_REGIONAL)or n1.ID_REGIONAL is null)
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS UF 
ON UF.UNIDADE_FIS = ue.UNIDADE_ENS
WHERE UF.USUARIO = @usuario
and (ue.ID_REGIONAL = ISNULL(@COORD,ue.ID_REGIONAL) or ue.ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO_LETIVO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT  DISTINCT ANO 
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
