          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	N.DESCRICAO COORDENADORIA, 
		M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, 
		MC.DESCRICAO MODALIDADE, TC.DESCRICAO SEGMENTO, 
		C.NOME ESCOLARIDADE, A.SERIE, A.TURNO, A.ALUNO, A.NOME_COMPL NOME_ALUNO
FROM	LY_ALUNO A (NOLOCK)
JOIN	LY_CURSO C (NOLOCK)
ON		A.CURSO = C.CURSO
JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
ON		MC.MODALIDADE = C.MODALIDADE
JOIN	LY_TIPO_CURSO TC (NOLOCK)
ON		TC.TIPO = C.TIPO
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		UE.UNIDADE_ENS = A.UNIDADE_ENSINO
JOIN	LY_NUCLEO N (NOLOCK)
ON		N.NUCLEO = UE.NUCLEO
JOIN	MUNICIPIO M (NOLOCK)
ON		M.CODIGO = UE.MUNICIPIO
WHERE	EXISTS (
				SELECT	1 
				FROM	LY_H_CURSOS_CONCL H (NOLOCK)
				WHERE	H.ALUNO = A.ALUNO
				AND		H.DT_REABERTURA IS NULL
				AND		H.MOTIVO = 'PROV_DES'
				AND	 YEAR(DT_ENCERRAMENTO) = YEAR(GETDATE())
				)
AND		EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK) 
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+US.ORDEM IN (SELECT UNIDADE_ENS+MAX(ORDEM) FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS)
				)
AND (N.nucleo = ISNULL(@coord, N.nucleo) OR N.nucleo IS NULL)       
AND (M.CODIGO = ISNULL(@municipio,  M.CODIGO) OR   M.CODIGO IS NULL)       
AND (UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
GROUP BY N.DESCRICAO, 
		M.NOME, UE.UNIDADE_ENS, UE.NOME_COMP, 
		MC.DESCRICAO, TC.DESCRICAO, 
		C.NOME, A.SERIE, A.TURNO, A.ALUNO, A.NOME_COMPL
ORDER BY N.DESCRICAO, M.NOME, UE.UNIDADE_ENS, MC.DESCRICAO, TC.DESCRICAO, 
		C.NOME, A.SERIE, A.TURNO, A.NOME_COMPL</CommandText>
      </Query>
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLARIDADE">
          <DataField>ESCOLARIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_ALUNO">
          <DataField>NOME_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_COORD">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' nucleo,' Selecione...' descricao 
union
select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.NUCLEO = ISNULL(@coord,n1.NUCLEO)or n1.NUCLEO is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' descricao 
union
select null codigo,' TODOS' nome  
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
order by NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="usuario">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>usuario</Prompt>
      <Hidden>true</Hidden>
    </ReportParameter>
    <ReportParameter Name="coord">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>COORDENADORIA</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>DS_COORD</DataSetName>
          <ValueField>nucleo</ValueField>
          <LabelField>descricao</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="municipio">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>MUNICÍPIO</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>MUNICIPIO</DataSetName>
          <ValueField>codigo</ValueField>
          <LabelField>nome</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="escola">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>ESCOLA</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>ESCOLA</DataSetName>
          <ValueField>UNIDADE_ENS</ValueField>
          <LabelField>NOME_COMP</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
  </ReportParameters>
