  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CENSO">
            <Value>=Parameters!CENSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
[CENSO]
      ,[QTDE_ALUNO]
      ,[TOTAL_FALTAS]
      ,[MODALIDADE]
      ,[SEGMENTO]
      ,[TURNO]
      ,[TOTAL_AULAS_DADAS]
      ,ROUND(CONVERT(FLOAT, REPLACE(PERC_FALTAS, ',' , '.')),2) as PERC_FALTAS
      ,NOME_COMP AS ESCOLA
  FROM [Metas].[dbo].[FREQUENCIA_GERAL_ALUNOS] F
  INNER JOIN [LYCEUM].dbo.LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = F.CENSO
  WHERE F.CENSO=@CENSO
AND F.ANO=YEAR(GETDATE())
order by modalidade,segmento,turno</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="QTDE_ALUNO">
          <DataField>QTDE_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_FALTAS">
          <DataField>TOTAL_FALTAS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
