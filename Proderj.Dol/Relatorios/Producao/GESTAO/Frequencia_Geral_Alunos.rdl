        </Field>
        <Field Name="TOTAL_AULAS_DADAS">
          <DataField>TOTAL_AULAS_DADAS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERC_FALTAS">
          <DataField>PERC_FALTAS</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
