  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null id_regional,' TODAS' regional 
union
select  l1.id_regional,SUBSTRING(l1.regional,1,35) from tce_regional L1
join LY_UNIDADE_ENSINO l2 on L1.id_regional=l2.id_regional
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by regional</CommandText>
      </Query>
      <Fields>
        <Field Name="id_regional">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="regional">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join tce_regional r on r.id_regional = l2.id_regional
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(r.id_regional = ISNULL(@coord,r.id_regional)or r.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' descricao 
union
select null codigo,' TODOS' nome  
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.NUCLEO = ISNULL(@coord,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@municipio,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
order by NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	N.REGIONAL, MM.NOME MUNICIPIO, 
		UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, 
		(
		SELECT	CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM_CUMPRIDO),0))/CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM),0)) *100
		FROM	APOLLO..REL_CURRICULO_MINIMO M
		WHERE	M.UNIDADE_ENS = UE.UNIDADE_ENS
		AND		M.BIMESTRE = '1'
		AND		M.ANO = @ANO
		) BIM1,
		(
		SELECT	CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM_CUMPRIDO),0))/CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM),0)) *100
		FROM	APOLLO..REL_CURRICULO_MINIMO M
		WHERE	M.UNIDADE_ENS = UE.UNIDADE_ENS
		AND		M.BIMESTRE = '2'
		AND		M.ANO = @ANO
		) BIM2,
		(
		SELECT	CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM_CUMPRIDO),0))/CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM),0)) *100
		FROM	APOLLO..REL_CURRICULO_MINIMO M
		WHERE	M.UNIDADE_ENS = UE.UNIDADE_ENS
		AND		M.BIMESTRE = '3'
		AND		M.ANO = @ANO
		) BIM3,
		(
		SELECT	CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM_CUMPRIDO),0))/CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM),0)) *100
		FROM	APOLLO..REL_CURRICULO_MINIMO M
		WHERE	M.UNIDADE_ENS = UE.UNIDADE_ENS
		AND		M.BIMESTRE = '4'
		AND		M.ANO = @ANO		
		) BIM4
FROM	LY_UNIDADE_ENSINO UE
JOIN	TCE_REGIONAL N 
ON		N.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO MM 
ON		MM.CODIGO = UE.MUNICIPIO
WHERE	EXISTS (
					SELECT 1
					FROM LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
					WHERE US.UNIDADE_ENS = UE.UNIDADE_ENS
					AND  US.SITUACAO = 'ESTADUAL'
					AND  US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
									(
									SELECT UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
									FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
									)
			    )
AND  (UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND		EXISTS (
				SELECT	1
				FROM	APOLLO..REL_CURRICULO_MINIMO M1
				WHERE	M1.UNIDADE_ENS = UE.UNIDADE_ENS
				)				
AND (N.ID_REGIONAL = ISNULL(@coord, N.ID_REGIONAL) OR N.ID_REGIONAL IS NULL)       
AND (MM.CODIGO = ISNULL(@municipio,  MM.CODIGO) OR   MM.CODIGO IS NULL)       
AND (UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BIM1">
          <DataField>BIM1</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="BIM2">
          <DataField>BIM2</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="BIM3">
          <DataField>BIM3</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="BIM4">
          <DataField>BIM4</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
