  <Width>12.5891in</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin>
    <RightMargin>2cm</RightMargin>
    <TopMargin>2cm</TopMargin>
    <BottomMargin>2cm</BottomMargin>
    <ColumnSpacing>0.13cm</ColumnSpacing>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	COORDENADORIA, CENSO, ESCOLA, MUNICIPIO, COUNT(ALUNO) QTDE_ALUNOS, SUM(ENTURMADOS) QTDE_ENTURMADOS
FROM (
		SELECT	N.DESCRICAO COORDENADORIA, UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, A.ALUNO, MM.NOME MUNICIPIO, 
		ISNULL((
		SELECT	TOP 1 1
		FROM	LY_MATRICULA M (NOLOCK)
		WHERE	M.ANO = @ANO
		AND		M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
		AND		M.ALUNO = A.ALUNO		
		),0) ENTURMADOS
FROM	LY_ALUNO A (NOLOCK) 
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) 
ON		UE.UNIDADE_ENS = A.UNIDADE_ENSINO
JOIN	LY_NUCLEO N (NOLOCK) 
ON		N.NUCLEO = UE.NUCLEO
JOIN	MUNICIPIO MM
ON		MM.CODIGO = UE.MUNICIPIO
WHERE	EXISTS (
				SELECT	1 
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK) 
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS + ORDEM IN (SELECT UNIDADE_ENS+MAX(ORDEM) FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS)
				)
AND		NOT EXISTS (
					SELECT	1
					FROM	LY_H_CURSOS_CONCL H (NOLOCK) 
					WHERE	H.ALUNO = A.ALUNO
					AND		H.DT_REABERTURA IS NULL
					)					
)	G						
GROUP BY G.COORDENADORIA, CENSO, ESCOLA, MUNICIPIO</CommandText>
      </Query>
      <Fields>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS">
          <DataField>QTDE_ALUNOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_ENTURMADOS">
          <DataField>QTDE_ENTURMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
