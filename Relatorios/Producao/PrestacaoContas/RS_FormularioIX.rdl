                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>4- Semestre Letivo: </Value>
                              <Style>
                                <FontFamily>Arial Narrow</FontFamily>
                              </Style>
                            </TextRun>
                            <TextRun>
                              <Value>=CStr(Fields!PERIODOLY.Value) + "/" + CStr(Fields!ANOLY.Value)</Value>
