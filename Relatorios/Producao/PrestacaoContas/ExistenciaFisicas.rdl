  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.197;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>229031ba-5c11-4e90-a47d-c1621f78e578</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Existencias">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@UNIDADEADMINISTRATIVA">
            <Value>=Parameters!UNIDADEADMINISTRATIVA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CLASSIFICACAO">
            <Value>=Parameters!CLASSIFICACAO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>DECLARE @DATA DATE = CONVERT(DATE ,(CONVERT(VARCHAR,@ANO)  +'-12-31'))

CREATE TABLE #UASREGIONAL
  (
     SETORID VARCHAR(50)
  )

IF ( @REGIONAL &gt; 0
     AND @UNIDADEADMINISTRATIVA IS NULL )
  BEGIN
      INSERT INTO #UASREGIONAL
      SELECT DISTINCT SETORID
      FROM   HADES.DBO.REGIONAL__SETOR (NOLOCK)
      WHERE  REGIONALID = @REGIONAL

      INSERT INTO #UASREGIONAL
      SELECT DISTINCT SETOR AS SETORID
      FROM   LY_UNIDADE_ENSINO (NOLOCK)
      WHERE  ID_REGIONAL = @REGIONAL
  END

IF ( @REGIONAL &gt; 0
     AND @UNIDADEADMINISTRATIVA &gt; 0 )
  BEGIN
      INSERT INTO #UASREGIONAL
      SELECT DISTINCT SETOR AS SETORID
      FROM   SETOR (NOLOCK)
      WHERE  SETOR = @UNIDADEADMINISTRATIVA
  END

SELECT DISTINCT SE.NOME                          AS UNIDADEADMINISTRATIVA,
                C.CONTA,
                Replicate('0', 6 - Len(MV.NUMERO))
                + CONVERT(VARCHAR(6), MV.NUMERO) AS NUMERO,
                B.DESCRICAO,
                'Unid'                           AS UNIDADEMEDIDA,
                1                                AS QUANTIDADE,
                PATRIMONIO.FN_CALCULOVALORATUALIZADO(B.BEMID, @DATA,
                I.DATAINICIO, I.VALOR,
                CV.TAXAVALORRESIDUAL,CV.VIDAUTIL)            AS VALORCALCULADO,
                CASE
                  WHEN T.TRANSFERENCIAITEMID IS NOT NULL THEN
                  'ATBM: '
                  + CONVERT(VARCHAR(20), T.TRANSFERENCIAID)
                  + '/'
                  + CONVERT(VARCHAR(20), Year(T.DATAANDAMENTO))
                  ELSE B.DOCUMENTOHABIL
                END                              OBSERVACAO,
                MV.SETOR,
                C.CLASSIFICACAOID,
                B.BEMID,
                MV.DATAINICIO,
                MV.DATAFIM
FROM   PATRIMONIO.BEM B
       INNER JOIN PATRIMONIO.CLASSIFICACAOVIGENCIA CV (NOLOCK)
               ON B.CLASSIFICACAOID = CV.CLASSIFICACAOID
                  AND CV.DATAINICIO &lt;= @DATA
                  AND ( CV.DATAFIM IS NULL
                         OR CV.DATAFIM &gt;= @DATA )
       INNER JOIN PATRIMONIO.MOVIMENTACAO MV (NOLOCK)
               ON B.BEMID = MV.BEMID
                  AND MV.DATAINICIO &lt;= @DATA
                  AND ( MV.DATAFIM IS NULL
                         OR MV.DATAFIM &gt;= @DATA )
       INNER JOIN #UASREGIONAL UR
               ON MV.SETOR = UR.SETORID
       INNER JOIN HADES.DBO.HD_SETOR SE (NOLOCK)
               ON SE.SETOR = MV.SETOR
       INNER JOIN PATRIMONIO.BEMVALOR I (NOLOCK)
               ON B.BEMID = I.BEMID
                  AND I.DATAINICIO &lt;= @DATA
                  AND ( I.DATAFIM IS NULL
                         OR I.DATAFIM &gt;= @DATA )
       INNER JOIN PATRIMONIO.CLASSIFICACAO C (NOLOCK)
               ON B.CLASSIFICACAOID = C.CLASSIFICACAOID
       LEFT JOIN (SELECT T.TRANSFERENCIAID,
                         T.SETORDESTINO,
                         T.DATAANDAMENTO,
                         TI.BEMID,
                         TI.TRANSFERENCIAITEMID
                  FROM   PATRIMONIO.TRANSFERENCIA T (NOLOCK)
                         INNER JOIN PATRIMONIO.TRANSFERENCIAITEM TI (NOLOCK)
                                 ON T.TRANSFERENCIAID = TI.TRANSFERENCIAID
                  WHERE  SITUACAO = 'ACEITA') T
              ON CONVERT(DATE, T.DATAANDAMENTO) = MV.DATAINICIO
                 AND T.BEMID = B.BEMID
                 AND T.SETORDESTINO = MV.SETOR
WHERE  ( B.DATABAIXA IS NULL
          OR B.DATABAIXA &gt; @DATA )
       AND ( MV.SETOR = ISNULL(@UNIDADEADMINISTRATIVA, MV.SETOR) )
       AND ( C.CLASSIFICACAOID = ISNULL(@CLASSIFICACAO, C.CLASSIFICACAOID) )
ORDER  BY UNIDADEADMINISTRATIVA,
          C.CONTA,
          NUMERO  

                                   
                                        DROP TABLE #UASREGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADEADMINISTRATIVA">
          <DataField>UNIDADEADMINISTRATIVA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CONTA">
          <DataField>CONTA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADEMEDIDA">
          <DataField>UNIDADEMEDIDA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QUANTIDADE">
          <DataField>QUANTIDADE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VALORCALCULADO">
          <DataField>VALORCALCULADO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="OBSERVACAO">
          <DataField>OBSERVACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CLASSIFICACAOID">
          <DataField>CLASSIFICACAOID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="BEMID">
          <DataField>BEMID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DATAINICIO">
          <DataField>DATAINICIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATAFIM">
          <DataField>DATAFIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>EXEC zzCRO_VarsSet 'OFFLINE', @usuario, NULL, 'S', ''

select  distinct R.ID_REGIONAL as regional, R.REGIONAL as descricao 
from VW_UNIDADE_ENSINO_SITUACAO uuf
                                join TCE_REGIONAL R on R.ID_REGIONAL = uuf.ID_REGIONAL
where exists (
select distinct ue.ID_REGIONAL from LY_USUARIO_UNIDADE_FIS LUUF 
inner join LY_UNIDADE_ENSINO ue on ue.UNIDADE_ENS=LUUF.UNIDADE_FIS
where (LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO)) and ue.ID_REGIONAL is not null
and ue.ID_REGIONAL=R.ID_REGIONAL
)
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="regional">
          <DataField>regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CLASSIFICACAO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>
select ' TODAS' CONTA,'' DESCRICAO , NULL CLASSIFICACAOID
union
SELECT CONTA + ' - '  + DESCRICAO as CONTA, DESCRICAO,CLASSIFICACAOID FROM [LYCEUM].[Patrimonio].[CLASSIFICACAO]
where ativo = 1
order by CONTA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CLASSIFICACAOID">
          <DataField>CLASSIFICACAOID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONTA">
          <DataField>CONTA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="UA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@regional">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null setor, ' TODAS' nome , ' TODAS' descricao
union
SELECT setor, (SETOR + ' - ' + nome), nome as descricao   from VW_UNIDADE_ADMINISTRATIVA_REGIONAL
where (regionalid= ISNULL(@regional,regionalid) or regionalid is null)
and exists (
select distinct ue.ID_REGIONAL from LY_USUARIO_UNIDADE_FIS LUUF 
inner join LY_UNIDADE_ENSINO ue on ue.UNIDADE_ENS=LUUF.UNIDADE_FIS
where (LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO)) 
and ue.ID_REGIONAL=regionalid
)

order by descricao </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="setor">
          <DataField>setor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO_LETIVO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!ANO.Value</FilterExpression>
          <Operator>LessThanOrEqual</Operator>
          <FilterValues>
            <FilterValue>=Year(Today)</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
  </DataSets>
