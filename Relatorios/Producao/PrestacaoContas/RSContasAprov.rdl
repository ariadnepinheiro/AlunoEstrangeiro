      <Query>
        <DataSourceName>DS_ContAprov</DataSourceName>
        <CommandText>select ID,DESCPERIODOREF+' (de '+CONVERT(varchar,DATAINIAPLICACAO,103)+' a '+CONVERT(varchar,DATAFIMAPLICACAO,103)+')' DATA
from LY_PC_PERIODOREF
order by DATAINIAPLICACAO desc</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
