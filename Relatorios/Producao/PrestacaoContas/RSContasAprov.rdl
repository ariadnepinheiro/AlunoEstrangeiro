  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ContAprov">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3ec91d64-4eb9-4298-8d3d-1084e43a07bc</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_ContAprov">
      <Query>
        <DataSourceName>DS_ContAprov</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@periodoref">
            <Value>=Parameters!periodoref.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select DATAINIAPLICACAO,DATAFIMAPLICACAO,PERIODOLY,ANOLY 
from LY_PC_PERIODOREF
where ID=@periodoref
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DATAINIAPLICACAO">
          <DataField>DATAINIAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATAFIMAPLICACAO">
          <DataField>DATAFIMAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="PERIODOLY">
          <DataField>PERIODOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ANOLY">
          <DataField>ANOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Coordenadoria">
      <Query>
        <DataSourceName>DS_ContAprov</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@periodoref">
            <Value>=Parameters!periodoref.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>with aprovadas(UNIDADELY,NUCLEOLY,TIPO) as 
( 
select distinct e.unidade_ens as UNIDADELY, e.nucleo as NUCLEOLY, 'Unidade de Ensino' as TIPO 
from LY_PC_PRESTADOR p 
inner join LY_UNIDADE_ENSINO e on p.UNIDADELY=e.unidade_ens
inner join LY_PC_PRESTACAOCONTAS pc on pc.ID_PRESTADOR=p.ID 
inner join LY_PC_SITUACAO sit on sit.ID=pc.ID_SITUACAO
where pc.ID_PERIODOREF=@periodoref and p.NUCLEOLY is null
and sit.TIPO='A'
union all 
select distinct p.UNIDADELY,p.NUCLEOLY, 'Coordenadoria' as TIPO  
from LY_PC_PRESTADOR p 
inner join LY_PC_PRESTACAOCONTAS pc on pc.ID_PRESTADOR=p.ID 
inner join LY_PC_SITUACAO sit on sit.ID=pc.ID_SITUACAO
where pc.ID_PERIODOREF=@periodoref and p.UNIDADELY is null
and sit.TIPO='A'
)
select 
ISNULL(aprovadas.UNIDADELY,aprovadas.NUCLEOLY) CODIGO, 
ISNULL(ue.NOME_COMP,nu.DESCRICAO) NOME,
nu.DESCRICAO as NOME_COORDENADORIA,
aprovadas.UNIDADELY,aprovadas.NUCLEOLY,aprovadas.TIPO
from aprovadas  
left outer join LY_UNIDADE_ENSINO ue on ue.UNIDADE_ENS=aprovadas.UNIDADELY 
left outer join LY_NUCLEO nu on nu.NUCLEO=aprovadas.NUCLEOLY 
order by nu.DESCRICAO,aprovadas.TIPO,ISNULL(ue.NOME_COMP,nu.DESCRICAO) </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
