    <DataSet Name="ds_15">
      <Query>
        <DataSourceName>DS_FormularioIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select SUM(mb.VALOR) VALOR, MONTH(mb.DATA) MES
from LY_PC_MOVBANCO mb
inner join LY_PC_TIPOMOVBANC tm on mb.ID_TIPOMOV=tm.ID
where tm.TIPO='A' 
and mb.ID_PRESTCONTAS=@ID_PRESTCONTAS 
and mb.ID_CONTABANCO=@ID_CONTABANCO
GROUP BY MONTH(mb.DATA)
  </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="VALOR">
          <DataField>VALOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MES">
          <DataField>MES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
