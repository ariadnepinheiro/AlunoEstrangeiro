  <DataSets>
    <DataSet Name="ds_Cabecalho">
      <Query>
        <DataSourceName>DS_FormularioIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct fr.CODIGO_FORMULARIO, UPPER(fr.NOME) NOME
from LY_PC_CONTABANCO cb
inner join  LY_PC_FONTERECURSO fr on cb.ID_FONTERECURSO=fr.ID
where cb.ID=@ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO_FORMULARIO">
          <DataField>CODIGO_FORMULARIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco1">
      <Query>
        <DataSourceName>DS_FormularioIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select cb.titular,
	cb.cnpj,
	pr.DATAINIAPLICACAO,
	pr.DATAFIMAPLICACAO,
	pr.PERIODOLY,
	pr.ANOLY,
	b.NOME as NOME_BANCO, 
	cb.BANCO, 
	ag.NOME as NOME_AGENCIA, 
	cb.AGENCIA, 
	cb.CONTA, 
	cb.ID as ID_CONTABANCO,
	pc.DATA_INICIO,
	pc.DATA_FIM
from LY_PC_CONTABANCO cb
inner join  LY_PC_PRESTACAOCONTAS PC on cb.ID_PRESTADOR=PC.ID_PRESTADOR
inner join  LY_PC_PERIODOREF pr on pr.ID=PC.ID_PERIODOREF
left outer join BANCOS b on cb.BANCO=b.BANCO
left outer join AGENCIAS ag on cb.AGENCIA=ag.AGENCIA and cb.BANCO=ag.BANCO
where PC.ID = @ID_PRESTCONTAS 
	and cb.ID = @ID_CONTABANCO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="titular">
          <DataField>titular</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cnpj">
          <DataField>cnpj</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATAINIAPLICACAO">
          <DataField>DATAINIAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATAFIMAPLICACAO">
          <DataField>DATAFIMAPLICACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="PERIODOLY">
          <DataField>PERIODOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ANOLY">
          <DataField>ANOLY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME_BANCO">
          <DataField>NOME_BANCO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BANCO">
          <DataField>BANCO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME_AGENCIA">
          <DataField>NOME_AGENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AGENCIA">
          <DataField>AGENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CONTA">
          <DataField>CONTA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_CONTABANCO">
          <DataField>ID_CONTABANCO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA_INICIO">
          <DataField>DATA_INICIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATA_FIM">
          <DataField>DATA_FIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2">
      <Query>
        <DataSourceName>DS_FormularioIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select mb.DATA,mb.VALOR, CBS.SALDO_INICIAL, ISNULL(mb.VALOR,0) + ISNULL(CBS.SALDO_INICIAL,0) TOTAL
from LY_PC_MOVBANCO mb
inner join LY_PC_TIPOMOVBANC tm on mb.ID_TIPOMOV=tm.ID
left join LY_PC_CONTABANCO_SALDO cbs on cbs.ID_CONTABANCO = mb.ID_CONTABANCO
									and cbs.ID_PRESTCONTAS = mb.ID_PRESTCONTAS
where  CBS.ID_PRESTCONTAS=@ID_PRESTCONTAS and CBS.ID_CONTABANCO=@ID_CONTABANCO
and tm.TIPO='R' </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SALDO_INICIAL">
          <DataField>SALDO_INICIAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="VALOR">
          <DataField>VALOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TOTAL">
          <DataField>TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_1">
      <Query>
        <DataSourceName>DS_FormularioIII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_CONTABANCO">
            <Value>=Parameters!ID_CONTABANCO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DT_INI">
            <Value>=Parameters!DT_INI.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DT_FIM">
            <Value>=Parameters!DT_FIM.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
			select cb.titular,
			cb.cnpj,
			pr.DATAINIAPLICACAO,
			pr.DATAFIMAPLICACAO,
			pr.PERIODOLY,
			pr.ANOLY,
			b.NOME as NOME_BANCO,
			cb.BANCO,
			ag.NOME as NOME_AGENCIA,
			cb.AGENCIA,
			cb.CONTA,
			cb.ID as ID_CONTABANCO,
			pc.DATA_INICIO,
			pc.DATA_FIM,
			mb.ID_PRESTCONTAS,
			mb.ID_CONTABANCO,
			mb.ID,
			mb.DATA,
			mb.VALOR,
			mb.ID_FINALIDADE,
			fin.CODIGO,
			month(mb.DATA) as mes,
			(
			select	sum(cbsf.SALDO)
			from LY_PC_CBS_FINALIDADE cbsf
			inner join	LY_PC_CONTABANCO_SALDO cbs on cbsf.ID_CONTABANCO_SALDO = cbs.ID
			where  CBS.ID_PRESTCONTAS=@ID_PRESTCONTAS and CBS.ID_CONTABANCO=@ID_CONTABANCO
			and cbsf.ID_FINALIDADE = mb.ID_FINALIDADE
			) as SALDO_INICIAL,
			(
			select sum(mbx.VALOR) as total
			from LY_PC_MOVBANCO mbx
			inner join LY_PC_TIPOMOVBANC tmx on mbx.ID_TIPOMOV = tmx.ID
			where tmx.TIPO = 'R'
			and mbx.ID_PRESTCONTAS = @ID_PRESTCONTAS
			and mbx.ID_CONTABANCO = @ID_CONTABANCO
			and mbx.DATA between @DT_INI and @DT_FIM
			and mbx.DATA &lt;= mb.data
			and mbx.ID &lt;= mb.ID
			and month(mbx.data) = month(mb.data)
			and mbx.ID_FINALIDADE = mb.ID_FINALIDADE
			) as total_parcial,
			(
			select sum(mby.VALOR) as total
			from LY_PC_MOVBANCO mby
			inner join LY_PC_TIPOMOVBANC tmy on mby.ID_TIPOMOV = tmy.ID
			where tmy.TIPO = 'R'
			and mby.ID_PRESTCONTAS = @ID_PRESTCONTAS
			and mby.ID_CONTABANCO = @ID_CONTABANCO
			and mby.DATA between @DT_INI and @DT_FIM
			and mby.DATA &lt;= mb.data
			and mby.ID &lt;= mb.ID
			and mby.ID_FINALIDADE = mb.ID_FINALIDADE
			) as total_acumulado,
			(
			select sum(mbz.VALOR) VALOR
			from LY_PC_MOVBANCO mbz
			inner join LY_PC_TIPOMOVBANC tmz on mbz.ID_TIPOMOV = tmz.ID
			where tmz.TIPO='A'
			and mbz.ID_PRESTCONTAS = @ID_PRESTCONTAS
			and mbz.ID_CONTABANCO = @ID_CONTABANCO
			AND month(mbz.data) = month(mb.DATA)
			and mbz.ID_FINALIDADE = mb.ID_FINALIDADE
			) as APLIC_FIN,
			(
			select sum(mba.VALOR) VALOR
			from LY_PC_MOVBANCO mba
			inner join LY_PC_TIPOMOVBANC tma on mba.ID_TIPOMOV = tma.ID
			where tma.TIPO = 'A'
			and mba.ID_PRESTCONTAS = @ID_PRESTCONTAS
			and mba.ID_CONTABANCO = @ID_CONTABANCO
			and month(mba.data) &lt;= month(mb.DATA)
			and mba.ID_FINALIDADE = mb.ID_FINALIDADE
	) as APLIC_FIN_ACUM,	
	(
		ISNULL((
			select sum(mba.VALOR) VALOR
			from LY_PC_MOVBANCO mba
			inner join LY_PC_TIPOMOVBANC tma on mba.ID_TIPOMOV = tma.ID
			where tma.TIPO = 'A' 
				and mba.ID_PRESTCONTAS = @ID_PRESTCONTAS 
				and mba.ID_CONTABANCO = @ID_CONTABANCO
				and month(mba.data) &lt;= month(mb.DATA)
				and mba.ID_FINALIDADE = mb.ID_FINALIDADE
		),0)
		-
		ISNULL((
			select sum(mbz.VALOR) VALOR
			from LY_PC_MOVBANCO mbz
			inner join LY_PC_TIPOMOVBANC tmz on mbz.ID_TIPOMOV = tmz.ID
			where tmz.TIPO='A' 
				and mbz.ID_PRESTCONTAS = @ID_PRESTCONTAS 
				and mbz.ID_CONTABANCO = @ID_CONTABANCO
				AND month(mbz.data) = month(mb.DATA)
				and mbz.ID_FINALIDADE = mb.ID_FINALIDADE
		),0)		
	) AS APLIC_FIN_PARCIAL
from LY_PC_MOVBANCO mb
inner join LY_PC_TIPOMOVBANC tm on mb.ID_TIPOMOV = tm.ID
inner join LY_PC_FINALIDADE fin on mb.ID_FINALIDADE = fin.ID_FINALIDADE
left outer join LY_PC_CONTABANCO cb on cb.ID = mb.ID_CONTABANCO
inner join  LY_PC_PRESTACAOCONTAS PC on cb.ID_PRESTADOR=PC.ID_PRESTADOR and PC.ID = mb.ID_PRESTCONTAS
inner join  LY_PC_PERIODOREF pr on pr.ID=PC.ID_PERIODOREF
left outer join BANCOS b on cb.BANCO=b.BANCO
left outer join AGENCIAS ag on cb.AGENCIA=ag.AGENCIA and cb.BANCO=ag.BANCO
where tm.TIPO = 'R'
	and mb.ID_PRESTCONTAS = @ID_PRESTCONTAS
	and mb.ID_CONTABANCO = @ID_CONTABANCO
	and mb.DATA between @DT_INI and @DT_FIM
order by mb.ID_FINALIDADE, mb.DATA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
