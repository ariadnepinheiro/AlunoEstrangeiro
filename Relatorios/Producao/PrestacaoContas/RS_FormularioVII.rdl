  <DataSets>
    <DataSet Name="ds_Bloco1">
      <Query>
        <DataSourceName>DS_FormularioVII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select F1.C01_NOMEUE, F1.C03_CNPJ, F1.C19_NOME_DIRETOR,F1.C20_CPF_DIRETOR,
F1.C31_MATRICULA_DIRETOR
from LY_PC_FORMULARIO1 F1
where F1.ID_PRESTCONTAS=@ID_PRESTCONTAS
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="C03_CNPJ">
          <DataField>C03_CNPJ</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="C01_NOMEUE">
          <DataField>C01_NOMEUE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="C19_NOME_DIRETOR">
          <DataField>C19_NOME_DIRETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="C20_CPF_DIRETOR">
          <DataField>C20_CPF_DIRETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="C31_MATRICULA_DIRETOR">
          <DataField>C31_MATRICULA_DIRETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Bloco2">
      <Query>
        <DataSourceName>DS_FormularioVII</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_PRESTCONTAS">
            <Value>=Parameters!ID_PRESTCONTAS.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT de.TIPO_COMPROV,
	de.NUM_COMPROV,
	de.DATA,
	it.NOME,
	id.QUANTIDADE,
	id.INVENTARIO_INI,
	id.INVENTARIO_FIM,
	id.VALOR_UNITARIO,
	id.VALOR_TOTAL,
	id.DESCONTO
FROM LY_PC_ITEMDESPESA id
INNER JOIN LY_PC_DESPESA de ON de.ID = id.ID_DESPESA
INNER JOIN LY_SM_ITENS it ON id.ID_ITEM = it.ID
INNER JOIN LY_PC_COMPRA co ON de.ID_COMPRA = co.ID
WHERE co.ID_PRESTCONTAS = @ID_PRESTCONTAS AND it.TIPO_PATR = 'S'
ORDER BY de.DATA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TIPO_COMPROV">
          <DataField>TIPO_COMPROV</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUM_COMPROV">
          <DataField>NUM_COMPROV</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QUANTIDADE">
          <DataField>QUANTIDADE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="INVENTARIO_INI">
          <DataField>INVENTARIO_INI</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="INVENTARIO_FIM">
          <DataField>INVENTARIO_FIM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_UNITARIO">
          <DataField>VALOR_UNITARIO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_TOTAL">
          <DataField>VALOR_TOTAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DESCONTO">
          <DataField>DESCONTO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="ID_PRESTCONTAS">
      <DataType>String</DataType>
      <Prompt>ID PRESTCONTAS</Prompt>
    </ReportParameter>
