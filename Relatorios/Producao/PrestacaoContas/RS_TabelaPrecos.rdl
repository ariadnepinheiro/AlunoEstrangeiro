              <TextRuns>
                <TextRun>
                  <Value>="Validade: " &amp; Format(First(Fields!DATAINI.Value, "DataSet1"), "dd/MM/yyyy") &amp; " a " &amp; Format(First(Fields!DATAFIM.Value, "DataSet1"), "dd/MM/yyyy")</Value>
