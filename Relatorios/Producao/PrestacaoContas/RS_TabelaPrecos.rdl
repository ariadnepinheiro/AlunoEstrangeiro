  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="SeeducDataSource">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>876f5a00-4000-48fa-ba74-8c5913fd9a96</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>SeeducDataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@p_VALIDADE">
            <Value>=Parameters!p_VALIDADE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT it2.ID AS ID_PAI,
	it2.ITEMID AS ITEMID_PAI,
	it2.NOME AS NOME_PAI,
	it.ID,
	it.ITEMID,
	it.NOME,
	um.UNIDADE,
	pit.PRECO,
	pm.DATAINI,
	pm.DATAFIM
FROM LY_SM_PRECOSITEM pit
INNER JOIN LY_SM_ITENS it ON pit.IDITEM = it.ID
LEFT OUTER JOIN LY_SM_ITENS it2 ON it.ITEMPAI = it2.ID
INNER JOIN LY_SM_UNIDMED um ON it.UNIDADE = um.ID
INNER JOIN LY_SM_PRECOSMERCADO pm ON pit.IDPRECOSMERCADO = pm.ID
WHERE pm.ID = ISNULL(@p_VALIDADE, pm.ID)
ORDER BY it2.ID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_PAI">
          <DataField>ID_PAI</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ITEMID_PAI">
          <DataField>ITEMID_PAI</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_PAI">
          <DataField>NOME_PAI</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID">
          <DataField>ID</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ITEMID">
          <DataField>ITEMID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PRECO">
          <DataField>PRECO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATAINI">
          <DataField>DATAINI</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATAFIM">
          <DataField>DATAFIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
