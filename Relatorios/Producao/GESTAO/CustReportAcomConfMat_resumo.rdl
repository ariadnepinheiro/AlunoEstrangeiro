  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>846a0706-a34d-422f-af64-8b66b975e2df</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_MATRICULA">
            <Value>=Parameters!ID_MATRICULA.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	N.REGIONAL, 
		UE.UNIDADE_ENS CENSO, 
		UE.NOME_COMP ESCOLA, 
		MC.DESCRICAO MODALIDADE, 
		C.NOME CURSO, 
		V.SERIE, 
		V.TURNO, 
		V.VAGAS,
		V.ALOCADOS, 
		V.CONFIRMADOS, 
		V.NAO_CONFIRMADOS,
		V.NAO_COMPARECERAM
FROM 	APOLLO..SISMAT_VAGAS V (NOLOCK)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK) ON V.ESCOLA = UE.UNIDADE_ENS
JOIN 	LY_CURSO C (NOLOCK) ON C.CURSO = V.MODALIDADE
JOIN 	LY_MODALIDADE_CURSO MC (NOLOCK) ON MC.MODALIDADE = C.MODALIDADE
JOIN	TCE_REGIONAL N (NOLOCK) ON N.ID_REGIONAL = UE.ID_REGIONAL
WHERE     V.ANO = @ANO
AND		V.ID_MATRICULA = @ID_MATRICULA
AND (N.ID_REGIONAL = ISNULL(@REGIONAL, N.ID_REGIONAL) OR N.ID_REGIONAL IS NULL) 
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO) OR UE.MUNICIPIO IS NULL) 
AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
ORDER BY 
		N.REGIONAL, 
		UE.NOME_COMP,
		MC.DESCRICAO,
		C.NOME, 
		V.TURNO, 
		V.SERIE</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VAGAS">
          <DataField>VAGAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALOCADOS">
          <DataField>ALOCADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONFIRMADOS">
          <DataField>CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_CONFIRMADOS">
          <DataField>NAO_CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_COMPARECERAM">
          <DataField>NAO_COMPARECERAM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT 0 ID_REGIONAL,' Selecione...' REGIONAL 
ORDER BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT DISTINCT L1.CODIGO, L1.NOME FROM LY_UNIDADE_ENSINO L2 (NOLOCK)
JOIN HADES..MUNICIPIO L1 (NOLOCK) ON L1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..TCE_REGIONAL N1 (NOLOCK) ON N1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE 
	(N1.ID_REGIONAL = ISNULL(@REGIONAL,N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
	AND
	(JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT NULL CODIGO,' TODOS' NOME
UNION
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING (UE.NOME_COMP,1,50)NOME_COMP 
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
WHERE (R.ID_REGIONAL = ISNULL(@REGIONAL, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL) 
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>
SELECT DISTINCT ANO, ANO AS NOME 
FROM LYCEUM..LY_PERIODO_LETIVO (NOLOCK) 
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
