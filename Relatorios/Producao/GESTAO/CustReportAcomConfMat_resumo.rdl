    <ReportParameter Name="ID_MATRICULA">
      <DataType>Integer</DataType>
      <Prompt>PERÍODO DA MATRÍCULA</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>1</Value>
            <Label>Anual e 1o. semestre</Label>
