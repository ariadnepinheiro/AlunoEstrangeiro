<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="LYCEUM">
      <DataSourceReference>DS_TREINAMENTO</DataSourceReference>
      <rd:DataSourceID>3026eee8-b6eb-4a78-b97b-7e4085061b5b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="TransferenciaAlunos">
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ORIGEM">
          <DataField>UNIDADE_ORIGEM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA_ORIGEM">
          <DataField>COORDENADORIA_ORIGEM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA_ORIGEM">
          <DataField>ESCOLA_ORIGEM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO_ORIGEM">
          <DataField>MUNICIPIO_ORIGEM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_TRANSFERENCIA">
          <DataField>DATA_TRANSFERENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MOTIVO_TRANSFERENCIA">
          <DataField>MOTIVO_TRANSFERENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_DESTINO">
          <DataField>UNIDADE_DESTINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA_DESTINO">
          <DataField>ESCOLA_DESTINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA_DESTINO">
          <DataField>COORDENADORIA_DESTINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO_DESTINO">
          <DataField>MUNICIPIO_DESTINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>SELECT DISTINCT 
                         LY_ALUNO.ALUNO AS MATRICULA, PE.NOME_COMPL AS ALUNO, LY_COORDENADORIA_ORIGEM.DESCRICAO AS COORDENADORIA_ORIGEM, 
                         MUNICIPIO_ORIGEM.NOME AS MUNICIPIO_ORIGEM, LY_H_CURR_ALUNO.UNIDADE_ENSINO AS UNIDADE_ORIGEM, 
                         LY_UNIDADE_ENSINO_ORIGEM.NOME_COMP AS ESCOLA_ORIGEM, CONVERT(VARCHAR(10), LY_H_CURR_ALUNO.DT_TRANS, 103) 
                         AS DATA_TRANSFERENCIA, LY_H_CURR_ALUNO.MOTIVO AS MOTIVO_TRANSFERENCIA, 
                         LY_COORDENADORIA_DESTINO.DESCRICAO AS COORDENADORIA_DESTINO, MUNICIPIO_DESTINO.NOME AS MUNICIPIO_DESTINO, 
                         LY_ALUNO.UNIDADE_ENSINO AS UNIDADE_DESTINO, LY_UNIDADE_ENSINO_DESTINO.NOME_COMP AS ESCOLA_DESTINO
FROM            LY_ALUNO 
INNER JOIN     LY_PESSOA PE (NOLOCK) ON PE.PESSOA = LY_ALUNO.PESSOA
INNER JOIN
                         LY_H_CURR_ALUNO ON LY_ALUNO.ALUNO = LY_H_CURR_ALUNO.ALUNO INNER JOIN
                         LY_UNIDADE_ENSINO AS LY_UNIDADE_ENSINO_ORIGEM ON 
                         LY_UNIDADE_ENSINO_ORIGEM.UNIDADE_ENS = LY_H_CURR_ALUNO.UNIDADE_ENSINO INNER JOIN
                         LY_UNIDADE_ENSINO_SITUACAO AS UES_ORIGEM ON UES_ORIGEM.UNIDADE_ENS = LY_UNIDADE_ENSINO_ORIGEM.UNIDADE_ENS AND 
                         UES_ORIGEM.DT_SITUACAO =
                             (SELECT        MAX(DT_SITUACAO) AS Expr1
                               FROM            LY_UNIDADE_ENSINO_SITUACAO AS LY_UNIDADE_ENSINO_SITUACAO
                               WHERE        (LY_UNIDADE_ENSINO_ORIGEM.UNIDADE_ENS = UNIDADE_ENS)) INNER JOIN
                         LY_NUCLEO AS LY_COORDENADORIA_ORIGEM ON LY_UNIDADE_ENSINO_ORIGEM.NUCLEO = LY_COORDENADORIA_ORIGEM.NUCLEO INNER JOIN
                         MUNICIPIO AS MUNICIPIO_ORIGEM ON MUNICIPIO_ORIGEM.CODIGO = LY_UNIDADE_ENSINO_ORIGEM.MUNICIPIO INNER JOIN
                         LY_UNIDADE_ENSINO AS LY_UNIDADE_ENSINO_DESTINO ON LY_UNIDADE_ENSINO_DESTINO.UNIDADE_ENS = LY_ALUNO.UNIDADE_ENSINO INNER JOIN
                         LY_UNIDADE_ENSINO_SITUACAO AS UES_DESTINO ON UES_DESTINO.UNIDADE_ENS = LY_UNIDADE_ENSINO_DESTINO.UNIDADE_ENS AND 
                         UES_DESTINO.DT_SITUACAO =
                             (SELECT        MAX(DT_SITUACAO) AS Expr1
                               FROM            LY_UNIDADE_ENSINO_SITUACAO
                               WHERE        (LY_UNIDADE_ENSINO_DESTINO.UNIDADE_ENS = UNIDADE_ENS)) INNER JOIN
                         LY_NUCLEO AS LY_COORDENADORIA_DESTINO ON LY_UNIDADE_ENSINO_DESTINO.NUCLEO = LY_COORDENADORIA_DESTINO.NUCLEO INNER JOIN
                         MUNICIPIO AS MUNICIPIO_DESTINO ON LY_UNIDADE_ENSINO_DESTINO.MUNICIPIO = MUNICIPIO_DESTINO.CODIGO
WHERE        (MONTH(LY_H_CURR_ALUNO.DT_TRANS) &gt;= LEFT(@PERIODO_INICIAL, 2)) AND (YEAR(LY_H_CURR_ALUNO.DT_TRANS) = RIGHT(@PERIODO_INICIAL, 4)) 
                         AND (MONTH(LY_H_CURR_ALUNO.DT_TRANS) &lt;= LEFT(@PERIODO_FINAL, 2)) AND (YEAR(LY_H_CURR_ALUNO.DT_TRANS) = RIGHT(@PERIODO_FINAL, 4)) 
                         AND (LY_COORDENADORIA_ORIGEM.NUCLEO = @COORD_ORIGEM) AND (MUNICIPIO_ORIGEM.CODIGO = @MUNIC_ORIGEM) AND 
                         (LY_COORDENADORIA_DESTINO.NUCLEO = ISNULL(@COORD_DESTINO, LY_COORDENADORIA_DESTINO.NUCLEO) OR
                         LY_COORDENADORIA_DESTINO.NUCLEO IS NULL) AND (MUNICIPIO_DESTINO.CODIGO = ISNULL(@MUNIC_DESTINO, MUNICIPIO_DESTINO.CODIGO) OR
                         MUNICIPIO_DESTINO.CODIGO IS NULL) AND (UES_ORIGEM.UNIDADE_ENS = ISNULL(@ESCOLA_ORIGEM, UES_ORIGEM.UNIDADE_ENS) OR
                         UES_ORIGEM.UNIDADE_ENS IS NULL) AND (UES_DESTINO.UNIDADE_ENS = ISNULL(@ESCOLA_DESTINO, UES_DESTINO.UNIDADE_ENS) OR
                         UES_DESTINO.UNIDADE_ENS IS NULL) OR
                         (MONTH(LY_H_CURR_ALUNO.DT_TRANS) &gt;= LEFT(@PERIODO_INICIAL, 2)) AND (YEAR(LY_H_CURR_ALUNO.DT_TRANS) = RIGHT(@PERIODO_INICIAL, 4)) 
                         AND (YEAR(LY_H_CURR_ALUNO.DT_TRANS) &lt; RIGHT(@PERIODO_FINAL, 4)) AND (LY_COORDENADORIA_ORIGEM.NUCLEO = @COORD_ORIGEM) AND 
                         (MUNICIPIO_ORIGEM.CODIGO = @MUNIC_ORIGEM) AND (LY_COORDENADORIA_DESTINO.NUCLEO = ISNULL(@COORD_DESTINO, 
                         LY_COORDENADORIA_DESTINO.NUCLEO) OR
                         LY_COORDENADORIA_DESTINO.NUCLEO IS NULL) AND (MUNICIPIO_DESTINO.CODIGO = ISNULL(@MUNIC_DESTINO, MUNICIPIO_DESTINO.CODIGO) OR
                         MUNICIPIO_DESTINO.CODIGO IS NULL) AND (UES_ORIGEM.UNIDADE_ENS = ISNULL(@ESCOLA_ORIGEM, UES_ORIGEM.UNIDADE_ENS) OR
                         UES_ORIGEM.UNIDADE_ENS IS NULL) AND (UES_DESTINO.UNIDADE_ENS = ISNULL(@ESCOLA_DESTINO, UES_DESTINO.UNIDADE_ENS) OR
                         UES_DESTINO.UNIDADE_ENS IS NULL) OR
                         (MONTH(LY_H_CURR_ALUNO.DT_TRANS) &lt;= LEFT(@PERIODO_FINAL, 2)) AND (YEAR(LY_H_CURR_ALUNO.DT_TRANS) &gt; RIGHT(@PERIODO_INICIAL, 4)) 
                         AND (YEAR(LY_H_CURR_ALUNO.DT_TRANS) = RIGHT(@PERIODO_FINAL, 4)) AND (LY_COORDENADORIA_ORIGEM.NUCLEO = @COORD_ORIGEM) AND 
                         (MUNICIPIO_ORIGEM.CODIGO = @MUNIC_ORIGEM) AND (LY_COORDENADORIA_DESTINO.NUCLEO = ISNULL(@COORD_DESTINO, 
                         LY_COORDENADORIA_DESTINO.NUCLEO) OR
                         LY_COORDENADORIA_DESTINO.NUCLEO IS NULL) AND (MUNICIPIO_DESTINO.CODIGO = ISNULL(@MUNIC_DESTINO, MUNICIPIO_DESTINO.CODIGO) OR
                         MUNICIPIO_DESTINO.CODIGO IS NULL) AND (UES_ORIGEM.UNIDADE_ENS = ISNULL(@ESCOLA_ORIGEM, UES_ORIGEM.UNIDADE_ENS) OR
                         UES_ORIGEM.UNIDADE_ENS IS NULL) AND (UES_DESTINO.UNIDADE_ENS = ISNULL(@ESCOLA_DESTINO, UES_DESTINO.UNIDADE_ENS) OR
                         UES_DESTINO.UNIDADE_ENS IS NULL) OR
                         (YEAR(LY_H_CURR_ALUNO.DT_TRANS) &gt; RIGHT(@PERIODO_INICIAL, 4)) AND (YEAR(LY_H_CURR_ALUNO.DT_TRANS) &lt; RIGHT(@PERIODO_FINAL, 4)) AND 
                         (LY_COORDENADORIA_ORIGEM.NUCLEO = @COORD_ORIGEM) AND (MUNICIPIO_ORIGEM.CODIGO = @MUNIC_ORIGEM) AND 
                         (LY_COORDENADORIA_DESTINO.NUCLEO = ISNULL(@COORD_DESTINO, LY_COORDENADORIA_DESTINO.NUCLEO) OR
                         LY_COORDENADORIA_DESTINO.NUCLEO IS NULL) AND (MUNICIPIO_DESTINO.CODIGO = ISNULL(@MUNIC_DESTINO, MUNICIPIO_DESTINO.CODIGO) OR
                         MUNICIPIO_DESTINO.CODIGO IS NULL) AND (UES_ORIGEM.UNIDADE_ENS = ISNULL(@ESCOLA_ORIGEM, UES_ORIGEM.UNIDADE_ENS) OR
                         UES_ORIGEM.UNIDADE_ENS IS NULL) AND (UES_DESTINO.UNIDADE_ENS = ISNULL(@ESCOLA_DESTINO, UES_DESTINO.UNIDADE_ENS) OR
                         UES_DESTINO.UNIDADE_ENS IS NULL)
ORDER BY ESCOLA_ORIGEM, UNIDADE_ORIGEM, ALUNO, ESCOLA_DESTINO, UNIDADE_DESTINO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@PERIODO_INICIAL">
            <Value>=Parameters!PERIODO_INICIAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PERIODO_FINAL">
            <Value>=Parameters!PERIODO_FINAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@COORD_ORIGEM">
            <Value>=Parameters!COORD_ORIGEM.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC_ORIGEM">
            <Value>=Parameters!MUNIC_ORIGEM.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@COORD_DESTINO">
            <Value>=Parameters!COORD_DESTINO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC_DESTINO">
            <Value>=Parameters!MUNIC_DESTINO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA_ORIGEM">
            <Value>=Parameters!ESCOLA_ORIGEM.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA_DESTINO">
            <Value>=Parameters!ESCOLA_DESTINO.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="DSCoordenadoria">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select 'NULO' nucleo,' Selecione...' descricao from ly_nucleo l1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
order by descricao</CommandText>
      </Query>
    </DataSet>
    <DataSet Name="DSMunicipio">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
where 
	(n1.NUCLEO = ISNULL(@COORD_ORIGEM,n1.NUCLEO)or n1.NUCLEO is null)
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@COORD_ORIGEM">
            <Value>=Parameters!COORD_ORIGEM.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="DSet_ESCOLA">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP
          UNION
          select null UNIDADE_ENS, ' TODAS' NOME_COMP
          union
          select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue
          where (ue.NUCLEO = ISNULL(@COORD_ORIGEM,ue.NUCLEO) or ue.NUCLEO is null)
          AND (ue.MUNICIPIO = ISNULL(@MUNIC_ORIGEM,ue.municipio)or ue.MUNICIPIO is null)
          order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@COORD_ORIGEM">
            <Value>=Parameters!COORD_ORIGEM.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC_ORIGEM">
            <Value>=Parameters!MUNIC_ORIGEM.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="DSetCoordenadoria_Destino">
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>select null nucleo,' TODAS' descricao from LY_NUCLEO L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
union
select 'NULO' nucleo,' Selecione...' descricao from ly_nucleo l1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
union
select  l1.NUCLEO,SUBSTRING(l1.descricao,1,35) from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="DSet_Municipio_Destino">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO
where 
	(n1.NUCLEO = ISNULL(@COORD_DESTINO,n1.NUCLEO)or n1.NUCLEO is null)
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@COORD_DESTINO">
            <Value>=Parameters!COORD_DESTINO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="DSet_Escola_Destino">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>
          select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP
          UNION
          select null UNIDADE_ENS, ' TODAS' NOME_COMP
          union
          select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue
          where (ue.NUCLEO = ISNULL(@COORD_DESTINO,ue.NUCLEO) or ue.NUCLEO is null)
          AND (ue.MUNICIPIO = ISNULL(@MUNIC_DESTINO,ue.municipio)or ue.MUNICIPIO is null)
          order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@COORD_DESTINO">
            <Value>=Parameters!COORD_DESTINO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC_DESTINO">
            <Value>=Parameters!MUNIC_DESTINO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="DSet_Periodo_Inicial">
      <Fields>
        <Field Name="PERIODO">
          <DataField>PERIODO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COD_PERIODO">
          <DataField>COD_PERIODO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MES">
          <DataField>MES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>SELECT *
FROM (select 'NULO' COD_PERIODO, ' Selecione...' AS PERIODO, YEAR(CONVERT( DATETIME,CONVERT(VARCHAR(10),'02/02/2060', 103))) AS ANO, MONTH(CONVERT( DATETIME,CONVERT(VARCHAR(10),'02/02/2060', 103)))  AS MES 
          UNION
          --select null COD_PERIODO, ' TODAS' PERIODO, YEAR(CONVERT( --DATETIME,CONVERT(VARCHAR(10),'01/01/2060', 103)))  AS ANO, MONTH(CONVERT( --DATETIME,CONVERT(VARCHAR(10),'01/01/2060', 103)))  AS MES
          --union
SELECT DISTINCT CASE WHEN LEN(CAST((MONTH(DT_TRANS)) AS VARCHAR(2))) = 1 THEN '0'+ CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) ELSE CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) END + '/' + CAST((YEAR(DT_TRANS)) AS VARCHAR(4)) AS COD_PERIODO, CASE WHEN LEN(CAST((MONTH(DT_TRANS)) AS VARCHAR(2))) = 1 THEN '0'+ CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) ELSE CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) END + '/' + CAST((YEAR(DT_TRANS)) AS VARCHAR(4)) AS PERIODO, YEAR(DT_TRANS) AS ANO, MONTH(DT_TRANS) AS MES
FROM LY_H_CURR_ALUNO) P
--WHERE @PERIODO_FINAL &gt; @PERIODO_INICIAL
ORDER BY ANO DESC, MES DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="DSet_Periodo_Final">
      <Fields>
        <Field Name="COD_PERIODO">
          <DataField>COD_PERIODO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERIODO">
          <DataField>PERIODO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MES">
          <DataField>MES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>SELECT *
FROM (select 'NULO' COD_PERIODO, ' Selecione...' AS PERIODO, YEAR(CONVERT( DATETIME,CONVERT(VARCHAR(10),'02/02/2060', 103))) AS ANO, MONTH(CONVERT( DATETIME,CONVERT(VARCHAR(10),'02/02/2060', 103)))  AS MES 
          UNION
          --select null COD_PERIODO, ' TODAS' PERIODO, YEAR(CONVERT( --DATETIME,CONVERT(VARCHAR(10),'01/01/2060', 103)))  AS ANO, MONTH(CONVERT( --DATETIME,CONVERT(VARCHAR(10),'01/01/2060', 103)))  AS MES
          --union
SELECT DISTINCT CASE WHEN LEN(CAST((MONTH(DT_TRANS)) AS VARCHAR(2))) = 1 THEN '0'+ CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) ELSE CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) END + '/' + CAST((YEAR(DT_TRANS)) AS VARCHAR(4)) AS COD_PERIODO, CASE WHEN LEN(CAST((MONTH(DT_TRANS)) AS VARCHAR(2))) = 1 THEN '0'+ CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) ELSE CAST((MONTH(DT_TRANS)) AS VARCHAR(2)) END + '/' + CAST((YEAR(DT_TRANS)) AS VARCHAR(4)) AS PERIODO, YEAR(DT_TRANS) AS ANO, MONTH(DT_TRANS) AS MES
FROM LY_H_CURR_ALUNO) P
WHERE 													   (P.ANO &gt; RIGHT(@PERIODO_INICIAL, 4))
													   
													   OR (P.MES &gt;=   LEFT(@PERIODO_INICIAL, 2) 
													   AND P.ANO = RIGHT(@PERIODO_INICIAL, 4))
ORDER BY ANO DESC, MES DESC</CommandText>
        <QueryParameters>
          <QueryParameter Name="@PERIODO_INICIAL">
            <Value>=Parameters!PERIODO_INICIAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
