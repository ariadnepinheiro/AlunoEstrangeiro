  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:DataSourceID>1f5c4d38-3e1d-4dea-b27b-31f815a35388</rd:DataSourceID>
      <rd:SecurityType>None</rd:SecurityType>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="TOTAL_DE_ALUNOS">
          <DataField>TOTAL DE ALUNOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALUNO_C__FOTO">
          <DataField>ALUNO C/ FOTO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALUNO_C___CARTEIRINHA">
          <DataField>ALUNO C / CARTEIRINHA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
	(SELECT COUNT(ALUNO) FROM LY_ALUNO)[TOTAL DE ALUNOS]
	,(SELECT COUNT(ALUNO) FROM LY_ALUNO L2
									WHERE EXISTS (SELECT 1 FROM LY_FOTO_PESSOA P1
											WHERE P1.PESSOA=L2.PESSOA))[ALUNO C/ FOTO]
	,(SELECT COUNT (L1.ALUNO) FROM LY_ALUNO L1 
									WHERE EXISTS (SELECT 1 FROM LY_CARTEIRINHA C1 
													WHERE C1.ALUNO=L1.ALUNO
													AND C1.SIT_CARTEIRINHA='ATIVA'))[ALUNO C / CARTEIRINHA]</CommandText>
      </Query>
    </DataSet>
  </DataSets>
