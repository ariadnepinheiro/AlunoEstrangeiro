        </Field>
        <Field Name="E_MAIL">
          <DataField>E_MAIL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUMERO_RES">
          <DataField>NUMERO_RES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMPLEMENTO_RES">
          <DataField>COMPLEMENTO_RES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BAIRRO_RES">
          <DataField>BAIRRO_RES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO_RES">
          <DataField>MUNICIPIO_RES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CEP_RES">
          <DataField>CEP_RES</DataField>
