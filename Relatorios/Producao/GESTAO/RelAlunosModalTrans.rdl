  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ee1345df-8c2a-441c-89df-e1f086af5ae5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT ALUNO, PESSOA, UNIDADE_ENSINO
INTO	#ALUNO
FROM	LY_ALUNO LA (NOLOCK)
WHERE	LA.SIT_ALUNO = 'ATIVO'
AND		(UNIDADE_ENSINO = ISNULL(@ESCOLA, UNIDADE_ENSINO) OR UNIDADE_ENSINO IS NULL)

SELECT	DISTINCT
		TR.REGIONAL REGIONAL,
		--LUE.SETOR UA,
		VWS.UA_ANTIGA UA,
		LUE.UNIDADE_ENS CENSO,
		LUE.NOME_COMP UE,
		LUE.ENDERECO ENDEREÇO_ESC,
		LUE.END_NUM NUMERO_ESC,
		ISNULL (LUE.END_COMPL, '') COMPLEMENTO_ESC,
		LUE.BAIRRO BAIRRO_ESC,
		MM.NOME MUNICIPIO_ESC,
		LUE.CEP CEP_ESC,
		LA.ALUNO MATRICULA,
		LP.NOME_COMPL NOME_ALUNO,
		LP.E_MAIL,
		LP.ENDERECO ENDERECO_RES,
		LP.END_NUM NUMERO_RES,
		ISNULL (LP.END_COMPL, '') COMPLEMENTO_RES,
		LP.BAIRRO BAIRRO_RES,
		M.NOME MUNICIPIO_RES,
		LP.CEP CEP_RES,
		LFP.FL_FIELD_04 TRANSPORTE,
		--LFP.FL_FIELD_05 AS MODAIS,
		--REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(LFP.FL_FIELD_05, '1;', 'BARCAS '), '2;', 'METRO '), 
		--'3;', 'ONIBUS '), '4;', 'TRANSPORTE RURAL '), '5;', 'TREM ') AS MODAL, 
		(
			CASE CHARINDEX('4',LFP.FL_FIELD_05)
			WHEN 0 THEN 'N'
			ELSE 'S'
			END
		) AS MODAL_BARCAS,
		(
			CASE CHARINDEX('3',LFP.FL_FIELD_05)
			WHEN 0 THEN 'N'
			ELSE 'S'
			END
		) AS MODAL_METRO,
		(
			CASE CHARINDEX('2',LFP.FL_FIELD_05)
			WHEN 0 THEN 'N'
			ELSE 'S'
			END
		) AS MODAL_ONIBUS,
		(
			CASE CHARINDEX('5',LFP.FL_FIELD_05)
			WHEN 0 THEN 'N'
			ELSE 'S'
			END
		) AS MODAL_TRANS_RURAL,
		(
			CASE CHARINDEX('1',LFP.FL_FIELD_05)
			WHEN 0 THEN 'N'
			ELSE 'S'
			END
		) AS MODAL_TREM,
		ISNULL(LFP.FL_FIELD_10,'') PODER_PUBLICO,
		VWS.UA_ATUAL

FROM	#ALUNO LA (NOLOCK)  
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LA.PESSOA
JOIN	LY_FL_PESSOA LFP (NOLOCK) ON LFP.PESSOA = LP.PESSOA 
						AND LFP.FL_FIELD_04 = 'S'	
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LA.UNIDADE_ENSINO
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES (NOLOCK) ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
						AND LUES.DT_SITUACAO = (
										SELECT	MAX(DT_SITUACAO)
										FROM	LY_UNIDADE_ENSINO_SITUACAO L1 (NOLOCK)
										WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS)
										AND		(SIT_FUNCIONAMENTO = 'EmAtividade' OR SIT_FUNCIONAMENTO IS NULL
										AND		SITUACAO = 'ESTADUAL'
										)																	
						--AND LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LP.END_MUNICIPIO
JOIN	MUNICIPIO MM (NOLOCK) ON MM.CODIGO = LUE.MUNICIPIO
						AND (MM.CODIGO = ISNULL(@MUNICIPIO, MM.CODIGO) OR MM.CODIGO IS NULL)
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
						AND (TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
JOIN HADES..VW_SETOR VS ON VS.SETOR = LUE.SETOR
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR

ORDER BY TR.REGIONAL, MM.NOME, LUE.NOME_COMP

DROP TABLE #ALUNO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
