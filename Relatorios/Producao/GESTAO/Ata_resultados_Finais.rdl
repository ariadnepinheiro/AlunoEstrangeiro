  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.197;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>287f17b2-3e6d-46b6-9198-b9cda4d2779d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@semestre">
            <Value>=Parameters!semestre.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@turma">
            <Value>=Parameters!turma.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT LY_TURMA.ANO as Ano,
LY_UNIDADE_ENSINO.unidade_ens AS CENSO,
LY_UNIDADE_ENSINO.NOME_COMP AS ESCOLA,
LY_MODALIDADE_CURSO.DESCRICAO AS MODALIDADE,
LY_CURSO.NOME AS CURSO,
LY_TURMA.SERIE AS SERIE,
LY_TURMA.TURNO,
LY_TURMA.TURMA,
ISNULL(LY_TURMA.DISCIPLINA_MULTIPLA,LY_TURMA.DISCIPLINA) AS PK_DISCIPLINA,
ISNULL(TOTAL_PONTOS,-1) TOTAL_PONTOS,
ISNULL(FI.TOTAL_FALTAS,-1) FALTAS,
FI.TOTAL_FALTAS FALTAS_NUM,
LY_DISCIPLINA.NOME_COMPL AS DISCIPLINA, 
ISNULL(REPLACE(M.AULAS_DADAS,'.0000',''),0) AULAS_DADAS, 
CASE WHEN SITUACAO_FINAL = 'Aprovado' THEN 'Aprovado'
	 WHEN SITUACAO_FINAL = 'Aprovado Com Dep' THEN 'Aprovado com dependência'
	 WHEN SITUACAO_FINAL = 'Rep Freq' THEN 'Reprovado por frequência'
	 WHEN SITUACAO_FINAL = 'Rep Nota' THEN 'Reprovado por nota' 
	 WHEN SITUACAO_FINAL = 'PROMOVIDO' THEN 'Promovido com continuidade curricular' END SITUACAO_FINAL, 
AA.ALUNO, 
PE.NOME_COMPL,
SS.FREQUENCIA_GLOBAL
FROM LY_UNIDADE_ENSINO (NOLOCK)
INNER JOIN TCE_REGIONAL (NOLOCK) ON TCE_REGIONAL.ID_REGIONAL = LY_UNIDADE_ENSINO.ID_REGIONAL
INNER JOIN LY_TURMA (NOLOCK) ON LY_UNIDADE_ENSINO.UNIDADE_ENS = LY_TURMA.UNIDADE_RESPONSAVEL	
INNER JOIN LY_CURSO (NOLOCK) ON LY_CURSO.CURSO = LY_TURMA.CURSO
INNER JOIN LY_MODALIDADE_CURSO (NOLOCK) ON LY_MODALIDADE_CURSO.MODALIDADE = LY_CURSO.MODALIDADE																
inner join LY_DISCIPLINA (NOLOCK) on ISNULL(LY_TURMA.DISCIPLINA_MULTIPLA,LY_TURMA.DISCIPLINA) = LY_DISCIPLINA.DISCIPLINA
INNER join LY_HISTMATRICULA M (NOLOCK) on LY_TURMA.TURMA = M.TURMA
						AND	LY_TURMA.DISCIPLINA = M.DISCIPLINA
						AND	LY_TURMA.ANO = M.ANO
						AND	LY_TURMA.SEMESTRE = M.SEMESTRE 
INNER JOIN LY_ALUNO AA (NOLOCK)  on AA.ALUNO = M.ALUNO 		
INNER JOIN LY_PESSOA PE (NOLOCK)  on PE.PESSOA = AA.PESSOA	
LEFT JOIN TCE_SITUACAO_FINAL_ALUNO SS (NOLOCK) ON SS.ALUNO = M.ALUNO 
								AND SS.ANO = M.ANO
								AND SS.PERIODO = M.SEMESTRE
								AND	SS.TURMA = M.TURMA
LEFT JOIN (
			SELECT	ALUNO, ANO, SEMESTRE, ORDEM, DISCIPLINA, SUM(CONVERT(DECIMAL(10,2), REPLACE(CONCEITO,',','.'))) TOTAL_PONTOS
			FROM	LY_NOTA_HISTMATR (NOLOCK)
			WHERE 	CONCEITO &lt;&gt; ''
			GROUP BY ALUNO, ANO, SEMESTRE, ORDEM, DISCIPLINA
			) FP
ON	FP.ALUNO = M.ALUNO
AND FP.SEMESTRE = M.SEMESTRE
AND FP.ANO = M.ANO
AND FP.DISCIPLINA = M.DISCIPLINA
AND FP.ORDEM = M.ORDEM
LEFT JOIN (
			SELECT	ALUNO, ANO, SEMESTRE, ORDEM, DISCIPLINA, SUM(CONVERT(INT, REPLACE(FALTAS,'.0000',''))) TOTAL_FALTAS
			FROM	LY_FALTA_HISTMATR H (NOLOCK)
			GROUP BY ALUNO, ANO, SEMESTRE, ORDEM, DISCIPLINA
			) FI
ON	FI.ALUNO = M.ALUNO
AND FI.SEMESTRE = M.SEMESTRE
AND FI.ANO = M.ANO
AND FI.DISCIPLINA = M.DISCIPLINA
AND FI.ORDEM = M.ORDEM
where LY_TURMA.SIT_TURMA = 'Finalizada'
AND SITUACAO_HIST &lt;&gt; 'CANCELADO'
and isnull(LY_TURMA.TURMAREFERENCIA, LY_TURMA.TURMA) = @turma
AND LY_TURMA.ANO = @ano
and LY_TURMA.SEMESTRE = @semestre
GROUP BY LY_TURMA.ANO,
LY_UNIDADE_ENSINO.unidade_ens,
LY_UNIDADE_ENSINO.NOME_COMP,
LY_MODALIDADE_CURSO.DESCRICAO,
LY_CURSO.NOME,
LY_TURMA.SERIE,
LY_TURMA.TURNO,
LY_TURMA.TURMA,
LY_DISCIPLINA.NOME_COMPL,
SS.SITUACAO_FINAL,  
LY_TURMA.DISCIPLINA, 
LY_TURMA.DISCIPLINA_MULTIPLA,
AA.ALUNO, 
PE.NOME_COMPL,
FP.TOTAL_PONTOS,
FI.TOTAL_FALTAS,
M.AULAS_DADAS,
SS.FREQUENCIA_GLOBAL
order by disciplina,PE.NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Ano">
          <DataField>Ano</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PK_DISCIPLINA">
          <DataField>PK_DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_PONTOS">
          <DataField>TOTAL_PONTOS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="FALTAS">
          <DataField>FALTAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FALTAS_NUM">
          <DataField>FALTAS_NUM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AULAS_DADAS">
          <DataField>AULAS_DADAS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO_FINAL">
          <DataField>SITUACAO_FINAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FREQUENCIA_GLOBAL">
          <DataField>FREQUENCIA_GLOBAL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSet_Coordenadoria">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT -1 ID_REGIONAL,' Selecione...' REGIONAL 
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN HADES..MUNICIPIO M1 (NOLOCK) ON M1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
ORDER BY REGIONAL </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSet_Municipio">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.ID_REGIONAL = ISNULL(@coord,n1.ID_REGIONAL)or n1.ID_REGIONAL is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSet_Escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (ue.ID_REGIONAL = ISNULL(@coord,ue.ID_REGIONAL) or ue.ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@munic,ue.municipio)or ue.MUNICIPIO is null)
AND  (gg.USUARIO = ISNULL(@usuario,gg.USUARIO) OR  gg.USUARIO IS NULL) 
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSet_Turma">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@semestre">
            <Value>=Parameters!semestre.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct LY_TURMA.TURMA, LY_TURMA.TURMA NOME 
from LY_UNIDADE_ENSINO l2
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
join LY_TURMA  ON L2.UNIDADE_ENS = LY_TURMA.UNIDADE_RESPONSAVEL
where 
	(l2.UNIDADE_ENS = ISNULL(@escola,l2.UNIDADE_ENS)or L2.UNIDADE_ENS is null)
and 	ano = @ano
and 	semestre = @semestre
and 	sit_turma = 'Finalizada'
and ISNULL(ELETIVA , 'N') = 'N'
AND ISNULL(OPTATIVAREFORCO,'N') = 'N'
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSetProfessor">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@TURMA">
            <Value>=Parameters!turma.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@semestre">
            <Value>=Parameters!semestre.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select DISTINCT 
LY_DISCIPLINA.NOME_COMPL AS DISCIPLINA_ATUACAO, 
MATRICULA,
NOME_PROF
FROM 
(select distinct LY_DOCENTE.MATRICULA, 
LY_PESSOA.NOME_COMPL AS NOME_PROF,
ISNULL(LY_TURMA.DISCIPLINA_MULTIPLA,LY_TURMA.DISCIPLINA)DISCIPLINA_ATUACAO
from  LY_PESSOA (NOLOCK)
INNER JOIN LY_DOCENTE (NOLOCK) ON LY_PESSOA.PESSOA = LY_DOCENTE.PESSOA
INNER JOIN LY_AULA_DOCENTE (NOLOCK) ON LY_AULA_DOCENTE.NUM_FUNC = ly_docente.NUM_FUNC
INNER JOIN LY_TURMA (NOLOCK) on LY_AULA_DOCENTE.ANO=LY_TURMA.ANO
			and LY_AULA_DOCENTE.DISCIPLINA=LY_TURMA.DISCIPLINA
			and LY_AULA_DOCENTE.FACULDADE=LY_TURMA.FACULDADE
			and LY_AULA_DOCENTE.SEMESTRE=LY_TURMA.SEMESTRE
			and LY_AULA_DOCENTE.TURMA=LY_TURMA.TURMA
			and LY_AULA_DOCENTE.TURNO=LY_TURMA.TURNO
			and LY_AULA_DOCENTE.DATA_FIM=LY_TURMA.DT_FIM
INNER JOIN LY_UNIDADE_ENSINO (NOLOCK) ON LY_TURMA.FACULDADE = LY_UNIDADE_ENSINO.UNIDADE_ENS
INNER JOIN ly_unidade_ensino_situacao UES (NOLOCK) on UES.UNIDADE_ENS = LY_UNIDADE_ENSINO.UNIDADE_ENS
			AND UES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
					FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK)
					WHERE ly_unidade_ensino.UNIDADE_ENS=LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
INNER JOIN  MUNICIPIO MUNICIPIO_ESCOLA (NOLOCK) ON MUNICIPIO_ESCOLA.CODIGO = LY_UNIDADE_ENSINO.MUNICIPIO																
INNER JOIN LY_NUCLEO (NOLOCK) ON LY_NUCLEO.NUCLEO = LY_UNIDADE_ENSINO.NUCLEO	
														
where 
LY_TURMA.ANO = @ano
and LY_TURMA.SEMESTRE = @semestre
AND LY_TURMA.TURMA = @TURMA
AND SIT_TURMA = 'Aberta'
and SITUACAO = 'Estadual'	
)SQL1 
INNER JOIN LY_DISCIPLINA ON SQL1.DISCIPLINA_ATUACAO = LY_DISCIPLINA.DISCIPLINA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DISCIPLINA_ATUACAO">
          <DataField>DISCIPLINA_ATUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_PROF">
          <DataField>NOME_PROF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SEMESTRE">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	PERIODO, PERIODO NOME
FROM 	LY_PERIODO_LETIVO
WHERE 	ANO = @ano
</CommandText>
      </Query>
      <Fields>
        <Field Name="PERIODO">
          <DataField>PERIODO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ano">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT ANO, ANO NOME 
FROM 	LY_PERIODO_LETIVO
WHERE 	ANO &lt;= YEAR(GETDATE())
and ANO not in (2020,2021)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
