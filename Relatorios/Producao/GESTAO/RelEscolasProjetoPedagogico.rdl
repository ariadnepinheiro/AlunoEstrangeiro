  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>DataSource1</DataSourceReference>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>86c52f8c-2e98-4034-adf0-72ff6971ce88</rd:DataSourceID>
