  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
        TCE_REGIONAL.REGIONAL AS REGIONAL ,
        MUNICIPIO.NOME AS MUNICIPIO ,
        LY_UNIDADE_ENSINO.UNIDADE_ENS AS CENSO ,
        LY_UNIDADE_ENSINO.NOME_COMP AS ESCOLA ,
        VS.UA_ATUAL AS UA ,
        LY_UNIDADE_ENSINO.POSSUIPROJETOPEDAGOGICO AS POSSUIPROJETOPEDAGOGICO ,
        LY_UNIDADE_ENSINO.CUMPRIUPROJETOPEDAGOGICO AS CUMPRIUPROJETOPEDAGOGICO ,
	VS.UA_ATUAL AS UA_ATUAL 
FROM    LY_UNIDADE_ENSINO
        INNER JOIN DBO.TCE_REGIONAL ON TCE_REGIONAL.ID_REGIONAL = LY_UNIDADE_ENSINO.ID_REGIONAL
        INNER JOIN MUNICIPIO ON MUNICIPIO.CODIGO = LY_UNIDADE_ENSINO.MUNICIPIO
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LY_UNIDADE_ENSINO.UNIDADE_ENS
JOIN HADES..VW_SETOR VS ON VS.SETOR =LY_UNIDADE_ENSINO.SETOR
WHERE   LY_UNIDADE_ENSINO.UNIDADE_ENS NOT IN ( '99999999', '33334444',
                                               '33335555', '33335556' )
        AND ( SELECT TOP 1
                        SITUACAO
              FROM      LY_UNIDADE_ENSINO_SITUACAO ues (NOLOCK)
              WHERE     ues.UNIDADE_ENS = LY_UNIDADE_ENSINO.UNIDADE_ENS
              ORDER BY  DT_SITUACAO DESC
            ) = 'ESTADUAL'
        AND SIT_FUNCIONAMENTO = 'EMATIVIDADE'
        AND ISNULL(POSSUIPROJETOPEDAGOGICO,'N') = 'N'     
AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL) 
and TCE_REGIONAL.id_REGIONAL = ISNULL(@REGIONAL, TCE_REGIONAL.id_REGIONAL)
and MUNICIPIO.CODIGO = ISNULL(@MUNIC, MUNICIPIO.CODIGO)
and LY_UNIDADE_ENSINO.UNIDADE_ENS = ISNULL(@ESCOLA, LY_UNIDADE_ENSINO.UNIDADE_ENS)
ORDER BY TCE_REGIONAL.REGIONAL ,
        MUNICIPIO.NOME ,
        LY_UNIDADE_ENSINO.UNIDADE_ENS</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="POSSUIPROJETOPEDAGOGICO">
          <DataField>POSSUIPROJETOPEDAGOGICO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CUMPRIUPROJETOPEDAGOGICO">
          <DataField>CUMPRIUPROJETOPEDAGOGICO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_ATUAL">
          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@USUARIO">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL AS ID_REGIONAL,' TODAS' AS REGIONAL 
UNION
SELECT R.ID_REGIONAL,SUBSTRING(R.REGIONAL,1,35) FROM LY_UNIDADE_ENSINO  L2
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = L2.ID_REGIONAL
JOIN LY_USUARIO_UNIDADE_FIS JJ ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@USUARIO,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="munic">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
        L1.codigo ,
        L1.nome
FROM    LY_UNIDADE_ENSINO l2
        JOIN municipio l1 ON l1.CODIGO = l2.MUNICIPIO
        JOIN dbo.TCE_REGIONAL r1 ON r1.ID_REGIONAL = l2.ID_REGIONAL
        JOIN LY_USUARIO_UNIDADE_FIS jj ON jj.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE   ( r1.ID_REGIONAL = ISNULL(@REGIONAL, r1.ID_REGIONAL)
          OR r1.ID_REGIONAL IS NULL
        )
        AND ( jj.USUARIO = ISNULL(@usuario, jj.USUARIO)
              OR jj.USUARIO IS NULL
            )
UNION
SELECT  NULL codigo ,
        ' TODOS' nome
UNION
SELECT  'NULO' codigo ,
        ' Selecione...' descricao
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.ID_REGIONAL = ISNULL(@REGIONAL,ue.ID_REGIONAL) or ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
