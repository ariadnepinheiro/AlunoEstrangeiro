          <DataField>DOC I 30 SEM LICENCA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DOC_I_30_COM_LICENCA">
          <DataField>DOC I 30 COM LICENCA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DOC_I_30_EXTRACLASSE">
          <DataField>DOC I 30 EXTRACLASSE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DOC_I_16_SEM_LICENCA">
          <DataField>DOC I 16 SEM LICENCA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DOC_I_16_COM_LICENCA">
          <DataField>DOC I 16 COM LICENCA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DOC_I_16_EXTRACLASSE">
          <DataField>DOC I 16 EXTRACLASSE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 	
	SUM (DOC_I_40_HORAS_SEM_LICENCA) 'DOC I 40 HORAS SEM LICENCA'
	, SUM (DOC_I_40_HORAS_COM_LICENCA) 'DOC I 40 HORAS COM LICENCA'
	, SUM (DOC_I_40_HORAS_EXTRACLASSE) 'DOC I 40 HORAS EXTRACLASSE'
	, SUM (DOC_II_40_HORAS_SEM_LICENCA) 'DOC II 40 SEM LICENCA'
	, SUM (DOC_II_40_HORAS_COM_LICENCA) 'DOC II 40 COM LICENCA'
	, SUM (DOC_II_40_HORAS_EXTRACLASSE) 'DOC II 40 EXTRACLASSE'	
	, SUM (DOC_II_20_HORAS_SEM_LICENCA) 'DOC II 20 SEM LICENCA'	
	, SUM (DOC_II_20_HORAS_COM_LICENCA) 'DOC II 20 COM LICENCA'	
	, SUM (DOC_II_20_HORAS_EXTRACLASSE) 'DOC II 20 EXTRACLASSE'	
	, SUM (DOC_I_30_HORAS_SEM_LICENCA) 'DOC I 30 SEM LICENCA'	
	, SUM (DOC_I_30_HORAS_COM_LICENCA) 'DOC I 30 COM LICENCA'	
	, SUM (DOC_I_30_HORAS_EXTRACLASSE) 'DOC I 30 EXTRACLASSE'	
	, SUM (DOC_I_16_HORAS_SEM_LICENCA) 'DOC I 16 SEM LICENCA'	
	, SUM (DOC_I_16_HORAS_COM_LICENCA) 'DOC I 16 COM LICENCA'	
	, SUM (DOC_I_16_HORAS_EXTRACLASSE) 'DOC I 16 EXTRACLASSE'	
		
	FROM 
	(
	
	SELECT 
		FUNCAO
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				  AND FUNCAO LIKE '%40%' THEN QTD_SEM_LICENCA ELSE 0 END) AS DOC_I_40_HORAS_SEM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				  AND FUNCAO LIKE '%40%' THEN QTD_COM_LICENCA ELSE 0 END) AS DOC_I_40_HORAS_COM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				  AND FUNCAO LIKE '%40%' THEN QTD_EXTRACLASSE ELSE 0 END) AS DOC_I_40_HORAS_EXTRACLASSE
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%II%' ) 
				  AND FUNCAO LIKE '%40%' THEN QTD_SEM_LICENCA ELSE 0 END) AS DOC_II_40_HORAS_SEM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%II%' ) 
				  AND FUNCAO LIKE '%40%' THEN QTD_COM_LICENCA ELSE 0 END) AS DOC_II_40_HORAS_COM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%II%' ) 
				  AND FUNCAO LIKE '%40%' THEN QTD_EXTRACLASSE ELSE 0 END) AS DOC_II_40_HORAS_EXTRACLASSE
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%II%' ) 
				  AND FUNCAO NOT LIKE '%40%' THEN QTD_SEM_LICENCA ELSE 0 END) AS DOC_II_20_HORAS_SEM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%II%' ) 
				  AND FUNCAO NOT LIKE '%40%' THEN QTD_COM_LICENCA ELSE 0 END) AS DOC_II_20_HORAS_COM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%II%' ) 
				  AND FUNCAO NOT LIKE '%40%' THEN QTD_EXTRACLASSE ELSE 0 END) AS DOC_II_20_HORAS_EXTRACLASSE
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				  AND FUNCAO LIKE '%30%' THEN QTD_SEM_LICENCA ELSE 0 END) AS DOC_I_30_HORAS_SEM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				  AND FUNCAO LIKE '%30%' THEN QTD_COM_LICENCA ELSE 0 END) AS DOC_I_30_HORAS_COM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				  AND FUNCAO LIKE '%30%' THEN QTD_EXTRACLASSE ELSE 0 END) AS DOC_I_30_HORAS_EXTRACLASSE
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				 AND (FUNCAO NOT LIKE '%30%' AND FUNCAO NOT LIKE '%40%' ) THEN QTD_SEM_LICENCA ELSE 0 END) AS DOC_I_16_HORAS_SEM_LICENCA	
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				 AND (FUNCAO NOT LIKE '%30%' AND FUNCAO NOT LIKE '%40%' ) THEN QTD_COM_LICENCA ELSE 0 END) AS DOC_I_16_HORAS_COM_LICENCA
		, (CASE 
				WHEN (FUNCAO LIKE '%DOC%I%' AND FUNCAO NOT LIKE '%DOC%II%') 
				 AND (FUNCAO NOT LIKE '%30%' AND FUNCAO NOT LIKE '%40%' ) THEN QTD_EXTRACLASSE ELSE 0 END) AS DOC_I_16_HORAS_EXTRACLASSE	
		FROM 
			(
			/*::: DOCENTES SEM LICENCA :::*/
			SELECT DISTINCT
				F.DESCRICAO AS FUNCAO, 
				COUNT (DISTINCT D.MATRICULA) AS QTD_SEM_LICENCA,
				'' AS QTD_COM_LICENCA,
				'' AS QTD_EXTRACLASSE
			FROM LY_DOCENTE D 
			INNER JOIN LY_LOTACAO L ON	D.MATRICULA = L.MATRICULA 
									AND	L.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
									AND (L.DATA_DESATIVACAO IS NULL OR L.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))
			INNER JOIN LY_FUNCAO F ON F.FUNCAO = L.FUNCAO	
			AND F.CAMPO_01 = 'S'		
			AND D.MATRICULA NOT IN ('00000000', '11111111', '222222222', '33333333', '44444444', '55555555', '66666666', 
									'77777777', '88888888', '99999999', '12121201', '12121209', '12121202', '12121220')
			GROUP BY F.DESCRICAO
			
			UNION 

			/*::: DOCENTES COM LICENCA VIGENTE :::*/
			SELECT DISTINCT 
				F.DESCRICAO AS FUNCAO,
				'' QTD_SEM_LICENCA,
				COUNT (DISTINCT D.MATRICULA) AS QTD_COM_LICENCA,
				'' AS QTD_EXTRACLASSE
			FROM LY_DOCENTE D 
			INNER JOIN LY_LOTACAO L ON	D.MATRICULA = L.MATRICULA 
									AND	L.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
									AND (L.DATA_DESATIVACAO IS NULL OR L.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))		
			LEFT JOIN LY_GRUPO_HABILITACAO_DOC GHD ON D.NUM_FUNC = GHD.NUM_FUNC
												   AND AGRUPAMENTO_INGRESSO = 'S'
			LEFT JOIN LY_GRUPO_HABILITACAO GH ON GH.AGRUPAMENTO = GHD.AGRUPAMENTO
			INNER JOIN LY_FUNCAO F ON F.FUNCAO = L.FUNCAO
			AND F.CAMPO_01 = 'S'
			AND EXISTS (
							SELECT	1
							FROM	LY_LICENCA_DOCENTE LD
							WHERE	LD.NUM_FUNC  = GHD.NUM_FUNC
							AND		((DTINI &lt;= GETDATE()) AND (DTFIM &gt; GETDATE() OR DTFIM IS NULL))
							)
			AND D.MATRICULA NOT IN ('00000000', '11111111', '222222222', '33333333', '44444444', '55555555', '66666666', 
								'77777777', '88888888', '99999999', '12121201', '12121209', '12121202', '12121220')
			GROUP BY
			F.DESCRICAO			

			UNION

			/*::: DOCENTES EXTRACLASSE :::*/
			SELECT DISTINCT			
				D.CATEGORIA AS FUNCAO,
				'' AS QTD_SEM_LICENCA,
				'' AS QTD_COM_LICENCA,			
				COUNT (DISTINCT D.MATRICULA) AS QTD_EXTRACLASSE
			FROM LY_DOCENTE D 
			INNER JOIN LY_LOTACAO L ON D.MATRICULA = L.MATRICULA 
									AND	L.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
									AND (L.DATA_DESATIVACAO IS NULL OR L.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))
			INNER JOIN LY_FUNCAO F ON F.FUNCAO = L.FUNCAO
								   AND F.CAMPO_02 = 'S'		
			AND D.MATRICULA NOT IN ('00000000', '11111111', '222222222', '33333333', '44444444', '55555555', '66666666', 
									'77777777', '88888888', '99999999', '12121201', '12121209', '12121202', '12121220')
			GROUP BY
			D.CATEGORIA			
			) SQL1
	) SQL2
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
