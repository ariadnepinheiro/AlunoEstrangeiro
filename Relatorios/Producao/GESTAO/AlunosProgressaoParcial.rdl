  <DataSources>
    <DataSource Name="LYCEUM">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3026eee8-b6eb-4a78-b97b-7e4085061b5b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Dataset1">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH TURMA_PROGRESSAO (ALUNO, ANO_REF, SEMESTRE, DISCIPLINAS, TURMAS)
AS(
SELECT	DISTINCT 
		LM.ALUNO, 
		A.ANO ANO_REF, 
		LT.SEMESTRE, 
		UPPER ((SELECT STUFF(
					(SELECT DISTINCT ' / ' + D.NOME
						FROM LY_MATRICULA M (NOLOCK)
						JOIN LY_TURMA T (NOLOCK) ON T.TURMA = M.TURMA 
								AND T.ANO = M.ANO 
								AND T.DISCIPLINA = M.DISCIPLINA 
								AND T.SEMESTRE = M.SEMESTRE
								AND T.ANO = YEAR(GETDATE())
								AND T.SIT_TURMA = 'ABERTA'
						JOIN LY_DISCIPLINA D (NOLOCK) ON D.DISCIPLINA = ISNULL(T.DISCIPLINA_MULTIPLA, T.DISCIPLINA)
						WHERE M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
						AND M.ALUNO = LM.ALUNO
						AND M.TURMA = LT.TURMA
				FOR XML PATH ('')), 1, 3, ''))) DISCIPLINAS,
		(SELECT	STUFF(
					(SELECT DISTINCT ' / ' + M.TURMA
						FROM LY_MATRICULA M (NOLOCK)
						WHERE M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
						AND M.ALUNO = LM.ALUNO
						AND M.TURMA = LT.TURMA
						AND M.ANO = YEAR(GETDATE())
					FOR XML PATH ('')), 1, 3, '')) TURMAS
FROM	APOLLO..ALUNOS_APROVADOS_DEPENDENCIA A (NOLOCK)
JOIN	LY_MATRICULA LM (NOLOCK) ON LM.ALUNO = A.ALUNO
				AND A.SERIE = LM.SERIE_REFERENCIA
				AND A.DISCIPLINA = LM.DISCIPLINA_REFERENCIA
				AND LM.ANO = @ANO
				AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
				AND LM.DEPENDENCIA = 'S'  
JOIN	LY_TURMA LT (NOLOCK) ON LT.TURMA = LM.TURMA
				AND	LT.DISCIPLINA = LM.DISCIPLINA
				AND	LT.ANO = LM.ANO
				AND LT.SEMESTRE = LM.SEMESTRE
				AND LT.SIT_TURMA = 'ABERTA'
JOIN	LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)	
WHERE	A.PROGRESSAO_CUMPRIDA = 'NÃO'
)

SELECT	DISTINCT 
		TR.REGIONAL,
		M.NOME MUNICIPIO,
		--LUE.SETOR UA,
		VWS.UA_ANTIGA UA,
		LUE.UNIDADE_ENS CENSO,
		LUE.NOME_COMP ESCOLA,
		LC.NOME ESCOLARIDADE,
		A.ALUNO, 
		PE.NOME_COMPL, 
		A.TURMA, 
		TP.SEMESTRE PERIODO_PROGRESSAO, 
		ISNULL (TP.ANO_REF, AD.ANO) ANO_REFERENCIA_PROGRESSAO, 
		TP.DISCIPLINAS DISCIPLINA_PROGRESSAO, 
		TP.TURMAS TURMA_PROGRESSAO,
		VWS.UA_ATUAL
		
FROM	APOLLO..TURMA_PRINCIPAL_ALUNO A
JOIN LY_PESSOA PE ON PE.PESSOA = A.PESSOA
JOIN	APOLLO..ALUNOS_APROVADOS_DEPENDENCIA AD ON AD.ALUNO = A.ALUNO
				AND AD.PROGRESSAO_CUMPRIDA = 'NÃO'
LEFT	JOIN TURMA_PROGRESSAO TP ON TP.ALUNO = A.ALUNO
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = A.CURSO
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = A.UNIDADE_RESPONSAVEL 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
JOIN    HADES..VW_SETOR VWS ON VWS.SETOR = LUE.SETOR
	
WHERE 	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND		(M.CODIGO = ISNULL(@MUNICIPIO, M.CODIGO) OR M.CODIGO IS NULL)
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)
AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLARIDADE">
          <DataField>ESCOLARIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERIODO_PROGRESSAO">
          <DataField>PERIODO_PROGRESSAO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA_PROGRESSAO">
          <DataField>DISCIPLINA_PROGRESSAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO_REFERENCIA_PROGRESSAO">
          <DataField>ANO_REFERENCIA_PROGRESSAO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA_PROGRESSAO">
          <DataField>TURMA_PROGRESSAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_ATUAL">
          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT	0 ID_REGIONAL,' Selecione...' REGIONAL
UNION
SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) REGIONAL
FROM	TCE_REGIONAL TR (NOLOCK)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER	BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	DISTINCT M.CODIGO, M.NOME 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
UNION
SELECT	NULL CODIGO,' TODOS' NOME
UNION
SELECT	'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER	BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT	NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT	LUE.UNIDADE_ENS, SUBSTRING (LUE.NOME_COMP,1,50) NOME_COMP 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK) 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND LUES.DT_SITUACAO = (
										SELECT	MAX(DT_SITUACAO)
										FROM	LY_UNIDADE_ENSINO_SITUACAO L1 
										WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS)
										AND		(SIT_FUNCIONAMENTO = 'EmAtividade' OR SIT_FUNCIONAMENTO IS NULL
										)
WHERE	(LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL) 
ORDER	BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>
SELECT    0 ANO, ' Selecione...' NOME
UNION
SELECT	DISTINCT CONVERT (VARCHAR(4), ANO) ANO, CONVERT (VARCHAR(4), ANO) NOME 
FROM	LY_PERIODO_LETIVO (NOLOCK) 
WHERE	ANO = YEAR(GETDATE())
ORDER	BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DATA_ATUALIZACAO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>
SELECT	TOP(1) 
		CONVERT(VARCHAR(2),
		(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), 
		DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), 
		DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
		CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 16</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
