  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null id_regional,' TODAS' regional
union
SELECT DISTINCT R.ID_REGIONAL, R.REGIONAL 
FROM TCE_REGIONAL R (nolock)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.ID_REGIONAL = R.ID_REGIONAL
WHERE 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
where (UF.USUARIO = ISNULL(@usuario,UF.USUARIO) OR  UF.USUARIO IS NULL) 
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY REGIONAL</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.id_regional = ISNULL(@COORD,n1.id_regional)or n1.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	UNIDADE_ENS, NOME_COMP
FROM 	LY_UNIDADE_ENSINO UE (NOLOCK)
WHERE 	(UE.MUNICIPIO = ISNULL(@municipio, UE.MUNICIPIO) OR UE.MUNICIPIO IS NULL)
AND 	(UE.ID_REGIONAL=ISNULL(@coord, UE.ID_REGIONAL) OR UE.ID_REGIONAL IS NULL)
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	(UF.USUARIO = ISNULL(@usuario,UF.USUARIO) OR UF.USUARIO IS NULL)
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
union 
SELECT NULL, ' TODAS'
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
		UE.SETOR UA, T.TURNO, O.ANO, O.SEMESTRE, O.TURMA TURMA_OTIMIZAR, O.QTDE_ALUNOS, 
		CASE WHEN AA.QTDE_ALUNOS - O.QTDE_ALUNOS &gt; 0 THEN AA.QTDE_ALUNOS - O.QTDE_ALUNOS ELSE 0 END QTDE_ALUNOS_ADD, 
		T.SIT_TURMA SITUACAO_ATUAL_TURMA, 
		V.TURMA TURMA_VAGA, V.QTDE_ALUNOS QTDE_ALUNOS_TURMA_VAGA, V.CAPACIDADE_SALAS CAPACIDADE_SALA_TURMA_VAGA, O.DATA
FROM	APOLLO..REL_TURMAS_OTM O (NOLOCK) 
LEFT JOIN LY_TURMA T (NOLOCK) 
ON		T.ANO = O.ANO
AND		T.SEMESTRE = O.SEMESTRE
AND		T.TURMA = O.TURMA 
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		O.UNIDADE_ENS = UE.UNIDADE_ENS
JOIN	TCE_REGIONAL R (NOLOCK) 
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) 
ON		M.CODIGO = UE.MUNICIPIO
JOIN	(
		SELECT	CURSO, UNIDADE_ENS, TURNO, SERIE, ANO, SEMESTRE, TURMA, QTDE_ALUNOS, CAPACIDADE_SALAS
		FROM	APOLLO..REL_TURMAS_OTM (NOLOCK) 
		WHERE	VERIFICAR_SALDO = 'S'
		AND		OTIMIZAR = 'N'
		)	V
ON		V.CURSO = O.CURSO
AND		V.TURNO = O.TURNO
AND		V.UNIDADE_ENS = O.UNIDADE_ENS
AND		V.SERIE = O.SERIE
AND		V.ANO = O.ANO
AND		V.SEMESTRE = O.SEMESTRE
LEFT JOIN APOLLO..REL_TURMAS_ALUNOS AA
ON		AA.ANO = O.ANO
AND		AA.SEMESTRE = O.SEMESTRE
AND		AA.TURMA = O.TURMA
WHERE	O.OTIMIZAR = 'S'
AND 	O.ANO = @ANO
AND		(R.ID_REGIONAL = ISNULL(@coord, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
AND		(UE.UNIDADE_ENS = ISNULL(@escola, UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
AND		(M.CODIGO = ISNULL(@municipio, M.CODIGO) OR M.CODIGO IS NULL)
</CommandText>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA_OTIMIZAR">
          <DataField>TURMA_OTIMIZAR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS">
          <DataField>QTDE_ALUNOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SITUACAO_ATUAL_TURMA">
          <DataField>SITUACAO_ATUAL_TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS_ADD">
          <DataField>QTDE_ALUNOS_ADD</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TURMA_VAGA">
          <DataField>TURMA_VAGA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS_TURMA_VAGA">
          <DataField>QTDE_ALUNOS_TURMA_VAGA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CAPACIDADE_SALA_TURMA_VAGA">
          <DataField>CAPACIDADE_SALA_TURMA_VAGA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO 
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
