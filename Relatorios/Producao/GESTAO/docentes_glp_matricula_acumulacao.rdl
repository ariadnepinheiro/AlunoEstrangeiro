  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.50.9.196;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>1b0652bd-f4bf-45da-bbc9-0d8b244617f5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT 
	X.ID_REGIONAL
	,X.REGIONAL
	,X.ID_MUNICIPIO
	,X.MUNICIPIO
	,X.CENSO
	,X.LOTACAO_ESCOLA
	,X.UA
	,X.CPF
	,X.NOME_DOCENTE
	,X.MATRICULA
	,COUNT(X.TIPO_AULA) AS TEMPOS_GLP_MATRICULA
	,X.CARGO
	,X.FUNCAO
	,X.DATA_ADMISSAO
	,X.DATA_NOMEACAO
	,X.DATA_DESATIVACAO
	,X.COD_DISCIPLINA
	,X.DISCIPLINA
FROM (
	SELECT 
		TR.ID_REGIONAL
		,ISNULL(TR.REGIONAL,'') AS REGIONAL
		,MUN.CODIGO AS ID_MUNICIPIO
		,UPPER(LTRIM(RTRIM(ISNULL(MUN.NOME,'')))) AS MUNICIPIO
		,ISNULL(LUE.UNIDADE_ENS,'') AS CENSO
		--,S.NOMESETOR AS LOTACAO_ESCOLA --UA_NOME
		,LUE.NOME_COMP AS LOTACAO_ESCOLA --UA_NOME
		,S.UA_ATUAL AS UA
		,ISNULL (LP.CPF, '') AS CPF
		,UPPER(LP.NOME_COMPL) AS NOME_DOCENTE
		,LD.MATRICULA              
		,ISNULL(CONVERT (VARCHAR (10), LD.DT_ADMISSAO, 103),'') AS DATA_ADMISSAO
		,ISNULL(CONVERT (VARCHAR (10), LL.DATA_NOMEACAO, 103),'') AS DATA_NOMEACAO
		,ISNULL(CONVERT (VARCHAR (10), LL.DATA_DESATIVACAO, 103),'') AS DATA_DESATIVACAO
		,ISNULL(LD.CATEGORIA,'') AS CARGO
		,ISNULL(LF.DESCRICAO,'') AS FUNCAO

		,D1.DISCIPLINA AS COD_DISCIPLINA
		,D1.NOME_COMPL AS DISCIPLINA
		,(
			ISNULL(ADC.TIPO_AULA,'NORMAL')
		) AS TIPO_AULA
		--,ADC.ID_DOCENTE_FUNCAO_GLP -- id da funcao gratificada ? junto com que tabela, ly_funcao ?

		--,LAD.ANO
		--,LAD.SEMESTRE  
	FROM   
		LY_AULA_DOCENTE LAD  (NOLOCK)            
		INNER JOIN LY_HOR_OPER LHO (NOLOCK) ON LAD.AULA = LHO.AULA              
											AND LAD.DIA_SEMANA = LHO.DIA_SEMANA              
											AND LAD.FACULDADE = LHO.FACULDADE              
											AND LAD.TURNO = LHO.TURNO 
		INNER JOIN LY_DOCENTE LD (NOLOCK) ON LD.NUM_FUNC = LAD.NUM_FUNC  --and ld.MATRICULA = @MATRICULA            
		INNER JOIN LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LAD.FACULDADE              
											AND LUE.UNIDADE_ENS = ISNULL(@ESCOLA,LUE.UNIDADE_ENS)
											
		INNER JOIN LY_TURMA LT (NOLOCK) ON LAD.ANO=LT.ANO 
											AND LAD.DISCIPLINA=LT.DISCIPLINA            
											AND LAD.FACULDADE=LT.FACULDADE
											AND LAD.SEMESTRE=LT.SEMESTRE            
											AND LAD.TURMA=LT.TURMA            
											AND LAD.TURNO=LT.TURNO           
											AND LAD.DATA_FIM&gt;=CONVERT(DATE,CURRENT_TIMESTAMP)     
											AND LAD.DATA_FIM=LT.DT_FIM        
											AND LAD.ANO = @ANO -- YEAR(GETDATE())
											
		 INNER JOIN LY_DISCIPLINA D1 (NOLOCK) ON D1.DISCIPLINA=ISNULL(LT.DISCIPLINA_MULTIPLA,LT.DISCIPLINA) --LT.DISCIPLINA          
		 INNER JOIN LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
		 INNER JOIN TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL 
											AND TR.ID_REGIONAL = ISNULL(@REGIONAL,TR.ID_REGIONAL)
											
		 INNER JOIN HADES..MUNICIPIO MUN (NOLOCK) ON MUN.CODIGO = LUE.MUNICIPIO 
											AND MUN.CODIGO = ISNULL(@MUNICIPIO,MUN.CODIGO)

		 INNER JOIN LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
					AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt;= GETDATE())
		 
		 INNER JOIN LY_FUNCAO LF (NOLOCK) ON LF.FUNCAO = LL.FUNCAO AND LF.FUNCAO NOT IN ('9999') --Funcao SEEDUC
							        
		 INNER JOIN HADES..VW_SETOR S (NOLOCK) ON S.SETOR = LL.SETOR AND UPPER(S.NOMESETOR) NOT LIKE 'CR %' -- REMOVE SERVIDORES LOTADOS EM COORDENADORIAS

		 LEFT JOIN LY_AULA_DOCENTE_TIPO ADC (NOLOCK) ON ADC.NUM_FUNC = LAD.NUM_FUNC
													AND ADC.ANO = LAD.ANO
													AND ADC.SEMESTRE = LAD.SEMESTRE
													AND ADC.TURNO = LAD.TURNO
													AND ADC.TURMA = LAD.TURMA
													AND ADC.DISCIPLINA = LAD.DISCIPLINA
													AND ADC.FACULDADE = LAD.FACULDADE
													AND ADC.AULA = LAD.AULA
													AND ADC.DIA_SEMANA = LAD.DIA_SEMANA
													AND ADC.DATA_FIM = LAD.DATA_FIM
													AND ADC.TIPO_AULA = 'GLP'


) X 
WHERE 
	X.TIPO_AULA = 'GLP'
	
	
	--,X.ID_REGIONAL = ISNULL(X.ID_REGIONAL,@REGIONAL)
	--,X.ID_MUNICIPIO = ISNULL(X.ID_MUNICIPIO,@MUNICIPIO)
	--,X.CENSO = ISNULL(X.CENSO,@ESCOLA)
	
GROUP BY
	X.REGIONAL
	,X.MUNICIPIO
	,X.CENSO
	,X.LOTACAO_ESCOLA
	,X.UA
	,X.CPF
	,X.NOME_DOCENTE
	,X.MATRICULA
	,X.CARGO
	,X.FUNCAO
	,X.DATA_ADMISSAO
	,X.DATA_NOMEACAO
	,X.DATA_DESATIVACAO
	,X.COD_DISCIPLINA
	,X.DISCIPLINA
	,X.ID_REGIONAL
	,X.ID_MUNICIPIO

ORDER BY
	X.REGIONAL
	,X.MUNICIPIO
	,X.CENSO
	,X.CPF
	,X.NOME_DOCENTE
	,X.MATRICULA
	,X.CARGO
	,X.FUNCAO
	,X.DISCIPLINA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_MUNICIPIO">
          <DataField>ID_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LOTACAO_ESCOLA">
          <DataField>LOTACAO_ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
