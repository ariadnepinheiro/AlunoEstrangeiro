    <DataSet Name="Regionais">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- REGIONAIS
select null id_regional,' TODAS' regional
union
select  l1.id_regional,SUBSTRING(l1.regional,1,35) from tce_regional L1 (nolock)
join LYCEUM..LY_UNIDADE_ENSINO l2 (nolock) on L1.id_regional=l2.id_regional
join HADES..MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LYCEUM..LY_USUARIO_UNIDADE_FIS jj (nolock) on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select -1 id_regional,' Selecione...' regional 
order by regional</CommandText>
      </Query>
      <Fields>
        <Field Name="id_regional">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="regional">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipios">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- MUNICIPIO (UNIDADE)
select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join HADES..municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LYCEUM..TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LYCEUM..LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	-- 8
	(n1.id_regional = ISNULL(@REGIONAL,n1.id_regional)or n1.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escolas">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- ESCOLA
select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LYCEUM..LY_UNIDADE_ENSINO ue 
JOIN LYCEUM..TCE_REGIONAL R ON R.ID_REGIONAL = UE.ID_REGIONAL
join LYCEUM..LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (R.ID_REGIONAL = ISNULL(@REGIONAL,R.ID_REGIONAL) or R.ID_REGIONAL is null)
--00007043
AND (ue.MUNICIPIO = ISNULL(@MUNICIPIO,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP
</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Anos">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>-- ANO
SELECT DISTINCT ANO, ANO AS NOME 
FROM LYCEUM..LY_PERIODO_LETIVO
WHERE 	ANO &lt;= YEAR(GETDATE())
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
