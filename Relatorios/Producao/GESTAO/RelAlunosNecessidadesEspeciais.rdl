  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.197;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>86c52f8c-2e98-4034-adf0-72ff6971ce88</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>USE LYCEUM

DECLARE @ANO INT 
SET @ANO = (SELECT DISTINCT ANO FROM LYCEUM..LY_PERIODO_LETIVO WHERE GETDATE() BETWEEN DT_INICIO AND DT_FIM)


SELECT ALUNOID,
       ( P.CPF + ' - ' + P.NOME_COMPL ) DADOS_CUIDADOR
INTO   #CUIDADOR
FROM   NECESSIDADEESPECIAL.CUIDADORALUNO CA (NOLOCK )
       INNER JOIN NECESSIDADEESPECIAL.RECURSONECESSIDADEESPECIAL R (NOLOCK )
               ON CA.RECURSONECESSIDADEESPECIALID =
                  R.RECURSONECESSIDADEESPECIALID
       INNER JOIN LY_PESSOA P (NOLOCK )
               ON R.PESSOAID = P.PESSOA
WHERE  ( Getdate() BETWEEN DATAINICIO AND DATAFIM )

SELECT ALUNOID,
       ( P.CPF + ' - ' + P.NOME_COMPL ) DADOS_LEDOR
INTO   #LEDOR
FROM   NECESSIDADEESPECIAL.LEDORALUNO L (NOLOCK )
       INNER JOIN NECESSIDADEESPECIAL.RECURSONECESSIDADEESPECIAL R (NOLOCK )
               ON L.RECURSONECESSIDADEESPECIALID =
                  R.RECURSONECESSIDADEESPECIALID
       INNER JOIN LY_PESSOA P (NOLOCK )
               ON R.PESSOAID = P.PESSOA
WHERE  ( Getdate() BETWEEN DATAINICIO AND DATAFIM )

SELECT DISTINCT M.ALUNO,
                ( P.CPF + ' - ' + P.NOME_COMPL ) DADOS_INTERPRETETURMA
INTO   #INTERPRETETURMA
FROM   NECESSIDADEESPECIAL.INTERPRETETURMA T (NOLOCK )
       INNER JOIN NECESSIDADEESPECIAL.RECURSONECESSIDADEESPECIAL R (NOLOCK )
               ON T.RECURSONECESSIDADEESPECIALID =
                  R.RECURSONECESSIDADEESPECIALID
       INNER JOIN LY_PESSOA P (NOLOCK )
               ON R.PESSOAID = P.PESSOA
       INNER JOIN LY_MATRICULA M (NOLOCK )
               ON M.TURMA = T.TURMA
                  AND M.ANO = T.ANO
                  AND M.SEMESTRE = T.SEMESTRE
       INNER JOIN LY_ALUNO A
               ON A.ALUNO = M.ALUNO
       INNER JOIN LY_PESSOA P2
               ON P2.PESSOA = A.PESSOA
WHERE  ( Getdate() BETWEEN DATAINICIO AND DATAFIM )
       AND P2.NECESSIDADEESPECIALID &lt;&gt; 30
	   
SELECT DISTINCT ALUNOID, 'SIM' AVALIADO
INTO #AVALIADONAPES
FROM [LYCEUM].[NecessidadeEspecial].[AVALIACAONAPES]  AP
WHERE ( Getdate() BETWEEN AP.DATAINICIO AND AP.DATAFIM AND AP.TRANSITORIO &lt;&gt; 0) OR (AP.TRANSITORIO = 0)

SELECT DISTINCT ALUNOID, 'SIM' MARCADO
INTO #MARCADODIRETOR
FROM [LYCEUM].[NecessidadeEspecial].[ALUNORECURSONECESSIDADEESPECIAL]


 SELECT DISTINCT R.REGIONAL,
       M.NOME                              AS MUNICIPIO,
       A.UNIDADE_ENSINO                    AS CENSO,
       UE.NOME_COMP                        AS ESCOLA,
       A.ALUNO,
       P.NOME_COMPL                        AS 'NOME ALUNO',
       NEC.DESCRICAO AS NECESSIDADE_ESPECIAL,

	   ISNULL(T.TURNO,'') TURNO,
	   ISNULL(T.TURMA,'') TURMA,
	   T.ANO ANO,
	   T.SEMESTRE PERÍODO,
	   T.SERIE SÉRIE,

	   ISNULL(C.NOME,'') CURSO,
	   ISNULL(MC.DESCRICAO,'') MODALIDADE,
	   ISNULL(MD.MARCADO, 'NÃO')		   AS MARCADODIRECAO,
	   ISNULL(AN.AVALIADO, 'NÃO')          AS AVALIADONAPES,
	   ISNULL(CD.DADOS_CUIDADOR, '')       AS CUIDADOR,
       ISNULL(L.DADOS_LEDOR, '')           AS LEDOR,
       ISNULL(I.DADOS_INTERPRETETURMA, '') AS INTERPRETE,
	   ISNULL((SELECT STUFF(
			(SELECT DISTINCT '/' + r.NOME 
             FROM [DBO].[PESSOA_RECURSOAPLICACAOPROVA] PR 
				INNER JOIN [NecessidadeEspecial].[RECURSOAPLICACAOPROVA] R   ON PR.RECURSOAPLICACAOPROVAID = R.RECURSOAPLICACAOPROVAID
				INNER JOIN LY_ALUNO A2 ON A2.PESSOA = PR.PESSOAID 
				WHERE r.RECURSOAPLICACAOPROVAID in (7,8,9) and R.ATIVO = 1 AND A2.ALUNO=A.ALUNO
              FOR XML PATH (''))
             , 1, 1, '')),'') RECURSOS_APLICACAO_PROVA
FROM   LY_ALUNO A
       INNER JOIN LY_PESSOA P
               ON P.PESSOA = A.PESSOA
       INNER JOIN LY_UNIDADE_ENSINO UE
               ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
       INNER JOIN TCE_REGIONAL R
               ON R.ID_REGIONAL = UE.ID_REGIONAL
       INNER JOIN MUNICIPIO M
               ON M.CODIGO = UE.MUNICIPIO
       LEFT JOIN #CUIDADOR CD
              ON CD.ALUNOID = A.ALUNO
       LEFT JOIN #LEDOR L
              ON L.ALUNOID = A.ALUNO
       LEFT JOIN #INTERPRETETURMA I
              ON I.ALUNO = A.ALUNO
	   LEFT JOIN #AVALIADONAPES AN
			  ON AN.ALUNOID = A.ALUNO
	   LEFT JOIN #MARCADODIRETOR MD
		      ON MD.ALUNOID = A.ALUNO 
	   LEFT JOIN HADES.dbo.NECESSIDADEESPECIAL NEC 
			 ON NEC.NECESSIDADEESPECIALID=P.NECESSIDADEESPECIALID
	   LEFT JOIN	LY_MATRICULA MM (NOLOCK) 
				ON		MM.ALUNO = A.ALUNO
				AND		MM.ANO = @ANO
				AND		MM.SIT_MATRICULA &lt;&gt; 'CANCELADO'
          AND		ISNULL(MM.DEPENDENCIA,'N') = 'N'
          AND		ISNULL(MM.CONCOMITANTE, 'N') = 'N'
          AND		ISNULL(MM.MAIS_EDUCACAO,'N') = 'N'
          AND		ISNULL(MM.EDUC_ESPECIAL,'N') = 'N'
          AND		MM.TURMA NOT LIKE 'MAIS%'
          AND		MM.TURMA NOT LIKE 'LE%'
          AND		MM.TURMA NOT LIKE 'ER%'
          AND		MM.TURMA NOT LIKE 'REF%'
          AND		MM.TURMA NOT LIKE 'SUP%'
          AND		MM.TURMA NOT LIKE 'SALA%'
          AND		MM.TURMA NOT LIKE 'PCE%'
          LEFT JOIN	LY_TURMA T (NOLOCK)
          ON		T.ANO = MM.ANO
          AND		T.SEMESTRE = MM.SEMESTRE
          AND		T.DISCIPLINA = MM.DISCIPLINA
          AND		T.TURMA = MM.TURMA
          LEFT JOIN	LY_CURSO C (NOLOCK)
          ON		C.CURSO = T.CURSO
          LEFT JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
          ON		MC.MODALIDADE = C.MODALIDADE
          JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = UE.UNIDADE_ENS

          WHERE  SIT_ALUNO = 'Ativo'
          AND P.NECESSIDADEESPECIALID &lt;&gt; 30
          AND (UE.ID_REGIONAL = ISNULL(@REGIONAL, UE.ID_REGIONAL) OR UE.ID_REGIONAL IS NULL)
          AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO) OR UE.MUNICIPIO IS NULL)
          AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
          AND (LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL)
          ORDER  BY R.REGIONAL,
          M.NOME,
          UE.NOME_COMP,
          P.NOME_COMPL

          DROP TABLE #CUIDADOR
          DROP TABLE #LEDOR
          DROP TABLE #INTERPRETETURMA
          DROP TABLE #AVALIADONAPES
          DROP TABLE #MARCADODIRETOR</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
