        </Field>
        <Field Name="MARCADODIRECAO">
          <DataField>MARCADODIRECAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AVALIADONAPES">
          <DataField>AVALIADONAPES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CUIDADOR">
          <DataField>CUIDADOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LEDOR">
          <DataField>LEDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="INTERPRETE">
          <DataField>INTERPRETE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RECURSOS_APLICACAO_PROVA">
          <DataField>RECURSOS_APLICACAO_PROVA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT	0 ID_REGIONAL,' Selecione...' REGIONAL
UNION
SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) REGIONAL
FROM	TCE_REGIONAL TR (NOLOCK)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER	BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	DISTINCT M.CODIGO, M.NOME 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL)OR TR.ID_REGIONAL IS NULL)
AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
UNION
SELECT	NULL CODIGO,' TODOS' NOME
UNION
SELECT	'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER	BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT	NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT	LUE.UNIDADE_ENS, SUBSTRING (LUE.NOME_COMP,1,50) NOME_COMP 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK) 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND LUES.DT_SITUACAO = (
										SELECT	MAX(DT_SITUACAO)
										FROM	LY_UNIDADE_ENSINO_SITUACAO L1 
										WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS)
										AND		(SIT_FUNCIONAMENTO = 'EmAtividade' OR SIT_FUNCIONAMENTO IS NULL
										)
WHERE	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO)OR LUE.MUNICIPIO IS NULL)
AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL) 
ORDER	BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DATA_ATUALIZACAO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>
SELECT	TOP(1) 
		CONVERT(VARCHAR(2),
		(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), 
		DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), 
		DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
		CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 14
</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
