    <BottomMargin>1cm</BottomMargin>
    <ColumnSpacing>0.13cm</ColumnSpacing>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LyceumGov</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>043b60d1-4934-4634-b111-e1800adbde23</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@munic">
            <Value>=Parameters!munic.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT * FROM (
SELECT DISTINCT VS.UA_ATUAL AS SETOR
                ,LY_UNIDADE_ENSINO.UNIDADE_ENS
                ,LY_UNIDADE_ENSINO.NOME_COMP ESCOLA
                ,ISNULL(ISNULL(LY_MATRICULA.TURMA,LY_HISTMATRICULA.TURMA),'NÃO CONSTA') TURMA
                ,LY_ALUNO.ALUNO
                ,UPPER(LY_PESSOA.NOME_COMPL)NOME_COMPL
                ,ISNULL(LY_H_CURSOS_CONCL.MOTIVO,UPPER(LY_ALUNO.SIT_ALUNO)) SIT_ALUNO
                ,LY_CURSO.NOME +'-'+LY_MODALIDADE_CURSO.DESCRICAO MODALIDADE_2009
                ,CONVERT(VARCHAR(30),LY_ALUNO.SERIE) ANO_ESCOLARIDADE_2009
                ,LY_TIPO_CURSO.DESCRICAO TIPO
                ,LY_MODALIDADE_CURSO.DESCRICAO MODALIDADE
                , NULL SITUACAO_2009
                , NULL MODALIDADE_2010
                , NULL ANO_ESCOLARIDADE_2010
                , NULL TURMA_2010
                , NULL OBS
                ,LY_NUCLEO.DESCRICAO COORDENADORIA
                ,LY_NUCLEO.NUCLEO
                ,MUNICIPIO.CODIGO 
                ,MUNICIPIO.NOME NOME_MUNIC
FROM   LY_ALUNO WITH(NOLOCK)
JOIN LY_PESSOA WITH(NOLOCK)
         ON LY_PESSOA.PESSOA = LY_ALUNO.PESSOA
       JOIN LY_CURSO WITH(NOLOCK)
         ON LY_CURSO.CURSO = LY_ALUNO.CURSO
       JOIN LY_MODALIDADE_CURSO
         ON LY_MODALIDADE_CURSO.MODALIDADE = LY_CURSO.MODALIDADE
       JOIN LY_TIPO_CURSO
         ON LY_TIPO_CURSO.TIPO = LY_CURSO.TIPO
       LEFT JOIN LY_H_CURSOS_CONCL
         ON LY_ALUNO.ALUNO = LY_H_CURSOS_CONCL.ALUNO
            AND LY_H_CURSOS_CONCL.DT_REABERTURA IS NULL
       JOIN LY_UNIDADE_ENSINO
         ON LY_UNIDADE_ENSINO.UNIDADE_ENS = LY_ALUNO.UNIDADE_ENSINO
       LEFT JOIN LY_HISTMATRICULA 
         ON LY_HISTMATRICULA.ALUNO = LY_ALUNO.ALUNO
            AND LY_HISTMATRICULA.ANO = 2009 AND LY_HISTMATRICULA.SITUACAO_HIST&lt;&gt;'Cancelado'
       LEFT JOIN LY_MATRICULA 
		 ON LY_MATRICULA.ALUNO=LY_ALUNO.ALUNO
		 AND LY_MATRICULA.ANO=2009 
		 AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
	   JOIN LY_NUCLEO ON LY_NUCLEO.NUCLEO=LY_UNIDADE_ENSINO.NUCLEO
	   JOIN MUNICIPIO ON MUNICIPIO.CODIGO=LY_UNIDADE_ENSINO.MUNICIPIO
	   JOIN HADES..VW_SETOR VS ON VS.SETOR =LY_UNIDADE_ENSINO.SETOR
WHERE  NOT EXISTS (SELECT 1
                   FROM   LY_MATRICULA WITH(NOLOCK)
                   WHERE  LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                          AND LY_MATRICULA.ANO = 2010
                          AND LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO) 
AND	 LY_ALUNO.ALUNO NOT LIKE '2010%'
UNION                           
SELECT DISTINCT VS.UA_ATUAL AS SETOR
                ,LY_UNIDADE_ENSINO.UNIDADE_ENS
                ,LY_UNIDADE_ENSINO.NOME_COMP ESCOLA
                ,ISNULL(ISNULL(LY_MATRICULA.TURMA,LY_HISTMATRICULA.TURMA),'NÃO CONSTA') TURMA
                ,LY_ALUNO.ALUNO
                ,UPPER(LY_PESSOA.NOME_COMPL)NOME_COMPL
                ,ISNULL(LY_H_CURSOS_CONCL.MOTIVO,UPPER(LY_ALUNO.SIT_ALUNO)) SIT_ALUNO
                ,'NÃO CONSTA' MODALIDADE_2009
                ,'NÃO CONSTA' ANO_ESCOLARIDADE_2009
                ,LY_TIPO_CURSO.DESCRICAO TIPO
                ,LY_MODALIDADE_CURSO.DESCRICAO MODALIDADE
                ,'NÃO CONSTA'
                ,LY_CURSO.NOME +'-'+LY_MODALIDADE_CURSO.DESCRICAO MODALIDADE_2010
                ,LY_ALUNO.SERIE ANO_ESCOLARIDADE_2010
                , NULL TURMA_2010
                , NULL OBS
                ,LY_NUCLEO.DESCRICAO COORDENADORIA
                ,LY_NUCLEO.NUCLEO
                ,MUNICIPIO.CODIGO 
                ,MUNICIPIO.NOME NOME_MUNIC
FROM   LY_ALUNO WITH(NOLOCK)
  JOIN LY_PESSOA WITH(NOLOCK)
         ON LY_PESSOA.PESSOA = LY_ALUNO.PESSOA
       JOIN LY_CURSO WITH(NOLOCK)
         ON LY_CURSO.CURSO = LY_ALUNO.CURSO
       JOIN LY_MODALIDADE_CURSO
         ON LY_MODALIDADE_CURSO.MODALIDADE = LY_CURSO.MODALIDADE
       JOIN LY_TIPO_CURSO
         ON LY_TIPO_CURSO.TIPO = LY_CURSO.TIPO
       LEFT JOIN LY_H_CURSOS_CONCL
         ON LY_ALUNO.ALUNO = LY_H_CURSOS_CONCL.ALUNO
            AND LY_H_CURSOS_CONCL.DT_REABERTURA IS NULL
       JOIN LY_UNIDADE_ENSINO
         ON LY_UNIDADE_ENSINO.UNIDADE_ENS = LY_ALUNO.UNIDADE_ENSINO
       LEFT JOIN LY_HISTMATRICULA 
         ON LY_HISTMATRICULA.ALUNO = LY_ALUNO.ALUNO
            AND LY_HISTMATRICULA.ANO = 2009 AND LY_HISTMATRICULA.SITUACAO_HIST&lt;&gt;'Cancelado'
       LEFT JOIN LY_MATRICULA 
		 ON LY_MATRICULA.ALUNO=LY_ALUNO.ALUNO
		 AND LY_MATRICULA.ANO=2009 
		 AND LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
		 JOIN LY_NUCLEO ON LY_NUCLEO.NUCLEO=LY_UNIDADE_ENSINO.NUCLEO
	   JOIN MUNICIPIO ON MUNICIPIO.CODIGO=LY_UNIDADE_ENSINO.MUNICIPIO
	   JOIN HADES..VW_SETOR VS ON VS.SETOR =LY_UNIDADE_ENSINO.SETOR
WHERE  NOT EXISTS (SELECT 1
                   FROM   LY_MATRICULA WITH(NOLOCK)
                   WHERE  LY_MATRICULA.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                          AND LY_MATRICULA.ANO = 2010
                          AND LY_MATRICULA.ALUNO = LY_ALUNO.ALUNO) 
AND	 LY_ALUNO.ALUNO LIKE '2010%'                          
)SQL1                          
WHERE 
SQL1.UNIDADE_ENS=@escola
and
SQL1.nucleo=@coord
and SQL1.CODIGO=@munic

ORDER BY SQL1.MODALIDADE_2009,SQL1.ANO_ESCOLARIDADE_2009,SQL1.TURMA,SQL1.MODALIDADE_2010,SQL1.ANO_ESCOLARIDADE_2010,SQL1.TURMA_2010,SQL1.NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
