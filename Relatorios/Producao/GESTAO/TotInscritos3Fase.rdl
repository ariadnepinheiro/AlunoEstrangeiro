      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>1f5c4d38-3e1d-4dea-b27b-31f815a35388</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select CONVERT(date,datacadastro),  CONVERT(VARCHAR(10), datacadastro, 103) as DATA,
count(*) as TOTAL
from [Matricula].[INSCRICAOALUNO] (NOLOCK)
where [INSCRICAOALUNOID] &lt;&gt; 1
GROUP BY  CONVERT(date,datacadastro),CONVERT(VARCHAR(10), datacadastro, 103)
ORDER BY  CONVERT(date,datacadastro)</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField />
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL">
          <DataField>TOTAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
