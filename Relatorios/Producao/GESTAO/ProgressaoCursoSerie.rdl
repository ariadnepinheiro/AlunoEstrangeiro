  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT 
LTC.DESCRICAO SEGMENTO, 
LMC.DESCRICAO MODALIDADE, 
LC.CURSO, 
LC.NOME DS_CURSO, 
P.SERIEID SERIE, 
LTC1.DESCRICAO PROX_SEGMENTO, 
LMC1.DESCRICAO PROX_MODALIDADE, 
LC1.CURSO PROX_CURSO, 
LC1.NOME PROX_DS_CURSO, 
P.PROXIMOSERIEID
FROM PROGRESSAOSERIE P (NOLOCK)
JOIN LY_CURSO LC (NOLOCK) ON P.CURSOID = LC.CURSO
JOIN LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE
JOIN LY_TIPO_CURSO LTC (NOLOCK) ON LTC.TIPO = LC.TIPO
JOIN LY_CURSO LC1 (NOLOCK) ON LC1.CURSO = P.PROXIMOCURSOID
JOIN LY_MODALIDADE_CURSO LMC1 (NOLOCK) ON  LMC1.MODALIDADE = LC1.MODALIDADE
JOIN LY_TIPO_CURSO LTC1 (NOLOCK) ON  LTC1.TIPO = LC1.TIPO
ORDER BY LMC.DESCRICAO, LTC.DESCRICAO, LC.CURSO, P.SERIEID</CommandText>
      </Query>
