  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>4a42e970-cebc-4b13-939f-55765f4e4f12</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT distinct R.REGIONAL, 
	M.NOME AS MUNICIPIO, 
	ue.UNIDADE_ENS,
	UE.NOME_COMP, 
	FORMAT((SELECT MAX(DT_ALTERACAO) 
		FROM  TCE_EQUIPAMENTO_UNIDADE_FISICA 
		WHERE UNIDADE_FISICA = UE.UNIDADE_ENS), 'dd/MM/yyyy HH:mm:ss') AS DATAEQUIPAMENTOS,
	FORMAT((SELECT MAX(DT_ALTERACAO)
		FROM  TCE_TIPO_DEPENDENCIA_UNIDADE_FISICA 
		WHERE UNIDADE_FISICA = UE.UNIDADE_ENS), 'dd/MM/yyyy HH:mm:ss') AS  DATADEPENDENCIA
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK)
	INNER JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
	INNER JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
	INNER JOIN LYCEUM..MUNICIPIO M ON UE.MUNICIPIO = M.CODIGO
WHERE (R.ID_REGIONAL = ISNULL(@REGIONAL, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
	AND (UE.MUNICIPIO = ISNULL(@MUNIC, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
	AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL)
	AND  EXISTS (SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN (SELECT UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO))
																FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS))
	AND	(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY REGIONAL, MUNICIPIO, NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATAEQUIPAMENTOS">
          <DataField>DATAEQUIPAMENTOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATADEPENDENCIA">
          <DataField>DATADEPENDENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT	0 ID_REGIONAL,' Selecione...' REGIONAL
UNION
SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) REGIONAL
FROM	TCE_REGIONAL TR (NOLOCK)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER	BY REGIONAL 
</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	DISTINCT M.CODIGO, M.NOME 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
UNION
SELECT	NULL CODIGO,' TODOS' NOME
UNION
SELECT	'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER	BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="usuario">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>usuario</Prompt>
      <Hidden>true</Hidden>
    </ReportParameter>
    <ReportParameter Name="REGIONAL">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
