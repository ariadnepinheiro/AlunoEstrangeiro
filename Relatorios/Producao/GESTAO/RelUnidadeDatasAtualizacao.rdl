          <LabelField>REGIONAL</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="MUNICIPIO">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>MUNICÍPIO</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>MUNICIPIO</DataSetName>
          <ValueField>CODIGO</ValueField>
          <LabelField>NOME</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
