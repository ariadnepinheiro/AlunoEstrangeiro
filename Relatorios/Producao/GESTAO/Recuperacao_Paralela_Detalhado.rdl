  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>e230a6d9-6cfd-4081-a510-7c5b4a6b7006</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="LANCAMENTOS">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PROVA">
            <Value>=Parameters!PROVA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	DISTINCT
		TR.REGIONAL, 
		MM.NOME DS_MUNICIPIO, 
		LUE.UNIDADE_ENS CENSO, 
		LUE.NOME_COMP UNIDADE, 
		LMC.DESCRICAO MODALIDADE, 
		LC.NOME CURSO, 
		CASE WHEN LN.PROVA = 'MÉDIA1' THEN '1BIM' 
			 WHEN LN.PROVA = 'MÉDIA2' THEN '2BIM'
			 WHEN LN.PROVA = 'MÉDIA3' THEN '3BIM'
			 WHEN LN.PROVA = 'MÉDIA4' THEN '4BIM' 
		END BIMESTRE, 
		LT.SERIE,
		LT.ANO, 
		LT.SEMESTRE, 
		LT.DISCIPLINA, 
		LT.TURMA, 
		UPPER (LD.NOME_COMPL) NOME_DISCIPLINA, 
		LA.ALUNO, 
		PE.NOME_COMPL, 
		LN.RECUPERACAO_PARALELA
FROM	LY_ALUNO LA (NOLOCK)
JOIN	LY_PESSOA PE (NOLOCK)ON PE.PESSOA = LA.PESSOA
JOIN	LY_MATRICULA LM (NOLOCK)ON LM.ALUNO = LA.ALUNO
JOIN	APOLLO..TURMA_PRINCIPAL_ALUNO A (NOLOCK) ON A.ALUNO = LM.ALUNO
		AND A.ANO = LM.ANO
		AND A.SEMESTRE = LM.SEMESTRE
		AND A.TURMA = LM.TURMA
		AND LM.ANO = YEAR(GETDATE())
JOIN	LY_TURMA LT (NOLOCK) ON LT.ANO = LM.ANO
		AND LT.SEMESTRE = LM.SEMESTRE
		AND LT.TURMA = LM.TURMA
		AND LT.DISCIPLINA = LM.DISCIPLINA
		AND LT.SIT_TURMA = 'ABERTA'
JOIN	LY_NOTA LN (NOLOCK) ON LN.ANO = LM.ANO
		AND LN.SEMESTRE = LM.SEMESTRE
		AND LN.DISCIPLINA = LM.DISCIPLINA
		AND LN.TURMA = LM.TURMA
		AND LN.ALUNO = LM.ALUNO
		AND LN.CONCEITO &lt;&gt; ''
		AND LN.CONCEITO IS NOT NULL
		AND LN.PROVA = @PROVA
		AND CONVERT(DECIMAL(10,2),REPLACE(LN.CONCEITO,',','.')) &lt; 5
JOIN	LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LT.CURSO
JOIN	LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO MM (NOLOCK) ON MM.CODIGO = LUE.MUNICIPIO
WHERE	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO,  LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)       
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)			
</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DS_MUNICIPIO">
          <DataField>DS_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
