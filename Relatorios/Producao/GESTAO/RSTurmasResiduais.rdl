  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENSINO">
          <DataField>UNIDADE_ENSINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ESCOLARIDADE">
          <DataField>ESCOLARIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SALA">
          <DataField>SALA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_CRIACAO">
          <DataField>DATA_CRIACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MAXIMO_ALUNOS">
          <DataField>MAXIMO_ALUNOS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CAPACIDADE">
          <DataField>CAPACIDADE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ALUNOS_MATRICULADOS">
          <DataField>ALUNOS_MATRICULADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALUNOS_RESERVADOS">
          <DataField>ALUNOS_RESERVADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VAGAS">
          <DataField>VAGAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT  TR.REGIONAL ,
        TM.NOME AS MUNICIPIO ,
        LUE.UNIDADE_ENS AS CENSO ,
        LUE.NOME_COMP AS UNIDADE_ENSINO ,
        LT.ANO ,
        LT.SEMESTRE ,
        LC.NOME AS ESCOLARIDADE ,
        LT.TURNO ,
        LT.SERIE ,
        LT.TURMA ,
        LT.DEPENDENCIA AS SALA ,
        CONVERT(VARCHAR, LT.DT_CRIACAO, 103) AS DATA_CRIACAO ,
        LT.NUM_ALUNOS AS CAPACIDADE ,
        MAX(NUM_ALUNOS) AS 'MAXIMO_ALUNOS' ,
        0 AS ALUNOS_MATRICULADOS ,
        0 AS ALUNOS_RESERVADOS ,
        0 AS 'VAGAS'
INTO    #TURMASRESIDUAIS
FROM    DBO.LY_TURMA LT ( NOLOCK )
        INNER JOIN LY_CURSO LC ( NOLOCK ) ON LC.CURSO = LT.CURSO
        INNER JOIN LY_UNIDADE_ENSINO LUE ( NOLOCK ) ON LUE.UNIDADE_ENS = LT.FACULDADE
        INNER JOIN TCE_REGIONAL TR ( NOLOCK ) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
        INNER JOIN HADES..TCE_MUNICIPIO TM ( NOLOCK ) ON TM.ID_MUNICIPIO = LUE.MUNICIPIO
WHERE   LT.SIT_TURMA = 'ABERTA'
        AND TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL)
        AND TM.ID_MUNICIPIO = ISNULL(@MUNIC, TM.ID_MUNICIPIO)
        AND LT.FACULDADE = ISNULL(@ESCOLA, LT.FACULDADE)
        AND LT.ANO = @ANO
        AND LT.SEMESTRE = @SEMESTRE
GROUP BY TR.REGIONAL ,
        TM.NOME ,
        LUE.UNIDADE_ENS ,
        LUE.NOME_COMP ,
        LT.ANO ,
        LT.SEMESTRE ,
        LC.NOME ,
        LT.TURNO ,
        LT.SERIE ,
        LT.TURMA ,
        LT.DEPENDENCIA ,
        LT.DT_CRIACAO ,
        LT.NUM_ALUNOS

--Atualiza alunos matriculados
UPDATE  #TURMASRESIDUAIS
SET     ALUNOS_MATRICULADOS = ( SELECT  COUNT(DISTINCT MAT.ALUNO)
                                FROM    LY_MATRICULA MAT ( NOLOCK )
                                WHERE   MAT.TURMA = #TURMASRESIDUAIS.TURMA
                                        AND MAT.ANO = #TURMASRESIDUAIS.ANO
                                        AND MAT.SEMESTRE = #TURMASRESIDUAIS.SEMESTRE
                                        AND MAT.SIT_MATRICULA &lt;&gt; 'CANCELADO'
                                        AND ISNULL(MAT.DEPENDENCIA, 'N') &lt;&gt; 'S'
                              )

--Atualiza transferencias pendentes       
UPDATE  #TURMASRESIDUAIS
SET     ALUNOS_RESERVADOS = ( SELECT    COUNT(DISTINCT TD.ID_TRANSFERENCIA_DESTINO)
                              FROM      DBO.TCE_TRANSFERENCIA_DESTINO TD ( NOLOCK )
                                        INNER JOIN DBO.TCE_TRANSFERENCIA TRA ON TD.ID_TRANSFERENCIA = TRA.ID_TRANSFERENCIA
                              WHERE     #TURMASRESIDUAIS.CENSO = TD.CENSO
                                        AND #TURMASRESIDUAIS.ANO = TD.ANO
                                        AND #TURMASRESIDUAIS.SEMESTRE = TD.PERIODO
                                        AND #TURMASRESIDUAIS.TURMA = TD.TURMA
                                        AND TRA.STATUS = 'PENDENTE'
                            )
--Atualiza saldo de vagas             
UPDATE  #TURMASRESIDUAIS
SET     VAGAS = MAXIMO_ALUNOS - ALUNOS_MATRICULADOS - ALUNOS_RESERVADOS

SELECT  *
FROM    #TURMASRESIDUAIS
WHERE   VAGAS &gt; 0
ORDER BY REGIONAL ,
        MUNICIPIO ,
        UNIDADE_ENSINO ,
        ANO ,
        SEMESTRE ,
        ESCOLARIDADE ,
        TURNO ,
        SERIE ,
        TURMA 

DROP TABLE #TURMASRESIDUAIS</CommandText>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.ID_REGIONAL = ISNULL(@REGIONAL,ue.ID_REGIONAL) or ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="municipio">
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT  NULL CODIGO, ' TODOS' DESCRICAO
UNION
SELECT DISTINCT L1.CODIGO, L1.NOME DESCRICAO
FROM    LY_UNIDADE_ENSINO l2
        JOIN municipio l1 ON l1.CODIGO = l2.MUNICIPIO
        JOIN dbo.TCE_REGIONAL r1 ON r1.ID_REGIONAL = l2.ID_REGIONAL
        JOIN LY_USUARIO_UNIDADE_FIS jj ON jj.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE   ( r1.ID_REGIONAL = ISNULL(@REGIONAL, r1.ID_REGIONAL)
          OR r1.ID_REGIONAL IS NULL
        )
        AND ( jj.USUARIO = ISNULL(@usuario, jj.USUARIO)
              OR jj.USUARIO IS NULL
            ) ORDER BY DESCRICAO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ANO">
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>-- RETORNA UMA LISTA DE ANOS QUE EXISTAM NA BASE (HIST E ATUAL)
SELECT DISTINCT ANO FROM LY_MATRICULA (NOLOCK) 
WHERE ANO &gt;= 2010
UNION 
SELECT DISTINCT ANO FROM LY_HISTMATRICULA (NOLOCK) 
WHERE ANO &gt;= 2010 ORDER BY ANO DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Regional">
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT NULL AS ID_REGIONAL, ' TODAS' AS REGIONAL 
UNION
SELECT ID_REGIONAL AS ID_REGIONAL, REGIONAL  AS REGIONAL
FROM TCE_REGIONAL  
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
