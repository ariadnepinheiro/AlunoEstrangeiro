<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.50.12.29;Initial Catalog=LYCEUM</ConnectString>
        <Prompt>Specify a user name and password for data source DS_ALUNOS:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @ANO &gt; YEAR(GETDATE()) AND @SEMESTRE = 1

BEGIN
SELECT	REGIONAL, 
		NOME MUNICIPIO, 
		UNIDADE_ENS CENSO, 
		NOME_COMP UNIDADE, 
		ANO,
		COUNT(DISTINCT ALUNO) TOTAL_ALUNOS,
		ISNULL(SUM (RENOVADOS),0) RENOVADOS,
		ISNULL(SUM (CANCELADOS),0) CANCELADOS,
		ISNULL(SUM (ENSINO_RELIGIOSO),0) ENSINO_RELIGIOSO, 
		ISNULL(SUM (LINGUA_ESTRANGEIRA),0) LINGUA_ESTRANGEIRA
FROM			
(
				SELECT	DISTINCT REGIONAL, 
						M.NOME,
						UE.UNIDADE_ENS,
						UE.NOME_COMP, 		
						LA.ALUNO, 
						@ANO ANO,
						CASE WHEN R.SITUACAORENOVACAOID = 1 OR R.SITUACAORENOVACAOID = 3 THEN 1 ELSE 0 END AS RENOVADOS,
						CASE WHEN R.SITUACAORENOVACAOID = 2 THEN 1 ELSE 0 END AS CANCELADOS,
						CONVERT(INT, R.ENSINORELIGIOSO) ENSINO_RELIGIOSO, 
						CONVERT(INT,R.LINGUAESTRANGEIRA) LINGUA_ESTRANGEIRA
				FROM	LY_ALUNO LA (NOLOCK)
				JOIN	LY_MATRICULA LM (NOLOCK) ON LM.ALUNO = LA.ALUNO
						AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
						AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
						AND ISNULL(LM.CONCOMITANTE, 'N') = 'N'
						AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
						AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
				JOIN	LY_TURMA LT (NOLOCK) ON LT.ANO = LM.ANO
						AND LT.TURMA = LM.TURMA
						AND LT.SEMESTRE = LM.SEMESTRE
						AND LT.DISCIPLINA = LM.DISCIPLINA
						AND SIT_TURMA = 'ABERTA'	
						AND LT.ANO = @ANO-1
						--AND LT.SEMESTRE IN (0,2)
						AND ((LT.ANO &lt;&gt; 2020 AND LT.SEMESTRE IN (0,2)) OR (LT.ANO = 2020 AND LT.SEMESTRE IN (0,1)))
						AND (LT.SERIE &lt;&gt; 9 OR 
						(LT.SERIE = 9 
							AND EXISTS (SELECT TOP 1 1  
										FROM LY_TURMA T2 (NOLOCK) 
										      INNER JOIN LY_CURSO C2 (NOLOCK) ON T2.CURSO = C2.CURSO
										WHERE T2.ANO = LT.ANO + 1 
											  AND T2.UNIDADE_RESPONSAVEL = LT.UNIDADE_RESPONSAVEL 
											  AND T2.SERIE = 1
											  AND C2.TIPO = 3 --Medio
											  AND C2.MODALIDADE NOT IN ('ED2', 'ED7') --EJA
											  )))
				JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
						AND LS.TURNO = LT.TURNO
						AND LS.CURRICULO = LT.CURRICULO
						AND LS.SERIE = LT.SERIE		
						AND ISNULL (LS.ANO_SERIE_CONCLUINTE, 'N') = 'N'
						AND LS.CURSO NOT IN ('0001.17', '0001.27', '0002.37', '9999.99')
				JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
				LEFT	JOIN RENOVACAO R (NOLOCK) ON LA.ALUNO = R.ALUNOID
						AND R.ANO = @ANO
						AND R.PERIODO IN (0,1)
						AND R.DATAALTERACAO = (
												SELECT	MAX(DATAALTERACAO) 
												FROM	RENOVACAO (NOLOCK)
												WHERE	ANO = @ANO
												AND		PERIODO IN  (0,1)
												AND		RENOVACAO.ALUNOID = R.ALUNOID
												)
				JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = UE.ID_REGIONAL
				JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = UE.MUNICIPIO
				
				) AA				
GROUP BY REGIONAL, 
		NOME, 
		UNIDADE_ENS, 
		NOME_COMP, 
		ANO	
ORDER BY 	 REGIONAL, 
		NOME, 		
		NOME_COMP	
END

ELSE IF @ANO = YEAR(GETDATE()) AND @SEMESTRE = 2

BEGIN

SELECT	REGIONAL, 
		NOME MUNICIPIO, 
		UNIDADE_ENS CENSO, 
		NOME_COMP UNIDADE, 
		ANO,
		COUNT(DISTINCT ALUNO) TOTAL_ALUNOS,
		ISNULL(SUM (RENOVADOS),0) RENOVADOS,
		ISNULL(SUM (CANCELADOS),0) CANCELADOS,
		ISNULL(SUM (ENSINO_RELIGIOSO),0) ENSINO_RELIGIOSO, 
		ISNULL(SUM (LINGUA_ESTRANGEIRA),0) LINGUA_ESTRANGEIRA
FROM			
(
				SELECT	DISTINCT REGIONAL, 
						M.NOME,
						UE.UNIDADE_ENS,
						UE.NOME_COMP, 		
						LA.ALUNO, 
						@ANO ANO,
						CASE WHEN R.SITUACAORENOVACAOID = 1 OR R.SITUACAORENOVACAOID = 3 THEN 1 ELSE 0 END AS RENOVADOS,
						CASE WHEN R.SITUACAORENOVACAOID = 2 THEN 1 ELSE 0 END AS CANCELADOS,
						CONVERT(INT, R.ENSINORELIGIOSO) ENSINO_RELIGIOSO, 
						CONVERT(INT,R.LINGUAESTRANGEIRA) LINGUA_ESTRANGEIRA
				FROM	LY_ALUNO LA (NOLOCK)
				JOIN	LY_MATRICULA LM (NOLOCK) ON LM.ALUNO = LA.ALUNO
						AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
						AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
						AND ISNULL(LM.CONCOMITANTE, 'N') = 'N'
						AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
						AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
				JOIN	LY_TURMA LT (NOLOCK) ON LT.ANO = LM.ANO
						AND LT.TURMA = LM.TURMA
						AND LT.SEMESTRE = LM.SEMESTRE
						AND LT.DISCIPLINA = LM.DISCIPLINA
						AND SIT_TURMA = 'ABERTA'	
						AND LT.ANO = @ANO	
						AND LT.SEMESTRE = 1
				JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
						AND LS.TURNO = LT.TURNO
						AND LS.CURRICULO = LT.CURRICULO
						AND LS.SERIE = LT.SERIE		
						AND ISNULL (LS.ANO_SERIE_CONCLUINTE, 'N') = 'N'
						AND LS.CURSO NOT IN ('0001.17', '0001.27', '0002.37', '9999.99')
				JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
				LEFT JOIN RENOVACAO R (NOLOCK) ON LA.ALUNO = R.ALUNOID
						AND R.ANO = @ANO
						AND R.PERIODO = 2
						AND R.DATAALTERACAO = (
												SELECT	MAX(DATAALTERACAO) 
												FROM	RENOVACAO (NOLOCK)
												WHERE	ANO = @ANO
												AND		PERIODO = 2
												AND		RENOVACAO.ALUNOID = R.ALUNOID
												)
				JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = UE.ID_REGIONAL
				JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = UE.MUNICIPIO
				) AA				
GROUP BY REGIONAL, 
		NOME, 
		UNIDADE_ENS, 
		NOME_COMP, 
		ANO	
ORDER BY 	 REGIONAL, 
		NOME, 		
		NOME_COMP			
END

ELSE IF @ANO &lt;= YEAR(GETDATE()) AND @SEMESTRE = 1 

BEGIN

SELECT	REGIONAL, 
		NOME MUNICIPIO, 
		UNIDADE_ENS CENSO, 
		NOME_COMP UNIDADE, 
		ANO,
		COUNT(DISTINCT ALUNO) TOTAL_ALUNOS,
		ISNULL(SUM (RENOVADOS),0) RENOVADOS,
		ISNULL(SUM (CANCELADOS),0) CANCELADOS,
		ISNULL(SUM (ENSINO_RELIGIOSO),0) ENSINO_RELIGIOSO, 
		ISNULL(SUM (LINGUA_ESTRANGEIRA),0) LINGUA_ESTRANGEIRA
FROM			
(									
				SELECT	DISTINCT REGIONAL, 
						M.NOME,
						UE.UNIDADE_ENS,
						UE.NOME_COMP, 		
						LA.ALUNO, 
						@ANO ANO,
						CASE WHEN R.SITUACAORENOVACAOID = 1 OR R.SITUACAORENOVACAOID = 3 THEN 1 ELSE 0 END AS RENOVADOS,
						CASE WHEN R.SITUACAORENOVACAOID = 2 THEN 1 ELSE 0 END AS CANCELADOS,
						CONVERT(INT, R.ENSINORELIGIOSO) ENSINO_RELIGIOSO, 
						CONVERT(INT,R.LINGUAESTRANGEIRA) LINGUA_ESTRANGEIRA
				FROM	LY_ALUNO LA (NOLOCK)
				JOIN	LY_HISTMATRICULA (NOLOCK) LM ON LM.ALUNO = LA.ALUNO
						AND SITUACAO_HIST &lt;&gt; 'CANCELADO'
						AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
						AND ISNULL(LM.CONCOMITANTE, 'N') = 'N'
						AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
						AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
				JOIN	LY_TURMA LT (NOLOCK) ON LT.ANO = LM.ANO
						AND LT.TURMA = LM.TURMA
						AND LT.SEMESTRE = LM.SEMESTRE
						AND LT.DISCIPLINA = LM.DISCIPLINA
						AND SIT_TURMA = 'FINALIZADA'	
						AND LT.ANO = @ANO-1
						AND LT.SEMESTRE IN (0,2)
				JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
						AND LS.TURNO = LT.TURNO
						AND LS.CURRICULO = LT.CURRICULO
						AND LS.SERIE = LT.SERIE		
						AND ISNULL (LS.ANO_SERIE_CONCLUINTE, 'N') = 'N' 
						AND LS.CURSO NOT IN ('0001.17', '0001.27', '0002.37', '9999.99')				
				JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
				LEFT JOIN RENOVACAO R (NOLOCK) ON LA.ALUNO = R.ALUNOID
						AND R.ANO = @ANO
						AND R.PERIODO IN  (0,1)
						AND R.DATAALTERACAO = (
												SELECT	MAX(DATAALTERACAO) 
												FROM	RENOVACAO (NOLOCK)
												WHERE	ANO = @ANO
												AND		PERIODO IN  (0,1)
												AND		RENOVACAO.ALUNOID = R.ALUNOID
												)
				JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = UE.ID_REGIONAL
				JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = UE.MUNICIPIO
				WHERE	NOT EXISTS (
									SELECT	1
									FROM	LY_H_CURSOS_CONCL H (NOLOCK)
									WHERE	H.ALUNO = LA.ALUNO
									AND		H.DT_REABERTURA IS NULL
									AND		MOTIVO &lt;&gt; 'CONCLUSAO' 
									AND		ANO_ENCERRAMENTO = @ANO-1
									)
)SQL1							
GROUP BY REGIONAL, 
		NOME, 
		UNIDADE_ENS, 
		NOME_COMP,
		ANO
ORDER BY 	 REGIONAL, 
		NOME, 		
		NOME_COMP			
END


ELSE IF @ANO &lt; YEAR(GETDATE()) AND @SEMESTRE = 2

BEGIN

SELECT	REGIONAL, 
		NOME MUNICIPIO, 
		UNIDADE_ENS CENSO, 
		NOME_COMP UNIDADE, 
		ANO,
		COUNT(DISTINCT ALUNO) TOTAL_ALUNOS,
		ISNULL(SUM (RENOVADOS),0) RENOVADOS,
		ISNULL(SUM (CANCELADOS),0) CANCELADOS,
		ISNULL(SUM (ENSINO_RELIGIOSO),0) ENSINO_RELIGIOSO, 
		ISNULL(SUM (LINGUA_ESTRANGEIRA),0) LINGUA_ESTRANGEIRA
FROM			
(					
				SELECT	DISTINCT REGIONAL, 
						M.NOME,
						UE.UNIDADE_ENS,
						UE.NOME_COMP, 		
						LA.ALUNO, 
						@ANO ANO,
						CASE WHEN R.SITUACAORENOVACAOID = 1 OR R.SITUACAORENOVACAOID = 3 THEN 1 ELSE 0 END AS RENOVADOS,
						CASE WHEN R.SITUACAORENOVACAOID = 2 THEN 1 ELSE 0 END AS CANCELADOS,
						CONVERT(INT, R.ENSINORELIGIOSO) ENSINO_RELIGIOSO, 
						CONVERT(INT,R.LINGUAESTRANGEIRA) LINGUA_ESTRANGEIRA
				FROM	LY_ALUNO LA (NOLOCK)
				JOIN	LY_HISTMATRICULA LM (NOLOCK) ON LM.ALUNO = LA.ALUNO
						AND SITUACAO_HIST &lt;&gt; 'CANCELADO'
						AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
						AND ISNULL(LM.CONCOMITANTE, 'N') = 'N'
						AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
						AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
				JOIN	LY_TURMA LT (NOLOCK) ON LT.ANO = LM.ANO
						AND LT.TURMA = LM.TURMA
						AND LT.SEMESTRE = LM.SEMESTRE
						AND LT.DISCIPLINA = LM.DISCIPLINA
						AND SIT_TURMA = 'FINALIZADA'	
						AND LT.ANO = @ANO
						AND LT.SEMESTRE IN (1)
				JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
						AND LS.TURNO = LT.TURNO
						AND LS.CURRICULO = LT.CURRICULO
						AND LS.SERIE = LT.SERIE		
						AND ISNULL (LS.ANO_SERIE_CONCLUINTE, 'N') = 'N' 
						AND LS.CURSO NOT IN ('0001.17', '0001.27', '0002.37', '9999.99')				
				JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
				LEFT JOIN RENOVACAO R (NOLOCK) ON LA.ALUNO = R.ALUNOID
						AND R.ANO = @ANO
						AND R.PERIODO = 2
						AND R.DATAALTERACAO = (
												SELECT	MAX(DATAALTERACAO) 
												FROM	RENOVACAO (NOLOCK)
												WHERE	ANO = @ANO
												AND		PERIODO = 2
												AND		RENOVACAO.ALUNOID = R.ALUNOID
												)
				JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = UE.ID_REGIONAL
				JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = UE.MUNICIPIO
				WHERE	
				NOT EXISTS (
									SELECT	1
									FROM	LY_H_CURSOS_CONCL H (NOLOCK)
									WHERE	H.ALUNO = LA.ALUNO
									AND		H.DT_REABERTURA IS NULL
									AND		MOTIVO &lt;&gt; 'CONCLUSAO' 
									AND		ANO_ENCERRAMENTO = @ANO
									)
)SQL1							
GROUP BY REGIONAL, 
		NOME, 
		UNIDADE_ENS, 
		NOME_COMP,
		ANO
ORDER BY 	 REGIONAL, 
		NOME, 		
		NOME_COMP			
END</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ALUNOS">
          <DataField>TOTAL_ALUNOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RENOVADOS">
          <DataField>RENOVADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CANCELADOS">
          <DataField>CANCELADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ENSINO_RELIGIOSO">
          <DataField>ENSINO_RELIGIOSO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="LINGUA_ESTRANGEIRA">
          <DataField>LINGUA_ESTRANGEIRA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO_LETIVO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
