        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MAT_FACIL">
          <DataField>MAT_FACIL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PROC_SELETIVO">
          <DataField>PROC_SELETIVO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="COMPARTILHADA">
          <DataField>COMPARTILHADA</DataField>
