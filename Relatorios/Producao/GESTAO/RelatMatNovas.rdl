  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	LA.ALUNO
INTO	#ALUNOS_NOVOS
FROM	LY_ALUNO LA (NOLOCK) 
WHERE	ANO_INGRESSO = @ANO
AND		SEM_INGRESSO IN (0, @SEMESTRE)

IF @ANO = YEAR(GETDATE()) AND @SEMESTRE IN (SELECT PERIODO FROM LY_PERIODO_LETIVO WHERE GETDATE() BETWEEN DT_INICIO AND DT_FIM)

BEGIN 

SELECT	REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO,
		SUM(MAT_FACIL) MAT_FACIL, SUM(PROC_SELETIVO) PROC_SELETIVO, SUM(COMPARTILHADA) COMPARTILHADA, SUM(MATRICULA_UE) MATRICULA_UE
FROM(

SELECT	REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO,
		CASE WHEN ALUNO IN (
								SELECT	ALUNO 
								FROM	APOLLO..REL_MATRICULA_FACIL A (NOLOCK)
								WHERE	A.ALUNO = ALUNO 
							) 
			THEN COUNT (DISTINCT ALUNO) ELSE 0 
		END MAT_FACIL,
		CASE WHEN ALUNO IN (
								SELECT	ALUNO 
								FROM	ProcessoSeletivoAluno.ALUNO_CANDIDATOINSCRITOCLASSIFICADO A (NOLOCK)
								WHERE	A.ALUNOID = ALUNO
							) 
			THEN COUNT (DISTINCT ALUNO) ELSE 0 
		END AS PROC_SELETIVO,
		CASE WHEN ALUNO IN (
								SELECT	ALUNO 
								FROM	Matricula.ALUNO_UNIDADEENSINOCOMPARTILHADA A (NOLOCK)
								WHERE	A.ALUNOID = ALUNO
							) 
			THEN COUNT (DISTINCT ALUNO) ELSE 0 
		END COMPARTILHADA,
		COUNT (DISTINCT ALUNO) MATRICULA_UE
FROM(

SELECT  DISTINCT TR.REGIONAL, M.NOME MUNICIPIO, LUE.UNIDADE_ENS CENSO, LUE.NOME_COMP ESCOLA, LMC.DESCRICAO MODALIDADE, 
		LTC.DESCRICAO SEGMENTO, LC.NOME CURSO, LT.SERIE SERIE, LT.TURNO, LA.ALUNO ALUNO 
FROM	LY_MATRICULA LM (NOLOCK)
JOIN	#ALUNOS_NOVOS LA (NOLOCK) ON LA.ALUNO = LM.ALUNO
JOIN	LY_TURMA LT (NOLOCK) ON LT.TURMA = LM.TURMA
				AND	LT.DISCIPLINA = LM.DISCIPLINA
				AND	LT.ANO = LM.ANO
				AND LT.SEMESTRE = LM.SEMESTRE
				AND LT.ANO = @ANO
				AND LT.SEMESTRE IN (0, @SEMESTRE)
JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
				AND LS.TURNO = LT.TURNO
				AND LS.CURRICULO = LT.CURRICULO
				AND LS.SERIE = LT.SERIE
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LS.CURSO
JOIN	LY_TIPO_CURSO LTC (NOLOCK) ON LTC.TIPO = LC.TIPO
JOIN	LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO	
WHERE
(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND		LM.DT_MATRICULA = (
					SELECT	MIN(M.DT_MATRICULA) 
					FROM	LY_MATRICULA M (NOLOCK)
					WHERE	M.ALUNO = LM.ALUNO
					)

)SQL1

GROUP BY REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO, ALUNO

)SQL2

GROUP BY REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO

END

ELSE 

BEGIN

SELECT	REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO,
		SUM(MAT_FACIL) MAT_FACIL, SUM(PROC_SELETIVO) PROC_SELETIVO, SUM(COMPARTILHADA) COMPARTILHADA, SUM(MATRICULA_UE) MATRICULA_UE
FROM(
SELECT	REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO,
		CASE WHEN ALUNO IN (
								SELECT	ALUNO 
								FROM	APOLLO..REL_MATRICULA_FACIL A (NOLOCK) 
								WHERE	A.ALUNO = ALUNO 
							) 
			THEN COUNT (DISTINCT ALUNO) ELSE 0 
		END MAT_FACIL,
		CASE WHEN ALUNO IN (
								SELECT	ALUNO 
								FROM	ProcessoSeletivoAluno.ALUNO_CANDIDATOINSCRITOCLASSIFICADO A (NOLOCK) 
								WHERE	A.ALUNOID = ALUNO
							) 
			THEN COUNT (DISTINCT ALUNO) ELSE 0 
		END AS PROC_SELETIVO,
		CASE WHEN ALUNO IN (
								SELECT	ALUNO 
								FROM	Matricula.ALUNO_UNIDADEENSINOCOMPARTILHADA A (NOLOCK) 
								WHERE	A.ALUNOID = ALUNO
							) 
			THEN COUNT (DISTINCT ALUNO) ELSE 0 
		END COMPARTILHADA,
		COUNT (DISTINCT ALUNO) MATRICULA_UE
FROM(
SELECT  DISTINCT TR.REGIONAL, M.NOME MUNICIPIO, LUE.UNIDADE_ENS CENSO, LUE.NOME_COMP ESCOLA, LMC.DESCRICAO MODALIDADE, 
		LTC.DESCRICAO SEGMENTO, LC.NOME CURSO, LT.SERIE SERIE, LT.TURNO, LA.ALUNO
FROM	LY_HISTMATRICULA LH (NOLOCK)	
JOIN	#ALUNOS_NOVOS LA (NOLOCK) ON LA.ALUNO = LH.ALUNO			
JOIN	LY_TURMA LT (NOLOCK) ON LT.TURMA = LH.TURMA
				AND	LT.DISCIPLINA = LH.DISCIPLINA
				AND	LT.ANO = LH.ANO
				AND LT.SEMESTRE = LH.SEMESTRE
				AND LT.ANO = @ANO
				AND LT.SEMESTRE IN (0, @SEMESTRE)
JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
				AND LS.TURNO = LT.TURNO
				AND LS.CURRICULO = LT.CURRICULO
				AND LS.SERIE = LT.SERIE
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LS.CURSO
JOIN	LY_TIPO_CURSO LTC (NOLOCK) ON LTC.TIPO = LC.TIPO
JOIN	LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO	
WHERE 
(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)  
AND		LH.DT_MATRICULA = (
							SELECT	MIN(M.DT_MATRICULA) 
							FROM	LY_HISTMATRICULA M (NOLOCK) 
							WHERE	M.ALUNO = LH.ALUNO
							)
)SQL1

GROUP BY REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO, ALUNO

)SQL2

GROUP BY REGIONAL, MUNICIPIO, CENSO, ESCOLA, MODALIDADE, SEGMENTO, CURSO, SERIE, TURNO

END

DROP TABLE #ALUNOS_NOVOS

</CommandText>
      </Query>
