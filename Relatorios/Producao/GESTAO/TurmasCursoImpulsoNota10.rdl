  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_TURMA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
        
          SELECT	NULL ID_REGIONAL,' TODAS' REGIONAL
          UNION
          SELECT	0 ID_REGIONAL,' Selecione...' REGIONAL
          UNION
          SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) REGIONAL
          FROM	TCE_REGIONAL TR (NOLOCK)
          JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
          JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
          WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL)
          ORDER	BY REGIONAL</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_TURMA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@regional">
            <Value>=Parameters!regional.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL CODIGO, 'TODOS' NOME 
UNION 
SELECT DISTINCT L1.CODIGO, L1.NOME 
FROM LY_UNIDADE_ENSINO L2 
JOIN MUNICIPIO L1 ON L1.CODIGO = L2.MUNICIPIO 
JOIN TCE_REGIONAL N1 ON N1.ID_REGIONAL = L2.ID_REGIONAL 
JOIN LY_USUARIO_UNIDADE_FIS JJ ON JJ.UNIDADE_FIS = L2.UNIDADE_ENS
WHERE 1 = 1 
AND (N1.ID_REGIONAL = ISNULL(@regional, N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
AND (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) </CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_TURMA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@regional">
            <Value>=Parameters!regional.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING(UE.NOME_COMP,1,50) NOME_COMP 
FROM LY_UNIDADE_ENSINO UE JOIN LY_USUARIO_UNIDADE_FIS GG ON GG.UNIDADE_FIS = UE.UNIDADE_ENS 
WHERE 1 = 1 
and (UE.ID_REGIONAL = ISNULL(@regional, UE.ID_REGIONAL) OR UE.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@municipio, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.USUARIO) OR GG.USUARIO IS NULL)
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURMAS">
      <Query>
        <DataSourceName>DS_TURMA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@regional">
            <Value>=Parameters!regional.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT R.REGIONAL,
       M.NOME                 AS MUNICIPIO,
	   B.DESCRICAO AS BAIRRO,
       UE.NOME_COMP           AS ESCOLA,
	   UE.UNIDADE_ENS AS CENSO,
       T.ANO,
       T.SEMESTRE,
	   T.DEPENDENCIA AS SALA,
	   T.TURMA,
	   T.TURNO,
	   MC.DESCRICAO   MODALIDADE,
	   TC.DESCRICAO   TIPO,
       T.CURSO,
       C.NOME AS 'DESCRIÇÃO CURSO',
	   T.CURRICULO,
       T.SERIE,
	   de.NUM_ALUNOS as CAPACIDADE_SALA,
	   T.NUM_ALUNOS AS 'Nº ALUNOS TURMAS',
	   T.SIT_TURMA 'SITUAÇÃO TURMA',
	   T.DT_CRIACAO
      
	 
FROM LY_TURMA T
INNER JOIN LY_CURSO C
               ON C.CURSO = T.CURSO
			    INNER JOIN LY_MODALIDADE_CURSO MC
         ON MC.MODALIDADE = C.MODALIDADE
     INNER  JOIN LY_TIPO_CURSO TC
         ON TC.TIPO = C.TIPO  
       INNER JOIN LY_UNIDADE_ENSINO UE
               ON UE.UNIDADE_ENS = T.FACULDADE
       INNER JOIN TCE_REGIONAL R
               ON R.ID_REGIONAL = UE.ID_REGIONAL
       INNER JOIN MUNICIPIO M
               ON M.CODIGO = UE.MUNICIPIO
		INNER JOIN HADES.DBO.BAIRRO B
			   ON UE.BAIRRO = B.CODIGO
		inner join LY_DEPENDENCIA de 
				on de.DEPENDENCIA = t.DEPENDENCIA 
				 and t.FACULDADE = DE.FACULDADE 
WHERE ANO= @ano
AND T.CURSO = '9999.90' 
	AND	(R.ID_REGIONAL = ISNULL(@regional, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL) 
	AND	(M.CODIGO = ISNULL(@municipio,  M.CODIGO) OR M.CODIGO IS NULL) 
	AND	(UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
ORDER BY REGIONAL,M.NOME, UE.NOME_COMP, C.NOME,
    
       T.TURNO,   T.SERIE</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BAIRRO">
          <DataField>BAIRRO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SALA">
          <DataField>SALA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO">
          <DataField>TIPO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRIÇÃO_CURSO">
          <DataField>DESCRIÇÃO CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURRICULO">
          <DataField>CURRICULO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CAPACIDADE_SALA">
          <DataField>CAPACIDADE_SALA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Nº_ALUNOS_TURMAS">
          <DataField>Nº ALUNOS TURMAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SITUAÇÃO_TURMA">
          <DataField>SITUAÇÃO TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_CRIACAO">
          <DataField>DT_CRIACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Ano">
      <Query>
        <DataSourceName>DS_TURMA</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO 
FROM 	LY_PERIODO_LETIVO
WHERE 	ANO &lt;= YEAR(GETDATE())
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
