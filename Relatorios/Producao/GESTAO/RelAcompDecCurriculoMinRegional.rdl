  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DISCIPLINA">
            <Value>=Parameters!DISCIPLINA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT  DISCIPLINA, REGIONAL, [1] BIM_1, [2] BIM_2, [3] BIM_3, [4] BIM_4
FROM(

SELECT	UPPER(DD.NOME_COMPL) DISCIPLINA, TR.REGIONAL, M.BIMESTRE, 
CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM_CUMPRIDO),0)) / CONVERT(DECIMAL(10,2), ISNULL(SUM(ITEM_CM),1)) PERCENTUAL
FROM	APOLLO..REL_CURRICULO_MINIMO M (NOLOCK)
JOIN    LY_DISCIPLINA DD (NOLOCK) ON DD.DISCIPLINA = M.DISCIPLINA 
				AND DD.NOME_COMPL = @DISCIPLINA
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = M.UNIDADE_ENS
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL

WHERE
M.ANO = @ANO
AND M.SEMESTRE = @SEMESTRE

GROUP BY DD.NOME_COMPL, TR.REGIONAL, M.BIMESTRE

)SQL1
PIVOT
(
SUM(PERCENTUAL) FOR BIMESTRE IN ([1],[2],[3],[4])
)AS PivotTable

ORDER BY DISCIPLINA, REGIONAL</CommandText>
      </Query>
      <Fields>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BIM_1">
          <DataField>BIM_1</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="BIM_2">
          <DataField>BIM_2</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="BIM_3">
          <DataField>BIM_3</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="BIM_4">
          <DataField>BIM_4</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DISCIPLINA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	' Selecione...' NOME 
UNION
SELECT	DISTINCT UPPER (LD.NOME_COMPL) NOME
FROM	APOLLO..REL_CURRICULO_MINIMO M (NOLOCK)
JOIN	LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = M.DISCIPLINA
WHERE	ANO = @ANO
AND	SEMESTRE = @SEMESTRE
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT  0 ANO, ' Selecione...' NOME
UNION
SELECT	DISTINCT CONVERT (VARCHAR(4), ANO) ANO, CONVERT (VARCHAR(4), ANO) NOME 
FROM	LY_PERIODO_LETIVO (NOLOCK) 
ORDER	BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="usuario">
      <DataType>String</DataType>
