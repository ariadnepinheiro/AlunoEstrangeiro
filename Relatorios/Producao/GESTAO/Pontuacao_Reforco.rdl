  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, 
		SUM(LP_NOTA) / CASE WHEN SUM(TURMA_PORT) = 0 THEN 1 ELSE SUM(TURMA_PORT) END IND_PORT, 
		SUM(MAT_NOTA)/ CASE WHEN SUM(TURMA_MAT) = 0 THEN 1 ELSE SUM(TURMA_MAT) END IND_MAT, 
		CASE WHEN SUM(TURMA_PORT) = 0 THEN SUM(MAT_NOTA)/ CASE WHEN SUM(TURMA_MAT) = 0 THEN 1 ELSE SUM(TURMA_MAT) END
			 WHEN SUM(TURMA_MAT) = 0 THEN SUM(LP_NOTA) / CASE WHEN SUM(TURMA_PORT) = 0 THEN 1 ELSE SUM(TURMA_PORT) END
			 ELSE ((SUM(LP_NOTA) / SUM(TURMA_PORT)) + (SUM(MAT_NOTA)/ SUM(TURMA_MAT))) /2 END IND_MEDIA
FROM	(
				SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, ANO, SEMESTRE, TURMA, TURMA_MAT, 
						TURMA_PORT, CASE WHEN TURMA_PORT = 1 THEN SUM(LP_NOTA) ELSE 0 END LP_NOTA, 
						CASE WHEN TURMA_MAT = 1 THEN SUM(MAT_NOTA) ELSE 0 END MAT_NOTA
				FROM	
				(
							SELECT	DISTINCT R.REGIONAL, MM.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
									M.ALUNO, CASE WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(LP_NOTA,-1),',','.')) BETWEEN 0.00 AND 19.99 THEN 2
												WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(LP_NOTA,-1),',','.')) BETWEEN 20.00 AND 23.99 THEN 1.5
												WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(LP_NOTA,-1),',','.')) BETWEEN 24.00 AND 100.00 THEN 1
												WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(LP_NOTA,-1),',','.')) = -1 THEN 0 END LP_NOTA, 
											CASE WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(MAT_NOTA,-1),',','.')) BETWEEN 0.00 AND 19.99 THEN 2
												WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(MAT_NOTA,-1),',','.')) BETWEEN 20.00 AND 23.99 THEN 1.5
												WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(MAT_NOTA,-1),',','.')) BETWEEN 24.00 AND 100.00 THEN 1
												WHEN CONVERT(NUMERIC(10,2), REPLACE(ISNULL(MAT_NOTA,-1),',','.')) = -1 THEN 0 END MAT_NOTA, 
											CASE WHEN T.TURMA LIKE 'REF%MAT%' THEN 1 ELSE 0 END TURMA_MAT, 
											CASE WHEN T.TURMA LIKE 'REF%PORT%' THEN 1 ELSE 0 END TURMA_PORT, 
									T.ANO, T.SEMESTRE, T.TURMA					
							FROM	LY_TURMA T (NOLOCK)
							LEFT JOIN	LY_MATRICULA M (NOLOCK)
							ON		T.ANO = M.ANO
							AND		T.SEMESTRE = M.SEMESTRE
							AND		T.DISCIPLINA = M.DISCIPLINA
							AND		T.TURMA = M.TURMA
							AND		M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
							AND		ISNULL(M.DEPENDENCIA, 'N') = 'N'
							LEFT JOIN	APOLLO..REL_REFORCO RR (NOLOCK)
							ON		M.ALUNO = RR.ALUNO 							
							JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
							ON		UE.UNIDADE_ENS = T.UNIDADE_RESPONSAVEL
							JOIN	TCE_REGIONAL R (NOLOCK)
							ON		R.ID_REGIONAL = UE.ID_REGIONAL
							JOIN	MUNICIPIO MM (NOLOCK)
							ON		MM.CODIGO = UE.MUNICIPIO
							JOIN	LY_AULA_DOCENTE AD (NOLOCK)
							ON		AD.ANO = T.ANO
							AND		AD.SEMESTRE = T.SEMESTRE
							AND		AD.DISCIPLINA = T.DISCIPLINA
							AND		AD.TURMA = T.TURMA
							AND		AD.DATA_FIM = T.DT_FIM
							AND		AD.NUM_FUNC NOT IN (115451,115460)
							WHERE	T.ANO = @ANO
							AND		T.CURSO = '9999.99'
							AND		T.TURMA LIKE 'REF%'
							) A 
				GROUP BY REGIONAL, MUNICIPIO, CENSO, UNIDADE, ANO, SEMESTRE, TURMA, TURMA_MAT, 
						TURMA_PORT
		) B 
GROUP BY REGIONAL, MUNICIPIO, CENSO, UNIDADE</CommandText>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IND_PORT">
          <DataField>IND_PORT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="IND_MAT">
          <DataField>IND_MAT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IND_MEDIA">
          <DataField>IND_MEDIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO 
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
