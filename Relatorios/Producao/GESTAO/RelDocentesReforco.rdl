  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, MATRICULA, NOME_DOCENTE, ID_FUNCIONAL, VINCULO, CPF,
		DISCIPLINA_INGRESSO, E_MAIL, FONE, CH_CARGO,  MIN(DATA_INICIO) DATA_INICIO, 
		ISNULL((
		SELECT	TOP 1 'S' 
		FROM	LY_GRUPO_HABILITACAO GH (NOLOCK)
		JOIN	LY_GRUPO_HABILITACAO_DISC GD (NOLOCK)
		ON		GD.AGRUPAMENTO = GH.AGRUPAMENTO
		JOIN	LY_GRUPO_HABILITACAO_DOC GDD (NOLOCK)
		ON		GDD.AGRUPAMENTO = GH.AGRUPAMENTO
		WHERE	GH.DESCRICAO LIKE '%PORTUGUES%'
		AND		GDD.NUM_FUNC = A.NUM_FUNC
		),'N') HABILITACAO_PORT,
		ISNULL((
		SELECT	TOP 1 'S' 
		FROM	LY_GRUPO_HABILITACAO GH (NOLOCK)
		JOIN	LY_GRUPO_HABILITACAO_DISC GD (NOLOCK)
		ON		GD.AGRUPAMENTO = GH.AGRUPAMENTO
		JOIN	LY_GRUPO_HABILITACAO_DOC GDD (NOLOCK)
		ON		GDD.AGRUPAMENTO = GH.AGRUPAMENTO
		WHERE	GH.DESCRICAO LIKE '%MATEMATICA%'
		AND		GDD.NUM_FUNC = A.NUM_FUNC
		),'N')	HABILITACAO_MAT,	
		CASE WHEN MAX(DATA_FIM) &gt; CONVERT(DATE,GETDATE()) THEN NULL ELSE MAX(DATA_FIM) END DATA_FIM,
		dbo.f_TotalAulaNormal_Ano(MATRICULA,@ANO)CH_MATRICULA, 
		dbo.f_TotalAulaGLP_ano(MATRICULA,@ANO)CH_GLP,
		SUM(AULA_ATIVA) AULA_ATIVA 
FROM	(
SELECT	DISTINCT R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO,		
		UE.NOME_COMP UNIDADE, D.MATRICULA, P.NOME_COMPL NOME_DOCENTE, 
		H.DISCIPLINA_INGRESSO, P.E_MAIL, P.FONE, AD.DATA_INICIO, AD.DATA_FIM, CH.CARGAHORARIAREGENCIA CH_CARGO, 
		CASE WHEN T.DT_FIM = AD.DATA_FIM THEN 1 ELSE 0 END AULA_ATIVA, 
		AD.TURMA, AD.ANO, AD.DISCIPLINA, AD.SEMESTRE, AD.DIA_SEMANA, AD.AULA, AD.NUM_FUNC, SS.ID_FUNCIONAL, SS.VINCULO, P.CPF
FROM	TCE_REGIONAL R (NOLOCK) 
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) 
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) 
ON		M.CODIGO = UE.MUNICIPIO
JOIN	LY_TURMA T (NOLOCK) 
ON		T.UNIDADE_RESPONSAVEL = UE.UNIDADE_ENS
AND		T.ANO = @ANO
AND		T.TURMA LIKE 'RE_%'
AND 	T.CURSO = '9999.99'
AND		T.TURMA NOT LIKE 'REFORCO%'
JOIN	LY_AULA_DOCENTE AD (NOLOCK) 
ON		AD.ANO = T.ANO
AND		AD.SEMESTRE = T.SEMESTRE
AND		AD.DISCIPLINA = T.DISCIPLINA
AND		AD.TURMA = T.TURMA
JOIN	LY_DOCENTE D (NOLOCK) 
ON		D.NUM_FUNC = AD.NUM_FUNC
JOIN	LY_PESSOA P (NOLOCK) 
ON		P.PESSOA = D.PESSOA
JOIN	LY_LOTACAO L (NOLOCK) 
ON		L.MATRICULA = D.MATRICULA
AND		(L.DATA_DESATIVACAO IS NULL 
OR		L.DATA_DESATIVACAO &gt; CONVERT(DATE,GETDATE()))
AND		L.DATA_NOMEACAO &lt;= CONVERT(DATE,GETDATE())
LEFT JOIN LY_CATEGORIA_DOCENTE CO ( NOLOCK ) ON CO.CATEGORIA = D.CATEGORIA  
 LEFT JOIN RecursosHumanos.CH_AGRUPAMENTOCARGO AS CH ( NOLOCK ) ON CH.AGRUPAMENTOCARGOSID = co.AGRUPAMENTOCARGOSID
                                                              AND CH.FUNCAO = L.FUNCAO                      
LEFT	JOIN (
				SELECT	NUM_FUNC, MIN(GH.DESCRICAO) DISCIPLINA_INGRESSO
				FROM	LY_GRUPO_HABILITACAO_DOC GD (NOLOCK) 
				JOIN	LY_GRUPO_HABILITACAO GH (NOLOCK) 
				ON		GD.AGRUPAMENTO = GH.AGRUPAMENTO
				WHERE	GD.AGRUPAMENTO_INGRESSO = 'S'
				GROUP BY NUM_FUNC
				) H 
ON		H.NUM_FUNC = D.NUM_FUNC	
LEFT JOIN APOLLO..SIGRH SS
ON		SS.MATRICULA = 	D.MATRICULA
WHERE	D.MATRICULA NOT IN ('00000000','11111111','22222222','33333333','44444444','55555555','66666666','77777777','88888888','99999999')
) A
GROUP BY REGIONAL, MUNICIPIO, CENSO, UNIDADE, MATRICULA, NOME_DOCENTE, 
		DISCIPLINA_INGRESSO, E_MAIL, FONE, CH_CARGO, NUM_FUNC, ID_FUNCIONAL, VINCULO, CPF
ORDER BY REGIONAL, MUNICIPIO, CENSO, UNIDADE, DATA_INICIO	</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA_INGRESSO">
          <DataField>DISCIPLINA_INGRESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_FUNCIONAL">
          <DataField>ID_FUNCIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="E_MAIL">
          <DataField>E_MAIL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VINCULO">
          <DataField>VINCULO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FONE">
          <DataField>FONE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CH_CARGO">
          <DataField>CH_CARGO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DATA_INICIO">
          <DataField>DATA_INICIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="HABILITACAO_PORT">
          <DataField>HABILITACAO_PORT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HABILITACAO_MAT">
          <DataField>HABILITACAO_MAT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_FIM">
          <DataField>DATA_FIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="CH_MATRICULA">
          <DataField>CH_MATRICULA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CH_GLP">
          <DataField>CH_GLP</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AULA_ATIVA">
          <DataField>AULA_ATIVA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO 
FROM LY_PERIODO_LETIVO (NOLOCK) 
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
