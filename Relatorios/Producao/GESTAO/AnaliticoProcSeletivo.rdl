    <DataSet Name="AGENDA">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT A.AGENDAID, DESCRICAO
FROM AGENDA.AGENDA A (NOLOCK)
JOIN AGENDA.EVENTO E (NOLOCK)
ON	A.AGENDAID = E.AGENDAID
WHERE	TIPOEVENTOID = '4'
ORDER BY A.AGENDAID DESC
</CommandText>
      </Query>
      <Fields>
        <Field Name="AGENDAID">
          <DataField>AGENDAID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
