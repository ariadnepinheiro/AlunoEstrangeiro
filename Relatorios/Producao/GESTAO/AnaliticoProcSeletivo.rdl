  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CANDIDATOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AGENDAID">
            <Value>=Parameters!AGENDAID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
			SELECT	DISTINCT R.REGIONAL
			, UE.UNIDADE_ENS
			, UE.NOME_COMP
			, CC.CURSO
			, CC.NOME NM_CURSO
			, AC.TURNOID TURNO
			, CONVERT(VARCHAR (20)
			, I.NUMEROINSCRICAO) NUMEROINSCRICAO
			, C.NOMECOMPLETO
			, C.NOMEMAE
			, C.NOMEPAI
			, C.DATANASCIMENTO
			, C.SEXO
			, C.ENDERECO
			, C.ENDERECONUMERO
			, C.ENDERECOCOMPLEMENTO
			, C.ENDERECOBAIRRO
			, M.NOME as 'ENDERECOMUNICIPIO'
			, C.CELULAR
			, C.TELEFONE
			, C.EMAIL
			, C.CERTIDAONUMEROMATRICULA
			, C.CERTIDAONUMERO
			, C.CERTIDAOLIVRO
			, C.CERTIDAOFOLHA
			, C.CERTIDAODATAEMISSAO
			, C.CERTIDAOCARTORIOUF
			, C.CPF
			, I.DATACADASTRO
			, I.DATAALTERACAO
			, C.REDEENSINOORIGEM
			, C.NECESSIDADEESPECIAL
			, CASE C.TIPOBOLSAPARTICULAR
			WHEN 0 THEN 'Não Bolsista'
			WHEN 1 THEN 'Bolsista Parcial'
			WHEN 2 THEN 'Bolsista Integral'
			END BOLSISTA
			FROM	AGENDA.PROCESSOSELETIVO P (NOLOCK)
			JOIN	AGENDA.AGENDA_UNIDADEENSINO AU
			ON		AU.AGENDAID = P.AGENDAID
			JOIN	AGENDA.AGENDA_CURSO__AGENDA_UNIDADEENSINO AUC
			ON		AUC.AGENDA_UNIDADEENSINO_ID = AU.AGENDA_UNIDADEENSINO_ID
			JOIN	AGENDA.AGENDA_CURSO AC
			ON		AC.AGENDAID = P.AGENDAID
			AND		AC.AGENDA_CURSO_ID = AUC.AGENDA_CURSO_ID
			JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
			ON		UE.UNIDADE_ENS = AU.UNIDADEENSINOID
			JOIN	LY_CURSO CC (NOLOCK)
			ON		CC.CURSO = AC.CURSOID
			JOIN	ProcessoSeletivoAluno.UNIDADEENSINO_CURSO_TURNO_INSCRICAO UCT (NOLOCK)
			ON		UCT.CURSOID = AC.CURSOID
			AND		UCT.UNIDADEENSINOID = AU.UNIDADEENSINOID
			JOIN	PROCESSOSELETIVOALUNO.INSCRICAO I (NOLOCK)
			ON		I.PROCESSOSELETIVOID = P.PROCESSOSELETIVOID
			AND		UCT.INSCRICAOID = I.INSCRICAOID
			JOIN	PROCESSOSELETIVOALUNO.CANDIDATO C (NOLOCK)
			ON		C.CANDIDATOID = I.CANDIDATOID
			AND		NOMECOMPLETO NOT LIKE '%TESTE%'
			JOIN	TCE_REGIONAL R (NOLOCK)
			ON		R.ID_REGIONAL = UE.ID_REGIONAL
			JOIN	      HADES..TCE_MUNICIPIO M
			ON	      M.ID_MUNICIPIO = c.ENDERECOMUNICIPIO
			WHERE	P.AGENDAID = @AGENDAID

			ORDER BY C.NOMECOMPLETO
			         , UE.NOME_COMP
		</CommandText>
      </Query>
      <Fields>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
