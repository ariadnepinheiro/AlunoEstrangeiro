        </Field>
        <Field Name="QTDE_LANC_4BIM">
          <DataField>QTDE_LANC_4BIM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_LANC_1TRI">
          <DataField>QTDE_LANC_1TRI</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
