        </Field>
        <Field Name="TURMAS_CARENCIA_ANUAL">
          <DataField>TURMAS_CARENCIA_ANUAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TURMAS_CARENCIA_1S">
          <DataField>TURMAS_CARENCIA_1S</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TURMAS_CARENCIA_2S">
          <DataField>TURMAS_CARENCIA_2S</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CARENCIA_ANUAL">
          <DataField>CARENCIA_ANUAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CARENCIA_1S">
          <DataField>CARENCIA_1S</DataField>
