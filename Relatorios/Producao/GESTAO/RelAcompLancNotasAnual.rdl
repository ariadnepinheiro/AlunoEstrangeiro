  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
        <Prompt>Especifique um nome de usuário e uma senha para a fonte de dados DS_ALUNOS:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT	*
FROM 	APOLLO..REL_LANC_NOTAS (NOLOCK)
WHERE QTDE_TURMAS_DISC &gt;0
--filtro de censo a pedido do chamado 85347
AND CENSO NOT IN(33194670,33066124,33079838,33063044,33166366,33079935)
order by regional,municipio,escola,censo</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_TURMAS_DISC">
          <DataField>QTDE_TURMAS_DISC</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_LANC_1BIM">
          <DataField>QTDE_LANC_1BIM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
