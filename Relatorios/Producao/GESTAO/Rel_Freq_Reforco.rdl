  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@QTDE_ACESSO">
            <Value>=Parameters!QTDE_ACESSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @QTDE_ACESSO &gt; 1 
BEGIN 
SELECT NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT 0 ID_REGIONAL,' Selecione...' REGIONAL 
ORDER BY REGIONAL 
END 
IF @QTDE_ACESSO &lt;= 1 
BEGIN 
SELECT 0 ID_REGIONAL,' Selecione...' REGIONAL 
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
ORDER BY REGIONAL 
END </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@QTDE_ACESSO">
            <Value>=Parameters!QTDE_ACESSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @QTDE_ACESSO &gt; 1 
BEGIN 

SELECT DISTINCT L1.CODIGO, L1.NOME FROM LY_UNIDADE_ENSINO L2 (NOLOCK)
JOIN HADES..MUNICIPIO L1 (NOLOCK) ON L1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..TCE_REGIONAL N1 (NOLOCK) ON N1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE 
	(N1.ID_REGIONAL = ISNULL(@COORD,N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
	AND
	(JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT NULL CODIGO,' TODOS' NOME
UNION
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME
END 
IF @QTDE_ACESSO &lt;= 1 
BEGIN 
SELECT DISTINCT L1.CODIGO, L1.NOME FROM LY_UNIDADE_ENSINO L2 (NOLOCK)
JOIN HADES..MUNICIPIO L1 (NOLOCK) ON L1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..TCE_REGIONAL N1 (NOLOCK) ON N1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE 
	(N1.ID_REGIONAL = ISNULL(@COORD,N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
	AND
	(JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME
END</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@QTDE_ACESSO">
            <Value>=Parameters!QTDE_ACESSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @QTDE_ACESSO &gt; 1 
BEGIN

SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING (UE.NOME_COMP,1,50)NOME_COMP 
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
WHERE 
(R.ID_REGIONAL = ISNULL(@COORD, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@municipio, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL) 
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP
END 
IF @QTDE_ACESSO &lt;= 1
BEGIN 

SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
--SELECT NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
--UNION
SELECT UE.UNIDADE_ENS, SUBSTRING (UE.NOME_COMP,1,50)NOME_COMP 
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
WHERE 
(R.ID_REGIONAL = ISNULL(@COORD, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@municipio, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL) 
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP
END</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="FREQUENCIA">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, TURNO, SALA, DISCIPLINA, SERIE, ANO, SEMESTRE, TURMA, TEM_PROF, QTDE_ALUNOS, LANC_FREQ, 
		ISNULL(CONVERT(VARCHAR(20),CONVERT(DECIMAL(10,2), SUM(BIM1)*100)),'SL') BIM1, 
		ISNULL(CONVERT(VARCHAR(20),CONVERT(DECIMAL(10,2), SUM(BIM2)*100)),'SL') BIM2, 
		ISNULL(CONVERT(VARCHAR(20),CONVERT(DECIMAL(10,2), SUM(BIM3)*100)),'SL') BIM3, 
		ISNULL(CONVERT(VARCHAR(20),CONVERT(DECIMAL(10,2), SUM(BIM4)*100)),'SL') BIM4
FROM	(
SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, TURNO, SALA, DISCIPLINA, SERIE, ANO, SEMESTRE, TURMA, TEM_PROF, QTDE_ALUNOS, LANC_FREQ, 
		CASE WHEN BIMESTRE = 1 THEN FREQ_TURMA END BIM1,
		CASE WHEN BIMESTRE = 2 THEN FREQ_TURMA END BIM2, 
		CASE WHEN BIMESTRE = 3 THEN FREQ_TURMA END BIM3,
		CASE WHEN BIMESTRE = 4 THEN FREQ_TURMA END BIM4
FROM (
SELECT	TR.REGIONAL, M.NOME MUNICIPIO, LUE.UNIDADE_ENS CENSO, LUE.NOME_COMP UNIDADE, LT.TURNO,
		LT.DEPENDENCIA SALA, LD.NOME DISCIPLINA, LT.SERIE, LT.ANO, LT.SEMESTRE, LT.TURMA, RR.QTDE_ALUNOS, 
		CASE WHEN ISNULL(LAD.NUM_FUNC,0) = 0 THEN 0 ELSE 1 END TEM_PROF, 
		CASE WHEN ISNULL(FF.BIMESTRE,0) = 0 THEN 0 ELSE 1 END LANC_FREQ, 
		FF.BIMESTRE, 1-(FF.FALTAS/FF.AULAS_DADAS) FREQ_TURMA 
FROM	LY_TURMA LT (NOLOCK) 
JOIN	LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)
LEFT	JOIN LY_AULA_DOCENTE LAD (NOLOCK) ON LT.ANO = LAD.ANO
				AND LT.SEMESTRE = LAD.SEMESTRE
				AND LT.DISCIPLINA = LAD.DISCIPLINA
				AND LT.TURMA = LAD.TURMA
				AND LT.DT_FIM = LAD.DATA_FIM
				AND LAD.NUM_FUNC NOT IN (115451,115460)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	APOLLO..REL_TURMAS_ALUNOS RR (NOLOCK) ON RR.ANO = LT.ANO
				AND RR.SEMESTRE = LT.SEMESTRE
				AND RR.TURMA = LT.TURMA
LEFT	JOIN (
				SELECT	ANO, SEMESTRE, TURMA, BIMESTRE, SUM(AULAS_DADAS) AULAS_DADAS, 
						SUM(FALTAS) FALTAS
				FROM	APOLLO..REL_FREQ_GLOB (NOLOCK)
				GROUP	BY ANO, SEMESTRE, TURMA, BIMESTRE
			)FF ON FF.ANO = LT.ANO
			AND FF.SEMESTRE = LT.SEMESTRE
			AND FF.TURMA = LT.TURMA
			AND FF.AULAS_DADAS &lt;&gt; 0
WHERE	LT.ANO = @ANO
AND		LT.SIT_TURMA = 'ABERTA'
AND		LT.TURMA LIKE 'REF%'
AND		LT.CURSO = '9999.99'
AND		(TR.ID_REGIONAL = ISNULL(@COORD, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND		(M.CODIGO = ISNULL(@MUNICIPIO, M.CODIGO) OR M.CODIGO IS NULL)
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)
GROUP	BY TR.REGIONAL, M.NOME, M.NOME, LUE.UNIDADE_ENS, 
		LUE.NOME_COMP, LT.TURNO, LT.DEPENDENCIA, LD.NOME, 
		LT.SERIE, LT.TURMA, RR.QTDE_ALUNOS, LAD.NUM_FUNC, FF.AULAS_DADAS, FF.FALTAS, LT.ANO, LT.SEMESTRE, 
		FF.BIMESTRE
) A 
) AB
GROUP BY REGIONAL, MUNICIPIO, CENSO, UNIDADE, TURNO, SALA, DISCIPLINA, SERIE, ANO, SEMESTRE, TURMA, TEM_PROF, QTDE_ALUNOS, 
		LANC_FREQ</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SALA">
          <DataField>SALA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TEM_PROF">
          <DataField>TEM_PROF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS">
          <DataField>QTDE_ALUNOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="LANC_FREQ">
          <DataField>LANC_FREQ</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="BIM1">
          <DataField>BIM1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BIM2">
          <DataField>BIM2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BIM3">
          <DataField>BIM3</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BIM4">
          <DataField>BIM4</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT  DISTINCT ANO 
FROM 	LY_PERIODO_LETIVO
WHERE ANO = YEAR(GETDATE())
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
