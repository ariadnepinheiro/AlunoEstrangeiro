  </Body>
  <Width>18.46311in</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin>
    <RightMargin>2cm</RightMargin>
    <TopMargin>2cm</TopMargin>
    <BottomMargin>2cm</BottomMargin>
    <ColumnSpacing>0.13cm</ColumnSpacing>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT 
REGIONAL, 
MUNICIPIO, 
CENSO, 
UNIDADE, 
COUNT (DISTINCT ALUNO) AS TOT_ALUNOS_UE,
SUM (TRANSPORTE) AS TOT_ALUNOS_GRATUIDADE, 
SUM (BARCA) AS TOT_ALUNOS_BARCA, 
SUM (METRO) AS TOT_ALUNOS_METRO, 
SUM (ONIBUS) AS TOT_ALUNOS_ONIBUS, 
SUM (RURAL) AS TOT_ALUNOS_RURAL, 
SUM (TREM) AS TOT_ALUNOS_TREM
FROM(
	SELECT DISTINCT
		TR.REGIONAL AS REGIONAL,
		M.NOME AS MUNICIPIO,
		LUE.UNIDADE_ENS AS CENSO,
		LUE.NOME_COMP AS UNIDADE,
		LA.ALUNO AS ALUNO,	
		CASE MODAL.TRANSPORTE 
			WHEN 'S' THEN 1
			ELSE 0
		END AS TRANSPORTE,			
		MODAL.MODAL_BARCA BARCA,
		MODAL.MODAL_METRO METRO,
		MODAL.MODAL_ONIBUS ONIBUS,
		MODAL.MODAL_TRANSPORTE_RURAL RURAL,
		MODAL.MODAL_TREM TREM
		FROM LY_ALUNO LA (NOLOCK)
		JOIN LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LA.PESSOA
		-- MODAL ALUNO
		LEFT JOIN (
			SELECT LFP.PESSOA, LFP.FL_FIELD_05, LFP.FL_FIELD_04 AS TRANSPORTE,
			(CASE 
				WHEN PATINDEX('%4;%',LFP.FL_FIELD_05) &lt;&gt; 0
				THEN 1
				ELSE 0
			END) AS MODAL_BARCA,
			(CASE 
				WHEN PATINDEX('%3;%',LFP.FL_FIELD_05) &lt;&gt; 0
				THEN 1
				ELSE 0
			END) AS MODAL_METRO,
			(CASE 
				WHEN PATINDEX('%2;%',LFP.FL_FIELD_05) &lt;&gt; 0
				THEN 1
				ELSE 0
			END) AS MODAL_ONIBUS,
			(CASE 
				WHEN PATINDEX('%5;%',LFP.FL_FIELD_05) &lt;&gt; 0
				THEN 1
				ELSE 0
			END) AS MODAL_TRANSPORTE_RURAL,
			(CASE 
				WHEN PATINDEX('%1;%',LFP.FL_FIELD_05) &lt;&gt; 0
				THEN 1
				ELSE 0
			END) AS MODAL_TREM	
			FROM LY_FL_PESSOA LFP
			WHERE LFP.FL_FIELD_04 = 'S'
		) 
		MODAL ON MODAL.PESSOA = LP.PESSOA
		JOIN LY_MATRICULA LM (NOLOCK) ON LA.ALUNO = LM.ALUNO 
					AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
					AND ISNULL(LM.CONCOMITANTE, 'N') = 'N'
					AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
					AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
		JOIN LY_TURMA LT (NOLOCK) ON LT.TURMA = LM.TURMA
					AND	LT.DISCIPLINA = LM.DISCIPLINA
					AND	LT.ANO = LM.ANO
					AND LT.SEMESTRE = LM.SEMESTRE
					AND LT.ANO = YEAR(GETDATE())
					AND LT.SIT_TURMA = 'ABERTA'
		JOIN LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
					--AND LUE.UNIDADE_ENS = '33051070'
		JOIN MUNICIPIO M (NOLOCK) ON LUE.MUNICIPIO = M.CODIGO
		JOIN TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
		WHERE
		NOT EXISTS (
					SELECT	1
					FROM	LY_H_CURSOS_CONCL H (NOLOCK)
					WHERE	H.ALUNO = LA.ALUNO
					AND		H.DT_REABERTURA IS NULL
					) 
		AND EXISTS (SELECT 1
						FROM LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
						WHERE US.UNIDADE_ENS = LUE.UNIDADE_ENS
						AND	US.SITUACAO = 'ESTADUAL'
						AND	US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
											(
											SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
											FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
											)
						)
		AND (LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')

		--AND LA.ALUNO IN ('201330200468069')--('200904470042769')
		
		AND (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
	)SQL1

GROUP BY 
REGIONAL, MUNICIPIO, CENSO, UNIDADE</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNOS_UE">
          <DataField>TOT_ALUNOS_UE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNOS_GRATUIDADE">
          <DataField>TOT_ALUNOS_GRATUIDADE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNOS_BARCA">
          <DataField>TOT_ALUNOS_BARCA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNOS_METRO">
          <DataField>TOT_ALUNOS_METRO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNOS_ONIBUS">
          <DataField>TOT_ALUNOS_ONIBUS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNOS_RURAL">
          <DataField>TOT_ALUNOS_RURAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOT_ALUNOS_TREM">
          <DataField>TOT_ALUNOS_TREM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@USUARIO">
            <Value>=Parameters!usuario.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN HADES..MUNICIPIO M1 (NOLOCK) ON M1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@USUARIO,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT -1 ID_REGIONAL,' Selecione...' REGIONAL 
ORDER BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TOTAL_ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=IIf(Parameters!REGIONAL.Value = -1, 0, NOTHING)</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT COUNT (DISTINCT LA.ALUNO) AS TOTAL_ALUNOS
FROM LY_ALUNO LA
JOIN LY_MATRICULA LM ON LA.ALUNO = LM.ALUNO 
			AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
JOIN LY_TURMA LT ON LT.TURMA = LM.TURMA
			AND	LT.DISCIPLINA = LM.DISCIPLINA
			AND	LT.ANO = LM.ANO
			AND LT.SEMESTRE = LM.SEMESTRE
			AND LT.SIT_TURMA = 'ABERTA'
			AND LT.ANO =YEAR(GETDATE())
JOIN LY_UNIDADE_ENSINO LUE ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
JOIN TCE_REGIONAL TR ON TR.ID_REGIONAL = LUE.ID_REGIONAL
WHERE 
NOT EXISTS (
				SELECT	1
				FROM	LY_H_CURSOS_CONCL H (NOLOCK)
				WHERE	H.ALUNO = LA.ALUNO
				AND		H.DT_REABERTURA IS NULL
				) 
AND EXISTS (SELECT 1
					FROM LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
					WHERE US.UNIDADE_ENS = LUE.UNIDADE_ENS
					AND	US.SITUACAO = 'ESTADUAL'
					AND	US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
										(
										SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
										FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
										)
					)
AND (LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')

AND (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)</CommandText>
      </Query>
      <Fields>
        <Field Name="TOTAL_ALUNOS">
          <DataField>TOTAL_ALUNOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
