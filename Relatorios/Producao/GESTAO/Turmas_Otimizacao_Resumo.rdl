  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>327c2f44-691e-4ccd-97b4-9e3b63f61a03</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT R.ID_REGIONAL, R.REGIONAL 
FROM TCE_REGIONAL R (nolock)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.ID_REGIONAL = R.ID_REGIONAL
WHERE 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = @usuario
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
union
select null id_regional,' TODAS' regional 
ORDER BY REGIONAL</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, UA, SUM(PASSIVEL_OTM) PASSIVEL_OTM, 
		COUNT(DISTINCT STR(ANO)+STR(SEMESTRE)+TURMA) TOTAL_TURMAS, SUM(TEMPOS_CARENCIA) TEMPOS_CARENCIA, 
		SUM(TEMPOS_PROF) TEMPOS_PROF, SUM(DESATIVADA) PASSIVEL_OTM_DESATIVADA, SUM(QTDE_ALUNOS_OTM) QTDE_ALUNOS_OTM, 
		SUM(QTDE_ALUNOS_OTM_ATUAL) QTDE_ALUNOS_OTM_ATUAL, 
		CASE WHEN SUM(QTDE_ALUNOS_OTM_ATUAL) &gt;= SUM(QTDE_ALUNOS_OTM) THEN SUM(QTDE_ALUNOS_OTM_ATUAL) - SUM(QTDE_ALUNOS_OTM) ELSE '' END ALUNOS_ADD, 
		SUM(PASSIVEL_OTM) - ISNULL(SUM(DESATIVADA),0) SALDO_TURMAS,
		UA_ATUAL
FROM	(
SELECT	DISTINCT R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
		--UE.SETOR UA, 
		VWS.UA_ANTIGA UA,
		CASE WHEN OTIMIZAR = 'S' THEN 1 ELSE 0 END PASSIVEL_OTM, 
		O.ANO, O.SEMESTRE, O.TURMA, CASE WHEN OTIMIZAR = 'S' THEN ISNULL(T1.AULAS,0) ELSE 0 END TEMPOS_CARENCIA, 
		CASE WHEN OTIMIZAR = 'S' THEN ISNULL(T2.QTDE_AULAS,0) ELSE 0 END TEMPOS_PROF, 
		CASE WHEN OTIMIZAR = 'S' AND TT.SIT_TURMA = 'DESATIVADA' THEN 1 ELSE 0 END DESATIVADA, 
		CASE WHEN OTIMIZAR = 'S' THEN O.QTDE_ALUNOS ELSE 0 END QTDE_ALUNOS_OTM, 
		CASE WHEN OTIMIZAR = 'S' THEN AA.QTDE_ALUNOS ELSE 0 END QTDE_ALUNOS_OTM_ATUAL,
		VWS.UA_ATUAL
FROM	APOLLO..REL_TURMAS_OTM O (NOLOCK) 
LEFT JOIN (
			SELECT	TURMA, ANO, SEMESTRE, SUM(TEMPOS) AULAS
			FROM	APOLLO..REL_CARENCIA_DETALHE (NOLOCK)
			WHERE	TIPO_CARENCIA LIKE 'CARENC%'
			GROUP BY TURMA, ANO, SEMESTRE
			) T1
ON		T1.ANO = O.ANO
AND		T1.SEMESTRE = O.SEMESTRE
AND		T1.TURMA = O.TURMA
LEFT JOIN (
			SELECT	T.TURMA, T.ANO, T.SEMESTRE, COUNT(DISTINCT AD.DISCIPLINA+STR(AD.AULA)+STR(AD.DIA_SEMANA)) QTDE_AULAS
			FROM	LY_TURMA T (NOLOCK)
			JOIN	LY_AULA_DOCENTE AD (NOLOCK)
			ON		AD.ANO = T.ANO
			AND		AD.SEMESTRE = T.SEMESTRE
			AND		AD.TURMA = T.TURMA
			AND		AD.DISCIPLINA = T.DISCIPLINA
			AND		AD.DATA_FIM = T.DT_FIM
			AND		AD.NUM_FUNC NOT IN (115451,115460)
			GROUP BY T.TURMA, T.ANO, T.SEMESTRE
			) T2
ON		T2.ANO = O.ANO
AND		T2.SEMESTRE = O.SEMESTRE
AND		T2.TURMA = O.TURMA
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		O.UNIDADE_ENS = UE.UNIDADE_ENS
JOIN	TCE_REGIONAL R (NOLOCK) 
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) 
ON		M.CODIGO = UE.MUNICIPIO
LEFT	JOIN	LY_TURMA TT
ON		TT.ANO = O.ANO
AND		TT.SEMESTRE = O.SEMESTRE
AND		TT.TURMA = O.TURMA
LEFT	JOIN APOLLO..REL_TURMAS_ALUNOS AA
ON		AA.ANO = O.ANO
AND		AA.SEMESTRE = O.SEMESTRE
AND		AA.TURMA = O.TURMA
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = UE.SETOR
WHERE	O.ANO = @ANO
AND		(R.ID_REGIONAL = ISNULL(@coord, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
) AS A
GROUP BY REGIONAL, MUNICIPIO, CENSO, UNIDADE, UA, UA_ATUAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PASSIVEL_OTM">
          <DataField>PASSIVEL_OTM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_TURMAS">
          <DataField>TOTAL_TURMAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TEMPOS_CARENCIA">
          <DataField>TEMPOS_CARENCIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TEMPOS_PROF">
          <DataField>TEMPOS_PROF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PASSIVEL_OTM_DESATIVADA">
          <DataField>PASSIVEL_OTM_DESATIVADA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS_OTM">
          <DataField>QTDE_ALUNOS_OTM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNOS_OTM_ATUAL">
          <DataField>QTDE_ALUNOS_OTM_ATUAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALUNOS_ADD">
          <DataField>ALUNOS_ADD</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SALDO_TURMAS">
          <DataField>SALDO_TURMAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UA_ATUAL">
          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT DISTINCT ANO 
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
