  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEGMENTO">
            <Value>=Parameters!SEGMENTO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT
		TR.REGIONAL AS  REGIONAL,
		M.NOME AS MUNICIPIO,
		LUE.UNIDADE_ENS AS CENSO,
		VS.UA_ATUAL AS UA,
		LUE.NOME_COMP AS UNIDADE,
		LC.NOME AS ESCOLARIDADE,
		LMC.DESCRICAO AS MODALIDADE,
		LTC.DESCRICAO AS SEGMENTO,
		LT.SEMESTRE AS SEMESTRE,
		LT.CURRICULO AS MATRIZ,
		UPPER (LD.NOME_COMPL) AS DISCIPLINA,
		LD.DISCIPLINA AS CODIGO_DISC,
		LT.SERIE AS SERIE,
		CASE LT.TURNO 
			WHEN 'M' THEN 'MANHÃ'
			WHEN 'T' THEN 'TARDE'
			WHEN 'N' THEN 'NOITE'
			WHEN 'A' THEN 'AMPLIADO'
			WHEN 'I' THEN 'INTEGRADO'
			END AS TURNO
FROM	LY_TURMA LT	
JOIN	LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)			
JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
				AND LS.TURNO = LT.TURNO
				AND LS.CURRICULO = LT.CURRICULO
				AND LS.SERIE = LT.SERIE
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LS.CURSO
JOIN	LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE	
JOIN	LY_TIPO_CURSO LTC (NOLOCK) ON LTC.TIPO = LC.TIPO
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN HADES..VW_SETOR VS ON VS.SETOR =LUE.SETOR
WHERE 
LT.SIT_TURMA = 'ABERTA'
AND LT.ANO = YEAR(GETDATE())
AND (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND (LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND (LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)
AND (LC.CURSO = ISNULL(@ESCOLARIDADE, LC.CURSO) OR LC.CURSO IS NULL) 
AND (LMC.MODALIDADE = ISNULL(@MODALIDADE, LMC.MODALIDADE) OR LMC.MODALIDADE IS NULL) 
AND (LTC.TIPO = ISNULL(@SEGMENTO, LTC.TIPO) OR LTC.TIPO IS NULL) 
AND EXISTS (SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
									(
									SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
									FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
									)
				)
AND	  (LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')


</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLARIDADE">
          <DataField>ESCOLARIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRIZ">
          <DataField>MATRIZ</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO_DISC">
          <DataField>CODIGO_DISC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN HADES..MUNICIPIO M1 (NOLOCK) ON M1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT -1 ID_REGIONAL,' Selecione...' REGIONAL 
ORDER BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT DISTINCT L1.CODIGO, L1.NOME FROM LY_UNIDADE_ENSINO L2 (NOLOCK)
JOIN HADES..MUNICIPIO L1 (NOLOCK) ON L1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..TCE_REGIONAL N1 (NOLOCK) ON N1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE 
	(N1.ID_REGIONAL = ISNULL(@REGIONAL,N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
	AND
	(JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT NULL CODIGO,' TODOS' NOME
UNION
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING (UE.NOME_COMP,1,50)NOME_COMP 
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
WHERE (R.ID_REGIONAL = ISNULL(@REGIONAL, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL) 
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLARIDADE">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT DISTINCT CC.CURSO CURSO, CC.NOME NOME
FROM LY_TURMA LT (NOLOCK)
JOIN LY_CURSO CC (NOLOCK) ON LT.CURSO = CC.CURSO
JOIN LY_UNIDADE_ENSINO LC (NOLOCK) ON LC.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
WHERE
(LC.UNIDADE_ENS = ISNULL(@ESCOLA, LC.UNIDADE_ENS) OR LC.UNIDADE_ENS IS NULL)
AND LT.ANO = YEAR(GETDATE())
AND LT.SIT_TURMA = 'ABERTA' 
UNION
SELECT 'NULO' CURSO,' Selecione...' NOME
UNION
SELECT NULL CURSO, ' TODAS' NOME
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MODALIDADE">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT DISTINCT CT.MODALIDADE MODALIDADE, CT.DESCRICAO DESCRICAO
FROM LY_TURMA LT (NOLOCK)
JOIN LY_CURSO CC (NOLOCK) ON CC.CURSO = LT.CURSO
JOIN LY_MODALIDADE_CURSO CT (NOLOCK) ON CT.MODALIDADE = CC.MODALIDADE
JOIN LY_UNIDADE_ENSINO LC (NOLOCK) ON LC.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
WHERE
(LC.UNIDADE_ENS = ISNULL(@ESCOLA, LC.UNIDADE_ENS) OR LC.UNIDADE_ENS IS NULL)
AND (CC.CURSO = ISNULL(@ESCOLARIDADE, CC.CURSO) OR  CC.CURSO IS NULL)
AND LT.ANO = YEAR(GETDATE())
AND LT.SIT_TURMA = 'ABERTA'  
UNION
SELECT 'NULO' MODALIDADE,' Selecione...' DESCRICAO
UNION
SELECT NULL MODALIDADE, ' TODAS' DESCRICAO
ORDER BY DESCRICAO</CommandText>
      </Query>
      <Fields>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SEGMENTO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>

SELECT DISTINCT CT.TIPO TIPO, CT.DESCRICAO NOME
FROM LY_TURMA LT (NOLOCK)
JOIN LY_CURSO CC (NOLOCK) ON LT.CURSO = CC.CURSO
JOIN LY_TIPO_CURSO CT (NOLOCK) ON CT.TIPO = CC.TIPO
JOIN LY_UNIDADE_ENSINO LC (NOLOCK) ON LC.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
WHERE
(LC.UNIDADE_ENS = ISNULL(@ESCOLA, LC.UNIDADE_ENS) OR LC.UNIDADE_ENS IS NULL) 
AND (CC.CURSO = ISNULL(@ESCOLARIDADE, CC.CURSO) OR  CC.CURSO IS NULL)
AND (CC.MODALIDADE = ISNULL(@MODALIDADE, CC.MODALIDADE) OR  CC.MODALIDADE IS NULL)
AND LT.ANO = YEAR(GETDATE())
AND LT.SIT_TURMA = 'ABERTA' 
UNION
SELECT 'NULO' TIPO,' Selecione...' NOME
UNION
SELECT NULL TIPO, ' TODOS' NOME
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="TIPO">
          <DataField>TIPO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
