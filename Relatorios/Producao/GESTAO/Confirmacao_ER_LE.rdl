<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:cl="http://schemas.microsoft.com/sqlserver/reporting/2010/01/componentdefinition" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>/Data Sources/10.50.12.29_Lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>229031ba-5c11-4e90-a47d-c1621f78e578</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PERIODO">
            <Value>=Parameters!PERIODO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
		SUM(CONVERT(INT, CM.ENSINO_RELIGIOSO)) ENSINO_RELIGIOSO, SUM(CONVERT(INT, CM.LINGUA_ESTRANGEIRA_FACULTATIVA)) LINGUA_FACULTATIVA
FROM	LY_ALUNO A (NOLOCK)
JOIN	TCE_CONFIRMACAO_MATRICULA CM (NOLOCK)
ON		CM.ALUNO = A.ALUNO
AND		CM.ANO = @ANO
AND		CM.PERIODO IN (0, @PERIODO)
AND		CM.STATUS = 'CONFIRMADO'
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		CM.CENSO = UE.UNIDADE_ENS
JOIN	TCE_REGIONAL R (NOLOCK)
ON		UE.ID_REGIONAL = R.ID_REGIONAL
JOIN	HADES..TCE_MUNICIPIO M (NOLOCK)
ON		M.ID_MUNICIPIO = UE.MUNICIPIO
WHERE		EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
					WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
					AND		US.SITUACAO = 'ESTADUAL'
					AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																					(
																					SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																					FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK)GROUP BY UNIDADE_ENS
																					)
					)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND		NOT EXISTS (
					SELECT	1
					FROM	LY_H_CURSOS_CONCL H (NOLOCK)
					WHERE	H.ALUNO = A.ALUNO
					AND		H.DT_REABERTURA IS NULL
					)
AND		UE.ID_REGIONAL = ISNULL(@COORD, UE.ID_REGIONAL)
AND		UE.MUNICIPIO = ISNULL(@MUNIC, UE.MUNICIPIO)
AND		UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS)
GROUP BY R.REGIONAL, M.NOME, UE.UNIDADE_ENS, UE.NOME_COMP
ORDER BY REGIONAL, M.NOME, UE.UNIDADE_ENS</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ENSINO_RELIGIOSO">
          <DataField>ENSINO_RELIGIOSO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LINGUA_FACULTATIVA">
          <DataField>LINGUA_FACULTATIVA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null nucleo,' TODAS' descricao 
union
select '0' nucleo,' Selecione...' descricao 
union
select  convert(varchar(10),l1.id_regional),SUBSTRING(l1.regional,1,35) from tce_regional L1
join LY_UNIDADE_ENSINO l2 on L1.id_regional=l2.id_regional
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null codigo,' TODOS' nome  
union
select 'NULO' ,' Selecione...'  
union
select distinct convert(varchar(10), L1.id_municipio), L1.nome from LY_UNIDADE_ENSINO l2
join hades..tce_municipio l1 on l1.id_municipio=l2.MUNICIPIO
join tce_regional n1 on n1.id_regional=l2.id_regional
where 
	(convert(varchar(10), n1.id_regional) = ISNULL(@COORD,n1.id_regional)or n1.id_regional is null)
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.id_regional = ISNULL(@COORD,ue.id_regional) or ue.id_regional is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT ANO 
FROM LY_PERIODO_LETIVO (NOLOCK)
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
