  </Body>
  <Width>24.52432in</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin>
    <RightMargin>2cm</RightMargin>
    <TopMargin>2cm</TopMargin>
    <BottomMargin>2cm</BottomMargin>
    <ColumnSpacing>0.13cm</ColumnSpacing>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>19dcf0c1-231b-42c8-92b8-30028ad4dc23</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT
TR.REGIONAL AS REGIONAL,
M.NOME AS MUNICIPIO,
LUE.UNIDADE_ENS AS CENSO,
LUE.NOME_COMP AS UE,
LD.MATRICULA AS MATRICULA,
PE.NOME_COMPL AS NOME,
SIGRH.ID_FUNCIONAL AS ID_FUNCIONAL,
SIGRH.VINCULO AS VINCULO,
PE.CPF AS CPF, 
LGH.DESCRICAO AS DISCIPLINA_INGRESSO,
UPPER(LDI.NOME_COMPL) AS DISCIPLINA_ATUACAO,
ISNULL (PE.E_MAIL, '') AS EMAIL,
ISNULL (PE.FONE, '') AS FONE,
ISNULL (LD.REGIME_TRABALHO, '') AS CH_CARGO,
CONVERT (VARCHAR(10), LL.DATA_NOMEACAO, 103) AS DT_INICIO,
ISNULL (CONVERT (VARCHAR(10), LL.DATA_DESATIVACAO, 103), '') AS DT_FIM,
(SELECT COUNT(DD.AULA)TOL_AULA_NORMAL
        FROM   LY_AULA_DOCENTE DD (NOLOCK)
        JOIN LY_DOCENTE DR (NOLOCK) ON DR.NUM_FUNC=DD.NUM_FUNC
        WHERE  DD.NUM_FUNC=DD.NUM_FUNC
			AND DD.ANO = YEAR(GETDATE())
			AND EXISTS (SELECT 1
                       FROM   LY_TURMA TT (NOLOCK)
                       WHERE  TT.FACULDADE = DD.FACULDADE
                              AND TT.ANO = DD.ANO
                              AND TT.SEMESTRE = TT.SEMESTRE
                              AND TT.TURMA = DD.TURMA
                              AND TT.TURNO = DD.TURNO
                              AND TT.DT_FIM = DD.DATA_FIM
                              AND DD.DATA_FIM&gt;=CONVERT(DATE,CURRENT_TIMESTAMP)
                              )
            AND NOT EXISTS (SELECT 1
                               FROM   LY_AULA_DOCENTE_TIPO T1 (NOLOCK)
                               WHERE  T1.ANO = DD.ANO
                                      AND T1.SEMESTRE = DD.SEMESTRE
                                      AND T1.TIPO_AULA = 'GLP'
                                      AND T1.DATA_FIM = DD.DATA_FIM
                                      AND T1.AULA=DD.AULA
                                      AND T1.DIA_SEMANA=DD.DIA_SEMANA
                                      AND T1.TURMA=DD.TURMA
                                      AND T1.TURNO=DD.TURNO
                                      AND T1.NUM_FUNC=DD.NUM_FUNC
                                      )
			AND DR.NUM_FUNC = LD.NUM_FUNC
) AS CH_MATRICULA,			
(SELECT COUNT(DD.AULA)TOL_AULA_NORMAL
        FROM   LY_AULA_DOCENTE DD (NOLOCK)
        JOIN LY_DOCENTE DR (NOLOCK) ON DR.NUM_FUNC=DD.NUM_FUNC
        WHERE 
			DD.ANO = YEAR(GETDATE())
			AND EXISTS (SELECT 1
                       FROM   LY_TURMA TT (NOLOCK)
                       WHERE  TT.ANO = DD.ANO
                              AND TT.SEMESTRE = DD.SEMESTRE
                              AND TT.DISCIPLINA = DD.DISCIPLINA
                              AND TT.TURMA = DD.TURMA
                              AND TT.DT_FIM = DD.DATA_FIM
                              AND DD.DATA_FIM&gt;=CONVERT(DATE,CURRENT_TIMESTAMP)
                              )
               AND EXISTS (SELECT 1
                               FROM   LY_AULA_DOCENTE_TIPO T1 (NOLOCK)
                               WHERE  T1.NUM_FUNC=DD.NUM_FUNC
                                      AND T1.TURNO=DD.TURNO
                                      AND T1.FACULDADE = DD.FACULDADE
                                      AND T1.DIA_SEMANA=DD.DIA_SEMANA
                                      AND T1.AULA=DD.AULA
                                      AND T1.DISCIPLINA = DD.DISCIPLINA
                                      AND T1.TURMA=DD.TURMA
									  AND T1.ANO = DD.ANO
                                      AND T1.SEMESTRE = DD.SEMESTRE
                                      AND T1.TIPO_AULA = 'GLP'
                                      AND T1.DATA_INICIO = DD.DATA_INICIO
                                      )
			AND DR.NUM_FUNC = LD.NUM_FUNC
) AS CH_GLP,
(SELECT COUNT(DD.AULA)TOL_AULA_NORMAL
        FROM   LY_AULA_DOCENTE DD (NOLOCK)
        JOIN LY_DOCENTE DR (NOLOCK) ON DR.NUM_FUNC=DD.NUM_FUNC
        WHERE  DD.NUM_FUNC=DD.NUM_FUNC
			AND DD.ANO = YEAR(GETDATE())
			AND EXISTS (SELECT 1
                       FROM   LY_TURMA TT (NOLOCK)
                       WHERE  TT.FACULDADE = DD.FACULDADE
                              AND TT.ANO = DD.ANO
                              AND TT.SEMESTRE = TT.SEMESTRE
                              AND TT.TURMA = DD.TURMA
                              AND TT.TURNO = DD.TURNO
                              AND TT.DT_FIM = DD.DATA_FIM
                              AND DD.DATA_FIM&gt;=CONVERT(DATE,CURRENT_TIMESTAMP)
                              AND TT.CURSO IN ('0002.33', '0002.38')
							  )
            AND NOT EXISTS (SELECT 1
                               FROM   LY_AULA_DOCENTE_TIPO T1 (NOLOCK)
                               WHERE  T1.ANO = DD.ANO
                                      AND T1.SEMESTRE = DD.SEMESTRE
                                      AND T1.TIPO_AULA = 'GLP'
                                      AND T1.DATA_FIM = DD.DATA_FIM
                                      AND T1.AULA=DD.AULA
                                      AND T1.DIA_SEMANA=DD.DIA_SEMANA
                                      AND T1.TURMA=DD.TURMA
                                      AND T1.TURNO=DD.TURNO
                                      AND T1.NUM_FUNC=DD.NUM_FUNC
									  )
			AND DR.NUM_FUNC = LD.NUM_FUNC
) AS CH_EMI/*,
(SELECT COUNT(DD.AULA)TOL_AULA_NORMAL
        FROM   LY_AULA_DOCENTE DD (NOLOCK)
        JOIN LY_DOCENTE DR (NOLOCK) ON DR.NUM_FUNC=DD.NUM_FUNC
        WHERE 
			DD.ANO = YEAR(GETDATE())
			AND EXISTS (SELECT 1
                       FROM   LY_TURMA TT (NOLOCK)
                       WHERE  TT.ANO = DD.ANO
                              AND TT.SEMESTRE = DD.SEMESTRE
                              AND TT.DISCIPLINA = DD.DISCIPLINA
                              AND TT.TURMA = DD.TURMA
                              AND TT.DT_FIM = DD.DATA_FIM
                              AND DD.DATA_FIM&gt;=CONVERT(DATE,CURRENT_TIMESTAMP)
                              AND TT.CURSO IN ('0002.33', '0002.38')
                              )
               AND EXISTS (SELECT 1
                               FROM   LY_AULA_DOCENTE_TIPO T1 (NOLOCK)
                               WHERE  T1.NUM_FUNC=DD.NUM_FUNC
                                      AND T1.TURNO=DD.TURNO
                                      AND T1.FACULDADE = DD.FACULDADE
                                      AND T1.DIA_SEMANA=DD.DIA_SEMANA
                                      AND T1.AULA=DD.AULA
                                      AND T1.DISCIPLINA = DD.DISCIPLINA
                                      AND T1.TURMA=DD.TURMA
									  AND T1.ANO = DD.ANO
                                      AND T1.SEMESTRE = DD.SEMESTRE
                                      AND T1.TIPO_AULA = 'GLP'
                                      AND T1.DATA_INICIO = DD.DATA_INICIO
                                      )
			AND DR.NUM_FUNC = LD.NUM_FUNC
) AS CH_GLP_EMI*/
FROM LY_DOCENTE LD 
INNER JOIN LY_PESSOA PE ON PE.PESSOA=LD.PESSOA
INNER JOIN LY_LOTACAO LL ON LD.MATRICULA = LL.MATRICULA 
				AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
				AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))
INNER JOIN APOLLO..SIGRH SIGRH ON SIGRH.MATRICULA = LD.MATRICULA
INNER JOIN LY_AULA_DOCENTE LAD ON LAD.NUM_FUNC = LD.NUM_FUNC
INNER JOIN LY_TURMA LT ON LAD.DISCIPLINA = LT.DISCIPLINA 
				AND LAD.TURMA = LT.TURMA 
				AND LAD.ANO = LT.ANO 
				AND LAD.FACULDADE = LT.FACULDADE
				AND LAD.SEMESTRE = LT.SEMESTRE
				AND LAD.TURNO = LT.TURNO
				AND LAD.DATA_FIM = LT.DT_FIM
				AND LT.ANO = YEAR(GETDATE())
				AND LT.SIT_TURMA = 'ABERTA'
				AND LAD.DATA_FIM &gt;= CONVERT(DATE,CURRENT_TIMESTAMP)
				AND LT.CURSO IN ('0002.33', '0002.38')
INNER JOIN LY_DISCIPLINA LDI WITH(NOLOCK) ON LDI.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)			
INNER JOIN LY_UNIDADE_ENSINO LUE ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
INNER JOIN TCE_REGIONAL TR ON TR.ID_REGIONAL = LUE.ID_REGIONAL 
INNER JOIN MUNICIPIO M ON M.CODIGO = LUE.MUNICIPIO
INNER JOIN LY_GRUPO_HABILITACAO_DOC LGHD ON LD.NUM_FUNC = LGHD.NUM_FUNC
				AND AGRUPAMENTO_INGRESSO = 's'
INNER JOIN LY_GRUPO_HABILITACAO LGH ON LGH.AGRUPAMENTO = LGHD.AGRUPAMENTO
			
WHERE EXISTS (SELECT 1
				FROM LY_UNIDADE_ENSINO_SITUACAO US
				WHERE US.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND	US.SITUACAO = 'ESTADUAL'
				AND	US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
									(
									SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
									FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
									)
				)
AND (LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND LD.MATRICULA NOT IN ('00000000', '11111111', '222222222', '33333333', '44444444', '55555555', '66666666', 
						'77777777', '88888888', '99999999', '12121201', '12121209', '12121202', '12121220')</CommandText>
      </Query>
