      <Textbox Name="Textbox3">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Última atualização em </Value>
                <Style>
                  <FontFamily>Calibri</FontFamily>
                  <FontSize>9pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                  <Color>Red</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>=First(Fields!DATA.Value, "DATA_ATUALIZACAO")</Value>
                <Style>
                  <FontFamily>Calibri</FontFamily>
