        </Field>
        <Field Name="MUNICIPIO_BILHETAGEM">
          <DataField>MUNICIPIO_BILHETAGEM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_DISTORCAO_IDADE_SERIE">
          <DataField>TOTAL_DISTORCAO_IDADE_SERIE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
