          <DataField>TOTAL_NACIONALIDADE_NAO_INF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_E_MAIL_INF">
          <DataField>TOTAL_E_MAIL_INF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
