  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>541d2d57-1ca6-4cdf-9211-09c7bdf37b73</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	ARSC.ID_REGIONAL,
		REGIONAL, 
		COD_MUNICIPIO_ESCOLA,
		MUNIC_ESCOLA, 
		--UA, 
		VWS.UA_ANTIGA UA,
		CENSO, 
		ESCOLA,
		COUNT (DISTINCT ALUNO) TOTAL_ALUNO,
		SUM (CASE WHEN PRE_NOME_SOCIAL &lt;&gt; '' AND PRE_NOME_SOCIAL IS NOT NULL THEN 1 ELSE 0 END) TOTAL_PRE_NOME_INF,
		SUM (CASE WHEN TIPO_SANGUINEO &lt;&gt; '' AND TIPO_SANGUINEO IS NOT NULL THEN 1 ELSE 0 END) TOTAL_TIPO_SANGUINEO_INF,
		SUM (CASE WHEN NECESSIDADE_ESPECIAL = 'PENDENTE' THEN 0 ELSE 1 END) TOTAL_NECESSIDADE_ESPECIAL_INF,
		SUM (CASE WHEN NACIONALIDADE = 'BRASILEIRA' THEN 1 ELSE 0 END) TOTAL_BRASILEIROS,
		SUM (CASE WHEN NACIONALIDADE LIKE 'ESTRANG%' THEN 1 ELSE 0 END) TOTAL_ESTRANGEIRO,
		SUM (CASE WHEN NACIONALIDADE = 'PENDENTE' THEN 1 ELSE 0 END) TOTAL_NACIONALIDADE_NAO_INF,
		SUM (CASE WHEN ARSC.E_MAIL &lt;&gt; '' OR ARSC.E_MAIL IS NULL THEN 1 ELSE 0 END) TOTAL_E_MAIL_INF,
		SUM (CASE WHEN RECEBE_ESC_OUTRO_ESPACO IN ('1', '2') THEN 1 ELSE 0 END) TOTAL_RECEBE_ESC_OUTRO_ESPACO,
		SUM (CASE WHEN UTILIZA_TRANSPORTE = 'PENDENTE' THEN 0 ELSE 1 END) TOTAL_UTILIZA_TRANSPORTE_MARCADO,
		SUM (CASE WHEN MODAL = 'PENDENTE' THEN 0 ELSE 1 END) TOTAL_MODAL_MARCADO,
		SUM (CASE WHEN CADASTRO_COMPLETO = 'SIM' THEN 1 ELSE 0 END) TOTAL_CADASTRO_COMPLETO,
		MUNICIPIO_BILHETAGEM,
		SUM (CASE WHEN DISTORCAO_IDADE_SERIE = 'SIM' THEN 1 ELSE 0 END) TOTAL_DISTORCAO_IDADE_SERIE,
VWS.UA_ATUAL
FROM	APOLLO..REL_SITUACAO_CADASTRAL_ALUNO ARSC
JOIN	LY_UNIDADE_ENSINO LUE on LUE.UNIDADE_ENS = ARSC.UNIDADE_ENSINO
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR 
WHERE	(ARSC.ID_REGIONAL = ISNULL(@REGIONAL, ARSC.ID_REGIONAL) OR ARSC.ID_REGIONAL IS NULL)
AND		(COD_MUNICIPIO_ESCOLA = ISNULL(@MUNICIPIO, COD_MUNICIPIO_ESCOLA) OR COD_MUNICIPIO_ESCOLA IS NULL)
AND		(CENSO = ISNULL(@ESCOLA, CENSO) OR CENSO IS NULL)
GROUP	BY ARSC.ID_REGIONAL, REGIONAL, COD_MUNICIPIO_ESCOLA, MUNIC_ESCOLA, VWS.UA_ANTIGA, CENSO, ESCOLA, MUNICIPIO_BILHETAGEM, VWS.UA_ATUAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
