          <DataField>TOTAL_TIPO_SANGUINEO_INF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_NECESSIDADE_ESPECIAL_INF">
          <DataField>TOTAL_NECESSIDADE_ESPECIAL_INF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_BRASILEIROS">
          <DataField>TOTAL_BRASILEIROS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ESTRANGEIRO">
          <DataField>TOTAL_ESTRANGEIRO</DataField>
