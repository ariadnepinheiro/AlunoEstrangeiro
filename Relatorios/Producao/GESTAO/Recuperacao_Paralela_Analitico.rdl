  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null id_regional,' TODAS' regional
union
SELECT DISTINCT R.ID_REGIONAL, R.REGIONAL 
FROM TCE_REGIONAL R (nolock)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.ID_REGIONAL = R.ID_REGIONAL
WHERE 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
where (UF.USUARIO = ISNULL(@usuario,UF.USUARIO) OR  UF.USUARIO IS NULL) 
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY REGIONAL
</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.id_regional = ISNULL(@COORD,n1.id_regional)or n1.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	UNIDADE_ENS, NOME_COMP
FROM 	LY_UNIDADE_ENSINO UE (NOLOCK)
WHERE 	(UE.MUNICIPIO = ISNULL(@municipio, UE.MUNICIPIO) OR UE.MUNICIPIO IS NULL)
AND 	(UE.ID_REGIONAL=ISNULL(@coord, UE.ID_REGIONAL) OR UE.ID_REGIONAL IS NULL)
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	(UF.USUARIO = ISNULL(@usuario,UF.USUARIO) OR UF.USUARIO IS NULL)
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
union 
SELECT NULL, ' TODAS'
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LANCAMENTOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@prova">
            <Value>=Parameters!prova.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, DS_MUNICIPIO, CENSO, UNIDADE, MODALIDADE, CURSO, BIMESTRE, SERIE, NOME_DISCIPLINA, COUNT(ALUNO) QTDE_NOTAS,
		SUM(RECUPERACAO_PARALELA) RECUPERACAO_PARALELA
FROM	(
			SELECT	R.ID_REGIONAL, R.REGIONAL, UE.MUNICIPIO, MM.NOME DS_MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
			MC.DESCRICAO MODALIDADE, C.NOME CURSO, 
			CASE WHEN N.PROVA = 'MÉDIA1' THEN '1BIM' 
						WHEN N.PROVA = 'MÉDIA2' THEN '2BIM'
						WHEN N.PROVA = 'MÉDIA3' THEN '3BIM'
						WHEN N.PROVA = 'MÉDIA4' THEN '4BIM' END BIMESTRE, T.SERIE,
					T.ANO, T.SEMESTRE, T.DISCIPLINA, T.TURMA, D.NOME_COMPL NOME_DISCIPLINA, A.ALUNO, 
					PE.NOME_COMPL, CASE WHEN RECUPERACAO_PARALELA = 'S' THEN 1 ELSE 0 END RECUPERACAO_PARALELA 
			FROM	LY_TURMA T (NOLOCK)
			JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
			ON		UE.UNIDADE_ENS = T.UNIDADE_RESPONSAVEL
			JOIN	TCE_REGIONAL R (NOLOCK)
			ON		R.ID_REGIONAL = UE.ID_REGIONAL
			JOIN	LY_DISCIPLINA D (NOLOCK)
			ON		D.DISCIPLINA = ISNULL(T.DISCIPLINA_MULTIPLA, T.DISCIPLINA)
			JOIN	LY_MATRICULA M (NOLOCK)
			ON		M.ANO = T.ANO
			AND		M.SEMESTRE = T.SEMESTRE
			AND		M.DISCIPLINA = T.DISCIPLINA
			AND		M.TURMA = T.TURMA
			AND		M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
			JOIN	LY_NOTA N (NOLOCK)
			ON		N.ANO = M.ANO
			AND		N.SEMESTRE = M.SEMESTRE
			AND		N.DISCIPLINA = M.DISCIPLINA
			AND		N.TURMA = M.TURMA
			AND		N.ALUNO = M.ALUNO
			JOIN	LY_ALUNO A (NOLOCK)
			ON		A.ALUNO = M.ALUNO
			JOIN	LY_PESSOA PE (NOLOCK)
			ON		PE.PESSOA = A.PESSOA
			JOIN	MUNICIPIO MM
			ON		MM.CODIGO = UE.MUNICIPIO
			JOIN	LY_CURSO C (NOLOCK)
			ON		C.CURSO = T.CURSO
			JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
			ON		MC.MODALIDADE = C.MODALIDADE
			WHERE	T.ANO = @ano
			AND		CONVERT(DECIMAL(10,2),REPLACE(N.CONCEITO,',','.')) &lt; 5
			AND		CONCEITO &lt;&gt; ''
			AND		CONCEITO IS NOT NULL
			AND		N.PROVA = @prova
	) B
WHERE	(B.ID_REGIONAL = ISNULL(@COORD, B.ID_REGIONAL) OR B.ID_REGIONAL IS NULL)
AND		(B.MUNICIPIO = ISNULL(@municipio,  B.MUNICIPIO) OR   B.MUNICIPIO IS NULL)       
AND		(CENSO = ISNULL(@escola, CENSO) OR CENSO IS NULL)	
GROUP BY REGIONAL, DS_MUNICIPIO, CENSO, UNIDADE, MODALIDADE, CURSO, BIMESTRE, SERIE, NOME_DISCIPLINA</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DS_MUNICIPIO">
          <DataField>DS_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BIMESTRE">
          <DataField>BIMESTRE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_NOTAS">
          <DataField>QTDE_NOTAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RECUPERACAO_PARALELA">
          <DataField>RECUPERACAO_PARALELA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME_DISCIPLINA">
          <DataField>NOME_DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT  DISTINCT ANO 
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
