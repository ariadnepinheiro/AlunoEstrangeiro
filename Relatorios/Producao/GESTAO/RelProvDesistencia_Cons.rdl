  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ALUNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, MUNICIPIO, CENSO, ESCOLA, SUM(QTDE_REATIVACAO_QUEDA) QTDE_REATIVACAO_QUEDA, 
		SUM(CASE WHEN SIT = 'AJUSTES' THEN 1 ELSE 0 END) AJUSTES,
		SUM(CASE WHEN SIT = 'REABERTURA' THEN 1 ELSE 0 END)REABERTURA, 
		COUNT(ALUNO) QTDE_CANCELADOS, SUM(ATIVO) ATIVO 
FROM	(
SELECT	DISTINCT N.REGIONAL, 
		M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP ESCOLA, 
		MC.DESCRICAO MODALIDADE, TC.DESCRICAO SEGMENTO, C.NOME CURSO, 
		A.SERIE, A.ALUNO, PE.NOME_COMPL NOME_ALUNO, 
		H.DT_ENCERRAMENTO DATA_ENCERRAMENTO_ORIGINAL, 
		CASE WHEN QTDE &gt; 1 THEN QTDE ELSE 0 END QTDE_REATIVACAO_QUEDA, 
		UPPER((
			CASE WHEN  HA.MOTIVOREABERTURA = 'Ajuste de Lançamentos Anteriores' THEN 'AJUSTES'
			WHEN  HA.MOTIVOREABERTURA = 'Reabertura de matrícula' THEN 'REABERTURA' END
			)) SIT, 
		CASE WHEN A.SIT_ALUNO = 'ATIVO' THEN 1 ELSE 0 END ATIVO
FROM	LY_UNIDADE_ENSINO UE (NOLOCK)
JOIN	TCE_REGIONAL N (NOLOCK)
ON		N.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK)
ON		M.CODIGO = UE.MUNICIPIO
JOIN	LY_ALUNO A (NOLOCK) 
ON		A.UNIDADE_ENSINO = UE.UNIDADE_ENS
JOIN	(
		SELECT	ALUNO, MOTIVO,  MIN(CONVERT(DATE,DT_ENCERRAMENTO)) DT_ENCERRAMENTO, 
		COUNT(DISTINCT ALUNO+CONVERT(VARCHAR(20), DT_ENCERRAMENTO)) QTDE
		FROM	LY_H_CURSOS_CONCL (NOLOCK)
		WHERE	MOTIVO = 'PROV_DES'
		AND	YEAR(DT_ENCERRAMENTO) = @ano
		GROUP BY ALUNO, MOTIVO
		) H
ON		A.ALUNO = H.ALUNO
LEFT	JOIN (
		SELECT	DISTINCT ALUNO, MOTIVO, CONVERT(DATE, DT_ENCERRAMENTO) DT_ENCERRAMENTO, 
		ISNULL(MOTIVOREABERTURA,'Reabertura de matrícula') MOTIVOREABERTURA, MM.DESCRICAO, 
		CASE WHEN DT_REABERTURA IS NULL THEN 1 ELSE 0 END INATIVO
		FROM	LY_H_CURSOS_CONCL H2 (NOLOCK)
		JOIN	LY_MOTIVOSAIDA MM (NOLOCK)
		ON		MM.MOTIVOSAIDA = H2.MOTIVO
		WHERE	H2.ALUNO + CONVERT(VARCHAR(20), (H2.DT_ENCERRAMENTO)) IN (
														SELECT	ALUNO + CONVERT(VARCHAR(20), MAX(DT_ENCERRAMENTO))
														FROM	LY_H_CURSOS_CONCL HJ (NOLOCK)
														WHERE	HJ.MOTIVO = 'PROV_DES'		
														AND		YEAR(DT_ENCERRAMENTO) = @ano
														GROUP BY ALUNO

												)
	    AND		H2.MOTIVO = 'PROV_DES'
	    AND		YEAR(DT_ENCERRAMENTO) = @ano
	    AND		DT_REABERTURA IS NOT NULL
		) HA
ON		HA.ALUNO = A.ALUNO
JOIN	LY_CURSO C (NOLOCK)
ON		C.CURSO = A.CURSO
JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
ON		MC.MODALIDADE = C.MODALIDADE
JOIN	LY_TIPO_CURSO TC (NOLOCK)
ON		TC.TIPO = C.TIPO
JOIN     LY_PESSOA PE (NOLOCK) ON PE.PESSOA = A.PESSOA
) AS A
GROUP BY REGIONAL, MUNICIPIO, CENSO, ESCOLA
</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_REATIVACAO_QUEDA">
          <DataField>QTDE_REATIVACAO_QUEDA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AJUSTES">
          <DataField>AJUSTES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REABERTURA">
          <DataField>REABERTURA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_CANCELADOS">
          <DataField>QTDE_CANCELADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ATIVO">
          <DataField>ATIVO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
