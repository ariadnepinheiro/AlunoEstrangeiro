  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>229031ba-5c11-4e90-a47d-c1621f78e578</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AGENDA_ID">
            <Value>=Parameters!AGENDA_ID.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	A.ALUNO, I.INSCRICAOID INSCRICAO, PE.NOME_COMPL, C.NOME CURSO, UC.TURNOID TURNO, 
		REGIONAL, M.NOME MUNICÍPIO, UE.UNIDADE_ENS UE_CENSO, UE.NOME_COMP ESCOLA, 
		 CASE WHEN STATUS = 'Confirmado' THEN 'S' ELSE 'N' END SIT_CONF,         
		CM.DT_ALTERACAO DATA_CONFIRMACAO, SIT_ALUNO
FROM  ProcessoSeletivoAluno.ALUNO_CANDIDATOINSCRITOCLASSIFICADO CA (NOLOCK)
JOIN  PROCESSOSELETIVOALUNO.CANDIDATOINSCRITOCLASSIFICADO CI (NOLOCK)
ON		CA.CANDIDATOINSCRITOCLASSIFICADOID = CI.CANDIDATOINSCRITOCLASSIFICADOID
JOIN  ProcessoSeletivoAluno.INSCRICAO I (NOLOCK)
ON		I.INSCRICAOID = CI.INSCRICAOID
JOIN	PROCESSOSELETIVOALUNO.UNIDADEENSINO_CURSO_TURNO_INSCRICAO UC (NOLOCK)
ON		UC.INSCRICAOID = I.INSCRICAOID
JOIN	AGENDA.PROCESSOSELETIVO AP (NOLOCK)
ON		AP.PROCESSOSELETIVOID = I.PROCESSOSELETIVOID
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		UE.UNIDADE_ENS = UC.UNIDADEENSINOID
JOIN	TCE_REGIONAL R (NOLOCK)
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK)
ON		M.CODIGO = UE.MUNICIPIO
JOIN	LY_ALUNO A (NOLOCK)
ON		A.ALUNO = CA.ALUNOID
JOIN	LY_PESSOA PE (NOLOCK)
ON		PE.PESSOA = A.PESSOA
LEFT JOIN TCE_CONFIRMACAO_MATRICULA CM (NOLOCK)
ON		CM.ID_CONFIRMACAO_MATRICULA = CA.ID_CONFIRMACAO_MATRICULA
JOIN	LY_CURSO C (NOLOCK)
ON		C.CURSO = UC.CURSOID
WHERE	AP.AGENDAID = @AGENDA_ID
AND R.ID_REGIONAL = ISNULL(@REGIONAL, R.ID_REGIONAL)
AND M.CODIGO = ISNULL(@MUNICIPIO, M.CODIGO)
AND UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS)</CommandText>
      </Query>
      <Fields>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="INSCRICAO">
          <DataField>INSCRICAO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICÍPIO">
          <DataField>MUNICÍPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE_CENSO">
          <DataField>UE_CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SIT_CONF">
          <DataField>SIT_CONF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SIT_ALUNO">
          <DataField>SIT_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_CONFIRMACAO">
          <DataField>DATA_CONFIRMACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT R.ID_REGIONAL, R.REGIONAL 
FROM TCE_REGIONAL R (nolock)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.ID_REGIONAL = R.ID_REGIONAL
WHERE 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
where UF.USUARIO = ISNULL(@usuario,UF.USUARIO)
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
UNION
SELECT -1 ID_REGIONAL,' Selecione...' REGIONAL 
ORDER BY REGIONAL </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@QTDE_ACESSO">
            <Value>=Parameters!QTDE_ACESSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @QTDE_ACESSO &gt; 1 
BEGIN 
select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2 (NOLOCK)
join municipio l1 (NOLOCK) on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL (NOLOCK) n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj (NOLOCK) on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	n1.id_regional = ISNULL(@REGIONAL,n1.id_regional)
	and
	jj.USUARIO = ISNULL(@usuario,jj.USUARIO)
union
select null codigo,' TODOS' nome  
UNION 
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME
END 
IF @QTDE_ACESSO &lt;= 1 
BEGIN 
select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2 (NOLOCK)
join municipio l1 (NOLOCK) on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL n1 (NOLOCK) on n1.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj (NOLOCK) on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	n1.id_regional = ISNULL(@REGIONAL,n1.id_regional)
	and
	jj.USUARIO = ISNULL(@usuario,jj.USUARIO)
UNION 
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME
END

</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@QTDE_ACESSO">
            <Value>=Parameters!QTDE_ACESSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @QTDE_ACESSO &gt; 1 
BEGIN
SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT 	UNIDADE_ENS, NOME_COMP
FROM 	LY_UNIDADE_ENSINO UE (NOLOCK)
WHERE 	UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO)
AND 	UE.ID_REGIONAL=ISNULL(@REGIONAL, UE.ID_REGIONAL) 
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = ISNULL(@usuario,UF.USUARIO) 
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
union 
SELECT NULL, ' TODAS'
ORDER BY NOME_COMP
END 
IF @QTDE_ACESSO &lt;= 1
BEGIN 
SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT 	UNIDADE_ENS, NOME_COMP
FROM 	LY_UNIDADE_ENSINO UE (NOLOCK)
WHERE 	UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO)
AND 	UE.ID_REGIONAL=ISNULL(@REGIONAL, UE.ID_REGIONAL) 
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = ISNULL(@usuario,UF.USUARIO)
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY NOME_COMP
END

</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="QTDE_ACESSO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	COUNT(DISTINCT UNIDADE_ENS)
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
where UF.USUARIO = ISNULL(@usuario,UF.USUARIO)</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField />
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AGENDA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT   AGENDAID, DESCRICAO
FROM 	AGENDA.AGENDA (NOLOCK)
WHERE 	DESCRICAO LIKE 'PROCESSO SELETIVO%'</CommandText>
      </Query>
      <Fields>
        <Field Name="AGENDAID">
          <DataField>AGENDAID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
