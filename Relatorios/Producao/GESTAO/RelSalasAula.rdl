  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>4a42e970-cebc-4b13-939f-55765f4e4f12</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	DISTINCT TR.REGIONAL, 
		M.NOME MUNICIPIO, 
		VS.UA_ATUAL UA,
		LUE.UNIDADE_ENS CENSO,
		LUE.NOME_COMP ESCOLA,
		LD.DEPENDENCIA SALA,
		CASE WHEN LTD.NOME = 'SALA' THEN 'SALA DE AULA' ELSE LTD.NOME END TIPO,
		LD.AREA, 
		LD.NUM_ALUNOS CAP_MAX_ALUNO
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	LY_DEPENDENCIA LD (NOLOCK) ON LD.FACULDADE = LUE.UNIDADE_ENS
					AND LD.ATIVA = 'S'
JOIN	LY_TIPO_DEPENDENCIA LTD (NOLOCK) ON LTD.TIPO_DEPEND = LD.TIPO_DEPEND
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES (NOLOCK)  ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
					AND LUES.DT_SITUACAO = (
											SELECT	MAX(DT_SITUACAO)
											FROM	LY_UNIDADE_ENSINO_SITUACAO L1 (NOLOCK)
											WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS
											)
					AND (SIT_FUNCIONAMENTO = 'EmAtividade' OR SIT_FUNCIONAMENTO IS NULL)
					AND SITUACAO = 'ESTADUAL'		
JOIN HADES..VW_SETOR VS ON VS.SETOR =LUE.SETOR								
WHERE   (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)

ORDER BY REGIONAL, MUNICIPIO, ESCOLA, SALA</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SALA">
          <DataField>SALA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO">
          <DataField>TIPO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AREA">
          <DataField>AREA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CAP_MAX_ALUNO">
          <DataField>CAP_MAX_ALUNO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT	0 ID_REGIONAL,' Selecione...' REGIONAL
UNION
SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) REGIONAL
FROM	TCE_REGIONAL TR (NOLOCK)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER	BY REGIONAL 
</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	DISTINCT M.CODIGO, M.NOME 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
UNION
SELECT	NULL CODIGO,' TODOS' NOME
UNION
SELECT	'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER	BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT	NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT	LUE.UNIDADE_ENS, SUBSTRING (LUE.NOME_COMP,1,50) NOME_COMP 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK) 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES (NOLOCK) ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND LUES.DT_SITUACAO = (
										SELECT	MAX(DT_SITUACAO)
										FROM	LY_UNIDADE_ENSINO_SITUACAO L1 (NOLOCK)
										WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS
										AND		SITUACAO = 'ESTADUAL'
										)
				AND	(SIT_FUNCIONAMENTO = 'EmAtividade' OR SIT_FUNCIONAMENTO IS NULL)						
WHERE	(LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL) 
ORDER	BY NOME_COMP
</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
