<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>14f6c4f5-6443-4849-9415-51a271cb9f30</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT 
	DISTINCT
	  TR.REGIONAL
	, LUE.UNIDADE_ENS AS CENSO
	, LUE.NOME_COMP AS ESCOLA
	, LC.NOME AS CURSO
	, LS.DESCRICAO AS SERIE
	, LT.TURNO	
FROM LY_UNIDADE_ENSINO_CURSOS LUEC 
INNER JOIN LY_UNIDADE_ENSINO LUE WITH(NOLOCK) ON LUE.UNIDADE_ENS = LUEC.UNIDADE_ENS
INNER JOIN LY_UNIDADE_ENSINO_SITUACAO LUES WITH(NOLOCK) ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
														AND LUES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
																				FROM LY_UNIDADE_ENSINO_SITUACAO LUES1 WITH(NOLOCK)
																				WHERE LUE.UNIDADE_ENS = LUES1.UNIDADE_ENS) 
														AND UPPER(LUES.SITUACAO) = 'ESTADUAL' 
														AND (LUE.SIT_FUNCIONAMENTO = 'EmAtividade' OR LUE.SIT_FUNCIONAMENTO IS NULL)
														AND LUE.UNIDADE_ENS NOT IN ('99999999', '33334444', '33335555', '33335556')
														AND LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS)
INNER JOIN LY_CURSO LC ON LC.CURSO = LUEC.CURSO 
					   AND LC.CURSO IN (SELECT CURSO FROM LY_CURSO WHERE NOME LIKE '%ENSINO FUNDAMENTAL%')						
					   AND LC.MODALIDADE &lt;&gt; 'ED3'					   
INNER JOIN LY_TURMA LTU ON LTU.CURSO = LC.CURSO
						AND LTU.UNIDADE_RESPONSAVEL = LUE.UNIDADE_ENS
						AND LTU.ANO = @ANO
INNER JOIN LY_SERIE LS ON LS.SERIE = LTU.SERIE
					   AND LS.CURSO = LTU.CURSO
					   AND LS.TURNO = LTU.TURNO
					   AND LS.CURRICULO = LTU.CURRICULO
					   AND LS.SERIE IN (3, 4, 5, 6) 
INNER JOIN LY_TURNO LT ON LT.TURNO = LS.TURNO
INNER JOIN TCE_REGIONAL TR WITH(NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL 
										AND LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL)
INNER JOIN HADES..TCE_MUNICIPIO TM WITH(NOLOCK) ON TM.ID_MUNICIPIO = LUE.MUNICIPIO 
												AND LUE.MUNICIPIO = ISNULL(@MUNIC, LUE.MUNICIPIO)
ORDER BY TR.REGIONAL, LUE.UNIDADE_ENS, LUE.NOME_COMP, LC.NOME, LT.TURNO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Regional">
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT NULL AS ID_REGIONAL,' TODAS' AS REGIONAL 
UNION
SELECT R.ID_REGIONAL,SUBSTRING(R.REGIONAL,1,35) FROM LY_UNIDADE_ENSINO  L2
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = L2.ID_REGIONAL
JOIN LY_USUARIO_UNIDADE_FIS JJ ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@USUARIO,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
ORDER BY REGIONAL</CommandText>
        <QueryParameters>
          <QueryParameter Name="@USUARIO">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.ID_REGIONAL = ISNULL(@REGIONAL,ue.ID_REGIONAL) or ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="municipio">
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT DISTINCT
        L1.codigo ,
        L1.nome
FROM    LY_UNIDADE_ENSINO l2
        JOIN municipio l1 ON l1.CODIGO = l2.MUNICIPIO
        JOIN dbo.TCE_REGIONAL r1 ON r1.ID_REGIONAL = l2.ID_REGIONAL
        JOIN LY_USUARIO_UNIDADE_FIS jj ON jj.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE   ( r1.ID_REGIONAL = ISNULL(@REGIONAL, r1.ID_REGIONAL)
          OR r1.ID_REGIONAL IS NULL
        )
        AND ( jj.USUARIO = ISNULL(@usuario, jj.USUARIO)
              OR jj.USUARIO IS NULL
            )
UNION
SELECT  NULL codigo ,
        ' TODOS' nome
UNION
SELECT  'NULO' codigo ,
        ' Selecione...' descricao
ORDER BY NOME</CommandText>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ANO">
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>-- RETORNA UMA LISTA DE ANOS QUE EXISTAM NA BASE (HIST E ATUAL)
SELECT DISTINCT ANO FROM LY_MATRICULA (NOLOCK) 
WHERE ANO &gt;= 2010
UNION 
SELECT DISTINCT ANO FROM LY_HISTMATRICULA (NOLOCK) 
WHERE ANO &gt;= 2010 ORDER BY ANO DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
