  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1b0652bd-f4bf-45da-bbc9-0d8b244617f5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT  DISTINCT LH.ALUNO, LT.ANO, LT.SEMESTRE, LT.TURNO, LT.TURMA, UNIDADE_RESPONSAVEL, LT.CURSO
INTO	#ALUNOS
FROM	LY_HISTMATRICULA LH (NOLOCK) 
JOIN	LY_TURMA LT (NOLOCK) ON LT.TURMA = LH.TURMA
				AND	LT.DISCIPLINA = LH.DISCIPLINA
				AND	LT.ANO = LH.ANO
				AND LT.SEMESTRE = LH.SEMESTRE
				AND LT.SIT_TURMA = 'FINALIZADA'
				AND LT.ANO = @ANO
				AND LT.SEMESTRE IN (0, @SEMESTRE)
WHERE	SITUACAO_HIST &lt;&gt; 'CANCELADO'

					
SELECT  REGIONAL, MUNICIPIO, UA, CENSO, ESCOLA, MODALIDADE, SEGMENTO, ESCOLARIDADE, ANO, SEMESTRE, TURNO, TURMA,
		([APROVADO]+[APROVADO_DEP]+[REP_FREQ]+[REP_NOTA]) TOTAL_ALUNOS, APROVADO, APROVADO_DEP, REP_FREQ, REP_NOTA
FROM(

SELECT	REGIONAL, MUNICIPIO, UA, CENSO, ESCOLA, MODALIDADE, SEGMENTO, ESCOLARIDADE, ANO, SEMESTRE, TURNO, TURMA, 
		ISNULL([APROVADO],0) APROVADO, ISNULL([APROVADO COM DEP],0) APROVADO_DEP, ISNULL([REP FREQ],0) REP_FREQ, ISNULL([REP NOTA],0) REP_NOTA
FROM(

SELECT  DISTINCT
		TR.REGIONAL,
		M.NOME MUNICIPIO,
		VS.UA_ATUAL UA,
		LUE.UNIDADE_ENS CENSO,
		LUE.NOME_COMP ESCOLA,
		LMC.DESCRICAO MODALIDADE,
		LTC.DESCRICAO SEGMENTO,
		LC.NOME ESCOLARIDADE,
		A.ANO,
		A.SEMESTRE,
		CASE A.TURNO
			WHEN 'A' THEN 'AMPLIADO'
			WHEN 'I' THEN 'INTEGRAL'
			WHEN 'M' THEN 'MANHÃ'
			WHEN 'N' THEN 'NOITE'
			WHEN 'T' THEN 'TARDE'
		END TURNO,
		A.TURMA,
		CASE TSFA.SITUACAO_FINAL 
				WHEN 'Reprovado' THEN 'Rep Nota'
				WHEN 'Rep Falta' THEN 'Rep Freq'
				ELSE TSFA.SITUACAO_FINAL
		END SITUACAO_FINAL,	
		COUNT (DISTINCT A.ALUNO) QTD_ALUNO
FROM	#ALUNOS A (NOLOCK)
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = A.CURSO
JOIN	LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE
JOIN	LY_TIPO_CURSO LTC (NOLOCK) ON LTC.TIPO = LC.TIPO
JOIN	TCE_SITUACAO_FINAL_ALUNO TSFA (NOLOCK) ON TSFA.ALUNO = A.ALUNO 
				AND TSFA.ANO = A.ANO
				AND TSFA.PERIODO = A.SEMESTRE
				AND	TSFA.TURMA = A.TURMA
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = A.UNIDADE_RESPONSAVEL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
INNER JOIN HADES..VW_SETOR VS ON VS.SETOR = LUE.SETOR	
WHERE	(LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)

GROUP BY VS.UA_ATUAL, TR.REGIONAL, M.NOME, LUE.SETOR, LUE.UNIDADE_ENS, LUE.NOME_COMP, LC.NOME, LTC.DESCRICAO, 
		 LMC.DESCRICAO, A.ANO, A.SEMESTRE, A.TURNO, A.TURMA, TSFA.SITUACAO_FINAL

)SQL1

PIVOT (SUM (QTD_ALUNO) FOR SITUACAO_FINAL IN ([Aprovado], [Aprovado Com Dep], [Rep Freq], [Rep Nota])) PIVOTABLE

)SQL2

DROP TABLE #ALUNOS
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
