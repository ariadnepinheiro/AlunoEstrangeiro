        </Field>
        <Field Name="ALUNO_ANALISE">
          <DataField>ALUNO_ANALISE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_NASC_ALUNO_ANALISE">
          <DataField>DT_NASC_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="NOME_MAE_ALUNO_ANALISE">
          <DataField>NOME_MAE_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARTAO_ALUNO">
          <DataField>CARTAO_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARTAO_ALUNO_ANALISE">
          <DataField>CARTAO_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_INCLUSAO_ALUNO">
          <DataField>DT_INCLUSAO_ALUNO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_INCLUSAO_ALUNO_ANALISE">
          <DataField>DT_INCLUSAO_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_REABERTURA_ALUNO">
          <DataField>DT_REABERTURA_ALUNO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_REABERTURA_ALUNO_ANALISE">
          <DataField>DT_REABERTURA_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="LANC_NOTA_ALUNO">
          <DataField>LANC_NOTA_ALUNO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="LANC_NOTA_ALUNO_ANALISE">
          <DataField>LANC_NOTA_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="data_hora_atualizacao">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 8</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@QTDE_ACESSO">
            <Value>=Parameters!QTDE_ACESSO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @QTDE_ACESSO &gt; 1 
BEGIN
SELECT 	UNIDADE_ENS, NOME_COMP
FROM 	LY_UNIDADE_ENSINO UE (NOLOCK)
WHERE 	UE.ID_REGIONAL=ISNULL(@coord, UE.ID_REGIONAL) 
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = ISNULL(@usuario,UF.USUARIO) 
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
union 
SELECT NULL, ' TODAS'
ORDER BY NOME_COMP
END 
IF @QTDE_ACESSO &lt;= 1
BEGIN 
SELECT 	UNIDADE_ENS, NOME_COMP
FROM 	LY_UNIDADE_ENSINO UE (NOLOCK)
WHERE 	UE.ID_REGIONAL=ISNULL(@coord, UE.ID_REGIONAL) 
AND 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	UF.USUARIO = ISNULL(@usuario,UF.USUARIO)
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY NOME_COMP
END</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="QTDE_ACESSO">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	COUNT(DISTINCT UNIDADE_ENS)
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
where UF.USUARIO = ISNULL(@usuario,UF.USUARIO)</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField />
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
