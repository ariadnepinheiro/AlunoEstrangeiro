  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT DISTINCT R.ID_REGIONAL, R.REGIONAL 
FROM TCE_REGIONAL R (nolock)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK)
ON 	UE.ID_REGIONAL = R.ID_REGIONAL
WHERE 	EXISTS (
SELECT 	1
FROM 	LY_USUARIO_UNIDADE_FIS UF (NOLOCK) 
JOIN 	LY_UNIDADES_ASSOCIADAS AD (NOLOCK)
ON 	AD.UNIDADE_FIS = UF.UNIDADE_FIS
WHERE 	(UF.USUARIO = ISNULL(@usuario,UF.USUARIO) OR  UF.USUARIO IS NULL) 
AND 	UE.UNIDADE_ENS = AD.UNIDADE_ENS
)
ORDER BY REGIONAL</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@coord">
            <Value>=Parameters!coord.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	R.REGIONAL, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
		E.ALUNO, E.NOME_ALUNO, E.DT_NASC, E.NOME_MAE, E.MESMA_PESSOA, 
		E.UNIDADE_ALUNO_ANALISE CENSO_ALUNO_ANALISE, UE1.NOME_COMP UNIDADE_ALUNO_ANALISE, E.ALUNO_ANALISE,  
		E.NOME_ALUNO_ANALISE, E.DT_NASC_ALUNO_ANALISE, E.NOME_MAE_ALUNO_ANALISE, E.SITUACAO, E.CARTAO_ALUNO, E.CARTAO_ALUNO_ANALISE, 
		E.DT_INCLUSAO_ALUNO, E.DT_INCLUSAO_ALUNO_ANALISE, E.DT_REABERTURA_ALUNO, 
		E.DT_REABERTURA_ALUNO_ANALISE, E.LANC_NOTA_ALUNO, E.LANC_NOTA_ALUNO_ANALISE
FROM	APOLLO..REL_DUPLIC_ALUNOS E (NOLOCK)
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		E.UNIDADE_ENSINO = UE.UNIDADE_ENS
JOIN	LY_UNIDADE_ENSINO UE1 (NOLOCK)
ON		UE1.UNIDADE_ENS = E.UNIDADE_ALUNO_ANALISE
JOIN	TCE_REGIONAL R (NOLOCK)
ON		R.ID_REGIONAL = UE.ID_REGIONAL
WHERE	R.ID_REGIONAL = ISNULL(@coord, R.ID_REGIONAL)
AND 	(UE.UNIDADE_ENS = ISNULL(@escola, UE.UNIDADE_ENS)
OR 	E.UNIDADE_ALUNO_ANALISE = ISNULL(@escola, UE.UNIDADE_ENS))
ORDER BY E.SITUACAO, E.NOME_ALUNO</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_ALUNO">
          <DataField>NOME_ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_NASC">
