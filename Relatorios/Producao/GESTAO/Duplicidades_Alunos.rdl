        </Field>
        <Field Name="NOME_MAE">
          <DataField>NOME_MAE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MESMA_PESSOA">
          <DataField>MESMA_PESSOA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CENSO_ALUNO_ANALISE">
          <DataField>CENSO_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ALUNO_ANALISE">
          <DataField>UNIDADE_ALUNO_ANALISE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_ALUNO_ANALISE">
          <DataField>NOME_ALUNO_ANALISE</DataField>
