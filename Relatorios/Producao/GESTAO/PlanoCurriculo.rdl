    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@turma">
            <Value>=Parameters!turma.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@semestre">
            <Value>=Parameters!semestre.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@disciplina">
            <Value>=Parameters!disciplina.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@datafrequencia">
            <Value>=Parameters!datafrequencia.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@tipo">
            <Value>=Parameters!tipo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT  (G.GRUPO + ' - ' + I.COMPETENCIA_HABILIDADE)  AS CURRICULO
              FROM TCE_COMPETENCIA_HABILIDADE_DOCENTE D
											INNER JOIN TCE_COMPETENCIA_HABILIDADE_ITEM I ON D.ID_COMPETENCIA_HABILIDADE_ITEM = I.ID_COMPETENCIA_HABILIDADE_ITEM
											INNER JOIN TCE_COMPETENCIA_HABILIDADE_GRUPO G ON G.ID_COMPETENCIA_HABILIDADE_GRUPO = I.ID_COMPETENCIA_HABILIDADE_GRUPO
                                        WHERE D.ANO = @ano						AND D.PERIODO = @semestre											AND D.TURMA = @turma
	                                AND D.DISCIPLINA = @disciplina
	                                AND DATAFREQUENCIA =@datafrequencia
												AND TIPO=@tipo</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CURRICULO">
          <DataField>CURRICULO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
