  <DataSets>
    <DataSet Name="DtSociologia">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  ANO ,
        CENSO ,
        BIMESTRE ,
        SUM(CAST(EFII6_COMP AS INT)) AS EFII6_COMP ,
        SUM(CAST(EFII6_TRAB AS INT)) AS EFII6_TRAB ,
        SUM(CAST(EFII7_COMP AS INT)) AS EFII7_COMP ,
        SUM(CAST(EFII7_TRAB AS INT)) AS EFII7_TRAB ,
        SUM(CAST(EFII8_COMP AS INT)) AS EFII8_COMP ,
        SUM(CAST(EFII8_TRAB AS INT)) AS EFII8_TRAB ,
        SUM(CAST(EFII9_COMP AS INT)) AS EFII9_COMP ,
        SUM(CAST(EFII9_TRAB AS INT)) AS EFII9_TRAB ,
        SUM(CAST(EM1_COMP AS INT)) AS EM1_COMP ,
        SUM(CAST(EM1_TRAB AS INT)) AS EM1_TRAB ,
        SUM(CAST(EM2_COMP AS INT)) AS EM2_COMP ,
        SUM(CAST(EM2_TRAB AS INT)) AS EM2_TRAB ,
        SUM(CAST(EM3_COMP AS INT)) AS EM3_COMP ,
        SUM(CAST(EM3_TRAB AS INT)) AS EM3_TRAB
FROM    CURRICULO_COMPETENCIAS_HABILIDADES T
WHERE   ANO = YEAR(GETDATE()) - 1
        AND DISCIPLINA IN ( 'SOCIOLOGIA',
                            'Sociologia da Educação' )
        AND CENSO = @ESCOLA
GROUP BY ANO ,
        CENSO ,
        BIMESTRE </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
