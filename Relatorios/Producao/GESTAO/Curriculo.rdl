      <Nullable>true</Nullable>
      <Prompt>Município</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>MUNICIPIO</DataSetName>
          <ValueField>CODIGO</ValueField>
          <LabelField>NOME</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="escola">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <Prompt>Escola</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>ESCOLA</DataSetName>
          <ValueField>UNIDADE_ENS</ValueField>
          <LabelField>NOME_COMP</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
  </ReportParameters>
  <Language>en-US</Language>
  <ConsumeContainerWhitespace>true</ConsumeContainerWhitespace>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <rd:ReportID>83e2a64d-0ab6-472e-8f75-b1e7bc01f2b2</rd:ReportID>
