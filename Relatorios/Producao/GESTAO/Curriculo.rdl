    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  T.*,
        UE.NOME_COMP AS ESCOLA
FROM    CURRICULO_TOTAL_TURMAS T
        INNER JOIN LYCEUM.DBO.LY_UNIDADE_ENSINO UE ON T.CENSO = UE.UNIDADE_ENS
WHERE   ANO = YEAR(GETDATE()) -1
AND CENSO= @ESCOLA</CommandText>
      </Query>
