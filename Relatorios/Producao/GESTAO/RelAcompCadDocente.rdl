  </Body>
  <Width>16.14118in</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin>
    <RightMargin>2cm</RightMargin>
    <TopMargin>2cm</TopMargin>
    <BottomMargin>2cm</BottomMargin>
    <ColumnSpacing>0.13cm</ColumnSpacing>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.50.9.196;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Docente">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>
SELECT 
		 SQL1.UA_ATUAL AS SETOR
		,SQL1.UNIDADE_ENS
		,SQL1.ESCOLA
		,SUM(SQL1.QTDE_PROB) QTDE_PROB
		,SQL1.REGIONAL 
		,SQL1.CODIGO
		,SQL1.NOME_MUNIC
		,SQL1.QTDE_PROF 
		,SQL1.QTDE_CADASTRO_COMPL
		,SQL1.QTDE_PENDENCIA_ABA_DOCENTE
		,SQL1.QTDE_PENDENCIA_ABA_FORMACAO_PESSOAL
FROM 
(
SELECT   VS.UA_ATUAL
        ,LUE.UNIDADE_ENS
        ,LUE.NOME_COMP ESCOLA
        ,COUNT(DISTINCT LD.MATRICULA) QTDE_PROB
        --,LD.MATRICULA
        ,TR.REGIONAL REGIONAL
        ,TR.ID_REGIONAL
        ,MUNICIPIO.CODIGO
        ,MUNICIPIO.NOME NOME_MUNIC
        ,(SELECT    COUNT(DISTINCT MATRICULA)
          FROM      LY_LOTACAO L1 (NOLOCK)
                    JOIN LY_FUNCAO F (NOLOCK) ON F.FUNCAO = L1.FUNCAO
          WHERE     L1.SETOR = LUE.SETOR
                    AND L1.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                    AND (L1.DATA_DESATIVACAO IS NULL OR L1.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
                    AND F.FUNCAO &lt;&gt; 10127 -- REGENTE MAIS EDUCAÇÃO
                    AND NOT EXISTS ( 
									 SELECT 1
									 FROM   LY_LICENCA_DOCENTE LLD (NOLOCK)
									 WHERE  LLD.NUM_FUNC = LD.NUM_FUNC
									 AND	LLD.DTFIM IS NULL 
									)
        )QTDE_PROF       
        ,(SELECT    COUNT(DISTINCT MATRICULA)
          FROM      LY_LOTACAO L1 (NOLOCK)
                    JOIN LY_FUNCAO F (NOLOCK) ON F.FUNCAO = L1.FUNCAO
          WHERE     L1.SETOR = LUE.SETOR
                    AND L1.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                    AND (L1.DATA_DESATIVACAO IS NULL OR L1.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
                    AND F.FUNCAO &lt;&gt; 10127 -- REGENTE MAIS EDUCAÇÃO
                    AND NOT EXISTS (
									  SELECT LP1.PESSOA 
									  FROM LY_PESSOA LP1 (NOLOCK)
									  JOIN LY_DOCENTE LD1 (NOLOCK) ON LD1.PESSOA = LP1.PESSOA
									  LEFT JOIN LY_FL_PESSOA FLP ON FLP.PESSOA = LP1.PESSOA  
									  WHERE LD1.MATRICULA = L1.MATRICULA 
									  AND (LP1.DT_NASC &lt; '1900-01-01'
									  OR LP1.DT_NASC IS NULL
									  OR LP1.NOME_COMPL IS NULL
									  OR LP1.SEXO IS NULL
									  OR LP1.NECESSIDADEESPECIALID IS NULL
									  OR LP1.ETNIA IS NULL
									  OR LP1.EST_CIVIL IS NULL
									  OR LP1.PAIS_NASC IS NULL
									  OR LP1.NACIONALIDADE IS NULL
									  OR LP1.MUNICIPIO_NASC IS NULL
									  OR LP1.ENDERECO IS NULL
									  OR LP1.END_MUNICIPIO IS NULL
									  OR LP1.CEP IS NULL
									  OR FLP.FL_FIELD_01 IS NULL
									  OR LP1.CPF IS NULL
									  OR NOT EXISTS ( 
														SELECT  1
														FROM    TCE_FORMACAO_PESSOAL FP (NOLOCK)
														WHERE   FP.PESSOA = LP1.PESSOA ))
													)
									  AND NOT EXISTS ( 
														SELECT  1
														FROM    LY_LICENCA_DOCENTE LLD (NOLOCK)
														WHERE   LLD.NUM_FUNC = LD.NUM_FUNC
														AND		LLD.DTFIM IS NULL 
													 )  
        )QTDE_CADASTRO_COMPL
        ,(SELECT    COUNT(DISTINCT MATRICULA)
          FROM      LY_LOTACAO L1 (NOLOCK)
                    JOIN LY_FUNCAO F (NOLOCK) ON F.FUNCAO = L1.FUNCAO
          WHERE     L1.SETOR = LUE.SETOR
                    AND L1.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                    AND (L1.DATA_DESATIVACAO IS NULL OR L1.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
                    AND F.FUNCAO &lt;&gt; 10127 -- REGENTE MAIS EDUCAÇÃO
                    AND EXISTS (
								  SELECT LP1.PESSOA 
								  FROM LY_PESSOA LP1 (NOLOCK)
								  JOIN LY_DOCENTE LD1 (NOLOCK) ON LD1.PESSOA = LP1.PESSOA
								   LEFT JOIN LY_FL_PESSOA FLP ON FLP.PESSOA = LP1.PESSOA  
								  WHERE LD1.MATRICULA = L1.MATRICULA 
								  AND (LP1.DT_NASC &lt; '1900-01-01'
								  OR LP1.DT_NASC IS NULL
								  OR LP1.NOME_COMPL IS NULL
								  OR LP1.SEXO IS NULL
								  OR LP1.NECESSIDADEESPECIALID IS NULL
								  OR LP1.ETNIA IS NULL
								  OR LP1.EST_CIVIL IS NULL
								  OR LP1.PAIS_NASC IS NULL
								  OR LP1.NACIONALIDADE IS NULL
								  OR LP1.MUNICIPIO_NASC IS NULL
								  OR LP1.ENDERECO IS NULL
								  OR LP1.END_MUNICIPIO IS NULL
								  OR LP1.CEP IS NULL
								  OR FLP.FL_FIELD_01 IS NULL
								  OR LP1.CPF IS NULL
								  OR LP1.BAIRRO IS NULL
								  OR LP1.END_MUNICIPIO IS NULL
								  OR LP1.END_NUM IS NULL									  
								 )
							)
								  AND NOT EXISTS ( 
													SELECT  1
													FROM    LY_LICENCA_DOCENTE LLD (NOLOCK)
													WHERE   LLD.NUM_FUNC = LD.NUM_FUNC
													AND		LLD.DTFIM IS NULL 
												 )
        )AS QTDE_PENDENCIA_ABA_DOCENTE
        ,(SELECT    COUNT(DISTINCT MATRICULA)
          FROM      LY_LOTACAO L1 (NOLOCK)
                    JOIN LY_FUNCAO F (NOLOCK) ON F.FUNCAO = L1.FUNCAO
          WHERE     L1.SETOR = LUE.SETOR
                    AND L1.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                    AND ( L1.DATA_DESATIVACAO IS NULL OR L1.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
                    AND F.FUNCAO &lt;&gt; 10127 -- REGENTE MAIS EDUCAÇÃO
                    AND EXISTS (
								  SELECT	1
								  FROM		LY_PESSOA LP1 (NOLOCK)
								  INNER		JOIN LY_DOCENTE LD1 (NOLOCK) ON LD1.PESSOA = LP1.PESSOA
								  WHERE		LD1.MATRICULA = L1.MATRICULA 
								  AND NOT	EXISTS (
														SELECT    1
														FROM      TCE_FORMACAO_PESSOAL FP (NOLOCK)
														WHERE     FP.PESSOA = LP1.PESSOA )
													)
					AND NOT EXISTS ( 
										SELECT		1
										FROM		LY_LICENCA_DOCENTE LLD (NOLOCK)
										WHERE		LLD.NUM_FUNC = LD.NUM_FUNC
										AND			LLD.DTFIM IS NULL 
									)
											  
        )AS QTDE_PENDENCIA_ABA_FORMACAO_PESSOAL
FROM    LY_DOCENTE LD (NOLOCK)
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
JOIN	LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
                    AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                    AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.SETOR = LL.SETOR
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO (NOLOCK) ON MUNICIPIO.CODIGO = LUE.MUNICIPIO
JOIN	LY_FUNCAO LF ON LF.FUNCAO = LL.FUNCAO
                     AND LF.FUNCAO &lt;&gt; 10127 -- REGENTE MAIS EDUCAÇÃO
LEFT JOIN LY_FL_PESSOA FLP ON FLP.PESSOA = LP.PESSOA
INNER JOIN HADES..VW_SETOR VS ON VS.SETOR = LUE.SETOR		
WHERE   
NOT		EXISTS ( 
						SELECT	1
						FROM	LY_LICENCA_DOCENTE LLD (NOLOCK)
						WHERE	LLD.NUM_FUNC = LD.NUM_FUNC
						AND		LLD.DTFIM IS NULL
					)
AND		(LP.DT_NASC &lt; '1900-01-01'
		OR LP.DT_NASC IS NULL
		OR LP.NOME_COMPL IS NULL
		OR LP.SEXO IS NULL
		OR LP.NECESSIDADEESPECIALID IS NULL
		OR LP.ETNIA IS NULL
		OR LP.EST_CIVIL IS NULL
		OR LP.PAIS_NASC IS NULL
		OR LP.NACIONALIDADE IS NULL
		OR LP.MUNICIPIO_NASC IS NULL
		OR LP.ENDERECO IS NULL
		OR LP.END_MUNICIPIO IS NULL
		OR LP.CEP IS NULL
		OR FLP.FL_FIELD_01 IS NULL
		OR LP.CPF IS NULL
		OR NOT EXISTS ( 
						SELECT    1
						FROM      TCE_FORMACAO_PESSOAL FP (NOLOCK)
						WHERE     FP.PESSOA = LP.PESSOA 
					  )	
		)
AND		EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
					WHERE	US.UNIDADE_ENS = LUE.UNIDADE_ENS
					AND		US.SITUACAO = 'ESTADUAL'
					AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
								(
								SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
								FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
								)
					)
AND		(LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
		
GROUP	BY VS.UA_ATUAL
		,LUE.SETOR
        ,LUE.UNIDADE_ENS
        ,LUE.NOME_COMP
        ,TR.REGIONAL
        ,TR.ID_REGIONAL
        ,MUNICIPIO.CODIGO
        ,MUNICIPIO.NOME
        ,LD.NUM_FUNC
) SQL1 
GROUP	BY SQL1.UA_ATUAL, 
		SQL1.UNIDADE_ENS,
		SQL1.ESCOLA,
		SQL1.REGIONAL,
		SQL1.CODIGO,
		SQL1.NOME_MUNIC,
		SQL1.QTDE_PROF,
		SQL1.QTDE_CADASTRO_COMPL,
		SQL1.QTDE_PENDENCIA_ABA_DOCENTE,
		SQL1.QTDE_PENDENCIA_ABA_FORMACAO_PESSOAL
ORDER	BY SQL1.ESCOLA        </CommandText>
      </Query>
      <Fields>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_PROB">
          <DataField>QTDE_PROB</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_MUNIC">
          <DataField>NOME_MUNIC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTDE_PROF">
          <DataField>QTDE_PROF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_CADASTRO_COMPL">
          <DataField>QTDE_CADASTRO_COMPL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_PENDENCIA_ABA_DOCENTE">
          <DataField>QTDE_PENDENCIA_ABA_DOCENTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_PENDENCIA_ABA_FORMACAO_PESSOAL">
          <DataField>QTDE_PENDENCIA_ABA_FORMACAO_PESSOAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
