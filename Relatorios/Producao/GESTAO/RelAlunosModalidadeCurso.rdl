    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CURSO">
            <Value>=Parameters!CURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT * FROM APOLLO..REL_ALUNO_MOD_CURSO
WHERE	(ID_REGIONAL = ISNULL(@REGIONAL, ID_REGIONAL) OR ID_REGIONAL IS NULL)
AND		(COD_MUNIC_ESCOLA = ISNULL(@MUNICIPIO, COD_MUNIC_ESCOLA) OR COD_MUNIC_ESCOLA IS NULL)
AND		(CENSO = ISNULL(@ESCOLA, CENSO) OR CENSO IS NULL)
AND		(COD_CURSO = ISNULL(@CURSO, COD_CURSO) OR COD_CURSO IS NULL)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
