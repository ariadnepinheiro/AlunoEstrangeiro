  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>20666aaf-7ebb-4c0a-87a8-c1b05ac3ce42</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_MATRICULA">
            <Value>=Parameters!ID_MATRICULA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	
	DATA,
	VAGAS, ALOCADOS, VAGAS_RESTANTES,
	CONFIRMADOS, NAO_CONFIRMADOS, 
	NAO_COMPARECERAM, 
	CONVERT(NUMERIC(10,2),(PERC_COMP_ACUM*100)) PERC_COMO_ACUM,
	CONVERT(NUMERIC(10,2),(PERC_CONF*100)) PERC_CONF,
	CONVERT(NUMERIC(10,2),(PERC_VAGAS_REST*100)) PERC_VAGAS_REST, COMP_DIA
FROM APOLLO..REL_CONF_MATRICULA_FACIL M (NOLOCK) 
WHERE ANO = @ANO
AND	 ID_MATRICULA = @ID_MATRICULA
AND		EXISTS (
				SELECT	1
				FROM	APOLLO..REL_MATRICULA_FACIL_PERIODO FP (NOLOCK)
				WHERE	FP.ANO = M.ANO
				AND		FP.ID_MATRICULA = M.ID_MATRICULA
				AND		M.DATA BETWEEN FP.DT_INICIO AND FP.DT_FIM
				)
ORDER BY DATA</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="VAGAS">
          <DataField>VAGAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALOCADOS">
          <DataField>ALOCADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VAGAS_RESTANTES">
          <DataField>VAGAS_RESTANTES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONFIRMADOS">
          <DataField>CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_CONFIRMADOS">
          <DataField>NAO_CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_COMPARECERAM">
          <DataField>NAO_COMPARECERAM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PERC_COMO_ACUM">
          <DataField>PERC_COMO_ACUM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PERC_CONF">
          <DataField>PERC_CONF</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PERC_VAGAS_REST">
          <DataField>PERC_VAGAS_REST</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="COMP_DIA">
          <DataField>COMP_DIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_MATRICULA">
            <Value>=Parameters!ID_MATRICULA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 	
	DATA,
	VAGAS, ALOCADOS, VAGAS_RESTANTES,
	CONFIRMADOS, NAO_CONFIRMADOS, 
	NAO_COMPARECERAM, 
	CONVERT(NUMERIC(10,2),(PERC_COMP_ACUM*100)) PERC_COMO_ACUM,
	CONVERT(NUMERIC(10,2),(PERC_CONF*100)) PERC_CONF,
	CONVERT(NUMERIC(10,2),(PERC_VAGAS_REST*100)) PERC_VAGAS_REST, COMP_DIA
FROM APOLLO..REL_CONF_MATRICULA_FACIL M (NOLOCK) 
WHERE ANO = @ANO -1
AND	 ID_MATRICULA = @ID_MATRICULA
AND		EXISTS (
				SELECT	1
				FROM	APOLLO..REL_MATRICULA_FACIL_PERIODO FP (NOLOCK)
				WHERE	FP.ANO = M.ANO
				AND		FP.ID_MATRICULA = M.ID_MATRICULA
				AND		M.DATA BETWEEN FP.DT_INICIO AND FP.DT_FIM
				)
ORDER BY DATA
</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="VAGAS">
          <DataField>VAGAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALOCADOS">
          <DataField>ALOCADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VAGAS_RESTANTES">
          <DataField>VAGAS_RESTANTES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CONFIRMADOS">
          <DataField>CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_CONFIRMADOS">
          <DataField>NAO_CONFIRMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NAO_COMPARECERAM">
          <DataField>NAO_COMPARECERAM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PERC_COMO_ACUM">
          <DataField>PERC_COMO_ACUM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PERC_CONF">
          <DataField>PERC_CONF</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PERC_VAGAS_REST">
          <DataField>PERC_VAGAS_REST</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="COMP_DIA">
          <DataField>COMP_DIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT ANO, ANO AS NOME 
FROM LYCEUM..LY_PERIODO_LETIVO (NOLOCK) 
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
