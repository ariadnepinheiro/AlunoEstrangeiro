  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>4ef0d4ca-f6b9-409e-9067-87cb37a9fbde</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @SEMESTRE = 1

BEGIN
SELECT	DISTINCT REGIONAL, 
		M.NOME AS MUNICIPIO,
		UE.UNIDADE_ENS AS CENSO,
		UE.NOME_COMP AS UNIDADE,
		LMC.DESCRICAO AS MODALIDADE,
		LTC.DESCRICAO AS SEGMENTO,
		LC.NOME AS CURSO,
		LS.SERIE,
		LT.TURNO, 		
		LA.ALUNO AS  MATRICULA, 
		PE.NOME_COMPL AS ALUNO
FROM	LY_ALUNO LA (NOLOCK)
INNER JOIN LY_PESSOA PE ON PE.PESSOA = LA.PESSOA
JOIN	LY_MATRICULA LM (NOLOCK) ON LM.ALUNO = LA.ALUNO
		AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
JOIN	LY_TURMA LT (NOLOCK) ON LT.ANO = LM.ANO
		AND LT.TURMA = LM.TURMA
		AND LT.SEMESTRE = LM.SEMESTRE
		AND LT.DISCIPLINA = LM.DISCIPLINA
		AND SIT_TURMA = 'ABERTA'	
		AND LT.ANO = @ANO	
		AND LT.SEMESTRE IN (0,2)
JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
		AND LS.TURNO = LT.TURNO
		AND LS.CURRICULO = LT.CURRICULO
		AND LS.SERIE = LT.SERIE
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LS.CURSO
JOIN	LY_TIPO_CURSO LTC (NOLOCK) ON LTC.TIPO = LC.TIPO
JOIN	LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE	
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	RENOVACAO R (NOLOCK) ON LA.ALUNO = R.ALUNOID
		AND R.ANO = @ANO
		AND R.DATAALTERACAO = (SELECT MAX(DATAALTERACAO) FROM RENOVACAO (NOLOCK) WHERE R.ALUNOID = RENOVACAO.ALUNOID)
		AND R.PERIODO IN  (0,1)
		AND R.SITUACAORENOVACAOID = 2
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = UE.MUNICIPIO
WHERE
(UE.ID_REGIONAL = ISNULL(@REGIONAL, UE.ID_REGIONAL) OR UE.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO) OR UE.MUNICIPIO IS NULL)
AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
AND (LT.TURNO = ISNULL(@TURNO, LT.TURNO) OR LT.TURNO IS NULL)	
AND NOT EXISTS (
					SELECT	1
					FROM	LY_H_CURSOS_CONCL H (NOLOCK)
					WHERE	H.ALUNO = LA.ALUNO
					AND		H.DT_REABERTURA IS NULL
					)
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND		NOT EXISTS (
					SELECT	1
					FROM	LY_SERIE S (NOLOCK)
					WHERE	S.CURSO = LA.CURSO
					AND		S.CURRICULO = LA.CURRICULO
					AND		S.TURNO = LA.TURNO
					AND		S.SERIE = LA.SERIE
					AND		S.ANO_SERIE_CONCLUINTE = 'S' 
					)
END

ELSE

BEGIN
SELECT	DISTINCT REGIONAL, 
		M.NOME AS MUNICIPIO,
		UE.UNIDADE_ENS AS CENSO,
		UE.NOME_COMP AS UNIDADE,
		LMC.DESCRICAO AS MODALIDADE,
		LTC.DESCRICAO AS SEGMENTO,
		LC.NOME AS CURSO,
		LS.SERIE,
		LT.TURNO, 		
		LA.ALUNO AS  MATRICULA, 
		PE.NOME_COMPL AS ALUNO
FROM	LY_ALUNO LA (NOLOCK)
INNER JOIN LY_PESSOA PE ON PE.PESSOA = LA.PESSOA
JOIN	LY_MATRICULA LM (NOLOCK) ON LM.ALUNO = LA.ALUNO
		AND SIT_MATRICULA &lt;&gt; 'CANCELADO'
JOIN	LY_TURMA LT (NOLOCK) ON LT.ANO = LM.ANO
		AND LT.TURMA = LM.TURMA
		AND LT.SEMESTRE = LM.SEMESTRE
		AND LT.DISCIPLINA = LM.DISCIPLINA
		AND SIT_TURMA = 'ABERTA'	
		AND LT.ANO = @ANO	
		AND LT.SEMESTRE IN (0,1)
JOIN	LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
		AND LS.TURNO = LT.TURNO
		AND LS.CURRICULO = LT.CURRICULO
		AND LS.SERIE = LT.SERIE
JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LS.CURSO
JOIN	LY_TIPO_CURSO LTC (NOLOCK) ON LTC.TIPO = LC.TIPO
JOIN	LY_MODALIDADE_CURSO LMC (NOLOCK) ON LMC.MODALIDADE = LC.MODALIDADE	
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	RENOVACAO R (NOLOCK) ON LA.ALUNO = R.ALUNOID
		AND R.ANO = @ANO
		AND R.DATAALTERACAO = (SELECT MAX(DATAALTERACAO) FROM RENOVACAO (NOLOCK) WHERE R.ALUNOID = RENOVACAO.ALUNOID)
		AND R.PERIODO IN  (0,2)
		AND R.SITUACAORENOVACAOID = 2
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = UE.MUNICIPIO
WHERE
(UE.ID_REGIONAL = ISNULL(@REGIONAL, UE.ID_REGIONAL) OR UE.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO) OR UE.MUNICIPIO IS NULL)
AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
AND (LT.TURNO = ISNULL(@TURNO, LT.TURNO) OR LT.TURNO IS NULL)		
AND NOT EXISTS (
					SELECT	1
					FROM	LY_H_CURSOS_CONCL H (NOLOCK)
					WHERE	H.ALUNO = LA.ALUNO
					AND		H.DT_REABERTURA IS NULL
					)
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND		NOT EXISTS (
					SELECT	1
					FROM	LY_SERIE S (NOLOCK)
					WHERE	S.CURSO = LA.CURSO
					AND		S.CURRICULO = LA.CURRICULO
					AND		S.TURNO = LA.TURNO
					AND		S.SERIE = LA.SERIE
					AND		S.ANO_SERIE_CONCLUINTE = 'S' 
					)
		
END</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT -1 ID_REGIONAL,' Selecione...' REGIONAL 
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN HADES..MUNICIPIO M1 (NOLOCK) ON M1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
ORDER BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT L1.CODIGO, L1.NOME FROM LY_UNIDADE_ENSINO L2 (NOLOCK)
JOIN HADES..MUNICIPIO L1 (NOLOCK) ON L1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..TCE_REGIONAL N1 (NOLOCK) ON N1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE 
	(N1.ID_REGIONAL = ISNULL(@REGIONAL,N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
	AND
	(JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING (UE.NOME_COMP,1,50)NOME_COMP 
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
WHERE (R.ID_REGIONAL = ISNULL(@REGIONAL, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL) 
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT ANO, ANO AS NOME 
FROM LYCEUM..LY_PERIODO_LETIVO (NOLOCK) 
WHERE ANO = YEAR(GETDATE())
</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'NULO' TURNO,' Selecione...' DESCRICAO
UNION
SELECT NULL TURNO, ' TODAS' DESCRICAO
UNION
SELECT DISTINCT LT.TURNO, LTU.DESCRICAO
FROM LY_UNIDADE_ENSINO LUE 
INNER JOIN LY_TURMA LT ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
				AND LUE.UNIDADE_ENS = @ESCOLA 
				AND LT.ANO = YEAR(GETDATE())
INNER JOIN LY_SERIE LS ON LS.CURSO = LT.CURSO
			AND LS.TURNO = LT.TURNO						
			AND LS.CURRICULO = LT.CURRICULO	
			AND LS.SERIE = LT.SERIE
INNER JOIN LY_CURSO LC ON LC.CURSO = LS.CURSO
INNER JOIN LY_TURNO LTU ON LTU.TURNO = LT.TURNO
ORDER BY DESCRICAO</CommandText>
      </Query>
      <Fields>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
