          <QueryParameter Name="@P_COORDENADORIA">
            <Value>=Parameters!P_COORDENADORIA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_UNIDADE">
            <Value>=Parameters!P_UNIDADE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--VERIFICANDO SE A DATA DE NASCIMENTO É NULA
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO --order by UE.NUCLEO
WHERE DT_NASC IS NULL 
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE

UNION 

--VERIFICANDO SE O ENDEREÇO É NULO
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE P.ENDERECO IS NULL
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE

UNION

--VERIFICANDO SE O NOME DA MÃE É NULO
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE NOME_MAE IS NULL
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE

UNION

--VERIFICANDO SE O NOME DO PAI É NULO
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE NOME_PAI IS NULL
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE

UNION

--VERIFICANDO SE O NOME TEM MENOS DE 7 CARACTERES
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE LEN(P.NOME_COMPL) &lt;= '7'
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE

UNION

--VERIFICANDO SE O ENDEREÇO TEM MENOS DE 1 CARACTER
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE LEN(P.ENDERECO) &lt;= '1'
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE

UNION

--VERIFICANDO SE O NUMERO TEM MENOS DE 1 CARACTER
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE LEN(P.END_NUM) &lt; '1'
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE


UNION

--VERIFICANDO SE EXISTE NUMEROS OU CARACTERES ESPECIAIS NO NOME DO ALUNO
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE P.NOME_COMPL LIKE '%[123456789~!@#$%^&amp;=+?*()]%' 
AND UE.ID_REGIONAL = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE

UNION

--VERIFICANDO SE EXISTE NUMEROS OU CARACTERES ESPECIAIS NO NOME DO PAI
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE P.NOME_PAI LIKE '%[123456789~!@#$%^&amp;=+?*()]%' 
AND UE.NUCLEO = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE


UNION

--VERIFICANDO SE EXISTE NUMEROS OU CARACTERES ESPECIAIS NO NOME DA MÃE
SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA, UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
UE.SETOR AS UA, A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE,
A.TURNO, M.TURMA, A.ALUNO, P.NOME_COMPL, P.NOME_PAI, P.NOME_MAE, P.DT_NASC, P.ENDERECO, P.END_NUM, P.END_COMPL, P.BAIRRO,
(SELECT NOME FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_MUNICIPIO, P.CEP, 
(SELECT UF_SIGLA FROM MUNICIPIO WHERE P.END_MUNICIPIO = CODIGO) AS END_UF
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
				INNER JOIN LY_PESSOA P ON P.PESSOA = A.PESSOA
				INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO 
WHERE P.NOME_MAE LIKE '%[123456789~!@#$%^&amp;=+?*()]%' 
AND UE.NUCLEO = @P_COORDENADORIA
AND UE.MUNICIPIO = @P_MUNICIPIO
AND UE.UNIDADE_ENS = @P_UNIDADE</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
