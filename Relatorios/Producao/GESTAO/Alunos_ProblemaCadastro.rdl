    <DataSet Name="ds_Municipio">
      <Query>
        <DataSourceName>DS_Registro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_COORDENADORIA">
            <Value>=Parameters!P_COORDENADORIA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
WHERE UE.ID_REGIONAL = @P_COORDENADORIA
ORDER BY MUNICIPIO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="COD_MUNICIPIO">
          <DataField>COD_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Coordenadoria">
      <Query>
        <DataSourceName>DS_Registro</DataSourceName>
        <CommandText>SELECT DISTINCT ID_REGIONAL, REGIONAL
FROM  TCE_REGIONAL 
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Unidade">
      <Query>
        <DataSourceName>DS_Registro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT A.UNIDADE_ENSINO, UE.NOME_COMP AS UNIDADE
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
				INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
WHERE UE.MUNICIPIO = @P_MUNICIPIO
ORDER BY UE.NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENSINO">
          <DataField>UNIDADE_ENSINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
