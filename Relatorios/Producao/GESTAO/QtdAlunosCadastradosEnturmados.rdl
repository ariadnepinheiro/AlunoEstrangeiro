        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QTD_TURMA">
          <DataField>QTD_TURMA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ATIVO">
          <DataField>ATIVO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MATRICULADO">
          <DataField>MATRICULADO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_Qtd_Alunos</DataSourceName>
        <CommandText>
SELECT NUCLEO, 
COORDENADORIA, 
COD_MUNICIPIO,
MUNICIPIO, 
UA, 
UNIDADE_ENSINO, 
UNIDADE,
ESCOLARIDADE, 
NIVEL_ESCOLARIDADE, 
MODALIDADE, 
SERIE, 
TURNO, 
COUNT(TURMA) AS QTD_TURMA, 
SUM(ATIVO) AS ATIVO, 
SUM(MATRICULADO) AS MATRICULADO
FROM (SELECT  NUCLEO, 
	  COORDENADORIA, 
	  COD_MUNICIPIO, 
	  MUNICIPIO, 
	  UA, 
	  UNIDADE, 
	  ESCOLARIDADE, 
	  NIVEL_ESCOLARIDADE, 
	  MODALIDADE,
	  UNIDADE_ENSINO, 
	  SERIE, 
	  TURNO, 
	  TURMA, 
	  COUNT(SIT_ALUNO) AS ATIVO, 
	  0 MATRICULADO--, SIT_MATRICULA, COUNT(*)
	  FROM ( SELECT DISTINCT UE.NUCLEO, 
			  N.DESCRICAO AS COORDENADORIA, 
			  UE.MUNICIPIO COD_MUNICIPIO,
			  (SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
			  VS.UA_ATUAL AS UA, 
			  A.UNIDADE_ENSINO, 
			  UE.NOME_COMP AS UNIDADE,
			  C.NOME AS ESCOLARIDADE, 
			  TC.DESCRICAO AS NIVEL_ESCOLARIDADE, 
			  MC.DESCRICAO AS MODALIDADE,
			  A.SERIE,
			  A.TURNO, 
			  A.SIT_ALUNO,
			  M.SIT_MATRICULA, 
			  A.ALUNO, 
			  M.TURMA
			FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
							INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
							INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO
							INNER JOIN LY_CURSO C ON C.CURSO = A.CURSO
							LEFT JOIN LY_MODALIDADE_CURSO MC ON MC.MODALIDADE = C.MODALIDADE
							LEFT JOIN LY_TIPO_CURSO TC ON TC.TIPO = MC.TIPO		
							INNER JOIN HADES..VW_SETOR VS ON VS.SETOR = UE.SETOR		
			WHERE UE.NUCLEO = @P_COORDENADORIA
			AND UE.MUNICIPIO = @P_MUNICIPIO
			AND UE.UNIDADE_ENS = @P_UNIDADE 
			AND A.SIT_ALUNO = 'ATIVO'

				)X
		GROUP BY NUCLEO, COORDENADORIA, COD_MUNICIPIO,MUNICIPIO, UA, UNIDADE_ENSINO, UNIDADE,ESCOLARIDADE, 
		NIVEL_ESCOLARIDADE, MODALIDADE, SERIE, TURNO, TURMA
	 UNION

	 SELECT NUCLEO, 
	  COORDENADORIA, 
	  COD_MUNICIPIO, 
	  MUNICIPIO, 
	  UA, 
	  UNIDADE, 
	  ESCOLARIDADE, 
	  NIVEL_ESCOLARIDADE, 
	  MODALIDADE,
	  UNIDADE_ENSINO, 
	  SERIE, 
	  TURNO, 
	 TURMA, 0 AS ATIVO, 
	 COUNT(*) AS MATRICULADO
	 FROM (	SELECT DISTINCT UE.NUCLEO, 
			  N.DESCRICAO AS COORDENADORIA, 
			  UE.MUNICIPIO COD_MUNICIPIO,
			  (SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO, 
			  VS.UA_ATUAL AS UA, 
			  A.UNIDADE_ENSINO, 
			  UE.NOME_COMP AS UNIDADE,
			  C.NOME AS ESCOLARIDADE, 
			  TC.DESCRICAO AS NIVEL_ESCOLARIDADE, 
			  MC.DESCRICAO AS MODALIDADE,
			  A.SERIE,
			  A.TURNO, 
			  A.SIT_ALUNO,
			  M.SIT_MATRICULA, 
			  A.ALUNO, 
			  M.TURMA
			FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
							INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
							INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO
							INNER JOIN LY_CURSO C ON C.CURSO = A.CURSO
							LEFT JOIN LY_MODALIDADE_CURSO MC ON MC.MODALIDADE = C.MODALIDADE
							LEFT JOIN LY_TIPO_CURSO TC ON TC.TIPO = MC.TIPO		
							INNER JOIN HADES..VW_SETOR VS ON VS.SETOR = UE.SETOR			
			WHERE UE.NUCLEO = @P_COORDENADORIA
			AND UE.MUNICIPIO = @P_MUNICIPIO
			AND UE.UNIDADE_ENS = @P_UNIDADE 
			AND A.SIT_ALUNO = 'ATIVO'
				)X
		WHERE SIT_MATRICULA = 'MATRICULADO'
		GROUP BY NUCLEO, COORDENADORIA, COD_MUNICIPIO,MUNICIPIO, UA, UNIDADE_ENSINO, UNIDADE,ESCOLARIDADE, 
		NIVEL_ESCOLARIDADE, MODALIDADE, SERIE, TURNO, TURMA
		) X2
GROUP BY NUCLEO, COORDENADORIA, COD_MUNICIPIO,MUNICIPIO, UA, UNIDADE_ENSINO, UNIDADE,ESCOLARIDADE, NIVEL_ESCOLARIDADE, MODALIDADE, SERIE, TURNO
</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_COORDENADORIA">
            <Value>=Parameters!P_COORDENADORIA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_UNIDADE">
            <Value>=Parameters!P_UNIDADE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ds_Unidade">
      <Fields>
        <Field Name="UNIDADE_ENSINO">
          <DataField>UNIDADE_ENSINO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_Qtd_Alunos</DataSourceName>
        <CommandText>SELECT DISTINCT
A.UNIDADE_ENSINO, 
UE.NOME_COMP AS UNIDADE
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
			INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
			INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO
WHERE UE.MUNICIPIO = @P_MUNICIPIO
ORDER BY UE.NOME_COMP</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ds_Municipio">
      <Fields>
        <Field Name="COD_MUNICIPIO">
          <DataField>COD_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_Qtd_Alunos</DataSourceName>
        <CommandText>SELECT DISTINCT
UE.MUNICIPIO COD_MUNICIPIO,
(SELECT NOME FROM MUNICIPIO WHERE UE.MUNICIPIO = CODIGO) AS MUNICIPIO
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
			INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
			INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO
WHERE UE.NUCLEO = @P_COORDENADORIA
ORDER BY MUNICIPIO</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_COORDENADORIA">
            <Value>=Parameters!P_COORDENADORIA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ds_Coordenadoria">
      <Fields>
        <Field Name="NUCLEO">
          <DataField>NUCLEO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DS_Qtd_Alunos</DataSourceName>
        <CommandText>SELECT DISTINCT UE.NUCLEO, N.DESCRICAO AS COORDENADORIA
FROM LY_ALUNO A	INNER JOIN LY_MATRICULA M ON A.ALUNO = M.ALUNO
		INNER JOIN LY_UNIDADE_ENSINO UE ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
		INNER JOIN LY_NUCLEO N ON N.NUCLEO = UE.NUCLEO
ORDER BY DESCRICAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
