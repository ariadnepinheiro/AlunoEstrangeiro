  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>86c52f8c-2e98-4034-adf0-72ff6971ce88</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
        N.REGIONAL ,
        VS.UA_ANTIGA AS SETOR ,
		VS.UA_ATUAL  ,
        UE.UNIDADE_ENS ,
        UE.NOME_COMP ,
        T.DESCRICAO AS DESC_TURNO ,
        D.MATRICULA ,
        PE.NOME_COMPL ,
        PE.CPF,
		D.VINCULO,
		PE.IDFUNCIONAL,
		(convert(varchar,PE.IDFUNCIONAL) + '/' + convert(varchar,D.VINCULO)) AS IDVINCULO
FROM    LY_DOCENTE D
		INNER JOIN LY_PESSOA PE ON PE.PESSOA = D.PESSOA
        INNER JOIN LY_AULA_DOCENTE AU ON AU.NUM_FUNC = D.NUM_FUNC
        INNER JOIN LY_UNIDADE_ENSINO UE ON AU.FACULDADE = UE.UNIDADE_ENS
        INNER JOIN dbo.TCE_REGIONAL N ON N.ID_REGIONAL = UE.ID_REGIONAL
        INNER JOIN LY_TURNO T ON T.TURNO = AU.TURNO
        JOIN HADES..VW_SETOR VS ON VS.SETOR = UE.SETOR
WHERE    AU.FACULDADE = @ESCOLA
        AND AU.TURNO = ISNULL(@TURNO, AU.TURNO)
        AND D.MATRICULA NOT IN ( '00000000', '11111111', '22222222',
                                 '44444444', '55555555', '66666666',
                                 '77777777', '88888888', '99999999' )
        AND AU.ANO = @ANO
ORDER BY N.REGIONAL ,
        VS.UA_ATUAL ,
        UE.UNIDADE_ENS ,
        UE.NOME_COMP ,
        T.DESCRICAO ,
        PE.NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_ATUAL">
          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="desc_turno">
          <DataField>DESC_TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VINCULO">
          <DataField>VINCULO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="IDFUNCIONAL">
          <DataField>IDFUNCIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="IDVINCULO">
          <DataField>IDVINCULO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@USUARIO">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL AS ID_REGIONAL,' TODAS' AS REGIONAL 
UNION
SELECT R.ID_REGIONAL,SUBSTRING(R.REGIONAL,1,35) FROM LY_UNIDADE_ENSINO  L2
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = L2.ID_REGIONAL
JOIN LY_USUARIO_UNIDADE_FIS JJ ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@USUARIO,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="munic">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
        L1.codigo ,
        L1.nome
FROM    LY_UNIDADE_ENSINO l2
        JOIN municipio l1 ON l1.CODIGO = l2.MUNICIPIO
        JOIN dbo.TCE_REGIONAL r1 ON r1.ID_REGIONAL = l2.ID_REGIONAL
        JOIN LY_USUARIO_UNIDADE_FIS jj ON jj.UNIDADE_FIS = l2.UNIDADE_ENS
WHERE   ( r1.ID_REGIONAL = ISNULL(@REGIONAL, r1.ID_REGIONAL)
          OR r1.ID_REGIONAL IS NULL
        )
        AND ( jj.USUARIO = ISNULL(@usuario, jj.USUARIO)
              OR jj.USUARIO IS NULL
            )
UNION
SELECT  NULL codigo ,
        ' TODOS' nome
UNION
SELECT  'NULO' codigo ,
        ' Selecione...' descricao
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.ID_REGIONAL = ISNULL(@REGIONAL,ue.ID_REGIONAL) or ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ano">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct ano from ly_turma</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ano">
          <DataField>ano</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Turno">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null cod_turno,' TODOS' desc_turno
union
select 'NULO' cod_turno,' Selecione...'  desc_turno
union
Select Mnemonico cod_turno, Descricao  desc_turno
from Ly_turno
Order by desc_turno</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="cod_turno">
          <DataField>cod_turno</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="desc_turno">
          <DataField>desc_turno</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
