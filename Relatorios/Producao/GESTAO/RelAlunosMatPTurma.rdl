  <DataSources>
    <DataSource Name="LYCEUM">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3026eee8-b6eb-4a78-b97b-7e4085061b5b</rd:DataSourceID>
    </DataSource>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>d1c38791-ae0f-4c79-8d9e-a8ebb9c3810e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Dataset1">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURMA">
            <Value>=Parameters!TURMA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT LA.ALUNO MATRICULA,
		PE.NOME_COMPL ALUNO,
		LT.TURMA TURMA_PRINCIPAL,
		CASE WHEN LM.DEPENDENCIA = 'S' THEN 'MATRICULADO - DEPENDÊNCIA' ELSE UPPER (LM.SIT_MATRICULA) END SITUACAO,
		(
		UPPER ((SELECT	STUFF(
					(SELECT DISTINCT ' / ' + LD.NOME
						FROM LY_MATRICULA M (NOLOCK)
						JOIN LY_TURMA T (NOLOCK) ON T.TURMA = M.TURMA 
								AND T.ANO = M.ANO 
								AND T.DISCIPLINA = M.DISCIPLINA 
								AND T.SEMESTRE = M.SEMESTRE
								AND T.SIT_TURMA = 'ABERTA'
								AND T.ANO = @ANO
								AND T.SEMESTRE = @SEMESTRE
						JOIN LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = ISNULL(T.DISCIPLINA_MULTIPLA, T.DISCIPLINA)
						WHERE M.ALUNO = LM.ALUNO
						AND	M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
						AND M.DEPENDENCIA = 'S'
						FOR XML PATH ('')), 1, 3, '')))
		) DISCIPLINAS_PROGRESSAO,
		(SELECT	STUFF(
				(SELECT DISTINCT ' / ' + M.TURMA
					FROM LY_MATRICULA M (NOLOCK)
					WHERE M.ALUNO = LM.ALUNO
					AND	M.SIT_MATRICULA &lt;&gt; 'CANCELADO'
					AND M.DEPENDENCIA = 'S'
					AND M.ANO = @ANO
					AND M.SEMESTRE = @SEMESTRE
					FOR XML PATH ('')), 1, 3, '') 
		)TURMAS_PROGRESSAO
FROM	LY_ALUNO LA (NOLOCK)
JOIN LY_PESSOA PE ON PE.PESSOA = LA.PESSOA
JOIN	LY_MATRICULA LM (NOLOCK) ON LM.ALUNO = LA.ALUNO
				AND LM.SIT_MATRICULA &lt;&gt; 'CANCELADO'
				AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
				AND ISNULL(LM.CONCOMITANTE, 'N') = 'N'
				AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
				AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
JOIN	LY_TURMA LT (NOLOCK) ON LT.TURMA = LM.TURMA
				AND	LT.DISCIPLINA = LM.DISCIPLINA
				AND	LT.ANO = LM.ANO
				AND LT.SEMESTRE = LM.SEMESTRE
				AND LT.SIT_TURMA = 'ABERTA'
				AND LT.CURSO &lt;&gt; '9999.99'
				AND LT.ANO = @ANO  
				AND LT.SEMESTRE = @SEMESTRE
				AND LT.TURMA = @TURMA				
				AND ISNULL(LT.ELETIVA, 'N') = 'N'
UNION
SELECT	DISTINCT LA.ALUNO MATRICULA,
		PE.NOME_COMPL ALUNO,
		LT.TURMA TURMA_PRINCIPAL,
		UPPER (LM.SIT_MATRICULA) AS SITUACAO,
		NULL AS DISCIPLINAS_PROGRESSAO,
		NULL AS TURMAS_PROGRESSAO
FROM	LY_ALUNO LA (NOLOCK)
JOIN LY_PESSOA PE ON PE.PESSOA = LA.PESSOA
JOIN	LY_MATRICULA LM (NOLOCK) ON LM.ALUNO = LA.ALUNO
				AND LM.SIT_MATRICULA &lt;&gt; 'CANCELADO'
				AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
				AND ISNULL(LM.CONCOMITANTE, 'N') = 'N'
				AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
				AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
JOIN	LY_TURMA LT (NOLOCK) ON LT.TURMA = LM.TURMA
				AND	LT.DISCIPLINA = LM.DISCIPLINA
				AND	LT.ANO = LM.ANO
				AND LT.SEMESTRE = LM.SEMESTRE
				AND LT.SIT_TURMA = 'ABERTA'
				AND LT.CURSO &lt;&gt; '9999.99'
				AND LT.ANO = @ANO  
				AND LT.SEMESTRE = @SEMESTRE
				AND LT.TURMA = @TURMA				
				AND ISNULL(LT.ELETIVA, 'S') = 'S'
				AND LT.TURMAREFERENCIA IS NOT NULL
ORDER BY SITUACAO, ALUNO</CommandText>
      </Query>
      <Fields>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ALUNO">
          <DataField>ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA_PRINCIPAL">
          <DataField>TURMA_PRINCIPAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINAS_PROGRESSAO">
          <DataField>DISCIPLINAS_PROGRESSAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMAS_PROGRESSAO">
          <DataField>TURMAS_PROGRESSAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	0 ID_REGIONAL, ' Selecione...' REGIONAL 
UNION
SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) 
FROM	TCE_REGIONAL TR (NOLOCK)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 

ORDER	BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	'NULO' CODIGO,' Selecione...' NOME
UNION
SELECT	DISTINCT M.CODIGO, M.NOME 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	TR.ID_REGIONAL = @REGIONAL
AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL)

ORDER	BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	'NULO' UNIDADE_ENS, ' Selecione...' ESCOLA 
UNION
SELECT	LUE.UNIDADE_ENS, SUBSTRING (LUE.NOME_COMP,1,50) ESCOLA 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK) 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	TR.ID_REGIONAL = @REGIONAL
AND		LUE.MUNICIPIO = @MUNICIPIO
AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL) 
AND		EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER	BY ESCOLA</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>
SELECT    0 ANO, ' Selecione...' NOME
UNION
SELECT	DISTINCT CONVERT (VARCHAR(4), ANO) ANO, CONVERT (VARCHAR(4), ANO) NOME 
FROM	LY_PERIODO_LETIVO (NOLOCK) 
WHERE	ANO = YEAR(GETDATE())
ORDER	BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURMA">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT  ' Selecione...' TURMA
UNION
SELECT	DISTINCT LT.TURMA 
FROM	LY_TURMA LT (NOLOCK) 
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
WHERE	LUE.UNIDADE_ENS = @ESCOLA
AND		LT.ANO = @ANO
AND		LT.SEMESTRE = @SEMESTRE
AND		SIT_TURMA = 'ABERTA'
ORDER	BY TURMA</CommandText>
      </Query>
      <Fields>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
