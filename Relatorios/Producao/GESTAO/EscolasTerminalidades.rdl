        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="municipio">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <Prompt>MUNICÍPIO</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Municipio</DataSetName>
          <ValueField>codigo</ValueField>
          <LabelField>nome</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="escola">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>UNIDADE ESCOLAR</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Escola</DataSetName>
          <ValueField>UNIDADE_ENS</ValueField>
          <LabelField>NOME_COMP</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="ano">
      <DataType>String</DataType>
      <DefaultValue>
        <DataSetReference>
          <DataSetName>Ano</DataSetName>
          <ValueField>ANO</ValueField>
        </DataSetReference>
      </DefaultValue>
