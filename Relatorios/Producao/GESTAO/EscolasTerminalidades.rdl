  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT NULL ID_REGIONAL, 'SELECIONE...' REGIONAL 
UNION 
SELECT ID_REGIONAL, REGIONAL 
FROM TCE_REGIONAL 
ORDER BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@regional">
            <Value>=Parameters!regional.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL CODIGO, 'TODOS' NOME 
UNION 
SELECT DISTINCT L1.CODIGO, L1.NOME 
FROM LY_UNIDADE_ENSINO L2 
JOIN MUNICIPIO L1 ON L1.CODIGO = L2.MUNICIPIO 
JOIN TCE_REGIONAL N1 ON N1.ID_REGIONAL = L2.ID_REGIONAL 
JOIN LY_USUARIO_UNIDADE_FIS JJ ON JJ.UNIDADE_FIS = L2.UNIDADE_ENS
WHERE 1 = 1 
AND (N1.ID_REGIONAL = ISNULL(@regional, N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
AND (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) </CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@regional">
            <Value>=Parameters!regional.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING(UE.NOME_COMP,1,50) NOME_COMP 
FROM LY_UNIDADE_ENSINO UE JOIN LY_USUARIO_UNIDADE_FIS GG ON GG.UNIDADE_FIS = UE.UNIDADE_ENS 
WHERE 1 = 1 
and (UE.ID_REGIONAL = ISNULL(@regional, UE.ID_REGIONAL) OR UE.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@municipio, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.USUARIO) OR GG.USUARIO IS NULL)
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURNOS">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@regional">
            <Value>=Parameters!regional.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ano">
            <Value>=Parameters!ano.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	N.REGIONAL, 
	MM.NOME MUNICIPIO, 
	UE.UNIDADE_ENS CENSO, 
	UE.NOME_COMP ESCOLA, 
	MC.DESCRICAO MODALIDADE, 
	TC.DESCRICAO SEGMENTO, 
	T.SERIE_MENOR SERIE, 
	COUNT(T.TURMA+STR(T.ANO)+STR(T.SEMESTRE)) QTDE_TURMAS, 
	SUM(QTDE_ALUNOS) QTDE_ALUNO 
FROM LY_UNIDADE_ENSINO UE (NOLOCK) 
	JOIN TCE_REGIONAL N (NOLOCK) ON N.ID_REGIONAL = UE.ID_REGIONAL 
	JOIN MUNICIPIO MM (NOLOCK) ON MM.CODIGO = UE.MUNICIPIO 
	JOIN APOLLO..REL_TURMAS_ALUNOS T ON T.UNIDADE_ENS = UE.UNIDADE_ENS 
	JOIN LY_CURSO C (NOLOCK) ON C.CURSO = T.CURSO 
	JOIN LY_MODALIDADE_CURSO MC (NOLOCK) ON MC.MODALIDADE = C.MODALIDADE 
	JOIN LY_TIPO_CURSO TC (NOLOCK) ON TC.TIPO = C.TIPO 
WHERE 1 = 1 
	AND C.MODALIDADE IN ('RE1','ED2')
	AND	C.CURSO NOT IN ('0001.17','0001.27','0002.37','0000.01')
	AND T.SERIE_MENOR NOT IN (6, 1)
	AND	T.SERIE = T.SERIE_MENOR
	AND	T.ANO = @ano 
	AND	(N.ID_REGIONAL = ISNULL(@regional, N.ID_REGIONAL) OR N.ID_REGIONAL IS NULL) 
	AND	(MM.CODIGO = ISNULL(@municipio,  MM.CODIGO) OR MM.CODIGO IS NULL) 
	AND	(UE.UNIDADE_ENS = ISNULL(@escola,UE.UNIDADE_ENS) OR UE.UNIDADE_ENS IS NULL)
GROUP BY 
	N.REGIONAL, 
	MM.NOME, 
	UE.UNIDADE_ENS, 
	UE.NOME_COMP, 
	MC.DESCRICAO, 
	TC.DESCRICAO, 
	T.SERIE_MENOR</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_TURMAS">
          <DataField>QTDE_TURMAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTDE_ALUNO">
          <DataField>QTDE_ALUNO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Ano">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO 
FROM 	LY_PERIODO_LETIVO
WHERE 	ANO &lt;= YEAR(GETDATE())
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="usuario">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>usuario</Prompt>
      <Hidden>true</Hidden>
    </ReportParameter>
    <ReportParameter Name="regional">
      <DataType>String</DataType>
      <Prompt>REGIONAL</Prompt>
      <ValidValues>
