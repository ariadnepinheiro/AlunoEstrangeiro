  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3026eee8-b6eb-4a78-b97b-7e4085061b5b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Dataset1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT TR.REGIONAL AS 'REGIONAL',
				HME.NOME AS 'MUNICIPIO ESCOLA',
				LUE.UNIDADE_ENS AS 'CENSO',				
				LUE.NOME_COMP AS 'UNIDADE ESCOLA',
				CONVERT (CHAR(11), ISNULL (LP.CPF, '')) AS 'CPF',
				CONVERT (CHAR(10), LP.DT_NASC, 103)AS 'DATA DE NASCIMENTO',
				ISNULL (LP.RG_NUM, '') AS 'IDENTIDADE',
				ISNULL (LP.RG_EMISSOR, '') AS 'ORGAO EXPEDIDOR',
				ISNULL (CONVERT (CHAR(10), LP.RG_DTEXP, 103), '') AS 'DATA EXPEDICAO',
				LA.ALUNO AS 'MATRICULA',
				LP.NOME_COMPL AS 'NOME DO ALUNO',
				ISNULL (LP.NOME_MAE, '') AS 'NOME DA MAE',
				ISNULL (LP.SEXO, '') AS 'SEXO',
				LP.ENDERECO AS 'ENDERECO', 
				ISNULL (LP.END_NUM, '') AS 'NUMERO',
				ISNULL (LP.END_COMPL, '') AS 'COMPLEMENTO',
				ISNULL (LP.BAIRRO, '') AS 'BAIRRO',
				HM.NOME AS 'MUNICIPIO',
				LP.CEP AS 'CEP',
				HM.UF_SIGLA AS 'UF',
				ISNULL (LP.FONE, '') AS 'TELEFONE',
				ISNULL (LP.CELULAR, '') AS 'CELULAR',
				LA.SERIE AS 'SERIE',
				CONVERT (CHAR(10), GETDATE(), 103) AS DATA_ATUAL,			
				DATEDIFF(YEAR, LP.DT_NASC, SYSDATETIME()) AS IDADE

FROM LY_ALUNO LA (NOLOCK)
INNER JOIN LY_MATRICULA LM (NOLOCK) ON LA.ALUNO = LM.ALUNO 
			AND LM.SIT_MATRICULA &lt;&gt; 'CANCELADO'
          INNER JOIN LY_PESSOA LP (NOLOCK) ON LA.PESSOA = LP.PESSOA
          INNER JOIN LY_TURMA LT (NOLOCK) ON LT.TURMA = LM.TURMA
          AND	LT.DISCIPLINA = LM.DISCIPLINA
          AND	LT.ANO = LM.ANO
          AND LT.SEMESTRE = LM.SEMESTRE
          AND LT.SIT_TURMA = 'ABERTA'
          AND LT.ANO = YEAR(GETDATE())
          INNER JOIN LY_SERIE LS (NOLOCK) ON LS.CURSO = LT.CURSO
          AND LS.TURNO = LT.TURNO
          AND LS.CURRICULO = LT.CURRICULO
          AND LS.SERIE = LT.SERIE
          AND (LS.CURSO = '0003.31' or (ls.CURSO= '003.32' and ls.SERIE=4)) -- CURSO NORMAL e INDIGENA 4º MODULO

          INNER JOIN LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
          INNER JOIN LY_UNIDADE_ENSINO_SITUACAO LUES (NOLOCK) ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
          AND LUES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
          FROM LY_UNIDADE_ENSINO_SITUACAO UES (NOLOCK)
          WHERE LUE.UNIDADE_ENS = UES.UNIDADE_ENS)
          AND (LUE.SIT_FUNCIONAMENTO = 'EmAtividade' OR LUE.SIT_FUNCIONAMENTO IS NULL)
          AND LUES.SITUACAO = 'ESTADUAL'
          -- FILTROS
          AND LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS)
          AND LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO)
          AND LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL)

          INNER JOIN TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
          INNER JOIN HADES..MUNICIPIO HM (NOLOCK) ON LP.END_MUNICIPIO = HM.CODIGO --MUN_ALUNO
          LEFT JOIN HADES..MUNICIPIO HME (NOLOCK) ON LUE.MUNICIPIO = HME.CODIGO --MUN_ESCOLA

          WHERE
          LA.ALUNO NOT IN (SELECT LHCC.ALUNO FROM LY_H_CURSOS_CONCL LHCC (NOLOCK) WHERE LHCC.DT_REABERTURA IS NULL)
        </CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO_ESCOLA">
          <DataField>MUNICIPIO ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ESCOLA">
          <DataField>UNIDADE ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_DE_NASCIMENTO">
          <DataField>DATA DE NASCIMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IDENTIDADE">
          <DataField>IDENTIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ORGAO_EXPEDIDOR">
          <DataField>ORGAO EXPEDIDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_EXPEDICAO">
          <DataField>DATA EXPEDICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DO_ALUNO">
          <DataField>NOME DO ALUNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DA_MAE">
          <DataField>NOME DA MAE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEXO">
          <DataField>SEXO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ENDERECO">
          <DataField>ENDERECO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COMPLEMENTO">
          <DataField>COMPLEMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BAIRRO">
          <DataField>BAIRRO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CEP">
          <DataField>CEP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UF">
          <DataField>UF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TELEFONE">
          <DataField>TELEFONE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CELULAR">
          <DataField>CELULAR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA_ATUAL">
          <DataField>DATA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IDADE">
          <DataField>IDADE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT	0 ID_REGIONAL,' Selecione...' REGIONAL
UNION
SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) REGIONAL
FROM	TCE_REGIONAL TR (NOLOCK)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER	BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	DISTINCT M.CODIGO, M.NOME 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL) OR TR.ID_REGIONAL IS NULL)
AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
UNION
SELECT	NULL CODIGO,' TODOS' NOME
UNION
SELECT	'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER	BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT	NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT	LUE.UNIDADE_ENS, SUBSTRING (LUE.NOME_COMP,1,50) NOME_COMP 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK) 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND LUES.DT_SITUACAO = (
										SELECT	MAX(DT_SITUACAO)
										FROM	LY_UNIDADE_ENSINO_SITUACAO L1 
										WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS)
										AND		(SIT_FUNCIONAMENTO = 'EmAtividade' OR SIT_FUNCIONAMENTO IS NULL
										)
WHERE	(LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL) 
ORDER	BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
