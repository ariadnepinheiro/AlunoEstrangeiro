  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>229031ba-5c11-4e90-a47d-c1621f78e578</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, 
		UE.NOME_COMP UNIDADE, MC.DESCRICAO MODALIDADE, 
		TC.DESCRICAO SEGMENTO, C.CURSO COD_CURSO, C.NOME CURSO, T.SERIE, 
		T.TURNO, T.VAGAS_LIBERADAS, 
		(SELECT		COUNT(DISTINCT CC.ALUNO) 
		FROM	TCE_CONFIRMACAO_MATRICULA CC (NOLOCK)
		JOIN	LY_ALUNO AA (NOLOCK)
		ON		AA.ALUNO = CC.ALUNO
		WHERE	CC.CENSO = T.CENSO
		AND		CC.TURNO = T.TURNO
		AND		CC.CURSO = T.CURSO
		AND		CC.SERIE = T.SERIE
		AND		CC.ANO = T.ANO
		AND		(CC.STATUS = 'Confirmado'
		OR 		CC.STATUS IS NULL)
		AND		AA.SIT_ALUNO = 'Ativo'
		) VAGAS_CONFIRMADAS
FROM	TCE_CONTROLE_VAGA T (NOLOCK)
JOIN	LY_CURSO C (NOLOCK)
ON		T.CURSO = C.CURSO 
JOIN	LY_MODALIDADE_CURSO MC (NOLOCK)
ON		MC.MODALIDADE = C.MODALIDADE
JOIN	LY_TIPO_CURSO TC (NOLOCK)
ON		TC.TIPO = C.TIPO
JOIN	LY_UNIDADE_ENSINO UE (NOLOCK)
ON		UE.UNIDADE_ENS = T.CENSO
JOIN	HADES..TCE_MUNICIPIO M (NOLOCK)
ON		M.ID_MUNICIPIO = UE.MUNICIPIO
JOIN	TCE_REGIONAL R (NOLOCK)
ON		R.ID_REGIONAL = UE.ID_REGIONAL
WHERE	EXISTS (
				SELECT	1 
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20), DT_SITUACAO) IN 
																			(
																			SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20), MAX(DT_SITUACAO))
																			FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK)
																			GROUP BY UNIDADE_ENS
																			)
				)
AND		(UE.ID_REGIONAL = ISNULL(@COORD, UE.ID_REGIONAL) OR
  UE.ID_REGIONAL IS NULL) AND (UE.MUNICIPIO = ISNULL(@MUNIC, UE.MUNICIPIO) OR
  UE.MUNICIPIO IS NULL) AND (UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) OR
  UE.UNIDADE_ENS IS NULL) 
AND		T.ANO = @ANO  
AND 	T.CURSO NOT IN ('0002.37','0001.27')</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CURSO">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGMENTO">
          <DataField>SEGMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COD_CURSO">
          <DataField>COD_CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SERIE">
          <DataField>SERIE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VAGAS_LIBERADAS">
          <DataField>VAGAS_LIBERADAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VAGAS_CONFIRMADAS">
          <DataField>VAGAS_CONFIRMADAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null nucleo,' TODAS' descricao 
union
select 'NULO' nucleo,' Selecione...' descricao 
union
select  convert(varchar(10),l1.id_regional),SUBSTRING(l1.regional,1,35) from tce_regional L1
join LY_UNIDADE_ENSINO l2 on L1.id_regional=l2.id_regional
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null codigo,' TODOS' nome  
union
select 'NULO' ,' Selecione...'  
union
select distinct convert(varchar(10), L1.id_municipio), L1.nome from LY_UNIDADE_ENSINO l2
join hades..tce_municipio l1 on l1.id_municipio=l2.MUNICIPIO
join tce_regional n1 on n1.id_regional=l2.id_regional
where 
	(convert(varchar(10), n1.id_regional) = ISNULL(@COORD,n1.id_regional)or n1.id_regional is null)
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.id_regional = ISNULL(@COORD,ue.id_regional) or ue.id_regional is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
