      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select M.* , GETDATE()  AS DATA,
 [ER_EFI_IDEB]
      ,[ER_EFI_IDERJ]
      ,[ER_EFI_ID]
      ,[ER_EFI_IF]
      ,[ER_EFII_IDEB]
      ,[ER_EFII_IDERJ]
      ,[ER_EFII_ID]
      ,[ER_EFII_IF]
      ,[ER_EM_IDERJ]
      ,[ER_EM_ID]
      ,[ER_EM_IF]
      ,[EJA_EFII_ID]
      ,[EJA_EM_ID]

from  dbo.metas M, DADOS2009 D
where
M.CENSO = D.CENSO
And M.CENSO = @censo</CommandText>
        <QueryParameters>
          <QueryParameter Name="@censo">
            <Value>=Parameters!censo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
