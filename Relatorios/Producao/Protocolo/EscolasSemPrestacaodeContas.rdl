  <DataSources>
    <DataSource Name="dbSemPrestacao">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>c2f05ac7-6674-4ef3-bfdb-c50711d3e745</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText> SELECT DISTINCT
  TCE_REGIONAL.REGIONAL         AS REGIONAL,
                MUNICIPIO.NOME                AS MUNICIPIO,
                LY_UNIDADE_ENSINO.UNIDADE_ENS AS CENSO,
                LY_UNIDADE_ENSINO.NOME_COMP   AS ESCOLA,
                LY_UNIDADE_ENSINO.SETOR       AS UA,
                LY_UNIDADE_ENSINO.ENDERECO    AS ENDERECO,
                LY_UNIDADE_ENSINO.END_NUM     AS NUMERO,
                LY_UNIDADE_ENSINO.BAIRRO,
                LY_UNIDADE_ENSINO.CEP,
                LY_UNIDADE_ENSINO.FONE,
                SITUACAO
FROM   LY_UNIDADE_ENSINO
       INNER JOIN DBO.TCE_REGIONAL
               ON TCE_REGIONAL.ID_REGIONAL = LY_UNIDADE_ENSINO.ID_REGIONAL
       INNER JOIN MUNICIPIO
               ON MUNICIPIO.CODIGO = LY_UNIDADE_ENSINO.MUNICIPIO
       INNER JOIN LY_UNIDADE_ENSINO_SITUACAO UES
               ON UES.UNIDADE_ENS = LY_UNIDADE_ENSINO.UNIDADE_ENS
                  AND UES.DT_SITUACAO = (SELECT Max(DT_SITUACAO)
                                         FROM   LY_UNIDADE_ENSINO_SITUACAO
                                                LY_UNIDADE_ENSINO_SITUACAO
                                         WHERE  LY_UNIDADE_ENSINO.UNIDADE_ENS =
LY_UNIDADE_ENSINO_SITUACAO.UNIDADE_ENS)
WHERE  LY_UNIDADE_ENSINO.UNIDADE_ENS NOT IN (
              '99999999', '33334444', '33335555', '33335556' )
       AND ( SIT_FUNCIONAMENTO = 'EMATIVIDADE'
              OR SIT_FUNCIONAMENTO IS NULL )
       AND LY_UNIDADE_ENSINO.UNIDADE_ENS NOT IN (SELECT P.UNIDADEENSINOID
                                                 FROM
               PROTOCOLO.PROTOCOLOPRESTACAO P (NOLOCK)
          
                                                 WHERE  P.ANO = @ANO
                                                        AND P.SEMESTRE = @SEMESTRE)

ORDER  BY TCE_REGIONAL.REGIONAL,
          MUNICIPIO.NOME,
          LY_UNIDADE_ENSINO.UNIDADE_ENS  </CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ENDERECO">
          <DataField>ENDERECO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BAIRRO">
          <DataField>BAIRRO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CEP">
          <DataField>CEP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FONE">
          <DataField>FONE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dtAno">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
