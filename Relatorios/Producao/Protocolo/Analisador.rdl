    <DataSet Name="dtAno">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dtSituacao">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <CommandText>SELECT [SITUACAOPROTOCOLOID]
      ,[DESCRICAO]
  FROM [LYCEUM].[Protocolo].[SITUACAOPROTOCOLO]
  order by DESCRICAO</CommandText>
      </Query>
      <Fields>
        <Field Name="SITUACAOPROTOCOLOID">
          <DataField>SITUACAOPROTOCOLOID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dtAnalisador">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <CommandText>SELECT DISTINCT A.USUARIOANALISADOR,FA.NOME_COMPL FROM Protocolo.ANALISE A
INNER JOIN  DBO.VW_FUNCIONARIOS FA (NOLOCK) 
		                                    ON A.USUARIOANALISADOR = FA.MATRICULA
ORDER BY FA.NOME_COMPL</CommandText>
      </Query>
      <Fields>
        <Field Name="USUARIOANALISADOR">
          <DataField>USUARIOANALISADOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMPL">
          <DataField>NOME_COMPL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dtPrograma">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <CommandText>SELECT [PROGRAMAPROTOCOLOID]
      ,[DESCRICAO] AS PROGRAMA
  FROM [LYCEUM].[PROTOCOLO].[PROGRAMAPROTOCOLO]
  ORDER BY DESCRICAO</CommandText>
      </Query>
      <Fields>
        <Field Name="PROGRAMAPROTOCOLOID">
          <DataField>PROGRAMAPROTOCOLOID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PROGRAMA">
          <DataField>PROGRAMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
