    </DataSet>
    <DataSet Name="dtAno">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <CommandText>  SELECT  0 ANO, 'TODOS' NOME
UNION
SELECT	DISTINCT CONVERT (VARCHAR(4), ANO) ANO, CONVERT (VARCHAR(4), ANO) NOME 
FROM	protocolo.PROTOCOLOPRESTACAO (NOLOCK) 
WHERE ANO&lt;&gt;0
ORDER	BY ANO </CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
