    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dbSemPrestacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>Protocolo.SP_QUANTITATIVOTIPOPROGRAMASITUACAOPRESTACAO</CommandText>
      </Query>
      <Fields>
        <Field Name="Tipo_de_Prestação">
          <DataField>Tipo de Prestação</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL">
          <DataField>TOTAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
