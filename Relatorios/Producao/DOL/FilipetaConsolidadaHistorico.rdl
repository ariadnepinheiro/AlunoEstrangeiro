    <DataSet Name="DtAulas">
      <Query>
        <DataSourceName>dsFilipetaConsolidada</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ano.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@PERIODO">
            <Value>=Parameters!periodo.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@TURMA">
            <Value>=Parameters!turma.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@DISCIPLINA">
            <Value>=Parameters!disciplina.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT        sum(AULAS_PREVISTAS) as AULAS_PREVISTAS, sum(AULAS_DADAS) as AULAS_DADAS
          FROM            LY_FREQ
          WHERE        (DISCIPLINA = @DISCIPLINA) AND (TURMA = @TURMA) AND (ANO = @ANO) AND (PERIODO = @PERIODO)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AULAS_PREVISTAS">
          <DataField>AULAS_PREVISTAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="AULAS_DADAS">
          <DataField>AULAS_DADAS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
