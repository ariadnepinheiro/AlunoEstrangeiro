          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FORMACAO_COMPLEMENTACAO_PEDAGOGICA">
          <DataField>FORMACAO_COMPLEMENTACAO_PEDAGOGICA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO_INICIO">
