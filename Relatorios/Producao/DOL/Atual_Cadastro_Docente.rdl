    <DataSet Name="FORMAÇÃO_PÓS_GRADUAÇÃO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MATRICULA">
            <Value>=Parameters!MATRICULA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT  DISTINCT 
		ROW_NUMBER() OVER(ORDER BY TFP.ANO_INICIO, TFP.ANO_CONCLUSAO) AS Row,
		TFP.ESCOLARIDADE, 
		TFP.SITUACAO_CURSO, 
		TAFP.AREA AREA_CURSO, 
		TCFP.CURSO, 
		TFP.FORMACAO_COMPLEMENTACAO_PEDAGOGICA, 
		TFP.ANO_INICIO,
		TFP.ANO_CONCLUSAO, 
		TFP.ID_INSTITUICAO COD_INSTITUICAO, 
		LI.NOME_COMP INSTITUICAO, 
		TFP.DOC_COMPROBATORIO
FROM    LY_DOCENTE LD (NOLOCK)
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
JOIN	LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
					AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
					AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
JOIN	LY_FUNCAO LF (NOLOCK) ON LF.FUNCAO = LL.FUNCAO
                    AND LF.CAMPO_01 = 'S'
JOIN	TCE_FORMACAO_PESSOAL TFP (NOLOCK) ON TFP.PESSOA = LP.PESSOA 
					AND TFP.ESCOLARIDADE IN ('Pós-Graduação - Especialização', 'Pós-Graduação - Doutorado', 'Pós-Graduação - Mestrado')
JOIN	TCE_CURSO_FORMACAO_PESSOAL TCFP (NOLOCK) ON TCFP.ID_CURSO_FORMACAO_PESSOAL = TFP.ID_CURSO_FORMACAO_PESSOAL
JOIN	TCE_AREA_FORMACAO_PESSOAL TAFP (NOLOCK) ON TAFP.ID_AREA_FORMACAO_PESSOAL = TCFP.ID_AREA_FORMACAO_PESSOAL 
JOIN	LY_INSTITUICAO LI (NOLOCK) ON LI.OUTRA_FACULDADE = TFP.ID_INSTITUICAO

WHERE   LD.MATRICULA = @MATRICULA


</CommandText>
      </Query>
