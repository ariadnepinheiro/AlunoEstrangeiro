  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.50.9.74;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>7bfb35cf-f8ed-4e02-9ffa-c404c6629045</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DADOS_CADASTRAIS">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MATRICULA">
            <Value>=Parameters!MATRICULA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT  DISTINCT LD.MATRICULA, 
		UPPER (LP.NOME_COMPL) NOME_DOCENTE, 
		CONVERT(VARCHAR(12), LP.DT_NASC, 103) DATA_NASC, 
		LP.ETNIA AS COR_RACA, 
		LP.SEXO,  
        NEC.DESCRICAO AS NECESSIDADE_ESPECIAL, 
        LP.EST_CIVIL, 
        MN.NOME NATURALIDADE,
        MN.UF_SIGLA UF_NASC, 
        LP.NACIONALIDADE, 
        HPN.NOME PAIS_NASC, 
        LP.ENDERECO, 
        LP.END_NUM NUMERO, 
        LP.END_COMPL COMPLEMENTO, 
        LP.BAIRRO, 
        ME.NOME END_MUNICIPIO,
        ME.UF_SIGLA UF_END,
        LP.CEP,
        HPE.NOME PAIS,  
       FLP.FL_FIELD_01 AS ZONA_RESIDENCIAL, 
        LP.FONE TELEFONE, 
        LP.CELULAR, 
        LP.E_MAIL, 
        LP.RG_TIPO, 
        LP.RG_NUM, 
        LP.RG_UF, 
        LP.RG_EMISSOR, 
        CONVERT(VARCHAR(12), LP.RG_DTEXP, 103) RG_DTEXP, 
        LP.CPF
FROM    LY_DOCENTE LD (NOLOCK)
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
JOIN	HADES..HD_PAIS HPN (NOLOCK) ON HPN.PAIS = LP.PAIS_NASC
JOIN	HADES..HD_PAIS HPE (NOLOCK) ON HPE.PAIS = LP.END_PAIS
JOIN	LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
					AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
					AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
JOIN	MUNICIPIO MN (NOLOCK) ON MN.CODIGO = LP.MUNICIPIO_NASC
JOIN	MUNICIPIO ME (NOLOCK) ON ME.CODIGO = LP.END_MUNICIPIO
JOIN	LY_FUNCAO LF (NOLOCK) ON LF.FUNCAO = LL.FUNCAO
                    AND LF.CAMPO_01 = 'S'
 LEFT JOIN HADES.dbo.NECESSIDADEESPECIAL NEC ON NEC.NECESSIDADEESPECIALID=LP.NECESSIDADEESPECIALID        
 LEFT JOIN LY_FL_PESSOA FLP ON FLP.PESSOA = LP.PESSOA                        
WHERE   LD.MATRICULA = @MATRICULA</CommandText>
      </Query>
