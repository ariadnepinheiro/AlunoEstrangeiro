        </Field>
        <Field Name="CARGA_HORARIA">
          <DataField>CARGA_HORARIA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DATA_CONCLUSAO">
          <DataField>DATA_CONCLUSAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
