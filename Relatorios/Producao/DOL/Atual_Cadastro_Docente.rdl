    <DataSet Name="CAPACITAÇÃO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MATRICULA">
            <Value>=Parameters!MATRICULA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT  DISTINCT 
		ROW_NUMBER() OVER(ORDER BY LC.DATA_CONCLUSAO) AS Row,
		'Não' OFERECIDOSEEDUC,
		LC.TIPO_CURSO, 
		A.DESCRICAO AREA_CONHECIMENTO, 
		LC.CAPACITACAO, 
		LC.NOME_INSTITUICAO, 
		LC.CARGA_HORARIA, 
		LC.DATA_CONCLUSAO DATA_CONCLUSAO
FROM    LY_DOCENTE LD (NOLOCK)
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
JOIN	LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
					AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
					AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
JOIN	LY_FUNCAO LF (NOLOCK) ON LF.FUNCAO = LL.FUNCAO
                    AND LF.CAMPO_01 = 'S'
JOIN	LY_CAPACITACAO LC (NOLOCK) ON LC.PESSOA = LP.PESSOA
JOIN	AREACONHECIMENTO A (NOLOCK) ON A.AREACONHECIMENTOID = LC.AREACONHECIMENTOID

WHERE   LD.MATRICULA = @MATRICULA

UNION ALL

SELECT  DISTINCT 
		ROW_NUMBER() OVER(ORDER BY DATACONCLUSAO) AS Row,
		CONVERT (VARCHAR(3), C.OFERECIDOSEEDUC) OFERECIDOSEEDUC,
		T.DESCRICAO, 
		A.DESCRICAO AREA_CONHECIMENTO, 
		C.NOMECURSO CAPACITACAO, 
		C.NOMEINSTITUICAO, 
		C.CARGAHORARIA, 
		DATACONCLUSAO DATA_CONCLUSAO
FROM    LY_DOCENTE LD (NOLOCK)
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
JOIN	LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
					AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
					AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt;= CONVERT(DATE, GETDATE()))
JOIN	LY_FUNCAO LF (NOLOCK) ON LF.FUNCAO = LL.FUNCAO
                    AND LF.CAMPO_01 = 'S'
JOIN	PESSOA_CURSOCAPACITACAO PC (NOLOCK) ON PC.PESSOAID = LP.PESSOA
JOIN	CURSOCAPACITACAO C (NOLOCK) ON C.CURSOCAPACITACAOID = PC.CURSOCAPACITACAOID
JOIN	CURSOCAPACITACAO_TIPOCURSOCAPACITACAO CTC (NOLOCK) ON CTC.CURSOCAPACITACAOID = C.CURSOCAPACITACAOID
JOIN	TIPOCURSOCAPACITACAO T (NOLOCK) ON T.TIPOCURSOCAPACITACAOID = CTC.TIPOCURSOCAPACITACAOID
JOIN	AREACONHECIMENTO A (NOLOCK) ON A.AREACONHECIMENTOID = C.AREACONHECIMENTOID

WHERE   LD.MATRICULA = @MATRICULA


</CommandText>
      </Query>
      <Fields>
        <Field Name="OFERECIDOSEEDUC">
          <DataField>OFERECIDOSEEDUC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Row">
          <DataField>Row</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="TIPO_CURSO">
          <DataField>TIPO_CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AREA_CONHECIMENTO">
