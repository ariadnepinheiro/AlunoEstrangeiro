          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_ANTIGA">
          <DataField>UA_ANTIGA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IDFUNCIONAL">
          <DataField>IDFUNCIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UA_11_DIGITOS">
          <DataField>UA_11_DIGITOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
