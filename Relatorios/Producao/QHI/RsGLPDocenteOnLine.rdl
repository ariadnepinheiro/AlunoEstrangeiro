  <DataSets>
    <DataSet Name="RelatProfDodentes">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT ARPC.*, VWS.UA_ATUAL, VWS.UA_ANTIGA , VWS.UA_11_DIGITOS, PP.IDFUNCIONAL, V1.VINCULO
FROM APOLLO..REL_PROF_CAD_GLP_ON_LINE ARPC
JOIN    LY_UNIDADE_ENSINO LUE on LUE.UNIDADE_ENS = ARPC.CENSO	
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR
JOIN    LY_VINCULO V1  ON  V1.MATRICULA = ARPC.MATRICULA
JOIN    LY_PESSOA PP  ON PP.PESSOA = V1.PESSOA
WHERE (ARPC.ID_REGIONAL = ISNULL(@REGIONAL, ARPC.ID_REGIONAL) OR ARPC.ID_REGIONAL IS NULL)
AND (COD_MUNICIPIO = ISNULL(@MUNICIPIO, COD_MUNICIPIO) OR COD_MUNICIPIO IS NULL)
AND (CENSO = ISNULL (@ESCOLA, CENSO) OR CENSO IS NULL)
AND ANO = @ANO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
