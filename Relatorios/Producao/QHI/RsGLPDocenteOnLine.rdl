          <DataField>HORA_FINAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EMAIL_INSTITUCIONAL">
          <DataField>EMAIL_INSTITUCIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
