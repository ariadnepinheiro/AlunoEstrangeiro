  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>1b0652bd-f4bf-45da-bbc9-0d8b244617f5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- ATENCAO: INCLUI OS CPF COM ERRO DE CADASTRO QUE GERA 3 OU 4 MATRICULAS POR CPF
SELECT  DISTINCT --TOP 10

	X.ID_REGIONAL
	,X.REGIONAL
	,X.ID_MUNICIPIO
	,X.MUNICIPIO
	,X.CENSO
	,X.ESCOLA
	
	,X.CPF
	,X.DOCENTE
	,X.MATRICULA AS MATRICULA_GRATIFICADA	
	,X.FUNCAO AS FUNCAO_GRATIFICADA
	,Y.MATRICULA_ACUMULACAO
	,Y.FUNCAO AS FUNCAO_ACUMULACAO
	,Y.TEMPOS_GLP_MATRICULA_ACUMULACAO
	,VINCULO
	,IDFUNCIONAL
FROM (
	--A02 MATRICULAS GRATIFICADAS
	SELECT DISTINCT
		 ISNULL (LP.CPF, '') AS CPF
		,LD.PESSOA
		,LD.MATRICULA
		,LP.NOME_COMPL AS DOCENTE
		--,ISNULL(CONVERT (VARCHAR (10), LD.DT_ADMISSAO, 103),'') AS DATA_ADMISSAO
		--,ISNULL(CONVERT (VARCHAR (10), LL.DATA_NOMEACAO, 103),'') AS DATA_NOMEACAO
		--,ISNULL(CONVERT (VARCHAR (10), LL.DATA_DESATIVACAO, 103),'') AS DATA_DESATIVACAO
		,ISNULL(LF.DESCRICAO,'') AS FUNCAO
		,LF.FUNCAOBB AS TIPO_FUNCAO --GRATIFICADA/SEMCLA/COMISSIONADA/NULL
		--,ISNULL(LD.CATEGORIA,'') AS CARGO
		--,LF.CAMPO_01 AS DOCENTE
		,LL.UNIDADE_ENS
		
		,TR.ID_REGIONAL
		,ISNULL(TR.REGIONAL,'') AS REGIONAL
		,TMUN.ID_MUNICIPIO AS ID_MUNICIPIO
		,UPPER(LTRIM(RTRIM(ISNULL(TMUN.NOME,'')))) AS MUNICIPIO
		,ISNULL(LUE.UNIDADE_ENS,'') AS CENSO
		,LUE.NOME_COMP AS ESCOLA 
		,LD.VINCULO
		,LP.IDFUNCIONAL
		
	FROM 
	LY_DOCENTE LD 
	INNER JOIN LY_PESSOA LP ON LP.PESSOA = LD.PESSOA 
					AND LP.CPF &lt;&gt; '00000000000'
					AND (LP.CPF &lt;&gt; '' OR LP.CPF &lt;&gt; '')
					--AND LP.CPF = '01328234703'

	--O JOIN SO É USADO QUANDO SE PRECISA DE INFORMACOES DE LOTACAO, UA DE LOTACAO E ETC..
	INNER JOIN LY_LOTACAO LL ON LL.MATRICULA = LD.MATRICULA 
					-- NAO PRECISA, POIS O SERVIDOR JA ESTA ATIVO PELA AULA_DOCENTE
					AND	LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
					AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))

	INNER JOIN LY_FUNCAO LF ON LF.FUNCAO = LL.FUNCAO
					--AND	LF.CAMPO_01 = 'S'  --NAO PRECISA PORQUE ELE JA É REGENTE PELA AULA_DOCENTE
--					AND LF.FUNCAO NOT IN ('9999') --Funcao SEEDUC
					AND LF.FUNCAOBB = 'GRATIFICADA' --COMISSIONADA/NULL
								        AND LF.FUNCAO NOT IN (10147,18,10146,11) 
	--INNER JOIN SETOR S (NOLOCK) ON S.SETOR = LL.SETOR AND UPPER(S.NOMESETOR) NOT LIKE 'CR %' -- REMOVE SERVIDORES LOTADOS EM COORDENADORIAS
	------
	INNER JOIN LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LL.UNIDADE_ENS 
					AND LUE.UNIDADE_ENS = ISNULL(@ESCOLA,LUE.UNIDADE_ENS)

	--	COLOCAR VALIDAÇÃO COMO "EXISTS"
	--INNER JOIN LY_UNIDADE_ENSINO_SITUACAO LUES (NOLOCK) ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
	--				AND LUES.DT_SITUACAO = (SELECT MAX(DT_SITUACAO)
	--										FROM LY_UNIDADE_ENSINO_SITUACAO UES (NOLOCK)
	--										WHERE LUE.UNIDADE_ENS = UES.UNIDADE_ENS) 
	--				AND UPPER(LUES.SITUACAO) = 'ESTADUAL' 
	--				AND (LUE.SIT_FUNCIONAMENTO = 'EmAtividade' OR LUE.SIT_FUNCIONAMENTO IS NULL)
	--				AND LUE.UNIDADE_ENS NOT IN ('99999999', '33334444', '33335555', '33335556')												
					-- que nao estao 'EmAtividade', o uso do criterio (LUE.SIT_FUNCIONAMENTO = 'EmAtividade'), exclui esse
					
					-- usado para pegar funcionarios lotados em coordenadorias/regionais
					--AND LUE.SETOR NOT IN ('187777', '189998', '189999', '999999', '186666')	
													
	INNER JOIN HADES..TCE_MUNICIPIO TMUN (NOLOCK) ON TMUN.ID_MUNICIPIO = LUE.MUNICIPIO
					AND TMUN.ID_MUNICIPIO = ISNULL(@MUNICIPIO,TMUN.ID_MUNICIPIO)

	INNER JOIN TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL	
					AND TR.ID_REGIONAL = ISNULL(@REGIONAL,TR.ID_REGIONAL)

	WHERE (LD.DT_DEMISSAO IS NULL 
	OR		LD.DT_DEMISSAO &gt; CONVERT(DATE,GETDATE()))
	AND		NOT EXISTS (
						SELECT	1
						FROM	LY_LICENCA_DOCENTE LDD
						WHERE	LDD.NUM_FUNC = LD.NUM_FUNC
						AND		LDD.DTFIM IS NULL
						)
	--EXISTS (
	--		-- CPF COM MAIS DE UMA MATRICULA ATIVA
	--		SELECT DISTINCT
	--			ISNULL (LD2.CPF, ISNULL (LP2.CPF, '')) AS CPF
	--			,COUNT(LD2.MATRICULA) AS QTD
	--		FROM 
	--		LY_DOCENTE LD2 
	--		INNER JOIN LY_PESSOA LP2 ON LP2.PESSOA = LD2.PESSOA 
	--						AND LD2.CPF &lt;&gt; '00000000000'
	--						AND (LD2.CPF &lt;&gt; '' OR LP2.CPF &lt;&gt; '')

			--O JOIN SO É USADO QUANDO SE PRECISA DE INFORMACOES DE LOTACAO, UA DE LOTACAO E ETC..
	--		INNER JOIN LY_LOTACAO LL ON LL.MATRICULA = LD2.MATRICULA 
	--						-- NAO PRECISA, POIS O SERVIDOR JA ESTA ATIVO PELA AULA_DOCENTE
	--						AND	LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
	--						AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))

	--		INNER JOIN LY_FUNCAO LF ON LF.FUNCAO = LL.FUNCAO
	--						--AND	LF.CAMPO_01 = 'S'  --NAO PRECISA PORQUE ELE JA É REGENTE PELA AULA_DOCENTE
	--						AND LF.FUNCAO NOT IN ('9999') --Funcao SEEDUC
										        
	--		INNER JOIN SETOR S (NOLOCK) ON S.SETOR = LL.SETOR AND UPPER(S.NOMESETOR) NOT LIKE 'CR %' -- REMOVE SERVIDORES LOTADOS EM COORDENADORIAS
	--		WHERE LD2.CPF = LD.CPF OR LP2.CPF = LP.CPF
	--		GROUP BY LD2.CPF, LP2.CPF
	--		HAVING COUNT(LD2.MATRICULA) &gt; 1
	--)
) X INNER JOIN (
	--A01 MATRICULAS COM ACUMULACAO COM GLP
	SELECT	
		 ISNULL (LP.CPF, '') AS CPF
		,LD.MATRICULA MATRICULA_ACUMULACAO
		, LD.PESSOA
		,ISNULL(LF.DESCRICAO,'') AS FUNCAO
		, COUNT(DISTINCT STR(LAD.AULA)+STR(LAD.DIA_SEMANA)+LAD.DISCIPLINA+LAD.TURMA) TEMPOS_GLP_MATRICULA_ACUMULACAO
	FROM 
	LY_DOCENTE LD 
	INNER JOIN LY_PESSOA LP ON LP.PESSOA = LD.PESSOA 
					AND LP.CPF &lt;&gt; '00000000000'
					AND (LP.CPF &lt;&gt; '' OR LP.CPF &lt;&gt; '')
					--AND LP.CPF = '01328234703'

	--O JOIN SO É USADO QUANDO SE PRECISA DE INFORMACOES DE LOTACAO, UA DE LOTACAO E ETC..
	INNER JOIN LY_LOTACAO LL ON LL.MATRICULA = LD.MATRICULA 
					-- NAO PRECISA, POIS O SERVIDOR JA ESTA ATIVO PELA AULA_DOCENTE
					AND	LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
					AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))

	INNER JOIN LY_FUNCAO LF ON LF.FUNCAO = LL.FUNCAO
					--AND	LF.CAMPO_01 = 'S'  --NAO PRECISA PORQUE ELE JA É REGENTE PELA AULA_DOCENTE
		--			AND LF.FUNCAO NOT IN ('9999') --Funcao SEEDUC

	INNER JOIN LY_AULA_DOCENTE LAD (NOLOCK) ON LAD.NUM_FUNC = LD.NUM_FUNC
	INNER JOIN LY_AULA_DOCENTE_TIPO ADC (NOLOCK) ON ADC.NUM_FUNC = LAD.NUM_FUNC
					AND ADC.TURNO = LAD.TURNO
					AND ADC.FACULDADE = LAD.FACULDADE
					AND ADC.DIA_SEMANA = LAD.DIA_SEMANA
					AND ADC.AULA = LAD.AULA
					AND ADC.DISCIPLINA = LAD.DISCIPLINA
					AND ADC.TURMA = LAD.TURMA
					AND ADC.ANO = LAD.ANO
					AND ADC.SEMESTRE = LAD.SEMESTRE
					AND ADC.DATA_INICIO = LAD.DATA_INICIO
					---
					AND ADC.TIPO_AULA = 'GLP'
					AND	LAD.DATA_FIM &gt;= CONVERT(DATE,GETDATE())
	WHERE (LD.DT_DEMISSAO IS NULL 
	OR		LD.DT_DEMISSAO &gt; CONVERT(DATE,GETDATE()))
	AND		NOT EXISTS (
						SELECT	1
						FROM	LY_LICENCA_DOCENTE LDD
						WHERE	LDD.NUM_FUNC = LD.NUM_FUNC
						AND		LDD.DTFIM IS NULL
						)

	GROUP BY LP.CPF, LD.MATRICULA, LD.PESSOA, LF.DESCRICAO, LP.CPF		
								
) Y ON X.PESSOA = Y.PESSOA
AND X.MATRICULA &lt;&gt; Y.MATRICULA_ACUMULACAO 
--AND	 X.MATRICULA = '09624354'

ORDER BY X.DOCENTE--1,2</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_MUNICIPIO">
          <DataField>ID_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DOCENTE">
          <DataField>DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA_GRATIFICADA">
          <DataField>MATRICULA_GRATIFICADA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO_GRATIFICADA">
          <DataField>FUNCAO_GRATIFICADA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA_ACUMULACAO">
          <DataField>MATRICULA_ACUMULACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO_ACUMULACAO">
          <DataField>FUNCAO_ACUMULACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TEMPOS_GLP_MATRICULA_ACUMULACAO">
          <DataField>TEMPOS_GLP_MATRICULA_ACUMULACAO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VINCULO">
          <DataField>VINCULO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="IDFUNCIONAL">
          <DataField>IDFUNCIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regionais">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- REGIONAIS
select null id_regional,' TODAS' regional
union
select  l1.id_regional,SUBSTRING(l1.regional,1,35) from tce_regional L1 (nolock)
join LYCEUM..LY_UNIDADE_ENSINO l2 (nolock) on L1.id_regional=l2.id_regional
join HADES..MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LYCEUM..LY_USUARIO_UNIDADE_FIS jj (nolock) on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select -1 id_regional,' Selecione...' regional 
order by regional</CommandText>
      </Query>
      <Fields>
        <Field Name="id_regional">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="regional">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipios">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- MUNICIPIO (UNIDADE)
select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join HADES..municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LYCEUM..TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LYCEUM..LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	-- 8
	(n1.id_regional = ISNULL(@REGIONAL,n1.id_regional)or n1.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escolas">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- ESCOLA
select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LYCEUM..LY_UNIDADE_ENSINO ue 
JOIN LYCEUM..TCE_REGIONAL R ON R.ID_REGIONAL = UE.ID_REGIONAL
join LYCEUM..LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (R.ID_REGIONAL = ISNULL(@REGIONAL,R.ID_REGIONAL) or R.ID_REGIONAL is null)
--00007043
AND (ue.MUNICIPIO = ISNULL(@MUNICIPIO,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP
</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Anos">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>-- ANO
SELECT DISTINCT ANO, ANO AS NOME 
FROM LYCEUM..LY_PERIODO_LETIVO
WHERE 	ANO &lt;= YEAR(GETDATE())
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="usuario">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>usuario</Prompt>
      <Hidden>true</Hidden>
    </ReportParameter>
    <ReportParameter Name="REGIONAL">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>-1</Value>
        </Values>
      </DefaultValue>
      <Prompt>REGIONAL</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Regionais</DataSetName>
          <ValueField>id_regional</ValueField>
          <LabelField>regional</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="MUNICIPIO">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>MUNICIPIO</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Municipios</DataSetName>
          <ValueField>codigo</ValueField>
          <LabelField>nome</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="ESCOLA">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>NULO</Value>
        </Values>
      </DefaultValue>
      <Prompt>ESCOLA</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Escolas</DataSetName>
          <ValueField>UNIDADE_ENS</ValueField>
          <LabelField>NOME_COMP</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
  </ReportParameters>
