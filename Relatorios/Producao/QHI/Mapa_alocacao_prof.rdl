  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Lyceum">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>578ffdb1-371c-46bb-a699-57e88d0cf77b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="MapaAlocacao">
      <Query>
        <DataSourceName>Lyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	TR.REGIONAL, LUE.UNIDADE_ENS, LUE.NOME_COMP, LT.ANO, LT.SEMESTRE, REPLACE(LT.TURMA,'-'+LUE.SETOR,'') TURMA, LT.TURNO,
		SUBSTRING(LDI.NOME,1,20) DISCIPLINA, LD.MATRICULA, SUBSTRING(PE.NOME_COMPL, 1,10) NOME_DOCENTE, 
		CASE WHEN ISNULL(LADT.NUM_FUNC,0) &lt;&gt; 0 AND LAD.TIPO_DOCENTE = '00000000' THEN 'GLP T' 
		WHEN ISNULL(LADT.NUM_FUNC,0) &lt;&gt; 0 AND ISNULL(LAD.TIPO_DOCENTE,'99999999') &lt;&gt; '00000000' THEN 'GLP R'
		WHEN LD.MATRICULA = '00000000' THEN 'CAR T'
		WHEN LD.MATRICULA = '99999999' THEN 'CAR R' 
		WHEN LD.CONCURSO IS NOT NULL AND LD.CANDIDATO IS NOT NULL THEN 'CT' END TIPO_AULA, 
		CASE WHEN LHO.DIA_SEMANA = 2 THEN '2-SEGUNDA'
			 WHEN LHO.DIA_SEMANA = 3 THEN '3-TERÇA'
			 WHEN LHO.DIA_SEMANA = 4 THEN '4-QUARTA'
			 WHEN LHO.DIA_SEMANA = 5 THEN '5-QUINTA'
			 WHEN LHO.DIA_SEMANA = 6 THEN '6-SEXTA'
			 WHEN LHO.DIA_SEMANA = 7 THEN '7-SÁBADO' END DIA_SEMANA, 
		LHO.ORDEM, 
		SUBSTRING(CONVERT(VARCHAR(10), MIN(CONVERT(TIME, LHO.HORAINI_AULA))),1,5) HORA_INICIO,
		SUBSTRING(CONVERT(VARCHAR(10), MAX(CONVERT(TIME, LHO.HORAFIM_AULA))),1,5) HORA_FIM, 
		LT.DEPENDENCIA SALA_AULA, 
		LUE.SETOR UA
FROM	LY_TURMA LT (NOLOCK) 
JOIN	LY_HOR_OPER LHO (NOLOCK) ON LHO.TURNO = LT.TURNO
				AND LHO.FACULDADE = LT.FACULDADE
				AND LHO.CURRICULO = LT.CURRICULO
				AND LHO.SERIE = LT.SERIE
				AND LHO.CURSO = LT.CURSO
JOIN	LY_AULA_DOCENTE LAD (NOLOCK) ON LAD.ANO = LT.ANO
				AND LAD.SEMESTRE = LT.SEMESTRE
				AND LAD.DISCIPLINA = LT.DISCIPLINA
				AND LAD.TURMA = LT.TURMA 
				AND LAD.DATA_FIM = LT.DT_FIM
				AND LAD.AULA = LHO.AULA
				AND LAD.DIA_SEMANA = LHO.DIA_SEMANA
				AND LAD.FACULDADE = LHO.FACULDADE
				AND LAD.TURNO = LHO.TURNO
				AND	LT.DT_FIM &gt;= CONVERT(DATE,GETDATE())
				AND LT.SIT_TURMA = 'ABERTA'
				AND LT.CURSO NOT IN ('9999.91','9999.92','9999.93','9999.94','9999.95','9999.96','9999.99')
JOIN	LY_DISCIPLINA LDI (NOLOCK) ON LDI.DISCIPLINA = LAD.DISCIPLINA
JOIN	LY_DOCENTE LD (NOLOCK) ON LD.NUM_FUNC = LAD.NUM_FUNC
JOIN	LY_PESSOA PE (NOLOCK) ON LD.PESSOA = PE.PESSOA
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
LEFT	JOIN LY_AULA_DOCENTE_TIPO LADT (NOLOCK) ON LADT.ANO = LAD.ANO
				AND LADT.SEMESTRE = LAD.SEMESTRE
				AND LADT.NUM_FUNC = LAD.NUM_FUNC 
				AND LADT.DISCIPLINA = LAD.DISCIPLINA
				AND LADT.TURMA = LAD.TURMA
				AND LADT.AULA = LAD.AULA
				AND LADT.DIA_SEMANA = LAD.DIA_SEMANA
				AND LADT.DATA_INICIO = LAD.DATA_INICIO 
				AND LADT.FACULDADE = LAD.FACULDADE
				AND LADT.TURNO = LAD.TURNO
				AND LADT.TIPO_AULA = 'GLP'
WHERE	LT.ANO = @ANO
AND		LT.UNIDADE_RESPONSAVEL = @ESCOLA
AND 	LT.TURNO = @TURNO

GROUP BY TR.REGIONAL, LUE.UNIDADE_ENS, LUE.NOME_COMP, LT.ANO, LT.SEMESTRE, LT.TURNO,
		SUBSTRING(LDI.NOME,1,20), LD.MATRICULA, SUBSTRING(PE.NOME_COMPL, 1,10),
		CASE WHEN ISNULL(LADT.NUM_FUNC,0) &lt;&gt; 0 AND LAD.TIPO_DOCENTE = '00000000' THEN 'GLP T' 
		WHEN ISNULL(LADT.NUM_FUNC,0) &lt;&gt; 0 AND ISNULL(LAD.TIPO_DOCENTE,'99999999') &lt;&gt; '00000000' THEN 'GLP R' 
		WHEN LD.MATRICULA = '00000000' THEN 'CAR T'
		WHEN LD.MATRICULA = '99999999' THEN 'CAR R' 
		WHEN LD.CONCURSO IS NOT NULL AND LD.CANDIDATO IS NOT NULL THEN 'CT' END, 
		LHO.DIA_SEMANA, LHO.ORDEM, LT.DEPENDENCIA, REPLACE(LT.TURMA,'-'+LUE.SETOR,''), LUE.SETOR</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO_AULA">
          <DataField>TIPO_AULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DIA_SEMANA">
          <DataField>DIA_SEMANA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ORDEM">
          <DataField>ORDEM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="HORA_INICIO">
          <DataField>HORA_INICIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA_FIM">
          <DataField>HORA_FIM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SALA_AULA">
          <DataField>SALA_AULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>Lyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	0 ID_REGIONAL,' Selecione...' REGIONAL 
UNION
SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35) 
FROM	TCE_REGIONAL TR (NOLOCK)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>Lyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT M.CODIGO, M.NOME 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
WHERE	TR.ID_REGIONAL = @REGIONAL
AND		(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
UNION
SELECT	'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER	BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>Lyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT	'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT	LUE.UNIDADE_ENS, SUBSTRING (LUE.NOME_COMP,1,50) NOME_COMP 
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK) 
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES (NOLOCK) ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND LUES.DT_SITUACAO = (
										SELECT	MAX(DT_SITUACAO)
										FROM	LY_UNIDADE_ENSINO_SITUACAO L1 (NOLOCK)
										WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS
										AND		SITUACAO = 'ESTADUAL'
										)
				AND	(SIT_FUNCIONAMENTO = 'EmAtividade' OR SIT_FUNCIONAMENTO IS NULL)	
WHERE	TR.ID_REGIONAL = @REGIONAL
AND		LUE.MUNICIPIO = @MUNIC
AND		(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER	BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Turno">
      <Query>
        <DataSourceName>Lyceum</DataSourceName>
        <CommandText>SELECT 	TURNO
FROM 	LY_TURNO (NOLOCK)</CommandText>
      </Query>
      <Fields>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>Lyceum</DataSourceName>
        <CommandText>
SELECT  0 ANO, ' Selecione...' NOME
UNION
SELECT	DISTINCT CONVERT (VARCHAR(4), ANO) ANO, CONVERT (VARCHAR(4), ANO) NOME 
FROM	LY_PERIODO_LETIVO (NOLOCK) 
WHERE	ANO = YEAR(GETDATE())
ORDER	BY ANO DESC
</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
