  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="LYCEUM">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>3026eee8-b6eb-4a78-b97b-7e4085061b5b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Dataset1">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT REGIONAL, 
		MUNICIPIO, UA, 
		CENSO, 
		ESCOLA,
		CLASSIFICACAO_UE,
		ENDERECO,
		NUMERO,
		COMPLEMENTO,
		BAIRRO,
		TELEFONE_UE1,
		TELEFONE_UE2,	
		(SELECT STUFF(
			(SELECT DISTINCT '/' + TURNO 
              FROM LY_TURMA T
              WHERE T.UNIDADE_RESPONSAVEL = CENSO
              AND T.SIT_TURMA = 'ABERTA'
              AND T.ANO = @ANO
              FOR XML PATH (''))
             , 1, 1, '')) TURNOS, 
		CODIGO_FUNC,
		(FUNCAO_DESC + ' ' + QTD_FUNCAO) FUNCAO, 
		MATRICULA,
		SERVIDOR,
		EMAIL, 
		TELEFONE_DOC,
		CELULAR_DOC,
		ACESSO_CONEXAO,
		UA_ATUAL,
		UA_11_DIGITOS
FROM(

SELECT	DISTINCT REGIONAL, 
		MUNICIPIO, UA, 
		CENSO, 
		ESCOLA,
		CLASSIFICACAO_UE,
		ENDERECO,
		NUMERO,
		COMPLEMENTO,
		BAIRRO,
		TELEFONE_UE1,
		TELEFONE_UE2,	
		CODIGO_FUNC,
		FUNCAO_DESC,
		ISNULL( 
			CONVERT (VARCHAR, 
				CASE WHEN CODIGO_FUNC IN (11,13,18) 
					THEN RANK() OVER (PARTITION BY CODIGO_FUNC, CENSO ORDER BY MATRICULA) 
					ELSE NULL 
				END), '') 
		AS QTD_FUNCAO,
		MATRICULA,
		SERVIDOR,
		EMAIL, 
		TELEFONE_DOC,
		CELULAR_DOC,
		ACESSO_CONEXAO,
		UA_ATUAL,
		UA_11_DIGITOS
FROM(

SELECT  DISTINCT 
		A.REGIONAL REGIONAL,
		A.MUNICIPIO,
		--A.UA,
		VWS.UA_ANTIGA UA,
        A.CENSO,
        A.UNIDADE ESCOLA,
        LUE.CLASSIFICACAO CLASSIFICACAO_UE,
        UPPER (LUF.ENDERECO) ENDERECO,
        ISNULL (LUF.END_NUM, '') NUMERO,
        ISNULL (UPPER (LUF.END_COMPL), '') COMPLEMENTO,
        UPPER ( B.DESCRICAO ) BAIRRO,
        ISNULL (LUE.FONE, '') TELEFONE_UE1,
        ISNULL (LUE.FAX, '') TELEFONE_UE2,
		CASE A.COD_FUNCAO
			WHEN '10091' THEN '14'
			WHEN '10092' THEN '13'
			WHEN '10146' THEN '11'
			WHEN '10147' THEN '18'
			ELSE A.COD_FUNCAO
		END CODIGO_FUNC,
        CASE A.FUNCAO 
			WHEN 'DIRETOR DE ESCOLA - PROVISÓRIO' THEN 'DIRETOR DE ESCOLA'
			WHEN 'DIRETOR ADJUNTO - PROVISÓRIO' THEN 'DIRETOR ADJUNTO'
			WHEN 'COORDENADOR PEDAGÓGICO - PROVISÓRIO' THEN 'COORDENADOR PEDAGÓGICO'
			WHEN 'ORIENTADOR EDUCACIONAL - PROVISÓRIO' THEN 'ORIENTADOR EDUCACIONAL'
			ELSE A.FUNCAO  
		END FUNCAO_DESC,
        CASE WHEN LS.DTFIM &gt;= GETDATE() 
				THEN '*' + A.MATRICULA 
				ELSE A.MATRICULA 
		END MATRICULA,
        A.NOME SERVIDOR,
        ISNULL (LP.E_MAIL, '') EMAIL,
        ISNULL (LP.FONE, '') TELEFONE_DOC,
        ISNULL (LP.CELULAR, '') CELULAR_DOC,
        ISNULL (HU.HABILITADO, 'N') ACESSO_CONEXAO,
	VWS.UA_ATUAL,
	VWS.UA_11_DIGITOS
FROM    APOLLO..REL_SERVIDORES_ATIVOS A (NOLOCK)
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = A.PESSOA
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = A.CENSO
JOIN	LY_UNIDADES_ASSOCIADAS LUA (NOLOCK) ON LUA.UNIDADE_ENS = LUE.UNIDADE_ENS
JOIN	LY_UNIDADE_FISICA LUF (NOLOCK) ON LUF.UNIDADE_FIS = LUA.UNIDADE_FIS
LEFT	JOIN HADES..HD_USUARIO HU (NOLOCK) ON HU.USUARIO = A.MATRICULA
LEFT JOIN HADES..BAIRRO B ON B.CODIGO = LUE.BAIRRO
LEFT	JOIN (SELECT *
             FROM   (SELECT DD.PESSOA, LLD.NUM_FUNC, DTINI, DTFIM, MOTIVO
                     FROM   LY_LICENCA_DOCENTE LLD (NOLOCK)
                     JOIN	LY_DOCENTE DD (NOLOCK) ON DD.NUM_FUNC = LLD.NUM_FUNC
                     WHERE  DTFIM &gt;= GETDATE()
                     UNION
                     SELECT LLP.PESSOA, NULL, DTINI, DTFIM, MOTIVO
                     FROM   LY_LICENCA_PESSOA LLP (NOLOCK)
                     WHERE  DTFIM &gt;= GETDATE()
                       ) LS
              ) LS
         ON LS.PESSOA = LP.PESSOA
	 JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR
WHERE   A.COD_FUNCAO IN 
		('14', '10091', -- DIRETOR DE ESCOLA MÁXIMO UM POR ESCOLA
		'13', '10092', -- DIRETOR ADJUNTO MÁXIMO TRES POR ESCOLA
		'26', -- SECRETÁRIO MÁXIMO UM POR ESCOLA
		'11', '10146', -- COORDENADOR PEDAGÓGICO MÁXIMO DOIS POR ESCOLA
		'18', '10147', -- ORIENTADOR EDUCACIONAL MÁXIMO DOIS POR ESCOLA
		'1') -- AGENTE DE PESSOAL MÁXIMO UM POR ESCOLA
		
AND		A.ID_REGIONAL = ISNULL(@REGIONAL, A.ID_REGIONAL)
AND		A.COD_MUNICIPIO = ISNULL(@MUNICIPIO, A.COD_MUNICIPIO)
AND		LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS)

)SQL1
)SQL2</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO_FUNC">
          <DataField>CODIGO_FUNC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CLASSIFICACAO_UE">
          <DataField>CLASSIFICACAO_UE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ENDERECO">
          <DataField>ENDERECO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NUMERO">
          <DataField>NUMERO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
