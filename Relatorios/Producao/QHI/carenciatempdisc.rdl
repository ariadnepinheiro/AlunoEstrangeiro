  <Description>Carência  por Disciplina</Description>
  <Author>Techne</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ecd23fea-0ebd-4ab6-963f-99ac80d750c6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@TIPO">
            <Value>=Parameters!TIPO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@sit">
            <Value>=Parameters!sit.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@escola">
            <Value>=Parameters!escola.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--------------------------------------------------------------------------------------------------------------------------------------------------------------------
IF  @TIPO='1' --CARÊNCIA TEMP
BEGIN
			SELECT 
			SUBSTRING(N1.DESCRICAO,1,35) COORD,
			(SELECT NOME FROM MUNICIPIO WHERE L1.MUNICIPIO=CODIGO)MUNICIPIO,
			TIPO_CARENCIA,
			L1.SETOR UA,
			L1.UNIDADE_ENS UE,
			L1.NOME_COMP ESCOLA,
			SUM(D1.TEMPOS)TOTAL_AULA,
			D1.DISCIPLINA,
			D1.TURMA
			FROM LY_UNIDADE_ENSINO L1 (NOLOCK)
			JOIN APOLLO..REL_CARENCIA_DETALHE D1 (NOLOCK) ON D1.UNIDADE_ENS=L1.UNIDADE_ENS
		    JOIN (
					SELECT	UNIDADE_ENS,SITUACAO,MAX(ORDEM)ORDEM 
					FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) 
					GROUP BY UNIDADE_ENS,SITUACAO
				 )SS1                
			ON SS1.UNIDADE_ENS=L1.UNIDADE_ENS
			JOIN LY_NUCLEO N1 (NOLOCK) ON N1.NUCLEO=L1.NUCLEO
			WHERE 
			(L1.NUCLEO = ISNULL(@COORD, L1.NUCLEO) OR L1.NUCLEO IS NULL )
			AND 
			 (SS1.situacao=isnull(@sit,SS1.situacao)or SS1.situacao is null)
			AND
			(L1.MUNICIPIO= isnull (@MUNIC,L1.MUNICIPIO)or L1.MUNICIPIO is null)
			and 
			(D1.UNIDADE_ENS= isnull(@escola,D1.UNIDADE_ENS) or D1.UNIDADE_ENS is null)
			AND D1.TIPO_CARENCIA='CARÊNCIA TEMPORÁRIA'
			GROUP BY N1.DESCRICAO,L1.MUNICIPIO,L1.NOME_COMP,L1.SETOR,L1.UNIDADE_ENS,L1.NOME_COMP,D1.TURMA,D1.DISCIPLINA, D1.TIPO_CARENCIA
END
--------------------------------------------------------------------------------------------------------------------------------------------------------------------
IF @TIPO='2' --SEM PROF
	BEGIN
			SELECT 
			SUBSTRING(N1.DESCRICAO,1,35) COORD,
			(SELECT NOME FROM MUNICIPIO WHERE L1.MUNICIPIO=CODIGO)MUNICIPIO,
			TIPO_CARENCIA,
			L1.SETOR UA,
			L1.UNIDADE_ENS UE,
			L1.NOME_COMP ESCOLA,
			SUM(D1.TEMPOS)TOTAL_AULA,
			D1.DISCIPLINA,
			D1.TURMA
			FROM LY_UNIDADE_ENSINO L1 (NOLOCK)
			JOIN APOLLO..REL_CARENCIA_DETALHE D1 (NOLOCK) ON D1.UNIDADE_ENS=L1.UNIDADE_ENS
		    JOIN (
					SELECT	UNIDADE_ENS,SITUACAO,MAX(ORDEM)ORDEM 
					FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) 
					GROUP BY UNIDADE_ENS,SITUACAO
				 )SS1                
			ON SS1.UNIDADE_ENS=L1.UNIDADE_ENS
			JOIN LY_NUCLEO N1 (NOLOCK) ON N1.NUCLEO=L1.NUCLEO
			WHERE 
			(L1.NUCLEO = ISNULL(@COORD, L1.NUCLEO) OR L1.NUCLEO IS NULL )
			AND 
			 (SS1.situacao=isnull(@sit,SS1.situacao)or SS1.situacao is null)
			AND
			(L1.MUNICIPIO= isnull (@MUNIC,L1.MUNICIPIO)or L1.MUNICIPIO is null)
			and 
			(D1.UNIDADE_ENS= isnull(@escola,D1.UNIDADE_ENS) or D1.UNIDADE_ENS is null)
			AND D1.TIPO_CARENCIA='CARÊNCIA REAL'
			GROUP BY N1.DESCRICAO,L1.MUNICIPIO,L1.NOME_COMP,L1.SETOR,L1.UNIDADE_ENS,L1.NOME_COMP,D1.TURMA,D1.DISCIPLINA, D1.TIPO_CARENCIA
END
--------------------------------------------------------------------------------------------------------------------------------------------------------------------
IF @TIPO='3' -- TODOS
BEGIN
			SELECT 
			SUBSTRING(N1.DESCRICAO,1,35) COORD,
			(SELECT NOME FROM MUNICIPIO WHERE L1.MUNICIPIO=CODIGO)MUNICIPIO,
			TIPO_CARENCIA,
			L1.SETOR UA,
			L1.UNIDADE_ENS UE,
			L1.NOME_COMP ESCOLA,
			SUM(D1.TEMPOS)TOTAL_AULA,
			D1.DISCIPLINA,
			D1.TURMA
			FROM LY_UNIDADE_ENSINO L1 (NOLOCK)
			JOIN APOLLO..REL_CARENCIA_DETALHE D1 (NOLOCK) ON D1.UNIDADE_ENS=L1.UNIDADE_ENS
		    JOIN (
					SELECT	UNIDADE_ENS,SITUACAO,MAX(ORDEM)ORDEM 
					FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) 
					GROUP BY UNIDADE_ENS,SITUACAO
				 )SS1                
			ON SS1.UNIDADE_ENS=L1.UNIDADE_ENS
			JOIN LY_NUCLEO N1 (NOLOCK) ON N1.NUCLEO=L1.NUCLEO
			WHERE 
			(L1.NUCLEO = ISNULL(@COORD, L1.NUCLEO) OR L1.NUCLEO IS NULL )
			AND 
			 (SS1.situacao=isnull(@sit,SS1.situacao)or SS1.situacao is null)
			AND
			(L1.MUNICIPIO= isnull (@MUNIC,L1.MUNICIPIO)or L1.MUNICIPIO is null)
			and 
			(D1.UNIDADE_ENS= isnull(@escola,D1.UNIDADE_ENS) or D1.UNIDADE_ENS is null)
			AND D1.TIPO_CARENCIA IN ('CARÊNCIA TEMPORÁRIA','CARÊNCIA REAL') 
			GROUP BY N1.DESCRICAO,L1.MUNICIPIO,L1.NOME_COMP,L1.SETOR,L1.UNIDADE_ENS,L1.NOME_COMP,D1.TURMA,D1.DISCIPLINA, D1.TIPO_CARENCIA
END</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="COORD">
          <DataField>COORD</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO_CARENCIA">
          <DataField>TIPO_CARENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE">
          <DataField>UE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_AULA">
          <DataField>TOTAL_AULA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="coord">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null nucleo,' TODAS'descricao 
union
select 'NULO' nucleo,' Selecione...'descricao
union
select distinct  l1.NUCLEO,SUBSTRING(l1.descricao,1,35)descricao from ly_nucleo L1
join LY_UNIDADE_ENSINO l2 on L1.NUCLEO=l2.NUCLEO
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="municipio">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join LY_NUCLEO n1 on n1.NUCLEO=l2.NUCLEO

where 
	(n1.NUCLEO = ISNULL(@COORD,n1.NUCLEO)or n1.NUCLEO is null)


union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' nome  
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@munic">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
where (ue.NUCLEO = ISNULL(@COORD,ue.NUCLEO) or ue.NUCLEO is null)
AND (ue.MUNICIPIO = ISNULL(@munic,ue.municipio)or ue.MUNICIPIO is null)

order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome_comp">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DATA_ATUALIZACAO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 2</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
