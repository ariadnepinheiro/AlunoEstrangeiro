  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ac19201d-3368-4dcf-a397-343724ccd0a3</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLARIDADE">
            <Value>=Parameters!ESCOLARIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @ESCOLARIDADE IS NULL
BEGIN
	SELECT DISTINCT
			LAD.DIA_SEMANA AS NUM_SEMANA,
			CASE LAD.DIA_SEMANA 
				WHEN '2' THEN 'SEGUNDA'
				WHEN '3' THEN 'TERÇA'
				WHEN '4' THEN 'QUARTA'
				WHEN '5' THEN 'QUINTA'
				WHEN '6' THEN 'SEXTA' END
			AS DIA_SEMANA,
			LEFT(LT.TURMA, LEN(LT.TURMA) - CHARINDEX('-', REVERSE(LAD.TURMA))) AS TURMA,
			UPPER ((ISNULL(LD.MATRICULA + ' - ', '') + PE.NOME_COMPL + ' - ' + UPPER (LDI.NOME) + ' ' + ISNULL (LADT.TIPO_AULA, ISNULL (LAD.TIPO, 
			CASE LD.MATRICULA
			WHEN '00000000' THEN ''
			WHEN '99999999' THEN ''
			ELSE 'NORMAL' END)))) 
			AS NOME_DOCENTE,
			CONVERT (CHAR(5), LHA.HORAINI_AULA, 108) AS HORA_INICIO,
			CONVERT (CHAR(5), LHA.HORAFIM_AULA, 108) AS HORA_FIM
	FROM    LY_AULA_DOCENTE LAD WITH (NOLOCK)
			LEFT JOIN LY_AULA_DOCENTE_TIPO LADT WITH (NOLOCK) ON LADT.TURNO = LAD.TURNO
						 AND LADT.FACULDADE = LAD.FACULDADE
						 AND LADT.DIA_SEMANA = LAD.DIA_SEMANA
						 AND LADT.AULA = LAD.AULA
						 AND LADT.DISCIPLINA = LAD.DISCIPLINA
						 AND LADT.TURMA = LAD.TURMA
						 AND LADT.ANO = LAD.ANO
						 AND LADT.SEMESTRE = LAD.SEMESTRE
						 AND LADT.NUM_FUNC = LAD.NUM_FUNC
						 AND LADT.TIPO_AULA = 'GLP'
			JOIN LY_HOR_AULA LHA WITH (NOLOCK) ON LHA.TURNO = LAD.TURNO
						 AND LHA.FACULDADE = LAD.FACULDADE
						 AND LHA.DIA_SEMANA = LAD.DIA_SEMANA
						 AND LHA.AULA = LAD.AULA
						 AND LHA.DISCIPLINA = LAD.DISCIPLINA
						 AND LHA.TURMA = LAD.TURMA
						 AND LHA.ANO = LAD.ANO
						 AND LHA.SEMESTRE = LAD.SEMESTRE
			JOIN LY_DOCENTE LD (NOLOCK) ON LD.NUM_FUNC = LAD.NUM_FUNC
			JOIN LY_PESSOA PE (NOLOCK) ON LD.PESSOA = PE.PESSOA
			JOIN LY_TURMA LT (NOLOCK) ON LT.TURMA = LAD.TURMA
						 AND LT.DT_FIM = LAD.DATA_FIM
						 AND LT.DISCIPLINA = LAD.DISCIPLINA
						 AND LT.ANO = LAD.ANO
						 AND LT.SEMESTRE = LAD.SEMESTRE
						 AND LT.SIT_TURMA = 'Aberta'
			--JOIN LY_SERIE LS ON LS.CURSO = LT.CURSO
			--	AND LS.TURNO = LT.TURNO						
			--	AND LS.CURRICULO = LT.CURRICULO	
			--	AND LS.SERIE = LT.SERIE
			--JOIN LY_CURSO LC ON LC.CURSO = LS.CURSO 
			JOIN LY_DISCIPLINA LDI (NOLOCK) ON LDI.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)

	WHERE   LAD.FACULDADE = @ESCOLA 
			AND LT.TURNO = @TURNO
			AND LAD.ANO = YEAR (GETDATE()) 
END
ELSE
BEGIN
	SELECT DISTINCT
			LAD.DIA_SEMANA AS NUM_SEMANA,
			CASE LAD.DIA_SEMANA 
				WHEN '2' THEN 'SEGUNDA'
				WHEN '3' THEN 'TERÇA'
				WHEN '4' THEN 'QUARTA'
				WHEN '5' THEN 'QUINTA'
				WHEN '6' THEN 'SEXTA' END
			AS DIA_SEMANA,
			LEFT(LT.TURMA, LEN(LT.TURMA) - CHARINDEX('-', REVERSE(LAD.TURMA))) AS TURMA,
			UPPER ((ISNULL(LD.MATRICULA + ' - ', '') + PE.NOME_COMPL + ' - ' + UPPER (LDI.NOME) + ' ' + ISNULL (LADT.TIPO_AULA, ISNULL (LAD.TIPO, 
			CASE LD.MATRICULA
			WHEN '00000000' THEN ''
			WHEN '99999999' THEN ''
			ELSE 'NORMAL' END)))) 
			AS NOME_DOCENTE,
			CONVERT (CHAR(5), LHA.HORAINI_AULA, 108) AS HORA_INICIO,
			CONVERT (CHAR(5), LHA.HORAFIM_AULA, 108) AS HORA_FIM
	FROM    LY_AULA_DOCENTE LAD WITH (NOLOCK)
			LEFT JOIN LY_AULA_DOCENTE_TIPO LADT WITH (NOLOCK) ON LADT.TURNO = LAD.TURNO
						 AND LADT.FACULDADE = LAD.FACULDADE
						 AND LADT.DIA_SEMANA = LAD.DIA_SEMANA
						 AND LADT.AULA = LAD.AULA
						 AND LADT.DISCIPLINA = LAD.DISCIPLINA
						 AND LADT.TURMA = LAD.TURMA
						 AND LADT.ANO = LAD.ANO
						 AND LADT.SEMESTRE = LAD.SEMESTRE
						 AND LADT.NUM_FUNC = LAD.NUM_FUNC
						 AND LADT.TIPO_AULA = 'GLP'
			JOIN LY_HOR_AULA LHA WITH (NOLOCK) ON LHA.TURNO = LAD.TURNO
						 AND LHA.FACULDADE = LAD.FACULDADE
						 AND LHA.DIA_SEMANA = LAD.DIA_SEMANA
						 AND LHA.AULA = LAD.AULA
						 AND LHA.DISCIPLINA = LAD.DISCIPLINA
						 AND LHA.TURMA = LAD.TURMA
						 AND LHA.ANO = LAD.ANO
						 AND LHA.SEMESTRE = LAD.SEMESTRE
			JOIN LY_DOCENTE LD (NOLOCK) ON LD.NUM_FUNC = LAD.NUM_FUNC
			JOIN LY_PESSOA PE (NOLOCK) ON LD.PESSOA = PE.PESSOA
			JOIN LY_TURMA LT (NOLOCK) ON LT.TURMA = LAD.TURMA
						 AND LT.DT_FIM = LAD.DATA_FIM
						 AND LT.DISCIPLINA = LAD.DISCIPLINA
						 AND LT.ANO = LAD.ANO
						 AND LT.SEMESTRE = LAD.SEMESTRE
						 AND LT.SIT_TURMA = 'Aberta'
			JOIN LY_SERIE LS ON LS.CURSO = LT.CURSO
				AND LS.TURNO = LT.TURNO						
				AND LS.CURRICULO = LT.CURRICULO	
				AND LS.SERIE = LT.SERIE
			JOIN LY_CURSO LC ON LC.CURSO = LS.CURSO 
			JOIN LY_DISCIPLINA LDI (NOLOCK) ON LDI.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)

	WHERE   
			LAD.FACULDADE = @ESCOLA
			AND LT.TURNO = @TURNO
			AND LAD.ANO = YEAR (GETDATE()) 
			AND LC.CURSO = @ESCOLARIDADE
END</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NUM_SEMANA">
          <DataField>NUM_SEMANA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DIA_SEMANA">
          <DataField>DIA_SEMANA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA_INICIO">
          <DataField>HORA_INICIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA_FIM">
          <DataField>HORA_FIM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT NULL ID_REGIONAL,' Selecione...' REGIONAL
UNION 
SELECT DISTINCT R.ID_REGIONAL, SUBSTRING(R.REGIONAL,1,35) AS REGIONAL
FROM TCE_REGIONAL R (NOLOCK)
JOIN LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.ID_REGIONAL = R.ID_REGIONAL
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Município">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'NULO' CODIGO,' Selecione...' NOME
UNION
SELECT 	DISTINCT CODIGO, NOME 
FROM 	MUNICIPIO M (NOLOCK)
JOIN 	LY_UNIDADE_ENSINO UE (NOLOCK) ON UE.MUNICIPIO = M.CODIGO
WHERE 	UE.ID_REGIONAL = @REGIONAL
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'NULO' UNIDADE_ENS,' Selecione...' NOME_COMP
UNION
SELECT UE.UNIDADE_ENS, UE.NOME_COMP
FROM LY_UNIDADE_ENSINO UE
JOIN MUNICIPIO M ON M.CODIGO = UE.MUNICIPIO
			AND M.CODIGO = @MUNICIPIO
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = UE.ID_REGIONAL
			AND R.ID_REGIONAL = @REGIONAL
WHERE
EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
						(
						SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
						FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
						)
				)
		AND (UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escolaridade">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'NULO' CURSO,' Selecione...' NOME
UNION
SELECT NULL CURSO,' TODAS' NOME
UNION
SELECT DISTINCT
LC.CURSO
,LC.NOME
FROM LY_UNIDADE_ENSINO LUE 
INNER JOIN LY_TURMA LT ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
			AND LUE.UNIDADE_ENS = @ESCOLA
			AND LT.ANO = YEAR(GETDATE())
			AND LT.SIT_TURMA = 'ABERTA'
INNER JOIN LY_SERIE LS ON LS.CURSO = LT.CURSO
			AND LS.TURNO = LT.TURNO						
			AND LS.CURRICULO = LT.CURRICULO	
			AND LS.SERIE = LT.SERIE
INNER JOIN LY_CURSO LC ON LC.CURSO = LS.CURSO 
INNER JOIN LY_TURNO LTU ON LTU.TURNO = LT.TURNO
			AND LTU.TURNO = @TURNO
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="curso">
          <DataField>CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Turno">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'NULO' TURNO,' Selecione...' DESCRICAO
UNION
SELECT DISTINCT
LT.TURNO
,LTU.DESCRICAO
FROM LY_UNIDADE_ENSINO LUE 
INNER JOIN LY_TURMA LT ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
				AND LUE.UNIDADE_ENS = @ESCOLA
				AND LT.ANO = YEAR(GETDATE())
INNER JOIN LY_SERIE LS ON LS.CURSO = LT.CURSO
			AND LS.TURNO = LT.TURNO						
			AND LS.CURRICULO = LT.CURRICULO	
			AND LS.SERIE = LT.SERIE
INNER JOIN LY_CURSO LC ON LC.CURSO = LS.CURSO
INNER JOIN LY_TURNO LTU ON LTU.TURNO = LT.TURNO

ORDER BY DESCRICAO</CommandText>
      </Query>
      <Fields>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
