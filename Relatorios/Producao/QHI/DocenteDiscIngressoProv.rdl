  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>6f682ed2-d540-4886-a298-ebe63e6a395d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT 
		LD.NUM_FUNC, 
		LD.MATRICULA,	
		LP.NOME_COMPL,
		LCD.NOME CARGO,		
		LF.FUNCAO COD_FUNCAO,
		LF.DESCRICAO FUNCAO,
		LI.DESCRICAO LICENCA,		
		LUE.ID_REGIONAL,
		REGIONAL,
		ISNULL (LUE.NOME_COMP, S.NOMESETOR) UNIDADE,
		LL.SETOR,
		VWS.UA_ATUAL,
		VWS.UA_11_DIGITOS,
		M.CODIGO COD_MUNICIPIO,
		M.NOME MUNICIPIO,
		LUE.UNIDADE_ENS CENSO,	
		LP.CPF,	
		isnull(LP.IDFUNCIONAL,SS.ID_FUNCIONAL) ID_FUNCIONAL, 
		isnull(LD.VINCULO,SS.VINCULO) VINCULO ,	
		LP.PESSOA,
		HB.DISC_INGRESSO,		
		HPB.DISC_PROVISORIA,
		HB2.DISC_INGRESSO AS DISC_HAB_MATR
	
FROM	LY_DOCENTE LD (NOLOCK)
JOIN	LY_PESSOA LP (NOLOCK) ON LD.PESSOA = LP.PESSOA
JOIN	LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
				AND LL.PESSOA = LD.PESSOA	
					AND LL.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
						AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt; CONVERT(DATE, GETDATE()))									
JOIN	LY_FUNCAO LF (NOLOCK) ON LF.FUNCAO = LL.FUNCAO
LEFT	JOIN LY_CATEGORIA_DOCENTE LCD (NOLOCK) ON LCD.CATEGORIA = LD.CATEGORIA 
JOIN	SETOR S (NOLOCK) ON S.SETOR = LL.SETOR                
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.SETOR = S.SETOR
JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
JOIN	LY_UNIDADE_ENSINO_SITUACAO LUES (NOLOCK) ON LUES.UNIDADE_ENS = LUE.UNIDADE_ENS
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LL.SETOR
				AND LUES.DT_SITUACAO = (
								SELECT	MAX(DT_SITUACAO)
								FROM	LY_UNIDADE_ENSINO_SITUACAO L1 (NOLOCK)
								WHERE	L1.UNIDADE_ENS = LUE.UNIDADE_ENS)
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
LEFT	JOIN MUNICIPIO MM (NOLOCK) ON MM.CODIGO = LP.END_MUNICIPIO
LEFT	JOIN (	
				SELECT	MAX(DE.DTFIM) DTFIM, DE.NUM_FUNC, MAX(DE.MOTIVO) MOTIVO, MAX(DE.DTINI) DTINI, MAX(LC.DESCRICAO) DESCRICAO
				FROM    LY_LICENCA_DOCENTE DE (NOLOCK)
				JOIN	LY_LICENCAS LC (NOLOCK) ON LC.MOTIVO = DE.MOTIVO
				WHERE   DE.DTINI &lt;= CONVERT(DATE, CURRENT_TIMESTAMP)
				AND		(DE.DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP) OR DE.DTFIM IS NULL )
				GROUP	BY DE.NUM_FUNC
			)LI ON LI.NUM_FUNC = LD.NUM_FUNC
LEFT	JOIN (
				SELECT	distinct H1.DESCRICAO DISC_INGRESSO, H2.NUM_FUNC
				FROM    LY_GRUPO_HABILITACAO H1 (NOLOCK)
				JOIN	LY_GRUPO_HABILITACAO_DOC H2 (NOLOCK) ON H1.AGRUPAMENTO = H2.AGRUPAMENTO
				WHERE   H2.AGRUPAMENTO_INGRESSO = 'S'
				)HB ON HB.NUM_FUNC = LD.NUM_FUNC   
LEFT	JOIN (
				SELECT	distinct HP.DESCRICAO DISC_PROVISORIA, HP2.NUM_FUNC
				FROM    LY_GRUPO_HABILITACAO HP (NOLOCK)
				JOIN	LY_GRUPO_HABILITACAO_DOC HP2 (NOLOCK) ON HP.AGRUPAMENTO = HP2.AGRUPAMENTO
				WHERE   HP2.PROVISORIO = 'S' and DT_LIMITE &gt;= convert(date,GETDATE())
				)HPB ON HPB.NUM_FUNC = LD.NUM_FUNC   
LEFT	JOIN APOLLO..SIGRH SS ON SS.MATRICULA = LD.MATRICULA 
LEFT	JOIN (
				SELECT	distinct H2.DESCRICAO DISC_INGRESSO, H3.NUM_FUNC
				FROM    LY_GRUPO_HABILITACAO H2 (NOLOCK)
				JOIN	LY_GRUPO_HABILITACAO_DOC H3 (NOLOCK) ON H2.AGRUPAMENTO = H3.AGRUPAMENTO
				WHERE   H3.AGRUPAMENTO_INGRESSO &lt;&gt; 'S'
				)HB2 ON HB2.NUM_FUNC = LD.NUM_FUNC 
WHERE   (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)
AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL) 
ORDER BY REGIONAL,MUNICIPIO,UNIDADE,NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
