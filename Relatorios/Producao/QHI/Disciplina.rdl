  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>65896895-609f-41b0-9df2-51cc744f64e0</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT UPPER(NOME)      AS NOME_DISCIPLINA,
	   D.DISCIPLINA				 AS CODIGO_DISCIPLINA,
       UPPER(isnull(I.DESCR, COMPONENTE))         AS COMPONENTE,
       UPPER(AREA_CONHECIMENTO)  AS AREA_CONHECIMENTO,
       NOME_FANTASIA             AS CODIGO_SARE,
       MULTIPLA,
       HORAS_AULA,
       AULAS_SEMANAIS,
       TEM_NOTA,
       TEM_FREQ,
	   ISNULL((SELECT TOP 1 'SIM' 
					FROM LY_GRADE G 
					INNER JOIN LY_CURRICULO C ON C.CURRICULO=G.CURRICULO 
								AND g.DISCIPLINA = D.DISCIPLINA 
								AND (DT_EXTINCAO IS NULL 
									OR DT_EXTINCAO &gt;= GETDATE())),'NÃO') AS ATIVO_MATRIZ,
	   CASE
		WHEN GD.AGRUPAMENTO IS NULL THEN 'NÃO'
		ELSE 'SIM'
	   END POSSUIAGRUPAMENTO
FROM   LY_DISCIPLINA D 
		LEFT JOIN ITEMTABELA I ON I.TAB = 'ComponenteDisciplina' AND ITEM = D.COMPONENTE
	   LEFT JOIN LY_GRUPO_HABILITACAO_DISC GD ON GD.DISCIPLINA = D.DISCIPLINA
ORDER  BY Upper(NOME)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
