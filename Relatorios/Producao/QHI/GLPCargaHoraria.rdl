  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CargaHoraria">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@UNIDADE_ENS">
            <Value>=Parameters!UNIDADE_ENS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@COMPONENTE">
            <Value>=Parameters!COMPONENTE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AGRUPAMENTO">
            <Value>=Parameters!AGRUPAMENTO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MESMA_UNIDADE_ENS">
            <Value>=Parameters!MESMA_UNIDADE_ENS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MESMO_MUNICIPIO">
            <Value>=Parameters!MESMO_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MESMA_REGIONAL">
            <Value>=Parameters!MESMA_REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OUTRA_REGIONAL">
            <Value>=Parameters!OUTRA_REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AGRUPAMENTO_INGRESSO">
            <Value>=Parameters!AGRUPAMENTO_INGRESSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>with lydoc (NUM_FUNC, MATRICULA, UNIDADE_ENS, DATA_NOMEACAO, SETOR, ID_REGIONAL, MUNICIPIO) 
as 
(
	SELECT distinct lyd.NUM_FUNC, lyl.MATRICULA, lyl.UNIDADE_ENS, lyl.DATA_NOMEACAO,  lyl.SETOR, 
	isnull(lyue.ID_REGIONAL, rs.REGIONALID) as ID_REGIONAL, lyue.MUNICIPIO
	FROM dbo.LY_LOTACAO lyl (nolock) 
	inner join dbo.LY_DOCENTE lyd (nolock) on lyl.MATRICULA = lyd.MATRICULA
	left join dbo.LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = lyl.UNIDADE_ENS
	left join hades..REGIONAL__SETOR rs (nolock) on lyl.SETOR = rs.SETORID
	WHERE
	(lyl.DATA_DESATIVACAO IS NULL OR CONVERT(DATE, lyl.DATA_DESATIVACAO) &gt; CONVERT(DATE, GETDATE()))
	AND CONVERT(DATE,lyl.DATA_NOMEACAO) &lt;= CONVERT(DATE,GETDATE())
)

select
glp1.DISPONIBILIDADEGLPID

, rel1.ID_REGIONAL
, rel1.REGIONAL
, rel1.COD_MUNICIPIO
, rel1.MUNICIPIO
, rel1.SETOR
, rel1.CENSO
, lydoc1.DATA_NOMEACAO
, rel1.MATRICULA
, rel1.CH_LOTACAO
, rel1.CARGO
, rel1.DISC_INGRESSO
, rel1.FUNCAO

, rel2.ID_REGIONAL as ID_REGIONAL_2
, rel2.REGIONAL as REGIONAL_2
, rel2.MUNICIPIO as MUNICIPIO_2
, rel2.SETOR as SETOR_2
, rel2.CENSO as CENSO_2
, lydoc2.DATA_NOMEACAO as DATA_NOMEACAO_2
, rel2.MATRICULA as MATRICULA_2
, rel2.CH_LOTACAO as CH_LOTACAO_2
, rel2.CARGO as CARGO_2
, rel2.DISC_INGRESSO as DISC_INGRESSO_2
, rel2.FUNCAO as FUNCAO_2

, rel1.CH_TOTAL

from 
APOLLO..REL_LOT_SIT_FUNC rel1 (nolock)
inner join RecursosHumanos.DISPONIBILIDADEGLP glp1 (nolock) on glp1.NUM_FUNC = rel1.NUM_FUNC
left join APOLLO..REL_LOT_SIT_FUNC rel2 (nolock) on rel1.MATRICULA = rel2.SEGUNDA_MATRICULA and rel1.NUM_FUNC = rel2.NUM_FUNC
left join RecursosHumanos.DISPONIBILIDADEGLP glp2 (nolock) on glp2.NUM_FUNC = rel2.NUM_FUNC
inner join lydoc as lydoc1 on lydoc1.NUM_FUNC = glp1.NUM_FUNC and lydoc1.SETOR = rel1.SETOR
left join lydoc as lydoc2 on lydoc2.NUM_FUNC = glp2.NUM_FUNC and lydoc2.SETOR = rel2.SETOR

where 1=1

and (exists(
	select top 1 1 
	from RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock) 
	inner join LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = u.UNIDADE_ENS
	where 1=1
	and u.DISPONIBILIDADEGLPID = glp1.DISPONIBILIDADEGLPID
	and lyue.ID_REGIONAL = @REGIONAL
) or @REGIONAL is null)

and (exists(
	select top 1 1 
	from RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock) 
	inner join LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = u.UNIDADE_ENS
	where 1=1
	and u.DISPONIBILIDADEGLPID = glp1.DISPONIBILIDADEGLPID
	and lyue.MUNICIPIO = @MUNICIPIO
) or @MUNICIPIO is null)

and (exists(
	select top 1 1 
	from RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock) 
	inner join LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = u.UNIDADE_ENS
	where 1=1
	and u.DISPONIBILIDADEGLPID = glp1.DISPONIBILIDADEGLPID
	and u.UNIDADE_ENS = @UNIDADE_ENS
) or @UNIDADE_ENS is null)

and (glp1.ANO = @ANO or @ANO is null)

and (exists (
	select top 1 1 
	from RecursosHumanos.DISPONIBILIDADEGLP_MODALIDADE m (nolock) 
	where 1=1
	and m.DISPONIBILIDADEGLPID = glp1.DISPONIBILIDADEGLPID 
	and m.MODALIDADE in (select value from string_split(@MODALIDADE, ','))
) or @MODALIDADE is null)

and (exists (
	select top 1 1 
	from LY_GRUPO_HABILITACAO_DISC lygd (nolock)
	inner join LY_DISCIPLINA lyd (nolock) on lygd.DISCIPLINA = lyd.DISCIPLINA
	where 1=1
	and glp1.AGRUPAMENTO = lygd.AGRUPAMENTO
	and lyd.COMPONENTE in (select value from string_split(@COMPONENTE, ','))
) or @COMPONENTE is null)

and (glp1.AGRUPAMENTO = @AGRUPAMENTO or @AGRUPAMENTO is null)

and (exists (
	select top 1 1 
	from RecursosHumanos.DISPONIBILIDADEGLP_TURNO t (nolock) 
	where 1=1
	and t.DISPONIBILIDADEGLPID = glp1.DISPONIBILIDADEGLPID 
	and t.TURNO in (select value from string_split(@TURNO, ','))
) or @TURNO is null)

and (case when exists (
	select top 1 1 
	from RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock)
	where 1=1
	and u.DISPONIBILIDADEGLPID = glp1.DISPONIBILIDADEGLPID 
	and u.UNIDADE_ENS = lydoc1.UNIDADE_ENS) then 1 else 0 end = @MESMA_UNIDADE_ENS 
or @MESMA_UNIDADE_ENS is null)

and (case when exists (
	select top 1 1 
	from RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock)
	inner join LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = u.UNIDADE_ENS
	where 1=1
	and u.DISPONIBILIDADEGLPID = glp1.DISPONIBILIDADEGLPID 
	and lyue.MUNICIPIO = lydoc1.MUNICIPIO) then 1 else 0 end = @MESMO_MUNICIPIO 
or @MESMO_MUNICIPIO is null)

and (case when exists (
	select top 1 1
	from RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock)
	inner join LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = u.UNIDADE_ENS
	where 1=1
	and lyue.ID_REGIONAL = lydoc1.ID_REGIONAL) then 1 else 0 end = @MESMA_REGIONAL 
or @MESMA_REGIONAL is null)

and (case when exists (
	select top 1 1
	from RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock)
	inner join LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = u.UNIDADE_ENS
	where 1=1
	and lyue.ID_REGIONAL &lt;&gt; lydoc1.ID_REGIONAL) then 1 else 0 end = @OUTRA_REGIONAL 
or @OUTRA_REGIONAL is null)

and (exists(
	select top 1 1 
	from LY_GRUPO_HABILITACAO_DOC lyghd (nolock) 
	where 1=1
	and glp1.AGRUPAMENTO = lyghd.AGRUPAMENTO 
	and glp1.NUM_FUNC = lyghd.NUM_FUNC 
	and (case when lyghd.AGRUPAMENTO_INGRESSO = 'S' then 1 else 0 end = @AGRUPAMENTO_INGRESSO or @AGRUPAMENTO_INGRESSO is null)
))</CommandText>
      </Query>
      <Fields>
        <Field Name="DISPONIBILIDADEGLPID">
          <DataField>DISPONIBILIDADEGLPID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COD_MUNICIPIO">
          <DataField>COD_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_NOMEACAO">
          <DataField>DATA_NOMEACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CH_LOTACAO">
          <DataField>CH_LOTACAO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DISC_INGRESSO">
          <DataField>DISC_INGRESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARGO">
          <DataField>CARGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_REGIONAL_2">
          <DataField>ID_REGIONAL_2</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL_2">
          <DataField>REGIONAL_2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO_2">
          <DataField>MUNICIPIO_2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR_2">
          <DataField>SETOR_2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO_2">
          <DataField>CENSO_2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_NOMEACAO_2">
          <DataField>DATA_NOMEACAO_2</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MATRICULA_2">
          <DataField>MATRICULA_2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
