  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT ARAI.*, VWS.UA_ATUAL , VWS.UA_ANTIGA, VWS.UA_11_DIGITOS FROM APOLLO..REL_ALOC_INDEVIDA ARAI
		  JOIN LY_UNIDADE_ENSINO UE (NOLOCK)
         ON UE.UNIDADE_ENS = ARAI.CENSO
		  JOIN    HADES..VW_SETOR VWS on VWS.SETOR = UE.SETOR
WHERE (ARAI.ID_REGIONAL = ISNULL(@REGIONAL, ARAI.ID_REGIONAL) OR ARAI.ID_REGIONAL IS NULL)
AND (COD_MUNICIPIO = ISNULL(@MUNICIPIO, COD_MUNICIPIO) OR COD_MUNICIPIO IS NULL)
AND (CENSO = ISNULL (@ESCOLA, CENSO) OR CENSO IS NULL)
AND QTD_CPF &gt; 1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
