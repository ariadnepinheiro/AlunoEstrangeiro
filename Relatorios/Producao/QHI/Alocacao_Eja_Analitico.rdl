  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>lyceum</DataSourceReference>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>080104a9-852c-4fa1-a82e-8f568367cd21</rd:DataSourceID>
