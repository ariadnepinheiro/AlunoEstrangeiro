  <DataSets>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null id_regional,' TODAS' regional
union
select  l1.id_regional,SUBSTRING(l1.regional,1,35) from tce_regional L1 (nolock)
join LY_UNIDADE_ENSINO l2 (nolock) on L1.id_regional=l2.id_regional
join MUNICIPIO m1 on m1.CODIGO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj (nolock) on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by regional</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="id_regional">
          <DataField>id_regional</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="regional">
          <DataField>regional</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Município">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct L1.codigo,L1.nome from LY_UNIDADE_ENSINO l2
join municipio l1 on l1.CODIGO=l2.MUNICIPIO
join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where 
	(n1.id_regional = ISNULL(@REGIONAL,n1.id_regional)or n1.id_regional is null)
	and
	(jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
union
select null codigo,' TODOS' nome  
union
select 'NULO' codigo,' Selecione...' descricao 
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP 
from LY_UNIDADE_ENSINO ue 
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = UE.ID_REGIONAL
join LY_USUARIO_UNIDADE_FIS gg on gg.UNIDADE_FIS=ue.UNIDADE_ENS
where (R.ID_REGIONAL = ISNULL(@REGIONAL,R.ID_REGIONAL) or R.ID_REGIONAL is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.municipio is null)
and (gg.USUARIO = ISNULL(@usuario,gg.usuario) OR gg.usuario IS NULL) 
order by NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, 
		SG.ID_FUNCIONAL, SG.VINCULO,
		D.MATRICULA, P.NOME_COMPL NOME_DOCENTE, P.CPF, P.E_MAIL, P.FONE, P.CELULAR, COUNT(DISTINCT AD.TURMA) AS NUM_TURMAS,
		T.SERIE MODULO, DD.NOME_COMPL DISCIPLINA, 
		COUNT(DISTINCT STR(t.ANO)+STR(t.SEMESTRE)+t.TURMA+STR(AD.AULA) + STR(AD.DIA_SEMANA)) CH_ALOCADA, 
		MIN(CONVERT(DATE, AD.DATA_INICIO)) PRIMEIRA_ALOCACAO
FROM	LY_TURMA T (NOLOCK) 
JOIN	LY_AULA_DOCENTE AD (NOLOCK) 
ON		AD.ANO = T.ANO
AND		AD.SEMESTRE = T.SEMESTRE
AND		AD.TURMA = T.TURMA
AND		AD.DISCIPLINA = T.DISCIPLINA
AND		AD.DATA_FIM = T.DT_FIM
JOIN	LY_DOCENTE D (NOLOCK)
ON		D.NUM_FUNC = AD.NUM_FUNC
JOIN	LY_PESSOA P (NOLOCK)
ON		P.PESSOA = D.PESSOA
JOIN	LY_UNIDADE_ENSINO UE
ON		UE.UNIDADE_ENS = T.UNIDADE_RESPONSAVEL
JOIN	TCE_REGIONAL R
ON		R.ID_REGIONAL = UE.ID_REGIONAL
JOIN	MUNICIPIO M (NOLOCK)
ON		M.CODIGO = UE.MUNICIPIO
JOIN	LY_DISCIPLINA DD (NOLOCK)
ON		DD.DISCIPLINA = ISNULL(T.DISCIPLINA_MULTIPLA, T.DISCIPLINA)
LEFT JOIN	APOLLO..SIGRH SG (NOLOCK) 
ON		SG.MATRICULA = D.MATRICULA
WHERE	T.CURSO = '0002.44'
AND		T.SIT_TURMA &lt;&gt; 'Desativada'
AND		T.ANO = @ANO
AND		T.SEMESTRE=@SEMESTRE
AND 	 (UE.UNIDADE_ENS = ISNULL(@ESCOLA,UE.UNIDADE_ENS) or UE.UNIDADE_ENS is null)
AND 	 (UE.ID_REGIONAL = ISNULL(@REGIONAL,UE.ID_REGIONAL) or UE.ID_REGIONAL is null)
AND 	 (UE.MUNICIPIO = ISNULL(@MUNICIPIO,UE.MUNICIPIO) or UE.MUNICIPIO is null)
GROUP BY R.REGIONAL, M.NOME, UE.UNIDADE_ENS, UE.NOME_COMP, 
		SG.ID_FUNCIONAL, SG.VINCULO,
		D.MATRICULA, P.NOME_COMPL, P.CPF, P.E_MAIL, P.FONE, P.CELULAR, 
		T.SERIE, DD.NOME_COMPL
ORDER BY P.NOME_COMPL</CommandText>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_FUNCIONAL">
          <DataField>ID_FUNCIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VINCULO">
          <DataField>VINCULO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="E_MAIL">
          <DataField>E_MAIL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FONE">
          <DataField>FONE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CELULAR">
          <DataField>CELULAR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODULO">
          <DataField>MODULO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NUM_TURMAS">
          <DataField>NUM_TURMAS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CH_ALOCADA">
          <DataField>CH_ALOCADA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PRIMEIRA_ALOCACAO">
          <DataField>PRIMEIRA_ALOCACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT DISTINCT ANO
FROM LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
