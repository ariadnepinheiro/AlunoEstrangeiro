    <DataSet Name="DataSet1">
      <Fields>
        <Field Name="ALUNO___FOTO">
          <DataField>ALUNO / FOTO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALUNO_C__CARTEIRINHA">
          <DataField>ALUNO C/ CARTEIRINHA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_DE_ALUNOS">
          <DataField>TOTAL DE ALUNOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_UA">
          <DataField>NOME UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE">
          <DataField>UE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_ESCOLA">
          <DataField>NOME ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORD_COD">
          <DataField>COORD_COD</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COORDENADORIA">
          <DataField>COORDENADORIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT     (SELECT     COUNT(ALUNO) AS Expr1
                       FROM          LY_ALUNO AS AM
                       WHERE      (UNIDADE_ENSINO = A2.UNIDADE_ENS) AND EXISTS
                                                  (SELECT     1 AS Expr1
                                                    FROM          LY_FOTO_PESSOA AS PW
                                                    WHERE      (PESSOA = AM.PESSOA))) AS [ALUNO / FOTO],
                          (SELECT     COUNT(ALUNO) AS Expr1
                            FROM          LY_ALUNO AS K1
                            WHERE      (UNIDADE_ENSINO = A2.UNIDADE_ENS) AND EXISTS
                                                       (SELECT     1 AS Expr1
                                                         FROM          LY_CARTEIRINHA AS CH
                                                         WHERE      (ALUNO = K1.ALUNO))) AS [ALUNO C/ CARTEIRINHA], COUNT(A1.ALUNO) AS [TOTAL DE ALUNOS], S1.SETOR AS UA, 
                      S1.NOMESETOR AS [NOME UA], A2.UNIDADE_ENS AS UE, A2.NOME_COMP AS [NOME ESCOLA], N1.NUCLEO AS COORD_COD, 
                      N1.DESCRICAO AS COORDENADORIA
FROM         LY_ALUNO AS A1 INNER JOIN
                      LY_UNIDADE_ENSINO AS A2 ON A1.UNIDADE_ENSINO = A2.UNIDADE_ENS INNER JOIN
                      SETOR AS S1 ON S1.SETOR = A2.SETOR INNER JOIN
                      LY_NUCLEO AS N1 ON N1.NUCLEO = A2.NUCLEO INNER JOIN
                      MUNICIPIO AS MM ON MM.CODIGO = A2.MUNICIPIO AND A2.MUNICIPIO = MM.CODIGO
WHERE     (MM.CODIGO = ISNULL(@municipio, MM.CODIGO)) OR
                      (MM.CODIGO IS NULL)
GROUP BY A2.UNIDADE_ENS, S1.SETOR, S1.NOMESETOR, A2.NOME_COMP, N1.NUCLEO, N1.DESCRICAO
ORDER BY COORDENADORIA, [NOME UA]</CommandText>
        <QueryParameters>
          <QueryParameter Name="@municipio">
            <Value>=Parameters!municipio.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="municipio">
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT CODIGO,NOME MUNICIPIO FROM MUNICIPIO
WHERE CODIGO IN (SELECT MUNICIPIO FROM LY_UNIDADE_ENSINO)
UNION
SELECT NULL CODIGO,' TODOS' MUNICIPIO
UNION
SELECT 'NULO' CODIGO,' Selecione...' MUNICIPIO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
