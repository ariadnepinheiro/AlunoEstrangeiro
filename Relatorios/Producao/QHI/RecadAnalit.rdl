    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:DataSourceID>05e0f559-4b17-4ccb-a5c0-e8be527e2ada</rd:DataSourceID>
    </DataSource>
  </DataSources>
