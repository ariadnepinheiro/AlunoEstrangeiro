  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT * FROM APOLLO..REL_GREVE_PROF_TURNO
WHERE (ID_REGIONAL = ISNULL(@REGIONAL, ID_REGIONAL) OR ID_REGIONAL IS NULL)
AND (COD_MUNICIPIO = ISNULL(@MUNICIPIO, COD_MUNICIPIO) OR COD_MUNICIPIO IS NULL)
AND (CENSO = ISNULL (@ESCOLA, CENSO) OR CENSO IS NULL)</CommandText>
      </Query>
