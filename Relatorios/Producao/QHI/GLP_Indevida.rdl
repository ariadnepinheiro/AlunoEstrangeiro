  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>080104a9-852c-4fa1-a82e-8f568367cd21</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT R.REGIONAL, 
		M.NOME MUNICIPIO, 
		LUE.UNIDADE_ENS CENSO, 
		LUE.NOME_COMP UNIDADE, 
		--LUE.SETOR UA,
		VWS.UA_ANTIGA UA,
		LT.ANO, 
		LT.SEMESTRE, 
		LT.TURMA, 
		UPPER (D.NOME) DISCIPLINA, 
		DD.MATRICULA, 
		PE.NOME_COMPL NOME_DOCENTE,
		VWS.UA_ATUAL,
		VWS.UA_11_DIGITOS,
		DD.VINCULO,
		PE.IDFUNCIONAL
FROM	LY_AULA_DOCENTE_TIPO LAD (NOLOCK)
JOIN	LY_TURMA LT (NOLOCK) ON LAD.ANO = LT.ANO
				AND LAD.SEMESTRE = LT.SEMESTRE
				AND LAD.DISCIPLINA = LT.DISCIPLINA
				AND LAD.TURMA = LT.TURMA
				AND LAD.DATA_FIM = LT.DT_FIM
				AND LT.ANO = @ANO
JOIN	LY_DISCIPLINA D (NOLOCK) ON D.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	LY_DOCENTE DD (NOLOCK) ON DD.NUM_FUNC = LAD.NUM_FUNC
JOIN	LY_PESSOA PE (NOLOCK) ON PE.PESSOA = DD.PESSOA
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR
WHERE	LAD.TIPO_AULA = 'GLP'
AND		LT.CURSO IN ('9999.99', '9999.94','9999.95','9999.96')
AND		LT.TURMA NOT LIKE 'LE-%' --'9999.99
AND		LT.TURMA NOT LIKE 'ER%' -- '9999.99
AND		LT.TURMA NOT LIKE 'SALA%' -- 9999.91
AND		LT.TURMA NOT LIKE 'SE%MULT%' -- 0093.29
AND		LT.TURMA NOT LIKE 'CEL-%' --'9999.99</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_DOCENTE">
          <DataField>NOME_DOCENTE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_ATUAL">
          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VINCULO">
          <DataField>VINCULO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UA_11_DIGITOS">
          <DataField>UA_11_DIGITOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IDFUNCIONAL">
          <DataField>IDFUNCIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>
SELECT  0 ANO, ' Selecione...' NOME
UNION
SELECT	DISTINCT CONVERT (VARCHAR(4), ANO) ANO, CONVERT (VARCHAR(4), ANO) NOME 
FROM	LY_PERIODO_LETIVO (NOLOCK) 
ORDER	BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
