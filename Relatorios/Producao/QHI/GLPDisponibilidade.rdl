  <DataSources>
    <DataSource Name="DS_ALUNOS">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>02095972-cbec-45ff-8576-26ea3f0d152c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Disponibilidade">
      <Query>
        <DataSourceName>DS_ALUNOS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@UNIDADE_ENS">
            <Value>=Parameters!UNIDADE_ENS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MODALIDADE">
            <Value>=Parameters!MODALIDADE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@COMPONENTE">
            <Value>=Parameters!COMPONENTE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AGRUPAMENTO">
            <Value>=Parameters!AGRUPAMENTO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURNO">
            <Value>=Parameters!TURNO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MESMA_UNIDADE_ENS">
            <Value>=Parameters!MESMA_UNIDADE_ENS.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MESMO_MUNICIPIO">
            <Value>=Parameters!MESMO_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MESMA_REGIONAL">
            <Value>=Parameters!MESMA_REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AGRUPAMENTO_INGRESSO">
            <Value>=Parameters!AGRUPAMENTO_INGRESSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OUTRA_REGIONAL">
            <Value>=Parameters!OUTRA_REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select distinct 
glp.DISPONIBILIDADEGLPID,
reg.ID_REGIONAL as POLO,
reg.REGIONAL,
mun.CODIGO,
mun.NOME as MUNICIPIO,
u.UNIDADE_ENS,
lyue.SETOR,
lyue.NOME_COMP as UNIDADE_ESCOLAR,
lygh.DESCRICAO as DISCIPLINA,

ltrim(STUFF((SELECT ', ' + m.MODALIDADE 
FROM RecursosHumanos.DISPONIBILIDADEGLP_MODALIDADE m
WHERE m.DISPONIBILIDADEGLPID = glp.DISPONIBILIDADEGLPID
FOR XML PATH('')), 1, 1, '')) as MODALIDADE,

ltrim(STUFF((SELECT ', ' + (case when d.DIASEMANA = 1 then 'DOM' when d.DIASEMANA = 2 then 'SEG' when d.DIASEMANA = 3 then 'TER' when d.DIASEMANA = 4 then 'QUA' when d.DIASEMANA = 5 then 'QUI' when d.DIASEMANA = 6 then 'SEX' when d.DIASEMANA = 7 then 'SAB' else null end)
FROM RecursosHumanos.DISPONIBILIDADEGLP_DIASEMANA d
WHERE d.DISPONIBILIDADEGLPID = glp.DISPONIBILIDADEGLPID
FOR XML PATH('')), 1, 1, '')) as DIASEMANA,

ltrim(STUFF((SELECT ', ' + t.TURNO
FROM RecursosHumanos.DISPONIBILIDADEGLP_TURNO t
WHERE t.DISPONIBILIDADEGLPID = glp.DISPONIBILIDADEGLPID
FOR XML PATH('')), 1, 1, '')) as TURNO,

convert(varchar, glp.DATACADASTRO, 103) as DATA,
format(glp.DATACADASTRO, 'HH:mm') as HORA

from 
RecursosHumanos.DISPONIBILIDADEGLP glp (nolock)
inner join RecursosHumanos.DISPONIBILIDADEGLP_UNIDADEENSINO u (nolock) on glp.DISPONIBILIDADEGLPID = u.DISPONIBILIDADEGLPID
inner join LY_GRUPO_HABILITACAO lygh (nolock) on glp.AGRUPAMENTO = lygh.AGRUPAMENTO
inner join LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = u.UNIDADE_ENS
inner join TCE_REGIONAL reg (nolock) on reg.ID_REGIONAL = lyue.ID_REGIONAL
inner join MUNICIPIO mun (nolock) on mun.CODIGO = lyue.MUNICIPIO
inner join (
	SELECT distinct lyd.NUM_FUNC, lyl.MATRICULA, lyl.UNIDADE_ENS, 
	isnull(lyue.ID_REGIONAL, rs.REGIONALID) as ID_REGIONAL, lyue.MUNICIPIO
	FROM dbo.LY_LOTACAO lyl (nolock) 
	inner join dbo.LY_DOCENTE lyd (nolock) on lyl.MATRICULA = lyd.MATRICULA
	left join dbo.LY_UNIDADE_ENSINO lyue (nolock) on lyue.UNIDADE_ENS = lyl.UNIDADE_ENS
	left join hades..REGIONAL__SETOR rs (nolock) on lyl.SETOR = rs.SETORID
	WHERE
	(lyl.DATA_DESATIVACAO IS NULL OR CONVERT(DATE, lyl.DATA_DESATIVACAO) &gt; CONVERT(DATE, GETDATE()))
	AND CONVERT(DATE,lyl.DATA_NOMEACAO) &lt;= CONVERT(DATE,GETDATE())
) lydoc on lydoc.NUM_FUNC = glp.NUM_FUNC

where 1=1
and (lyue.ID_REGIONAL = @REGIONAL or @REGIONAL is null)
and (lyue.MUNICIPIO = @MUNICIPIO or @MUNICIPIO is null)
and (lyue.UNIDADE_ENS = @UNIDADE_ENS or @UNIDADE_ENS is null)
and (glp.ANO = @ANO or @ANO is null)
and (exists (select top 1 1 from RecursosHumanos.DISPONIBILIDADEGLP_MODALIDADE m (nolock) where m.DISPONIBILIDADEGLPID = glp.DISPONIBILIDADEGLPID and m.MODALIDADE in (select value from string_split(@MODALIDADE, ','))) or @MODALIDADE is null)
and (exists (
	select top 1 1 from 
	LY_GRUPO_HABILITACAO_DISC lygd (nolock),
	LY_DISCIPLINA lyd (nolock)
	where 1=1
	and glp.AGRUPAMENTO = lygd.AGRUPAMENTO
	and lygd.DISCIPLINA = lyd.DISCIPLINA
	and lyd.COMPONENTE in (select value from string_split(@COMPONENTE, ','))
) or @COMPONENTE is null)
and (glp.AGRUPAMENTO = @AGRUPAMENTO or @AGRUPAMENTO is null)
and (exists (select top 1 1 from RecursosHumanos.DISPONIBILIDADEGLP_TURNO t (nolock) where t.DISPONIBILIDADEGLPID = glp.DISPONIBILIDADEGLPID and t.TURNO in (select value from string_split(@TURNO, ','))) or @TURNO is null)
and (case when u.UNIDADE_ENS = lydoc.UNIDADE_ENS then 1 else 0 end = @MESMA_UNIDADE_ENS or @MESMA_UNIDADE_ENS is null)
and (case when lyue.MUNICIPIO = lydoc.MUNICIPIO then 1 else 0 end = @MESMO_MUNICIPIO or @MESMO_MUNICIPIO is null)
and (case when lyue.ID_REGIONAL = lydoc.ID_REGIONAL then 1 else 0 end = @MESMA_REGIONAL or @MESMA_REGIONAL is null)
and (case when lyue.ID_REGIONAL &lt;&gt; lydoc.ID_REGIONAL then 1 else 0 end = @OUTRA_REGIONAL or @OUTRA_REGIONAL is null)
and (exists(select top 1 1 from LY_GRUPO_HABILITACAO_DOC lyghd (nolock) where glp.AGRUPAMENTO = lyghd.AGRUPAMENTO and glp.NUM_FUNC = lyghd.NUM_FUNC and (case when lyghd.AGRUPAMENTO_INGRESSO = 'S' then 1 else 0 end = @AGRUPAMENTO_INGRESSO or @AGRUPAMENTO_INGRESSO is null)))

group by 
glp.DISPONIBILIDADEGLPID,
reg.ID_REGIONAL,
reg.REGIONAL,
mun.CODIGO,
mun.NOME,
u.UNIDADE_ENS,
lyue.SETOR,
lyue.NOME_COMP,
lygh.DESCRICAO,
glp.DATACADASTRO</CommandText>
      </Query>
      <Fields>
        <Field Name="DISPONIBILIDADEGLPID">
          <DataField>DISPONIBILIDADEGLPID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="POLO">
          <DataField>POLO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SETOR">
          <DataField>SETOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE_ESCOLAR">
          <DataField>UNIDADE_ESCOLAR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MODALIDADE">
          <DataField>MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DIASEMANA">
          <DataField>DIASEMANA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
