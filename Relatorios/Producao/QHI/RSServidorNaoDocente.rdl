  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.12.18.10;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>14f6c4f5-6443-4849-9415-51a271cb9f30</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  REGIONAL ,
        MUNICIPIO ,
        UNIDADE ,
        UA ,
        MATRICULA ,
        NOME ,
        CARGO ,
    -- COMENTADO EM 14/01/2014
	--( 
	--	CASE WHEN ISNULL(AULAS_ALOCADAS, 0) &gt; 0 THEN 'REGENTE'
	--		 WHEN 'S' = CAMPO_01 AND A.FUNCAO &lt;&gt; '10052' THEN '   '
	--	ELSE A.FUNCAO
	--	END 
	--) FUNCAO ,
        F.DESCRICAO AS FUNCAO ,
        ISNULL(READAPTADO, 'N') READAPTADO ,
        DT_INICIO_READAPTACAO ,
        DT_FIM_READAPTACAO ,
    -- EXLUIR OS DOCENTES
    --AULAS_ALOCADAS ,
    --AULAS_ALOCADAS_GLP ,
        MOTIVO ,
        DESCRICAO_LICENCA ,
        DATAINI ,
        DATAFIM
FROM    ( SELECT DISTINCT
                    D.NUM_FUNC AS NUM_FUNC ,
                    L.MATRICULA AS MATRICULA ,
                    D.PESSOA AS PESSOA ,
                    PE.NOME_COMPL AS NOME ,
                    F.FUNCAO AS FUNCAO ,
                    D.CATEGORIA AS CARGO ,
                    L.DATA_DESATIVACAO AS DATA_DESATIVACAO ,
                    L.READAPTADO AS READAPTADO ,
                    L.DT_INICIO_READAPTACAO AS DT_INICIO_READAPTACAO ,
                    L.DT_FIM_READAPTACAO AS DT_FIM_READAPTACAO ,
                    GH.DESCRICAO AS DISCIPLINA ,
     -- AULAS ALOCADAS
                    ( SELECT    ( SELECT    COUNT(1)
                                  FROM      LY_AULA_DOCENTE AD
                                            JOIN LY_TURMA T ON AD.ANO = T.ANO
                                                              AND AD.SEMESTRE = T.SEMESTRE
                                                              AND AD.DISCIPLINA = T.DISCIPLINA
                                                              AND AD.FACULDADE = T.FACULDADE
                                                              AND AD.TURMA = T.TURMA
                                                              AND AD.TURNO = T.TURNO
                                                              AND AD.DATA_FIM = T.DT_FIM
                                  WHERE     AD.NUM_FUNC = D.NUM_FUNC
                                            AND T.SIT_TURMA = 'ABERTA'
                                            AND AD.DATA_FIM &gt;= CONVERT(DATE, GETDATE())
                                )
                                - ( SELECT  COUNT(1)
                                    FROM    LY_AULA_DOCENTE_TIPO AD
                                            JOIN LY_TURMA T ON AD.ANO = T.ANO
                                                              AND AD.SEMESTRE = T.SEMESTRE
                                                              AND AD.DISCIPLINA = T.DISCIPLINA
                                                              AND AD.FACULDADE = T.FACULDADE
                                                              AND AD.TURMA = T.TURMA
                                                              AND AD.TURNO = T.TURNO
                                                              AND AD.DATA_FIM = T.DT_FIM
                                    WHERE   AD.NUM_FUNC = D.NUM_FUNC
                                            AND T.SIT_TURMA = 'ABERTA'
                                            AND AD.DATA_FIM &gt;= CONVERT(DATE, GETDATE())
                                            AND AD.DATA_INICIO &lt;= CONVERT(DATE, GETDATE())
                                            AND AD.TIPO_AULA = 'GLP'
                                  )
                    ) AS AULAS_ALOCADAS ,
	-- AULAS ALOCADAS GLP
                    ( SELECT    COUNT(1)
                      FROM      LY_AULA_DOCENTE_TIPO AD
                                JOIN LY_TURMA T ON AD.ANO = T.ANO
                                                   AND AD.SEMESTRE = T.SEMESTRE
                                                   AND AD.DISCIPLINA = T.DISCIPLINA
                                                   AND AD.FACULDADE = T.FACULDADE
                                                   AND AD.TURMA = T.TURMA
                                                   AND AD.TURNO = T.TURNO
                                                   AND AD.DATA_FIM = T.DT_FIM
                      WHERE     AD.NUM_FUNC = D.NUM_FUNC
                                AND T.SIT_TURMA = 'ABERTA'
                                AND AD.DATA_FIM &gt;= CONVERT(DATE, GETDATE())
                                AND AD.DATA_INICIO &lt;= CONVERT(DATE, GETDATE())
                                AND AD.TIPO_AULA = 'GLP'
                    ) AS AULAS_ALOCADAS_GLP ,
	--LICENÇA
                    LIC.MOTIVO AS MOTIVO ,
	--DATA INÍCIO DA LICENÇA
                    LIC.DTINI AS DATAINI ,
	--DATA FIM DA LICENÇA
                    LIC.DTFIM AS DATAFIM ,
                    TR.REGIONAL ,
                    TM.NOME AS MUNICIPIO ,
                    UE.SETOR AS UA ,
                    UE.NOME_COMP AS UNIDADE ,
                    LIC.DESCRICAO AS DESCRICAO_LICENCA
          FROM      LY_LOTACAO L
                    JOIN LY_UNIDADE_ENSINO UE ON L.UNIDADE_ENS = UE.UNIDADE_ENS
                    JOIN LY_DOCENTE D ON L.MATRICULA = D.MATRICULA
                    JOIN LY_PESSOA PE ON PE.PESSOA = D.PESSOA
                    JOIN LY_FUNCAO F ON L.FUNCAO = F.FUNCAO
					 -- EXCLUINDO OS SERVIDORES COM CARGO DE PROFESSOR ('S' PARA REGENTE OU 'N' PARA NAO REGENTE)
                                        AND F.FUNCAO NOT IN ( SELECT
                                                              FUNCAO
                                                              FROM
                                                              LY_FUNCAO
                                                              WHERE
                                                              CAMPO_01 = 'S' )
                    LEFT JOIN ( SELECT  LD.NUM_FUNC ,
                                        LD.DTFIM ,
                                        LD.DTINI ,
                                        LD.MOTIVO + '|' + LI.POSSUI_DTFIM AS MOTIVO ,
                                        LI.DESCRICAO
                                FROM    LY_LICENCA_DOCENTE LD
                                        INNER JOIN LY_LICENCAS LI ON LI.MOTIVO = LD.MOTIVO
                                WHERE   ISNULL(LD.DTFIM, '') &gt;= ( CASE LI.POSSUI_DTFIM
                                                              WHEN 'N' THEN ''
                                                              ELSE CONVERT(DATE, GETDATE())
                                                              END )
						-- ALTERADO EM 15/01/2014 : OBTER SOMENTE A LICENÇA VIGENTE
                                        AND LD.DTINI = ( SELECT
                                                              MAX(LLD1.DTINI)
                                                         FROM LY_LICENCA_DOCENTE LLD1
                                                         WHERE
                                                              LLD1.NUM_FUNC = LD.NUM_FUNC
                                                              AND LD.DTFIM IS NULL
                                                       )
                              ) LIC ON LIC.NUM_FUNC = D.NUM_FUNC
                                       AND ( LIC.DTFIM IS NULL
                                             OR LIC.DTFIM = ( SELECT TOP 1
                                                              LD.DTFIM
                                                              FROM
                                                              LY_LICENCA_DOCENTE LD
                                                              WHERE
                                                              LD.NUM_FUNC = D.NUM_FUNC
                                                              ORDER BY DTFIM DESC
                                                            )
                                           )
                    LEFT JOIN LY_GRUPO_HABILITACAO_DOC GHD ON D.NUM_FUNC = GHD.NUM_FUNC
                                                              AND GHD.AGRUPAMENTO_INGRESSO = 'S'
                    LEFT JOIN LY_GRUPO_HABILITACAO GH ON GHD.AGRUPAMENTO = GH.AGRUPAMENTO
                    INNER JOIN TCE_REGIONAL TR ON TR.ID_REGIONAL = UE.ID_REGIONAL
                                                  AND TR.ID_REGIONAL = ISNULL(@REGIONAL,
                                                              TR.ID_REGIONAL)
                    INNER JOIN HADES..TCE_MUNICIPIO TM ON TM.ID_MUNICIPIO = UE.MUNICIPIO
          WHERE     L.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                    AND ( L.DATA_DESATIVACAO IS NULL
                          OR CONVERT(DATE, L.DATA_DESATIVACAO) &gt; CONVERT(DATE, GETDATE())
                        )
    -- POR REGIONAL E NÃO POR NUCLEO
					--AND L.NUCLEO = ISNULL(@REGIONAL, L.NUCLEO)
                    AND L.UNIDADE_ENS = ISNULL(@ESCOLA, L.UNIDADE_ENS)
                    AND TM.ID_MUNICIPIO = ISNULL(@MUNIC, TM.ID_MUNICIPIO)
          UNION
          SELECT DISTINCT
                    0 AS NUM_FUNC ,
                    V.MATRICULA AS MATRICULA ,
                    V.PESSOA AS PESSOA ,
                    P.NOME_COMPL AS NOME ,
                    F.FUNCAO AS FUNCAO ,
                    cd.NOME AS CARGO ,
                    L.DATA_DESATIVACAO AS DATA_DESATIVACAO ,
                    L.READAPTADO AS READAPTADO ,
                    L.DT_INICIO_READAPTACAO AS DT_INICIO_READAPTACAO ,
                    L.DT_FIM_READAPTACAO AS DT_FIM_READAPTACAO ,
                    NULL AS DISCIPLINA ,
                    NULL AS AULAS_ALOCADAS ,
                    NULL AS AULAS_ALOCADAS_GLP ,
    --LICENÇA
                    LIC.MOTIVO AS MOTIVO ,
	--DATA INÍCIO DA LICENÇA
                    LIC.DTINI AS DATAINI ,
	--DATA FIM DA LICENÇA
                    LIC.DTFIM AS DATAFIM ,
                    TR.REGIONAL ,
                    TM.NOME AS MUNICIPIO ,
                    UE.SETOR AS UA ,
                    UE.NOME_COMP AS UNIDADE ,
                    LIC.DESCRICAO AS DESCRICAO_LICENCA
          FROM      LY_LOTACAO L
                    JOIN LY_UNIDADE_ENSINO UE ON L.UNIDADE_ENS = UE.UNIDADE_ENS
                    JOIN LY_VINCULO V ON L.MATRICULA = V.MATRICULA
                    JOIN LY_FUNCAO F ON L.FUNCAO = F.FUNCAO
					 -- EXCLUINDO OS SERVIDORES COM CARGO DE PROFESSOR ('S' PARA REGENTE OU 'N' PARA NAO REGENTE)
                                        AND F.FUNCAO NOT IN ( SELECT
                                                              FUNCAO
                                                              FROM
                                                              LY_FUNCAO
                                                              WHERE
                                                              CAMPO_01 = 'S' )
                    JOIN LY_PESSOA P ON V.PESSOA = P.PESSOA
                    LEFT JOIN ( SELECT  LD.PESSOA ,
                                        LD.DTFIM ,
                                        LD.DTINI ,
                                        LD.MOTIVO + '|' + LI.POSSUI_DTFIM AS MOTIVO ,
                                        LI.DESCRICAO
                                FROM    LY_LICENCA_PESSOA LD
                                        INNER JOIN LY_LICENCAS LI ON LI.MOTIVO = LD.MOTIVO
                                WHERE   ISNULL(LD.DTFIM, '') &gt;= ( CASE LI.POSSUI_DTFIM
                                                              WHEN 'N' THEN ''
                                                              ELSE CONVERT(DATE, GETDATE())
                                                              END )
                              ) LIC ON LIC.PESSOA = P.PESSOA
                                       AND ( LIC.DTFIM IS NULL
                                             OR LIC.DTFIM = ( SELECT TOP 1
                                                              LD.DTFIM
                                                              FROM
                                                              LY_LICENCA_PESSOA LD
                                                              WHERE
                                                              LD.PESSOA = P.PESSOA
                                                              ORDER BY DTFIM DESC
                                                            )
                                           )
                    INNER JOIN TCE_REGIONAL TR ON TR.ID_REGIONAL = UE.ID_REGIONAL
                                                  AND TR.ID_REGIONAL = ISNULL(@REGIONAL,
                                                              TR.ID_REGIONAL)
                    INNER JOIN HADES..TCE_MUNICIPIO TM ON TM.ID_MUNICIPIO = UE.MUNICIPIO
                    LEFT JOIN LY_CATEGORIA_DOCENTE CD ON CD.CATEGORIA = v.CATEGORIA  
          WHERE     L.DATA_NOMEACAO &lt;= CONVERT(DATE, GETDATE())
                    AND ( L.DATA_DESATIVACAO IS NULL
                          OR CONVERT(DATE, L.DATA_DESATIVACAO) &gt; CONVERT(DATE, GETDATE())
                        )
    -- POR REGIONAL E NÃO POR NUCLEO
    --AND L.NUCLEO = ISNULL(@REGIONAL, L.NUCLEO)
                    AND L.UNIDADE_ENS = ISNULL(@ESCOLA, L.UNIDADE_ENS)
                    AND TM.ID_MUNICIPIO = ISNULL(@MUNIC, TM.ID_MUNICIPIO)
                    AND V.DATA_DESATIVACAO IS NULL
        ) A
        LEFT JOIN LY_FUNCAO F ON A.FUNCAO = F.FUNCAO
ORDER BY A.NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MATRICULA">
          <DataField>MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CARGO">
          <DataField>CARGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="READAPTADO">
          <DataField>READAPTADO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_INICIO_READAPTACAO">
          <DataField>DT_INICIO_READAPTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_FIM_READAPTACAO">
          <DataField>DT_FIM_READAPTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
