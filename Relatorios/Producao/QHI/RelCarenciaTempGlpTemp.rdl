  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>ca5a0312-59c5-4bc8-ab44-49187c7d5c87</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Dataset1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT
		TR.REGIONAL,
		M.NOME MUNICIPIO,
		LUE.UNIDADE_ENS CENSO,
		LUE.NOME_COMP UNIDADE,
				--LUE.SETOR UA,
		VWS.UA_ANTIGA UA ,
		VWS.UA_11_DIGITOS,
		UA.ANO, 
		UA.SEMESTRE,
		UA.TURMA,  
		UA.TURNO,
		CASE UA.DIA_SEMANA 
				WHEN '2' THEN 'SEGUNDA'                      
				WHEN '3' THEN 'TERÇA'                      
				WHEN '4' THEN 'QUARTA'                      
				WHEN '5' THEN 'QUINTA'                      
				WHEN '6' THEN 'SEXTA'                      
				WHEN '7' THEN 'SÁBADO' 
		END DIA_SEMANA, 
		UA.HORA_INICIO,
		UA.HORA_FIM,
		UA.TIPO_CARENCIA,      
		UPPER (UA.DESC_DISCIPLINA) DISCIPLINA,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN 'SIM' ELSE 'NÃO' END GLP_COMPLEMENTACAO,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LD.MATRICULA END MATRICULA,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LP.NOME_COMPL END NOME_COMPL,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LP.CPF END CPF,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LD.CATEGORIA END CARGO,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE GH.DESCRICAO END DISCIPLINA_INGRESSO,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LF.DESCRICAO END FUNCAO,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LI.DESCRICAO END AFASTAMENTO,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LLD.DTINI END DTINI,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LLD.DTFIM END DTFIM,
		VWS.UA_ATUAL,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE lp.IDFUNCIONAL END IDFUNCIONAL,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE LD.VINCULO END VINCULO,
		CASE WHEN AC.TIPO_DIVERGENCIA &lt;&gt; '' THEN NULL ELSE (convert(varchar,lp.IDFUNCIONAL) + '/' + convert(varchar,LD.VINCULO)) END IDVINCULO
FROM	APOLLO..ULTIMA_ALOCACAO_TURMA_CARENCIA UA (NOLOCK)
LEFT	JOIN APOLLO..ALOCACAO_CARENCIA AC (NOLOCK) ON AC.ANO = UA.ANO
				AND AC.SEMESTRE = UA.SEMESTRE
				AND AC.DISCIPLINA = UA.DISCIPLINA 
				AND AC.TURMA = UA.TURMA	
				AND AC.TIPO_DIVERGENCIA = 'GLP TEMPORÁRIA COMPLEMENTAR'			
JOIN	LY_DOCENTE LD (NOLOCK) ON LD.NUM_FUNC = UA.NUM_FUNC
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
JOIN	LY_LOTACAO LL (NOLOCK) ON LL.MATRICULA = LD.MATRICULA
				AND LL.DATA_NOMEACAO &lt;= UA.DATA_FIM 
                AND (LL.DATA_DESATIVACAO IS NULL OR LL.DATA_DESATIVACAO &gt;= UA.DATA_FIM) 
JOIN	LY_FUNCAO LF (NOLOCK) ON LF.FUNCAO = LL.FUNCAO
LEFT	JOIN LY_LICENCA_DOCENTE LLD (NOLOCK) ON LLD.NUM_FUNC = LD.NUM_FUNC
				AND DTFIM &gt;= GETDATE()
LEFT	JOIN LY_LICENCAS LI (NOLOCK) ON LI.MOTIVO = LLD.MOTIVO
LEFT	JOIN LY_GRUPO_HABILITACAO_DOC LGH (NOLOCK) ON LD.NUM_FUNC = LGH.NUM_FUNC
				AND AGRUPAMENTO_INGRESSO = 'S'
LEFT	JOIN LY_GRUPO_HABILITACAO GH (NOLOCK) ON GH.AGRUPAMENTO = LGH.AGRUPAMENTO
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = UA.FACULDADE
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR

WHERE   (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)
AND		TIPO_CARENCIA IN ('CARÊNCIA TEMPORÁRIA', 'GLP TEMPORÁRIA')
AND		UA.TURMA NOT LIKE 'ME%'

UNION

SELECT	DISTINCT
		TR.REGIONAL,
		M.NOME MUNICIPIO,
		LUE.UNIDADE_ENS CENSO,
		LUE.NOME_COMP ESCOLA,
		--LUE.SETOR UA,
		VWS.UA_ANTIGA UA ,
		VWS.UA_11_DIGITOS,
		CT.ANO, 
		CT.SEMESTRE,
		CT.TURMA, 
		CT.TURNO, 
		CASE CT.DIA_SEMANA 
				WHEN '2' THEN 'SEGUNDA'                      
				WHEN '3' THEN 'TERÇA'                      
				WHEN '4' THEN 'QUARTA'                      
				WHEN '5' THEN 'QUINTA'                      
				WHEN '6' THEN 'SEXTA'                      
				WHEN '7' THEN 'SÁBADO' 
		END DIA_SEMANA,
		CT.HORA_INICIO,
		CT.HORA_FIM,
		CT.TIPO_CARENCIA,
		UPPER (CT.DESC_DISCIPLINA) DISCIPLINA,
		CASE WHEN AC.TIPO_DIVERGENCIA = 'GLP TEMPORÁRIA COMPLEMENTAR' THEN 'SIM' ELSE 'NÃO' END GLP_COMPLEMENTACAO,
		NULL MATRICULA,
		NULL NOME_COMPL,
		NULL CPF,
		NULL CARGO,
		NULL DISCIPLINA_INGRESSO,
		NULL FUNCAO,
		NULL AFASTAMENTO,
		NULL DTINI,
		NULL DTFIM,
		VWS.UA_ATUAL  ,
		NULL as IDFUNCIONAL,
		NULL as VINCULO,
		NULL AS IDVINCULO
FROM    APOLLO..CARENCIA_TIPO CT (NOLOCK)
LEFT	JOIN APOLLO..ALOCACAO_CARENCIA AC (NOLOCK) ON AC.ANO = CT.ANO
				AND AC.SEMESTRE = CT.SEMESTRE
				AND AC.DISCIPLINA = CT.DISCIPLINA 
				AND AC.TURMA = CT.TURMA
				AND AC.TIPO_DIVERGENCIA = 'GLP TEMPORÁRIA COMPLEMENTAR'
JOIN	LY_DOCENTE LD (NOLOCK) ON LD.NUM_FUNC = CT.NUM_FUNC
				AND (LD.CONCURSO IS NULL AND LD.CANDIDATO IS NULL)
JOIN	LY_PESSOA LP (NOLOCK) ON LP.PESSOA = LD.PESSOA
JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = CT.UNIDADE_ENS
JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR
WHERE	TIPO_CARENCIA IN ('CARÊNCIA TEMPORÁRIA', 'GLP TEMPORÁRIA')
AND		CT.CLASSIFICACAO &lt;&gt; 'MaisEducacao'
AND		NOT	EXISTS (
				SELECT	1 
				FROM	APOLLO..ULTIMA_ALOCACAO_TURMA_CARENCIA UA (NOLOCK)
				WHERE	CT.ANO = UA.ANO
				AND		CT.SEMESTRE = UA.SEMESTRE
				AND		CT.DISCIPLINA = UA.DISCIPLINA 
				AND		CT.UNIDADE_ENS = UA.FACULDADE
				AND		CT.TURMA = UA.TURMA
				AND		CT.TURNO = UA.TURNO 
				AND		CT.DIA_SEMANA = UA.DIA_SEMANA
				AND		CT.AULA = UA.AULA 
				AND		CT.TIPO_CARENCIA = UA.TIPO_CARENCIA 
			)	
AND     (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
