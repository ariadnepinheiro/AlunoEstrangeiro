  <DataSources>
    <DataSource Name="dblyceum">
      <DataSourceReference>DataSource4</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>b6e0b271-0647-4393-b958-2f5a52784648</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT
          TR.REGIONAL REGIONAL,
          MUNICIPIO.NOME NOME_MUNICIPIO,
          LUE.UNIDADE_ENS UE_CENSO,
          --LUE.SETOR UA,
		  VWS.UA_ANTIGA UA ,
          UPPER(LUE.NOME_COMP) ESCOLA,
          LC.NOME NOME_CURSO,
          ISNULL (M.DESCRICAO, '') DESCRICAO,
          LEFT(M.TURMA, LEN(M.TURMA) - CHARINDEX('-', REVERSE(M.TURMA))) TURMA,
          M.SEMESTRE SEMESTRE,
          M.CURRICULO MATRIZ,
          M.TURNO TURNO,
          ISNULL(M.QTDE_ALUNOS, '0') TOTAL_ALUNO,
          M.SALA,
          M.SERIE,
	  VWS.UA_ATUAL
          FROM    APOLLO..REL_TURMAS_ALUNOS M (NOLOCK)
          JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = M.UNIDADE_ENS
          JOIN	LY_UNIDADES_ASSOCIADAS LUA (NOLOCK) ON LUA.UNIDADE_ENS = LUE.UNIDADE_ENS
          JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
          JOIN	LY_UNIDADE_FISICA LUF (NOLOCK) ON LUF.UNIDADE_FIS = LUA.UNIDADE_FIS
          LEFT	JOIN TCE_COMPARTILHADA TC (NOLOCK) ON TC.CENSO = LUE.UNIDADE_ENS
          JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
          JOIN	MUNICIPIO (NOLOCK) ON MUNICIPIO.CODIGO = LUE.MUNICIPIO
          JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = M.CURSO
          JOIN	LY_DEPENDENCIA DD (NOLOCK) ON DD.DEPENDENCIA = M.SALA AND DD.FACULDADE = LUF.UNIDADE_FIS
	  JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR
          WHERE   M.ANO = @ANO
          AND   (LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) OR LUE.ID_REGIONAL IS NULL)
          AND		(LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) OR LUE.MUNICIPIO IS NULL)
          AND		(LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS) OR LUE.UNIDADE_ENS IS NULL)
          AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL)
          AND		EXISTS (
          SELECT 1
          FROM LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
          WHERE US.UNIDADE_ENS = LUE.UNIDADE_ENS
          AND  US.SITUACAO = 'ESTADUAL'
          AND  US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN
          (
          SELECT UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO))
          FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
          )
          )
          AND		(LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_MUNICIPIO">
          <DataField>NOME_MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UE_CENSO">
          <DataField>UE_CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_CURSO">
          <DataField>NOME_CURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MATRIZ">
          <DataField>MATRIZ</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TURNO">
          <DataField>TURNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ALUNO">
          <DataField>TOTAL_ALUNO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SALA">
          <DataField>SALA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
