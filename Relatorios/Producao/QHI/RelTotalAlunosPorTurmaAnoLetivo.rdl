    <DataSet Name="ANO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>
          SELECT DISTINCT ANO
          FROM LY_PERIODO_LETIVO
          ORDER BY ANO DESC
        </CommandText>
      </Query>
      <Fields>
