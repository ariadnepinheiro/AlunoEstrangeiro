    <DataSet Name="Coordenadoria">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select -1 nucleo,' Selecione...' descricao 
union
select 0 nucleo,' TODAS' descricao from TCE_REGIONAL L1
join LY_UNIDADE_ENSINO l2 on L1.ID_REGIONAL=l2.ID_REGIONAL
union
select  l1.ID_REGIONAL, SUBSTRING(l1.REGIONAL,1,35) from TCE_REGIONAL L1
join LY_UNIDADE_ENSINO l2 on L1.ID_REGIONAL=l2.ID_REGIONAL
join HADES..TCE_MUNICIPIO m1 on m1.ID_MUNICIPIO=l2.MUNICIPIO
join LY_USUARIO_UNIDADE_FIS jj on jj.UNIDADE_FIS=l2.UNIDADE_ENS
where (jj.USUARIO = ISNULL(@usuario,jj.USUARIO) OR  jj.USUARIO IS NULL) 
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @COORD &gt; 0
begin
	select distinct L1.ID_MUNICIPIO as codigo,L1.nome from LY_UNIDADE_ENSINO l2
	join HADES..TCE_MUNICIPIO l1 on l1.ID_MUNICIPIO=l2.MUNICIPIO
	join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
	where 
		n1.ID_REGIONAL = @COORD
	union
	select 0 codigo,' TODOS' nome  
	union
	select -1 codigo,' Selecione...' nome 
	ORDER BY NOME
end
ELSE
begin
	select distinct L1.ID_MUNICIPIO as codigo,L1.nome from LY_UNIDADE_ENSINO l2
	join HADES..TCE_MUNICIPIO l1 on l1.ID_MUNICIPIO=l2.MUNICIPIO
	join TCE_REGIONAL n1 on n1.ID_REGIONAL=l2.ID_REGIONAL
	where 
		n1.ID_REGIONAL is not null--= @COORD
	union
	select 0 codigo,' TODOS' nome  
	union
	select -1 codigo,' Selecione...' nome 
	ORDER BY NOME
end</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escola">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>IF @COORD &gt; 0
begin
	select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
	UNION
	select null UNIDADE_ENS, ' TODAS' NOME_COMP 
	union
	select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
	where 
		ue.UNIDADE_ENS NOT in ('99999999','33334444','33335555','33335556')
	AND	ue.ID_REGIONAL = @COORD
	AND (ue.MUNICIPIO = ISNULL(convert(int,@MUNIC)
	,ue.municipio)or ue.MUNICIPIO is null)
	order by NOME_COMP 
end
ELSE
begin
	IF @MUNIC &gt; 0
	begin
		select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
		UNION
		select null UNIDADE_ENS, ' TODAS' NOME_COMP 
		union
		select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
		where 
			ue.UNIDADE_ENS NOT in ('99999999','33334444','33335555','33335556')
		AND	ue.ID_REGIONAL is not null--= @COORD
		AND (ue.MUNICIPIO = ISNULL(convert(int,@MUNIC)
		,ue.municipio)or ue.MUNICIPIO is null)
		order by NOME_COMP 
	end
	ELSE
	begin
		select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
		UNION
		select null UNIDADE_ENS, ' TODAS' NOME_COMP 
		union
		select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
		where 
			ue.UNIDADE_ENS NOT in ('99999999','33334444','33335555','33335556')
		AND	ue.ID_REGIONAL is not null--= @COORD
		order by NOME_COMP 
	end
end</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SituacaoFuncionamentoUE">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>select SIT_FUNCIONAMENTO as ID_FUNCIONAMENTO, SIT_FUNCIONAMENTO from LY_UNIDADE_ENSINO where SIT_FUNCIONAMENTO is not null group by SIT_FUNCIONAMENTO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
