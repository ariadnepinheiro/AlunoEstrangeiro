        </Field>
        <Field Name="DT_INICIO_READAPTACAO">
          <DataField>DT_INICIO_READAPTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_FIM_READAPTACAO">
          <DataField>DT_FIM_READAPTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="LICENCA">
          <DataField>LICENCA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_INICIO">
          <DataField>DATA_INICIO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DATA_FIM">
          <DataField>DATA_FIM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PADRAO_ACESSO">
          <DataField>PADRAO_ACESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PADRAO_ACESSO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>
SELECT  'NULO' PADRAO, ' Selecione...' NOME
UNION
SELECT	NULL PADRAO, ' TODAS' NOME
UNION
SELECT	DISTINCT PADACES PADRAO, PADACES NOME 
FROM	PADUSUARIO (NOLOCK)
WHERE	PADACES IN('AGENTE_PESSOAL', 'COORDENADORIA', 'LINKS_CGP', 'COORD_QHI','DRDV',
'RELAT_QHI',
'SUP_GES_PES',
'SUPLAN',
'SUBGPASSE',
'SUBGP',
'SEEDUC',
'RELAT_COORD_PE',
'ME_CGP',
'CCADME',
'CAUDITME',
'CAME',
'CAPOSME',
'GER_ADM_COORD',
'ecosepgp_edit',
'ecosepgp',
'DIR_GEST_PESS',
'DIRETOR_UE',
'DIRETOR_QHITOT',
'DIRETOR_UE_QHI',
'DIRETOR_ADJ',
'DIESP',
'Coordenação Geral de Prestação de Contas',
'CONTRATO TEMPO',
'COORD_QHICONS2',
'COORD_QHI_CONS',
'COORD_QHI',
'COORDENADORIA',
'COORD_GP',
'CRGP',
'CQH',
'CPA',
'CPAB',
'CM',
'COORD_QHI_GLP',
'CEFOLHA',
'CDV',
'CCAD',
'CAUDIT',
'CA',
'CAPOS',
'CRGPME',
'CQHME',
'CPAME',
'CPABME',
'CEFOLHAME',
'CDVME',
'COCAC',
'GESTAO_PESSOAS',
'CECIERJ',
'ALTDOC_PARCIAL',
'ATCCFG',
'ALT_MATRICULA',
'CMAP') 
ORDER	BY NOME </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="PADRAO">
          <DataField>PADRAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
