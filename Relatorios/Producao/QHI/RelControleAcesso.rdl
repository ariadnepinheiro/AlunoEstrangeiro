          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IDVINCULO">
          <DataField>IDVINCULO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
