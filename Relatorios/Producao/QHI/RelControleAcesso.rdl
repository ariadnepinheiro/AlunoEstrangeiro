          <DataField>CARGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA_INGRESSO">
          <DataField>DISCIPLINA_INGRESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEGUNDA_MATRICULA">
          <DataField>SEGUNDA_MATRICULA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="READAPTADO">
          <DataField>READAPTADO</DataField>
