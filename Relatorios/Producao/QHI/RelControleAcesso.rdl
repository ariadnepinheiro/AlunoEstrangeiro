  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>14f6c4f5-6443-4849-9415-51a271cb9f30</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@PADRAO_ACESSO">
            <Value>=Parameters!PADRAO_ACESSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT P.PADACES,
		S.REGIONAL,
		S.MUNICIPIO,
		S.UA,
		VWS.UA_ATUAL,
		VWS.UA_11_DIGITOS,
		S.CENSO,
		S.UNIDADE,
		S.IDFUNCIONAL as ID_FUNCIONAL,
		S.VINCULO,
		(convert(varchar,S.IDFUNCIONAL) + '/' + convert(varchar,S.VINCULO)) AS IDVINCULO,
		S.MATRICULA,
		(
			SELECT	MAX(D.MATRICULA)
			FROM    LY_DOCENTE D (NOLOCK)
			WHERE   D.MATRICULA &lt;&gt; LD.MATRICULA
			AND		D.PESSOA = S.PESSOA
		) SEGUNDA_MATRICULA,
		S.CPF,
		S.NOME,
		S.CARGO CARGO,
		LGH.DESCRICAO DISCIPLINA_INGRESSO,
		S.FUNCAO,
		REPLACE (S.READAPTADO, 'N', '') READAPTADO,
		S.DT_INICIO_READAPTACAO DT_INICIO_READAPTACAO,
		S.DT_FIM_READAPTACAO DT_FIM_READAPTACAO,
		LTRIM(RTRIM(LL.DESCRICAO)) LICENCA,
		LS.DTINI DATA_INICIO,
		LS.DTFIM DATA_FIM,
		P.PADACES PADRAO_ACESSO
FROM    APOLLO..REL_SERVIDORES_ATIVOS S (NOLOCK)
LEFT	JOIN LY_DOCENTE LD (NOLOCK) ON LD.MATRICULA = S.MATRICULA
LEFT	JOIN LY_GRUPO_HABILITACAO_DOC LGHD (NOLOCK) ON LGHD.NUM_FUNC = LD.NUM_FUNC
					AND AGRUPAMENTO_INGRESSO = 'S'
LEFT	JOIN LY_GRUPO_HABILITACAO LGH (NOLOCK) ON LGH.AGRUPAMENTO = LGHD.AGRUPAMENTO
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = S.UA
LEFT	JOIN (
				SELECT	DD.PESSOA, LLD.NUM_FUNC, DTINI, DTFIM, MOTIVO
				FROM	LY_LICENCA_DOCENTE LLD (NOLOCK)
				JOIN	LY_DOCENTE DD (NOLOCK) ON DD.NUM_FUNC = LLD.NUM_FUNC
				WHERE	DTFIM &gt;= CONVERT(DATE,CURRENT_TIMESTAMP)
				UNION
				SELECT	LLP.PESSOA, NULL, DTINI, DTFIM, MOTIVO
				FROM	LY_LICENCA_PESSOA LLP (NOLOCK)
				WHERE	DTFIM &gt;= CONVERT(DATE,CURRENT_TIMESTAMP) 
              ) LS
         ON LS.PESSOA = S.PESSOA
LEFT	JOIN LY_LICENCAS LL (NOLOCK) ON LL.MOTIVO = LS.MOTIVO
JOIN	PADUSUARIO P (NOLOCK) ON P.USUARIO = S.MATRICULA
				AND P.PADACES IN ('AGENTE_PESSOAL', 'COORDENADORIA', 'LINKS_CGP', 'COORD_QHI','DRDV',
'RELAT_QHI',
'SUP_GES_PES',
'SUPLAN',
'SUBGPASSE',
'SUBGP',
'SEEDUC',
'RELAT_COORD_PE',
'ME_CGP',
'CCADME',
'CAUDITME',
'CAME',
'CAPOSME',
'GER_ADM_COORD',
'ecosepgp_edit',
'ecosepgp',
'DIR_GEST_PESS',
'DIRETOR_UE',
'DIRETOR_QHITOT',
'DIRETOR_UE_QHI',
'DIRETOR_ADJ',
'DIESP',
'Coordenação Geral de Prestação de Contas',
'CONTRATO TEMPO',
'COORD_QHICONS2',
'COORD_QHI_CONS',
'COORD_QHI',
'COORDENADORIA',
'COORD_GP',
'CRGP',
'CQH',
'CPA',
'CPAB',
'CM',
'COORD_QHI_GLP',
'CEFOLHA',
'CDV',
'CCAD',
'CAUDIT',
'CA',
'CAPOS',
'CRGPME',
'CQHME',
'CPAME',
'CPABME',
'CEFOLHAME',
'CDVME',
'COCAC',
'GESTAO_PESSOAS',
'CECIERJ',
'ALTDOC_PARCIAL',
'ATCCFG',
'ALT_MATRICULA',
'CMAP') 
WHERE	(P.PADACES = ISNULL(@PADRAO_ACESSO, P.PADACES) OR P.PADACES IS NULL)
ORDER BY UA, UNIDADE</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PADACES">
          <DataField>PADACES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
