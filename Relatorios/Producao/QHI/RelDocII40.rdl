  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.197;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>ca5a0312-59c5-4bc8-ab44-49187c7d5c87</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Rel_carga_hor_livre">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DATA">
            <Value>=Parameters!DATA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
       REGIONAL
     , MUNICIPIO
     , UA
     , UNIDADE
     , MATRICULA
     , CPF
     , NOME_COMPL
     , CARGO
     , FUNCAO
     , CH_AULA_MATRICULA
     , CH_AULA_GLP
     , DISCIPLINA     
     , CARGA_HR
     , UA_ATUAL  
	 ,IDFUNCIONAL
	 ,VINCULO  
	 ,UA_11_DIGITOS
  FROM (
SELECT 
       REGIONAL
     , MUNICIPIO
     , UA
     , UNIDADE
     , MATRICULA
     , CPF
     , NOME_COMPL
     , CARGO
     , FUNCAO
     , CH_AULA_MATRICULA
     , CH_AULA_GLP
     , DISCIPLINA     
     , CARGA_HR
     , RANK() OVER (PARTITION BY REGIONAL
                               , MUNICIPIO
                               , UNIDADE 
                               , NOME_COMPL
                        ORDER BY CARGA_HR     DESC
                               , T.DISCIPLINA ASC) AS RANK_A
     , UA_ATUAL
	 , IDFUNCIONAL
	 , VINCULO  
	 ,UA_11_DIGITOS
  FROM (  
SELECT  
       R.REGIONAL
     , M.NOME        MUNICIPIO
     --, UE.SETOR      UA
	 ,VWS.UA_ANTIGA UA 
	 , VWS.UA_11_DIGITOS
     , UE.NOME_COMP  UNIDADE
     , D.MATRICULA
     , P.CPF
     , P.NOME_COMPL
     , D.CATEGORIA   CARGO
     , F.DESCRICAO   FUNCAO
--   , DBO.f_TotalAulaNormal_Ano (D.MATRICULA, 2012) CH_AULA_MATRICULA
     , DBO.f_TotalAulaNormal_Ano (D.MATRICULA, YEAR(GETDATE())) CH_AULA_MATRICULA
     , DBO.f_TotalAulaGLP_Ano    (D.MATRICULA, YEAR(GETDATE())) CH_AULA_GLP
--   , DISC.NOME_DISCIPLINA
--   , DISC.CARGA_HORARIA
     , DD.NOME_COMPL             AS 'DISCIPLINA'     
     , MAX(DD.HORAS_AULA)        AS 'CARGA_HR'
     , UA_ATUAL
	 , P.IDFUNCIONAL
	 , D.VINCULO     
  FROM LY_DOCENTE D 
  JOIN LY_PESSOA P 
    ON D.PESSOA            = P.PESSOA
  JOIN LY_LOTACAO L 
    ON D.MATRICULA         = L.MATRICULA
   AND L.DATA_NOMEACAO     &lt; @DATA
   AND (L.DATA_DESATIVACAO IS NULL 
    OR  L.DATA_DESATIVACAO &gt; @DATA)
  JOIN LY_UNIDADE_ENSINO UE 
    ON UE.SETOR            = L.SETOR
  JOIN TCE_REGIONAL R
    ON R.ID_REGIONAL       = UE.ID_REGIONAL
  JOIN HADES..TCE_MUNICIPIO M 
    ON M.ID_MUNICIPIO      = UE.MUNICIPIO
  JOIN LY_FUNCAO F
    ON F.FUNCAO            = L.FUNCAO
  JOIN LY_AULA_DOCENTE AL 
    ON AL.NUM_FUNC         = D.NUM_FUNC  
  JOIN LY_TURMA TT   
    ON AL.DISCIPLINA       = TT.DISCIPLINA 
   AND AL.TURMA            = TT.TURMA 
   AND AL.ANO              = TT.ANO 
   AND AL.FACULDADE        = TT.FACULDADE
   AND AL.SEMESTRE         = TT.SEMESTRE
   AND AL.TURNO            = TT.TURNO
   AND AL.DATA_FIM         = TT.DT_FIM
   AND TT.ANO              = YEAR(@DATA)
   AND TT.SIT_TURMA        = 'ABERTA'
   AND AL.DATA_FIM        &gt;= @DATA 
   
  JOIN LY_DISCIPLINA DD WITH(NOLOCK) 
    ON DD.DISCIPLINA       = ISNULL(TT.DISCIPLINA_MULTIPLA, TT.DISCIPLINA) 
  JOIN    HADES..VW_SETOR VWS on VWS.SETOR = UE.SETOR 	
--AND DD.HORAS_AULA = DISC.CARGA_HORARIA

 WHERE EXISTS (SELECT 1
                 FROM LY_UNIDADE_ENSINO_SITUACAO US
                WHERE US.UNIDADE_ENS = UE.UNIDADE_ENS
                  AND US.SITUACAO    = 'ESTADUAL'
                  AND US.UNIDADE_ENS + CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
                                                            (
                                                             SELECT UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
                                                               FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
                                                            )
              )
   AND (UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
   AND (
        (-- DOC II 40 ATUANDO COMO DOC I 40
         D.CATEGORIA LIKE '%II%40%' -- LY_DOCENTE D
         AND      L.FUNCAO in ('107', '10086','10085','10084','10083',
'10089','10164','10169','10145',
'10143','10088','10087','10136',
'10144','10138','10140','10102',
'10101','10100','10099','10098',
'10097','10096','10095','10154',
'10125','10080','10103','10104',
'10116','10151','10110','10106',
'10105','10141','10094','10111',
'10124') -- LY_LOTACAO L 
        ) 
         OR
         (
           -- DOC II 20 ATUANDO COMO DOC I
          (
          D.CATEGORIA LIKE 'prof d%II%ref%' 
          OR
          D.CATEGORIA LIKE '%II%20%' -- LY_DOCENTE D
          )
        AND L.FUNCAO in ('106', '10086','10085','10084','10083',
'10089','10164','10169','10145',
'10143','10088','10087','10136',
'10144','10138','10140','10102',
'10101','10100','10099','10098',
'10097','10096','10095','10154',
'10125','10080','10103','10104',
'10116','10151','10110','10106',
'10105','10141','10094','10111',
'10124') -- LY_LOTACAO L 
       )
      )
GROUP BY R.REGIONAL
       , VWS.UA_ANTIGA
       , VWS.UA_11_DIGITOS
       , D.MATRICULA
       , P.CPF
       , D.CATEGORIA
       , F.DESCRICAO
--     , DISC.NOME_DISCIPLINA 
--     , DISC.CARGA_HORARIA
       , M.NOME,UE.NOME_COMP --UNIDADE (UE)
       , DD.NOME_COMPL
       
       , P.NOME_COMPL -- NOME DOCENTE
--     , DD.HORAS_AULA
       , VWS.UA_ATUAL
	   , P.IDFUNCIONAL
	   , D.VINCULO  
       ) AS T
       ) AS T 
   WHERE T.RANK_A = 1      
ORDER BY REGIONAL
       , MUNICIPIO
       , UNIDADE 
       , NOME_COMPL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
