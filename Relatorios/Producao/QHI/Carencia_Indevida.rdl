  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>080104a9-852c-4fa1-a82e-8f568367cd21</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	 REGIONAL, MUNICIPIO, CENSO, UNIDADE, UA, ANO, SEMESTRE, TURMA, DISCIPLINA, SUM(TOT_CARENCIA) TOT_CARENCIA, UA_ATUAL, UA_11_DIGITOS
FROM(
SELECT	 DISTINCT TR.REGIONAL, 
		 MM.NOME MUNICIPIO, 
		 LUE.UNIDADE_ENS CENSO, 
		 LUE.NOME_COMP UNIDADE, 
		 --LUE.SETOR UA, 
		 VWS.UA_ANTIGA UA,		 
		 LT.ANO, 
		 LT.SEMESTRE, 
		 LT.TURMA, 
		 UPPER (DI.NOME) DISCIPLINA,
		 CASE WHEN LAD.NUM_FUNC = '115451' THEN 'CARÊNCIA TEMPORÁRIA' ELSE 'CARÊNCIA REAL' END TIPO_CARENCIA,            
		 COUNT(LT.TURMA+DI.DISCIPLINA+STR(LT.ANO)+STR(LT.SEMESTRE)+RTRIM(LTRIM(STR(LAD.AULA))) + RTRIM(LTRIM(STR(LAD.DIA_SEMANA)))) TOT_CARENCIA, 
VWS.UA_ATUAL, VWS.UA_11_DIGITOS  
FROM	 LY_AULA_DOCENTE LAD (NOLOCK)
JOIN	 LY_TURMA LT (NOLOCK) ON LAD.ANO = LT.ANO
					 AND LAD.SEMESTRE = LT.SEMESTRE
					 AND LAD.TURMA = LT.TURMA
					 AND LAD.DISCIPLINA = LT.DISCIPLINA 
AND LAD.TURNO = LT.TURNO
					 AND LAD.DATA_FIM = LT.DT_FIM
					 AND LT.ANO = @ANO
					 AND SIT_TURMA = 'Aberta'
JOIN	 LY_DISCIPLINA DI (NOLOCK) ON DI.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA)
					 AND COMPONENTE IN ('ReforcoMatematica', 'Correcaodefluxoef', 'Base Nacional Comum', 'NucleoArticuladorE.F.AnosFinais', 'ReforcoPortugues')
JOIN	 LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL
JOIN	 TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN	 MUNICIPIO MM (NOLOCK) ON MM.CODIGO = LUE.MUNICIPIO
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR
WHERE	 LAD.NUM_FUNC IN ('115451','115460') 
AND		 EXISTS (
				SELECT	1
				FROM	LY_AULA_DOCENTE AD1 (NOLOCK)
				WHERE	AD1.ANO = LT.ANO
				AND		AD1.SEMESTRE = LT.SEMESTRE
				AND		AD1.TURMA = LT.TURMA
				AND		AD1.DISCIPLINA = LT.DISCIPLINA 
				AND		AD1.DATA_FIM = LT.DT_FIM
AND		AD1.TURNO =  LT.TURNO
				AND		AD1.NUM_FUNC NOT IN ('115451','115460') 
				)
AND		NOT EXISTS (
					SELECT	1
					FROM	LY_TURMA T (NOLOCK)
					WHERE	T.ANO = LT.ANO
					AND		T.SEMESTRE = LT.SEMESTRE
					AND		T.TURMA = LT.TURMA 
					AND		T.DISCIPLINA = LT.DISCIPLINA
					AND		T.CURSO IN ('0001.17', '0001.27', '0002.37', '9999.92') -- SEMIPRESENCIAL E MAIS EDUCAÇÃO
					)
AND		 EXISTS (
			    SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = LUE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20), US.DT_SITUACAO) IN (
				SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20), MAX(DT_SITUACAO)) 
				FROM	LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS)
 			   )
GROUP BY TR.REGIONAL, 
		 MM.NOME, 
		 LUE.UNIDADE_ENS, 
		 LUE.NOME_COMP, 
		 VWS.UA_ANTIGA, 
		 LT.ANO, 
		 LT.SEMESTRE, 
		 LT.TURMA, 
		 DI.NOME,
		 LAD.NUM_FUNC,
		 VWS.UA_ATUAL,
		 VWS.UA_11_DIGITOS 
)Q1

GROUP BY REGIONAL, 
		 MUNICIPIO, 
		 CENSO, 
		 UNIDADE, 
		 UA, 
		 ANO, 
		 SEMESTRE,
		 TURMA, 
		 DISCIPLINA,
		 UA_ATUAL,
		 UA_11_DIGITOS
ORDER BY REGIONAL, 
		 MUNICIPIO, 		
		 UNIDADE, 
		 TURMA, 
		 DISCIPLINA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SEMESTRE">
          <DataField>SEMESTRE</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA">
          <DataField>DISCIPLINA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOT_CARENCIA">
          <DataField>TOT_CARENCIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UA_ATUAL">
          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_11_DIGITOS">
          <DataField>UA_11_DIGITOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>
SELECT  0 ANO, ' Selecione...' NOME
UNION
SELECT	DISTINCT CONVERT (VARCHAR(4), ANO) ANO, CONVERT (VARCHAR(4), ANO) NOME 
FROM	LY_PERIODO_LETIVO (NOLOCK) 
ORDER	BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
