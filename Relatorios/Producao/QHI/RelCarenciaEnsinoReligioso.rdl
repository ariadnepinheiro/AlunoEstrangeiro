  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="dblyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>3f4de5ff-0c95-4153-bf1c-fd75567563cd</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PERIODO">
            <Value>=Parameters!PERIODO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT  DISTINCT 
		LTR.REGIONAL
		,HTM.NOME AS MUNICIPIO_ESCOLA
		,LUE.SETOR AS UA
		,VWS.UA_ATUAL
		,VWS.UA_11_DIGITOS
		,LUE.UNIDADE_ENS AS CENSO
		,LUE.NOME_COMP AS ESCOLA
		,ISNULL(Y.TOT_ALU_ENS_REL, 0) AS TOTAL_ALUNOS_OPTANTES
		,(CASE 
				WHEN ISNULL(Y.TOT_ALU_ENS_REL, 0) = 0 THEN 0
				WHEN ISNULL(Y.TOT_ALU_ENS_REL, 0) &lt;= 360 THEN 1
				ELSE (ISNULL(Y.TOT_ALU_ENS_REL, 0) / 360) + 1 -- NO CASO DE VALOR QUEBRADO, ACRESCENTO MAIS UM PROFESSOR
			END	
		) AS NECESSIDADE_PROFESSORES
		,ISNULL(Z.TOT_DOC_ENS_REL, 0) AS TOTAL_PROFESSORES_ALOCADOS
FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
JOIN	MUNICIPIO HTM (NOLOCK) ON LUE.MUNICIPIO = HTM.CODIGO
JOIN	TCE_REGIONAL LTR (NOLOCK) ON LTR.ID_REGIONAL = LUE.ID_REGIONAL
JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR 
LEFT	JOIN (
				SELECT  DISTINCT 
						LL.SETOR AS SETOR
						,COUNT (DISTINCT LD.MATRICULA) AS TOT_DOC_ENS_REL
				FROM	LY_DOCENTE LD (NOLOCK)
				JOIN	LY_LOTACAO LL (NOLOCK) ON LD.MATRICULA = LL.MATRICULA 
								AND (DATA_DESATIVACAO IS NULL OR DATA_DESATIVACAO &gt;= GETDATE())				 
								 AND LL.FUNCAO = 10152 -- REGENTE DO ENSINO RELIGIOSO
				GROUP BY LL.SETOR 
			) Z ON Z.SETOR = LUE.SETOR 

LEFT	JOIN (
				SELECT  DISTINCT
						TCM.CENSO
						,COUNT (DISTINCT TCM.ALUNO) AS TOT_ALU_ENS_REL
				FROM	TCE_CONFIRMACAO_MATRICULA TCM (NOLOCK) 
				WHERE	TCM.ALUNO NOT IN (SELECT ALUNO FROM LY_H_CURSOS_CONCL (NOLOCK) WHERE DT_REABERTURA IS NULL) 
						AND TCM.ANO = @ANO 
						AND TCM.PERIODO IN (0, @PERIODO)
						AND TCM.ENSINO_RELIGIOSO = 1
						AND TCM.STATUS = 'Confirmado'
				GROUP BY TCM.CENSO
			) Y ON Y.CENSO = LUE.UNIDADE_ENS

WHERE	LUE.ID_REGIONAL = ISNULL(@REGIONAL, LUE.ID_REGIONAL) 
AND		LUE.MUNICIPIO = ISNULL(@MUNICIPIO, LUE.MUNICIPIO) 
AND		LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS)  
AND		EXISTS (
					SELECT	1
					FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
					WHERE	US.UNIDADE_ENS = LUE.UNIDADE_ENS
					AND		US.SITUACAO = 'ESTADUAL'
					AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
								(
								SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
								FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
								)
					)	
AND		(LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
AND		LUE.NOME_COMP NOT LIKE 'CEJA%'</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO_ESCOLA">
          <DataField>MUNICIPIO_ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA">
          <DataField>UA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_11_DIGITOS">
          <DataField>UA_11_DIGITOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UA_ATUAL">
          <DataField>UA_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOTAL_ALUNOS_OPTANTES">
          <DataField>TOTAL_ALUNOS_OPTANTES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NECESSIDADE_PROFESSORES">
          <DataField>NECESSIDADE_PROFESSORES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TOTAL_PROFESSORES_ALOCADOS">
          <DataField>TOTAL_PROFESSORES_ALOCADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Ano">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <CommandText>SELECT DISTINCT ANO, ANO AS NOME 
FROM LYCEUM..LY_PERIODO_LETIVO (NOLOCK) 
WHERE ANO &gt;= 2014
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Escolas">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT NULL UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING (UE.NOME_COMP,1,50)NOME_COMP 
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
WHERE (R.ID_REGIONAL = ISNULL(@REGIONAL, R.ID_REGIONAL) OR R.ID_REGIONAL IS NULL)
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO, UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL) 
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipios">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT DISTINCT L1.CODIGO, L1.NOME FROM LY_UNIDADE_ENSINO L2 (NOLOCK)
JOIN HADES..MUNICIPIO L1 (NOLOCK) ON L1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..TCE_REGIONAL N1 (NOLOCK) ON N1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE 
	(N1.ID_REGIONAL = ISNULL(@REGIONAL,N1.ID_REGIONAL)OR N1.ID_REGIONAL IS NULL)
	AND
	(JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT NULL CODIGO,' TODOS' NOME
UNION
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regionais">
      <Query>
        <DataSourceName>dblyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT NULL ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT 0 ID_REGIONAL,' Selecione...' REGIONAL 
ORDER BY REGIONAL </CommandText>
      </Query>
      <Fields>
        <Field Name="id_regional">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="regional">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
