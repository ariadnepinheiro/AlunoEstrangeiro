    <DataSet Name="ds_Titulacao">
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CT.TITULACAO, COT.PONTUACAO PONTU_TIT,CCT.DESCRICAO AS DESCR_TITULAÇÃO
FROM LY_CANDIDATO_DOCENTE CD, LY_CANDIDATO_DOC_TITULACOES CT, LY_CONCURSO_DOC_TITULACOES COT,
LY_CONCURSO_TITULACAO CCT
WHERE CT.CANDIDATO = CD.CANDIDATO
AND CT.CONCURSO = CD.CONCURSO
AND COT.CONCURSO = CT.CONCURSO
AND COT.TITULACAO = CT.TITULACAO
AND CCT.TITULACAO = COT.TITULACAO
AND CD.CANDIDATO = @P_CANDIDATO
AND CD.CONCURSO = @P_CONCURSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TITULACAO">
          <DataField>TITULACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PONTU_TIT">
          <DataField>PONTU_TIT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DESCR_TITULAÇÃO">
          <DataField>DESCR_TITULAÇÃO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Experiencia">
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CE.EXPERIENCIA, COE.PONTUACAO PONTU_EXP,CCE.DESCRICAO AS DESCR_EXPERIENCIA
FROM LY_CANDIDATO_DOCENTE CD, LY_CANDIDATO_DOC_EXPERIENCIAS CE, LY_CONCURSO_DOC_EXPERIENCIA COE,LY_CONCURSO_EXPERIENCIA CCE
WHERE CE.CANDIDATO = CD.CANDIDATO
AND CCE.EXPERIENCIA = COE.EXPERIENCIA
AND CE.CANDIDATO = CD.CANDIDATO
AND CE.CONCURSO = CD.CONCURSO
AND COE.CONCURSO = CE.CONCURSO
AND COE.EXPERIENCIA = CE.EXPERIENCIA
AND CD.CANDIDATO = @P_CANDIDATO
AND CD.CONCURSO = @P_CONCURSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="EXPERIENCIA">
          <DataField>EXPERIENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PONTU_EXP">
          <DataField>PONTU_EXP</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DESCR_EXPERIENCIA">
          <DataField>DESCR_EXPERIENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Situacao_Avaliacao">
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CA.CANDIDATO, CA.CONCURSO, CA.SITUACAO, CO.DESCRICAO
FROM LY_CONCURSO_DOC_SIT_AVALIACAO CO, LY_CANDIDATO_DOC_SIT_AVALIACAO CA
WHERE CO.SITUACAO = CA.SITUACAO
AND CA.CANDIDATO = @P_CANDIDATO
AND CA.CONCURSO = @P_CONCURSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SITUACAO">
          <DataField>SITUACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CANDIDATO">
          <DataField>CANDIDATO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CONCURSO">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Processo_Seletivo">
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CDS.DESCRICAO AS STATUS,
(SELECT SUM(CTPONT.PONTUACAO) FROM
((SELECT PONTUACAO
FROM LY_CONCURSO_DOC_EXPERIENCIA CODE
INNER JOIN LY_CANDIDATO_DOC_EXPERIENCIAS CADE ON
CODE.CONCURSO = CADE.CONCURSO AND CODE.EXPERIENCIA = CADE.EXPERIENCIA
WHERE CADE.CANDIDATO = CD.CANDIDATO AND CD.CONCURSO = CADE.CONCURSO)
UNION ALL
(SELECT PONTUACAO FROM LY_CONCURSO_DOC_TITULACOES CODT
INNER JOIN LY_CANDIDATO_DOC_TITULACOES CADT ON
CODT.CONCURSO = CADT.CONCURSO AND CODT.TITULACAO = CADT.TITULACAO
WHERE CADT.CANDIDATO = CD.CANDIDATO AND CADT.CONCURSO = CD.CONCURSO
)
) CTPONT
) SOMA_PONTUACAO, CD.DT_APRESENTACAO, CD.HORA_APRESENTACAO,CDC.DT_INICIO_CONTRATO,CDC.DT_FIM_CONTRATO
FROM LY_CANDIDATO_DOCENTE CD WITH(NOLOCK)
INNER JOIN LY_CANDIDATO_DOCENTE_STATUS CDS WITH(NOLOCK) ON CDS.STATUSID = CD.STATUS
LEFT JOIN LY_CANDIDATO_DOC_CONTRATO CDC WITH(NOLOCK) ON
CD.CANDIDATO = CDC.CANDIDATO AND CD.CONCURSO = CDC.CONCURSO
WHERE CD.CANDIDATO = @P_CANDIDATO
AND CD.CONCURSO = @P_CONCURSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_APRESENTACAO">
          <DataField>DT_APRESENTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="HORA_APRESENTACAO">
          <DataField>HORA_APRESENTACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_INICIO_CONTRATO">
          <DataField>DT_INICIO_CONTRATO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_FIM_CONTRATO">
          <DataField>DT_FIM_CONTRATO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="SOMA_PONTUACAO">
          <DataField>SOMA_PONTUACAO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Contrato_Temporário">
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT *
FROM LY_CANDIDATO_DOC_CONTRATO
WHERE CANDIDATO = @P_CANDIDATO
AND CONCURSO = @P_CONCURSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
