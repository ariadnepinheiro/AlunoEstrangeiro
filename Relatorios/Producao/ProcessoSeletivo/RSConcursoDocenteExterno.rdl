    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_ConcursoDocente">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.197;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>5e9eb66c-f329-42d8-8714-8284646c12f6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_Dados">
      <Query>
        <DataSourceName>DS_ConcursoDocente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT DISTINCT CD.CONCURSO, CO.DESCRICAO, CO.STATUS STATUS_CONCURSO, CD.CANDIDATO, CD.NOME, CD.DT_NASC, CD.SEXO,
NEC.DESCRICAO  AS NECESSIDADE_ESPECIAL, CD.NOME_MAE, CD.NOME_PAI, CD.ESTADO_CIVIL,
(SELECT NOME FROM PAISES WHERE CODIGO = CD.PAIS_NASC) AS PAIS_NASC, CD.NACIONALIDADE,
(SELECT NOME FROM MUNICIPIO WHERE CODIGO = CD.MUNICIPIO_NASC) AS MUNICIPIO_NASC,
(SELECT UF_SIGLA FROM MUNICIPIO WHERE CODIGO = CD.MUNICIPIO_NASC) AS UF_NASC,
(SELECT NOME FROM PAISES WHERE CODIGO = CD.END_PAIS) AS END_PAIS, CD.CEP,
(SELECT NOME FROM MUNICIPIO WHERE CODIGO = CD.END_MUNICIPIO) AS END_MUNICIPIO,
(SELECT UF_SIGLA FROM MUNICIPIO WHERE CODIGO = CD.END_MUNICIPIO) AS END_UF,
CD.ENDERECO, CD.END_NUM, CD.END_COMPL, CD.BAIRRO, CD.FONE, CD.CELULAR, CD.E_MAIL, CD.RG_TIPO, CD.RG_NUM, CD.RG_EMISSOR, CD.RG_UF, CONVERT(varchar, CD.RG_DTEXP, 103) AS RG_DTEXP,
CD.CPF, CD.PIS_PASEP, CD.CPROF_NUM,CD.CPROF_SERIE, CD.CPROF_UF, CD.CPROF_DTEXP,
CD.NUCLEO, NU.DESCRICAO DESCRICAO_NUCLEO, GH.DESCRICAO DESC_AGRUPAMENTO_INGRESSO,
CD.STATUS, CD.STATUS_OBS, CD.DT_CONVOCACAO, CD.DT_APRESENTACAO, CD.HORA_APRESENTACAO, CD.CDRH, CD.DT_CDRH, CD.CQHI, CD.DT_CQHI, CD.REMESSA_DOCUMENTO,
CD.DT_REMESSA_DOCUMENTO, CD.DT_PROPOSTA, CD.USULOGIN, CD.USUSENHA,Munic.NOME as MUNICIPIO, CD.ETNIAID, HD.NOME as ETNIA,
CD.DHR_CADASTRO as DT_CADASTRO, C.SIGLA AS COTA,cD.REGIONALID, ISNULL(RE.REGIONAL,'') AS REGIONAL
FROM LY_CANDIDATO_DOCENTE CD
LEFT JOIN MUNICIPIO Munic ON Munic.CODIGO = CD.MUNICIPIO_PROC
inner join Lyceum.ContratoTemporario.COTA C ON C.COTAID = CD.COTAIDINSCRICAO
inner join HADES..ETNIA HD ON HD.ETNIAID = CD.ETNIAID
inner join LY_CONCURSO_DOCENTE CO ON CO.CONCURSO = CD.CONCURSO
LEFT join LY_NUCLEO NU ON CD.NUCLEO = NU.NUCLEO
LEFT JOIN TCE_REGIONAL RE ON RE.ID_REGIONAL = CD.REGIONALID

inner join ContratoTemporario.CANDIDATODOCENTE_GRUPOHABILITACAO CG ON CG.CONCURSO = CD.CONCURSO and CG.CANDIDATO = CD.CANDIDATO
inner join LY_GRUPO_HABILITACAO GH ON GH.AGRUPAMENTO = CG.AGRUPAMENTO
	   LEFT JOIN HADES.dbo.NECESSIDADEESPECIAL NEC 
			 ON NEC.NECESSIDADEESPECIALID=CD.NECESSIDADEESPECIALID 
LEFT join LY_GRUPO_HABILITACAO GHI ON GHI.AGRUPAMENTO = CD.AGRUPAMENTO_INGRESSO
          WHERE CD.CANDIDATO = @P_CANDIDATO
          AND CD.CONCURSO = @P_CONCURSO
        </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CONCURSO">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="STATUS_CONCURSO">
          <DataField>STATUS_CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CANDIDATO">
          <DataField>CANDIDATO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
