  <DataSets>
    <DataSet Name="ds_experiencia">
      <Query>
        <DataSourceName>DS_Experiencia</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select CD.CANDIDATO AS CANDIDATO, COE.EXPERIENCIA, CODE.PONTUACAO AS PONTUACAO, COE.ORIGEM
from  LY_CONCURSO_DOC_EXPERIENCIA code  
inner join LY_CANDIDATO_DOC_EXPERIENCIAS cade on code.CONCURSO = cade.CONCURSO 
inner join LY_CONCURSO_EXPERIENCIA coe on coe.EXPERIENCIA = code.EXPERIENCIA and code.EXPERIENCIA = cade.EXPERIENCIA 
INNER JOIN LY_CANDIDATO_DOCENTE CD ON CD.CANDIDATO = cade.CANDIDATO AND CD.CONCURSO = cade.CONCURSO 
WHERE CD.CONCURSO = @P_CONCURSO 
AND CD.CANDIDATO = @P_CANDIDATO 
ORDER BY CD.CANDIDATO, COE.ORIGEM</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CANDIDATO">
          <DataField>CANDIDATO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="EXPERIENCIA">
          <DataField>EXPERIENCIA</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="PONTUACAO">
          <DataField>PONTUACAO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="ORIGEM">
          <DataField>ORIGEM</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_experiencia_dentro_seeduc">
      <Query>
        <DataSourceName>DS_Experiencia</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select CD.CANDIDATO AS CANDIDATO, COE.EXPERIENCIA, CODE.PONTUACAO AS PONTUACAO, COE.ORIGEM
from  LY_CONCURSO_DOC_EXPERIENCIA code  
inner join LY_CANDIDATO_DOC_EXPERIENCIAS cade on code.CONCURSO = cade.CONCURSO 
inner join LY_CONCURSO_EXPERIENCIA coe on coe.EXPERIENCIA = code.EXPERIENCIA and code.EXPERIENCIA = cade.EXPERIENCIA 
INNER JOIN LY_CANDIDATO_DOCENTE CD ON CD.CANDIDATO = cade.CANDIDATO AND CD.CONCURSO = cade.CONCURSO
WHERE CD.CONCURSO = @P_CONCURSO
AND CD.CANDIDATO = @P_CANDIDATO 
AND COE.ORIGEM = 'S' 
ORDER BY CD.CANDIDATO, COE.ORIGEM</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
