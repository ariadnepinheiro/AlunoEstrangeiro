    <DataSet Name="Data_Hora_atualizacao">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT TOP(1) CONVERT(VARCHAR(2),(DATEPART(DAY, DT_ATUALIZACAO)))+'/'+ CONVERT(VARCHAR(2), DATEPART(MONTH, DT_ATUALIZACAO))+'/'+ CONVERT(VARCHAR(4), DATEPART(YEAR, DT_ATUALIZACAO)) AS DATA, 
CONVERT(VARCHAR(5),CONVERT(TIME, DT_ATUALIZACAO)) HORA 
FROM	APOLLO..REL_CONTR_ATUALIZACAO (NOLOCK)
WHERE	ID_REL = 1</CommandText>
      </Query>
      <Fields>
        <Field Name="DATA">
          <DataField>DATA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HORA">
          <DataField>HORA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL AS ID_REGIONAL,' TODAS' AS REGIONAL 
UNION
SELECT R.ID_REGIONAL,SUBSTRING(R.REGIONAL,1,35) FROM LY_UNIDADE_ENSINO  L2
JOIN TCE_REGIONAL R ON R.ID_REGIONAL = L2.ID_REGIONAL
JOIN LY_USUARIO_UNIDADE_FIS JJ ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
ORDER BY REGIONAL</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL AS CODIGO, 'TODOS' AS NOME  
UNION

SELECT DISTINCT L1.CODIGO, L1.NOME 
FROM LY_UNIDADE_ENSINO L2 
JOIN LY_USUARIO_UNIDADE_FIS JJ ON JJ.UNIDADE_FIS = L2.UNIDADE_ENS
JOIN MUNICIPIO L1 ON L1.CODIGO = L2.MUNICIPIO
JOIN TCE_REGIONAL N1 ON N1.ID_REGIONAL = L2.ID_REGIONAL
-- JOIN LY_NUCLEO N1 ON N1.NUCLEO = L2.NUCLEO
WHERE 1 = 1 
AND (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR JJ.USUARIO IS NULL) 
AND (N1.ID_REGIONAL = ISNULL(@REGIONAL, N1.ID_REGIONAL) OR N1.ID_REGIONAL IS NULL) </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT NULL AS UNIDADE_ENS, 'TODAS' AS NOME_COMP 
UNION

SELECT DISTINCT UE.UNIDADE_ENS, SUBSTRING(UE.NOME_COMP,1,50) NOME_COMP 
FROM LY_UNIDADE_ENSINO UE 
JOIN LY_USUARIO_UNIDADE_FIS GG ON GG.UNIDADE_FIS = UE.UNIDADE_ENS
WHERE 1 = 1 
AND (UE.MUNICIPIO = ISNULL(@MUNICIPIO,UE.MUNICIPIO)OR UE.MUNICIPIO IS NULL)
AND (UE.ID_REGIONAL = ISNULL(@REGIONAL, UE.ID_REGIONAL)OR UE.ID_REGIONAL IS NULL)
ORDER BY NOME_COMP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
