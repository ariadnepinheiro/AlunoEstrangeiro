  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>ca5a0312-59c5-4bc8-ab44-49187c7d5c87</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Rel_Contratos_Alocados">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
	 SQL1.REGIONAL
	,SQL1.MUNICIPIO
	,SQL1.FUNCAO
	,SQL1.DISCIPLINA_INGRESSO
	,SQL1.PROFESSOR
	,SQL1.MATRICULA
	,SQL1.DATA_ADMISSAO
	,SQL1.UA
	,SQL1.CENSO
	,SQL1.UE
	,SQL1.CARGA_HORARIA
	,SQL1.ATUACAO
	,SQL1.RESTANTE
	,SQL1.SITUACAO
	,SQL1.DATA_OCORRENCIA
	,SQL1.UA_ATUAL
	,SQL1.IDFUNCIONAL
	,SQL1.VINCULO
	FROM
(
	SELECT DISTINCT		 
		 TR.REGIONAL
		,TM.NOME AS MUNICIPIO
		,LF.DESCRICAO AS FUNCAO
		,(
			 SELECT TOP 1 HH.DESCRICAO 
			 FROM  LY_GRUPO_HABILITACAO HH (NOLOCK) 
			 INNER JOIN LY_GRUPO_HABILITACAO_DOC DF (NOLOCK) ON DF.AGRUPAMENTO = HH.AGRUPAMENTO 
			 WHERE DF.NUM_FUNC = LD.NUM_FUNC 
			 AND DF.AGRUPAMENTO_INGRESSO = 'S'
			) AS DISCIPLINA_INGRESSO
		,UPPER(PE.NOME_COMPL) AS PROFESSOR
		,LD.MATRICULA
		,SS.NUM_FUNC
		,CONVERT(VARCHAR(10), LD.DT_ADMISSAO, 103) AS DATA_ADMISSAO
		--,LT.SETOR AS UA
		,VWS.UA_ANTIGA AS UA
		,LUE.UNIDADE_ENS AS CENSO
		,LUE.NOME_COMP AS UE
		,ISNULL(CH.CARGAHORARIAREGENCIA, 0) AS CARGA_HORARIA
		,ISNULL(SS.ATUACAO, 0) AS ATUACAO
		,CASE 
			WHEN MT.MOTIVO = '43' THEN CONVERT(INT, ISNULL(CH.CARGAHORARIAREGENCIA, 0)) / 2 - ISNULL(SS.ATUACAO, 0)
			ELSE CONVERT(INT, ISNULL(CH.CARGAHORARIAREGENCIA, 0)) - ISNULL(SS.ATUACAO, 0) 
		 END RESTANTE 
		,SC.DESCRICAO AS SITUACAO
		,CONVERT(VARCHAR, LCDO.DT_PROPOSTA, 103) AS DATA_OCORRENCIA
		,VWS.UA_ATUAL
		,LD.VINCULO
		,PE.IDFUNCIONAL
	FROM LY_DOCENTE LD WITH (NOLOCK)
	INNER JOIN LY_PESSOA PE WITH (NOLOCK) ON PE.PESSOA = LD.PESSOA
	INNER JOIN LY_CANDIDATO_DOCENTE LCDO WITH (NOLOCK) ON LCDO.CANDIDATO = LD.CANDIDATO
	INNER JOIN LY_AULA_DOCENTE LAD WITH (NOLOCK) ON LAD.NUM_FUNC = LD.NUM_FUNC
	INNER JOIN LY_LOTACAO LT WITH (NOLOCK) ON LD.MATRICULA = LT.MATRICULA 								  								  
										   AND (
													LT.DATA_NOMEACAO &lt;= CONVERT(DATE, CURRENT_TIMESTAMP) 
													AND (LT.DATA_DESATIVACAO &gt; CONVERT(DATE,CURRENT_TIMESTAMP) OR LT.DATA_DESATIVACAO IS NULL)
												)
	INNER JOIN LY_TURMA LTU WITH (NOLOCK) ON  LAD.ANO = LTU.ANO            
									AND LAD.DISCIPLINA = LTU.DISCIPLINA            
									AND LAD.FACULDADE = LTU.FACULDADE            
									AND LAD.SEMESTRE = LTU.SEMESTRE            
									AND LAD.TURMA = LTU.TURMA            
									AND LAD.TURNO = LTU.TURNO           
									AND LAD.DATA_FIM &gt;= CONVERT(DATE,CURRENT_TIMESTAMP)     
									AND LAD.DATA_FIM = LTU.DT_FIM 
									AND LTU.ANO = YEAR(GETDATE())
	INNER JOIN LY_FUNCAO LF WITH (NOLOCK) ON  LF.FUNCAO = LT.FUNCAO    
	INNER JOIN LY_UNIDADE_ENSINO LUE WITH (NOLOCK) ON LT.SETOR = LUE.SETOR 												   	
	INNER JOIN TCE_REGIONAL TR ON TR.ID_REGIONAL = LUE.ID_REGIONAL
	INNER JOIN HADES..TCE_MUNICIPIO TM WITH (NOLOCK) ON TM.ID_MUNICIPIO = LUE.MUNICIPIO
	 LEFT JOIN LY_CATEGORIA_DOCENTE CO ( NOLOCK ) ON CO.CATEGORIA = LD.CATEGORIA
  LEFT JOIN RecursosHumanos.CH_AGRUPAMENTOCARGO AS CH ( NOLOCK ) ON CH.AGRUPAMENTOCARGOSID = co.AGRUPAMENTOCARGOSID
                                                              AND CH.FUNCAO = LT.FUNCAO      
	INNER JOIN STATUS_CONTRATO SC WITH(NOLOCK) ON SC.STATUS = LCDO.STATUS
	LEFT JOIN
	( 
		SELECT NUM_FUNC, ATUACAO, ANO 
		FROM APOLLO.dbo.REL_CH_LIVRE WITH (NOLOCK)  
		WHERE ANO = (SELECT YEAR(GETDATE()))
	) AS SS ON SS.NUM_FUNC = LD.NUM_FUNC 
	LEFT JOIN 
	(
		SELECT NUM_FUNC, MOTIVO
		FROM LY_LICENCA_DOCENTE WITH(NOLOCK) 
		WHERE MOTIVO = '43' 
		AND DTINI &lt;= CONVERT(DATE, CURRENT_TIMESTAMP) 
		AND DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP) 
	) AS MT ON MT.NUM_FUNC = LD.NUM_FUNC
	JOIN    HADES..VW_SETOR VWS on VWS.SETOR = LUE.SETOR 
	WHERE 
	(LD.CANDIDATO IS NOT NULL AND LD.CONCURSO IS NOT NULL)
	AND (TR.ID_REGIONAL = ISNULL(@REGIONAL, TR.ID_REGIONAL))
	AND (TM.ID_MUNICIPIO = ISNULL(@MUNICIPIO, TM.ID_MUNICIPIO))
	AND (LUE.UNIDADE_ENS = ISNULL(@ESCOLA, LUE.UNIDADE_ENS))
)
AS SQL1
WHERE 
	NOT EXISTS 
	( 
		SELECT 1 FROM LY_LICENCA_DOCENTE WITH (NOLOCK) 
		WHERE SQL1.NUM_FUNC = NUM_FUNC 
		AND MOTIVO &lt;&gt; '43' 
		AND (DTFIM IS NULL OR DTFIM &gt;= CONVERT(DATE, CURRENT_TIMESTAMP)) 
	) 
ORDER BY SQL1.REGIONAL, SQL1.MUNICIPIO, SQL1.UE, SQL1.DISCIPLINA_INGRESSO, SQL1.PROFESSOR</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DISCIPLINA_INGRESSO">
          <DataField>DISCIPLINA_INGRESSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
