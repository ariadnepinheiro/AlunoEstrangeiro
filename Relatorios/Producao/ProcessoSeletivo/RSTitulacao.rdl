  <DataSources>
    <DataSource Name="DS_Titulacao">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.197;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>15dd8341-3961-4388-b23c-963d1036ce35</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_titulacao">
      <Query>
        <DataSourceName>DS_Titulacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select CD.CANDIDATO AS CANDIDATO, cont.TITULACAO AS TITULACAO, CONT.DESCRICAO AS TIT_DESCRICAO, CODT.PONTUACAO AS PONTUACAO
from  LY_CONCURSO_DOC_TITULACOES codt  
inner join LY_CANDIDATO_DOC_TITULACOES cadt on codt.CONCURSO = cadt.CONCURSO 
inner join LY_CONCURSO_TITULACAO cont on cont.TITULACAO = codt.TITULACAO and cont.TITULACAO = cadt.TITULACAO
INNER JOIN LY_CANDIDATO_DOCENTE CD ON CD.CANDIDATO = cadt.CANDIDATO AND CD.CONCURSO = cadt.CONCURSO
WHERE CD.CONCURSO = @P_CONCURSO
AND CD.CANDIDATO = @P_CANDIDATO 
ORDER BY CD.CANDIDATO, cadt.TITULACAO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CANDIDATO">
          <DataField>CANDIDATO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="TITULACAO">
          <DataField>TITULACAO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="TIT_DESCRICAO">
          <DataField>TIT_DESCRICAO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="PONTUACAO">
          <DataField>PONTUACAO</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="P_CONCURSO">
