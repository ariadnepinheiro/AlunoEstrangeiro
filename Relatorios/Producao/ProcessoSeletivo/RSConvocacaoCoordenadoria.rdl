    <DataSet Name="Concurso">
      <Query>
        <DataSourceName>DS_Convocacao</DataSourceName>
        <CommandText>Select DISTINCT CONCURSO,ANO  
from LY_CONCURSO_DOCENTE 
WHERE TIPO = 'Contrato'
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="CONCURSO">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regional">
      <Query>
        <DataSourceName>DS_Convocacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText> SELECT  NULL as 	ID_REGIONAL ,
        ' TODOS' NOME
UNION
SELECT DISTINCT
        ID_REGIONAL ,
        REGIONAL
FROM    LY_CONCURSO_DOC_HABILITACAO H
        INNER JOIN MUNICIPIO M ON M.CODIGO = H.MUNICIPIO_PROC
        INNER JOIN LY_CONCURSO_DOCENTE D ON D.CONCURSO = H.CONCURSO
       INNER JOIN EXTRACOES..REGIONAL_MUNICIPIO RM ON H.MUNICIPIO_PROC = RM.MUNICIPIO
WHERE   ( D.CONCURSO = ISNULL(@CONCURSO, D.CONCURSO)
          OR D.CONCURSO IS NULL
        )
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Municipio">
      <Query>
        <DataSourceName>DS_Convocacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!P_REGIONAL.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  NULL as MUNICIPIO_PROC ,
        ' TODOS' NOME
UNION
SELECT DISTINCT
        MUNICIPIO_PROC ,
        NOME
FROM    LY_CONCURSO_DOC_HABILITACAO H
        INNER JOIN MUNICIPIO M ON M.CODIGO = H.MUNICIPIO_PROC
        INNER JOIN LY_CONCURSO_DOCENTE D ON D.CONCURSO = H.CONCURSO
		INNER JOIN EXTRACOES..REGIONAL_MUNICIPIO RM ON H.MUNICIPIO_PROC = RM.MUNICIPIO
WHERE   ( D.CONCURSO = ISNULL(@CONCURSO, D.CONCURSO)
          OR D.CONCURSO IS NULL
        )
		AND ( ID_REGIONAL = ISNULL(@REGIONAL, ID_REGIONAL)
          OR ID_REGIONAL IS NULL
        )
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="MUNICIPIO_PROC">
          <DataField>MUNICIPIO_PROC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Disciplina">
      <Query>
        <DataSourceName>DS_Convocacao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!P_MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT DISTINCT gh.AGRUPAMENTO as AGRUPAMENTO, UPPER (gh.DESCRICAO) as DESCRICAO
          FROM LY_CONCURSO_DOC_HABILITACAO H
          INNER JOIN LY_GRUPO_HABILITACAO GH ON gh.AGRUPAMENTO = H.AGRUPAMENTO
          WHERE
          (H.MUNICIPIO_PROC = ISNULL(@MUNICIPIO, H.MUNICIPIO_PROC) or H.MUNICIPIO_PROC is null)
          AND  (H.CONCURSO = ISNULL (@CONCURSO, H.CONCURSO)OR H.CONCURSO IS NULL)
          UNION
          SELECT NULL CODIGO,' TODOS' DESCRICAO
          UNION
          SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
          ORDER BY DESCRICAO
        </CommandText>
      </Query>
      <Fields>
        <Field Name="AGRUPAMENTO">
          <DataField>AGRUPAMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
