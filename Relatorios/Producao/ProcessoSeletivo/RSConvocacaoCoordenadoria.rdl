              <TextRuns>
                <TextRun>
                  <Value>=First(Fields!REGIONAL.Value, "ds_Convocacao")</Value>
                  <Style>
                    <FontWeight>Bold</FontWeight>
                  </Style>
                </TextRun>
                <TextRun>
                  <Value xml:space="preserve">  </Value>
                  <Style>
                    <FontWeight>Bold</FontWeight>
                  </Style>
                </TextRun>
                <TextRun>
                  <Value>=iif(FIRST(Fields!CONCURSO.Value, "ds_Convocacao") &lt;&gt; "24º Processo", FIRST(Fields!MUNICIPIO.Value, "ds_Convocacao"),"")</Value>
                  <Style>
                    <FontWeight>Bold</FontWeight>
                  </Style>
                </TextRun>
              </TextRuns>
              <Style>
                <TextAlign>Center</TextAlign>
              </Style>
            </Paragraph>
