  <Code>Public Function FormatarCPFCNPJ(Valor As String) As String

    If InStr(1, Valor, ".") &lt;&gt; 0 Or _
       Trim(Valor) = "" Then
        
        'o campo informado já está formatado ou é vazio
        FormatarCPFCNPJ = Valor
    
    ElseIf Len(Valor) = 11 Then
        'CPF
        FormatarCPFCNPJ = Mid(Valor, 1, 3) &amp; "." &amp; _
                          Mid(Valor, 4, 3) &amp; "." &amp; _
                          Mid(Valor, 7, 3) &amp; "-" &amp; _
                          Mid(Valor, 10, 2)
            
    Else
        'CNPJ
        FormatarCPFCNPJ = Mid(Valor, 1, 2) &amp; "." &amp; _
                          Mid(Valor, 3, 3) &amp; "." &amp; _
                          Mid(Valor, 6, 3) &amp; "/" &amp; _
                          Mid(Valor, 9, 4) &amp; "-" &amp; _
                          Mid(Valor, 13, 2)
        
    End If

End Function</Code>
