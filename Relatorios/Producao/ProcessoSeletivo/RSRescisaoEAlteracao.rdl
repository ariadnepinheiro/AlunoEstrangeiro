  <DataSources>
    <DataSource Name="DS_Recisao">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>d7e21c2e-bee6-499c-bc95-82876bbe65ee</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ds_Recisao">
      <Query>
        <DataSourceName>DS_Recisao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CD.NOME, cd.CANDIDATO, cd.CONCURSO
         , CD.IDFUNCIONAL
         , CD.CPF
         , CT.SIGLA AS COTA
         , CD.DT_PROPOSTA AS DATAADMISSAO
         , CDS.DESCRICAO AS SITUACAO
         , UE.NOME_COMP
         , CD.CATEGORIA AS CARGO
         , CD.CARGA_HORARIA
         , CDC.DT_FIM_CONTRATO AS DATAULTIMOEXERCICIO
         , CD.STATUS_OBS AS JUSTIFICATIVA
         , (Select NOME from MUNICIPIO WHERE CODIGO = Cd.MUNICIPIO_PROC) as Municipio
         , (Select REGIONAL from TCE_REGIONAL WHERE ID_REGIONAL = Cd.REGIONALID) as Regional
         , (Select DESCRICAO from LY_NUCLEO WHERE NUCLEO = Cd.NUCLEO) as Coordenadoria
         , UE.NOME_COMP as Unidade_Ensino
         , GH.DESCRICAO AS DISCIPLINA
         , DOC.PESSOA,DOC.MATRICULA
         , DOC.NUM_FUNC
		 ,DOC.VINCULO
      FROM LY_CANDIDATO_DOCENTE CD (NOLOCK)
     INNER
      JOIN LY_CANDIDATO_DOCENTE_STATUS CDS (NOLOCK)
        ON CDS.STATUSID = CD.STATUS
     INNER
      JOIN LY_DOCENTE DOC (NOLOCK)
        ON CD.CONCURSO = DOC.CONCURSO
       AND CD.CANDIDATO = DOC.CANDIDATO
     INNER
      JOIN LY_LOTACAO LT (NOLOCK)
        ON DOC.MATRICULA = LT.MATRICULA
       AND DOC.PESSOA = LT.PESSOA
     INNER
      JOIN LY_UNIDADE_ENSINO UE (NOLOCK)
        ON UE.UNIDADE_ENS = LT.UNIDADE_ENS
     INNER
      JOIN LY_GRUPO_HABILITACAO GH (NOLOCK)
        ON GH.AGRUPAMENTO = CD.AGRUPAMENTO_INGRESSO
     LEFT
      JOIN LY_CANDIDATO_DOC_CONTRATO CDC (NOLOCK)
        ON CD.CANDIDATO = CDC.CANDIDATO
       AND CD.CONCURSO = CDC.CONCURSO
      LEFT
      JOIN ContratoTemporario.COTA CT (NOLOCK)
        ON CT.COTAID = CD.COTAIDCONVOCACAO
WHERE CD.CANDIDATO = @P_CANDIDATO
     AND CD.CONCURSO = @P_CONCURSO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CANDIDATO">
          <DataField>CANDIDATO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CONCURSO">
          <DataField>CONCURSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IDFUNCIONAL">
          <DataField>IDFUNCIONAL</DataField>
