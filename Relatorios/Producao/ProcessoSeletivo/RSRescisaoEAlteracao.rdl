    <DataSet Name="ds_Aulas_Alocadas">
      <Query>
        <DataSourceName>DS_Recisao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT COUNT(*) FROM LY_CANDIDATO_DOCENTE CD JOIN LY_DOCENTE D ON CD.CONCURSO = D.CONCURSO AND CD.CANDIDATO = D.CANDIDATO JOIN LY_AULA_DOCENTE A ON D.NUM_FUNC = A.NUM_FUNC
WHERE CD.CONCURSO = @P_CONCURSO AND CD.CANDIDATO = @P_CANDIDATO AND (CONVERT(DATE,GETDATE()) BETWEEN CONVERT(DATE,A.DATA_INICIO) AND CONVERT(DATE,A.DATA_FIM) )</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField />
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Carga_Horaria">
      <Query>
        <DataSourceName>DS_Recisao</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@P_CANDIDATO">
            <Value>=Parameters!P_CANDIDATO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@P_CONCURSO">
            <Value>=Parameters!P_CONCURSO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT CARGA_HORARIA_ATUAL AS CARGAHORARIAANTERIOR, CARGA_HORARIA_NOVA FROM LY_CANDIDATO_DOC_SOLICITACOES
WHERE CANDIDATO = @P_CANDIDATO AND CONCURSO = @P_CONCURSO AND ID_CANDIDATO_DOC_SOLICITACOES =
(SELECT MAX(ID_CANDIDATO_DOC_SOLICITACOES)
FROM LY_CANDIDATO_DOC_SOLICITACOES
WHERE CANDIDATO = @P_CANDIDATO AND
CONCURSO = @P_CONCURSO)</CommandText>
      </Query>
      <Fields>
        <Field Name="CARGAHORARIAANTERIOR">
          <DataField>CARGAHORARIAANTERIOR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CARGA_HORARIA_NOVA">
          <DataField>CARGA_HORARIA_NOVA</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSConcurso">
      <Query>
        <DataSourceName>DS_Recisao</DataSourceName>
        <CommandText>Select Concurso from ly_concurso_docente order by concurso desc</CommandText>
      </Query>
      <Fields>
        <Field Name="Concurso">
          <DataField>Concurso</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
