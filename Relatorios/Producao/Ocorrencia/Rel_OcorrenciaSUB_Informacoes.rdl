            <TextRuns>
              <TextRun>
                <Value>="Essa ocorrência foi cadastrada por " + Fields!NOMEPESSOA.Value + ", " + Fields!FUNCAO.Value + ", em " + format(Fields!DATACADASTRO.Value, "dd/MM/yyyy HH:mm") + "h, horário oficial de Brasília."</Value>
                <Style>
                  <FontFamily>Calibri</FontFamily>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
            <Style />
          </Paragraph>
        </Paragraphs>
        <rd:DefaultName>Textbox9</rd:DefaultName>
        <Top>14.69538cm</Top>
