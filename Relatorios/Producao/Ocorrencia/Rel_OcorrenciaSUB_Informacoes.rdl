  </Body>
  <Width>8.1372in</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>0cm</LeftMargin>
    <RightMargin>0cm</RightMargin>
    <TopMargin>0cm</TopMargin>
    <BottomMargin>0cm</BottomMargin>
    <ColumnSpacing>0.13cm</ColumnSpacing>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DBLyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>a807f783-f9ea-45c5-92c6-af7a50187174</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CH_Informacoes">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@OCORRENCIAID">
            <Value>=Parameters!OCORRENCIAID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>  SELECT	  O.[NUMEROOCORRENCIA] AS N_OCORRENCIA, O.OCORRENCIAID
	  ,U.NOME_COMP AS ESCOLA
	  ,M.NOME AS MUNICIPIO
	  ,Ba.DESCRICAO as BAIRRO
	  ,[CENSO]
	  ,O.RELATO
	  ,O.OBSERVACAO
	  ,R.REGIONAL
	  ,[DATAOCORRENCIA]
	   ,C.DESCRICAO AS CLASSE
 	   ,S.DESCRICAO AS SUBCLASSE
   ,ME.DESCRICAO AS MEIO
   ,O.DATACADASTRO
	   ,YEAR(O.DATACADASTRO) AS ANO
	   	  ,IIF(o.USOARMA = 0 , 'NÃO', 'SIM') AS USOARMA
	  ,o.REGISTROOCORRENCIA
	  ,B.DESCRICAO AS BATALHAO
	  ,D.DESCRICAO AS DELEGACIA ,(SELECT F.DESCRICAO FROM VW_FUNCIONARIOS L 
	  INNER JOIN USUARIO U ON U.PESSOA_USUARIO = L.PESSOA AND (L.MATRICULA = U.USUARIO OR L.IDVINCULO = U.USUARIO)	  
	  INNER JOIN LY_FUNCAO F ON F.FUNCAO = L.FUNCAO
	  WHERE O.USUARIOCADASTRO=U.USUARIO  
	  AND O.DATACADASTRO BETWEEN L.DATA_NOMEACAO AND ISNULL(L.DATA_DESATIVACAO, GETDATE())) AS FUNCAO
	  ,(SELECT L.NOME_COMPL FROM VW_FUNCIONARIOS L 
	  INNER JOIN USUARIO U ON U.PESSOA_USUARIO = L.PESSOA AND (L.MATRICULA = U.USUARIO OR L.IDVINCULO = U.USUARIO)	  
	  INNER JOIN LY_FUNCAO F ON F.FUNCAO = L.FUNCAO
	  WHERE O.USUARIOCADASTRO=U.USUARIO  
	  AND O.DATACADASTRO BETWEEN L.DATA_NOMEACAO AND ISNULL(L.DATA_DESATIVACAO, GETDATE())) AS NOMEPESSOA
  FROM [LYCEUM].[Ocorrencias].[OCORRENCIA] O
  INNER JOIN LY_UNIDADE_ENSINO U							ON U.UNIDADE_ENS   = O.CENSO
  INNER JOIN MUNICIPIO M								ON U.MUNICIPIO	   = M.CODIGO
LEFT JOIN HADES..BAIRRO Ba ON U.BAIRRO = Ba.CODIGO
  INNER JOIN TCE_REGIONAL R							ON R.ID_REGIONAL   = U.ID_REGIONAL
  LEFT JOIN  [LYCEUM].[Ocorrencias].[CLASSE] C						ON C.CLASSEID      = O.CLASSEID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[SUBCLASSE] S					ON S.SUBCLASSEID   = O.SUBCLASSEID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[MEIO] ME ON O.MEIOID = ME.MEIOID 
  LEFT join [LYCEUM].[Ocorrencias].[BATALHAO] B on O.BATALHAOID = B.BATALHAOID
  LEFT JOIN [LYCEUM].[Ocorrencias].[DELEGACIA] D ON D.DELEGACIAID = O.DELEGACIAID
where O.[OCORRENCIAID]  = @OCORRENCIAID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
