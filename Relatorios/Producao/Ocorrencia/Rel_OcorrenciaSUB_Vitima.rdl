  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DBLyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>a807f783-f9ea-45c5-92c6-af7a50187174</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CH_Vitima">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@OCORRENCIAID">
            <Value>=Parameters!OCORRENCIAID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>  SELECT TOP (1000) V.[VITIMAID]
      ,V.[OCORRENCIAID]
     ,iif(V.[TIPO]=1,'ALUNO',iif(V.[TIPO]=2,'SERVIDOR',iif(V.[TIPO]=3,'UNIDADE DE ENSINO','OUTRO'))) AS TIPO
      ,V.[DESCONHECIDO]
      ,V.[PESSOAID]
      ,V.[VINCULO]
      ,V.[RGNUMERO]
      ,V.[RGTIPO]
      ,V.[RGEMISSOR]
      ,V.[RGUF]
	  ,V.CPF
    ,convert(varchar, V.RGDATAEXP, 103) as RGDATAEXP
	,iif(p.NOME_COMPL is null,iif(V.[NOME] is null,u.NOME_COMP,V.[NOME]),p.NOME_COMPL) as NOME_COMPL
	  ,iif(p.IDFUNCIONAL is null, iif(a.ALUNO is null, CAST(V.[CPF] AS varchar),CAST(a.ALUNO AS varchar)),CAST(p.IDFUNCIONAL AS varchar)) as id
  FROM [LYCEUM].[Ocorrencias].[VITIMA] v 
  left join [LYCEUM].[dbo].[LY_PESSOA] p on v.[PESSOAID] = p.PESSOA
  left JOIN DBO.LY_ALUNO A ON p.PESSOA = A.PESSOA
   left JOIN [LYCEUM].[Ocorrencias].[OCORRENCIA] O on v.OCORRENCIAID = o.OCORRENCIAID
   left JOIN LY_UNIDADE_ENSINO U							ON U.UNIDADE_ENS   = O.CENSO
  where V.[OCORRENCIAID] = @OCORRENCIAID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
