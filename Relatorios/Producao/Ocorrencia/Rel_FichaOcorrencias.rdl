  <DataSets>
    <DataSet Name="DT_Regional">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 0 ID_REGIONAL,' TODAS' REGIONAL
UNION
SELECT  L1.ID_REGIONAL, SUBSTRING(L1.REGIONAL,1,35) FROM TCE_REGIONAL L1 (NOLOCK)
JOIN LYCEUM..LY_UNIDADE_ENSINO L2 (NOLOCK) ON L1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE (JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_Municipio">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT L1.CODIGO, L1.NOME FROM LY_UNIDADE_ENSINO L2 (NOLOCK)
JOIN HADES..MUNICIPIO L1 (NOLOCK) ON L1.CODIGO=L2.MUNICIPIO
JOIN LYCEUM..TCE_REGIONAL N1 (NOLOCK) ON N1.ID_REGIONAL=L2.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS JJ (NOLOCK) ON JJ.UNIDADE_FIS=L2.UNIDADE_ENS
WHERE 
	(N1.ID_REGIONAL =@REGIONAL OR @REGIONAL=0 )
	AND
	(JJ.USUARIO = ISNULL(@usuario,JJ.USUARIO) OR  JJ.USUARIO IS NULL) 
UNION
SELECT '0' CODIGO,' TODOS' NOME
UNION
SELECT 'NULO' CODIGO,' Selecione...' DESCRICAO
ORDER BY NOME</CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_Escola">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
SELECT '0' UNIDADE_ENS, ' TODAS' NOME_COMP 
UNION
SELECT UE.UNIDADE_ENS, SUBSTRING (UE.NOME_COMP,1,50)NOME_COMP 
FROM LYCEUM..LY_UNIDADE_ENSINO UE (NOLOCK) 
JOIN LYCEUM..TCE_REGIONAL R (NOLOCK) ON R.ID_REGIONAL = UE.ID_REGIONAL
JOIN LYCEUM..LY_USUARIO_UNIDADE_FIS GG (NOLOCK) ON GG.UNIDADE_FIS=UE.UNIDADE_ENS
WHERE (R.ID_REGIONAL = @REGIONAL OR @REGIONAL=0)
AND (UE.MUNICIPIO =@MUNICIPIO OR @MUNICIPIO='0')
AND (GG.USUARIO = ISNULL(@usuario, GG.usuario) OR GG.USUARIO IS NULL) 
AND  EXISTS (
				SELECT	1
				FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
				WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
				AND		US.SITUACAO = 'ESTADUAL'
				AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
							(
							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
							FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
							)
				)
AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
ORDER BY NOME_COMP</CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_Ano">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <CommandText>SELECT 0 AS ANO, 'TODOS' AS TODOS
UNION
select distinct year(DATAOCORRENCIA) as ano,CAST(year(DATAOCORRENCIA) AS nvarchar) AS TODOS 
from [LYCEUM].[Ocorrencias].[OCORRENCIA]</CommandText>
      </Query>
      <Fields>
        <Field Name="ano">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TODOS">
          <DataField>TODOS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_Classe">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <CommandText> select 0 AS CLASSEID, 'TODOS' AS DESCRICAO
UNION
 select CLASSEID, DESCRICAO
 from  [LYCEUM].[Ocorrencias].[CLASSE]</CommandText>
      </Query>
      <Fields>
        <Field Name="CLASSEID">
          <DataField>CLASSEID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_SubClasse">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CLASSE">
            <Value>=Parameters!CLASSE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>	select 0 AS SUBCLASSEID, 'TODOS' AS DESCRICAO 
UNION
	select SUBCLASSEID,DESCRICAO 
	from  [LYCEUM].[Ocorrencias].[SUBCLASSE]
	WHERE (CLASSEID = @CLASSE)</CommandText>
      </Query>
      <Fields>
        <Field Name="SUBCLASSEID">
          <DataField>SUBCLASSEID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_Tratamento">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <CommandText>select 0 AS TRATAMENTOID,'TODOS' AS DESCRICAO
UNION
select TRATAMENTOID,DESCRICAO from  [LYCEUM].[Ocorrencias].[TRATAMENTO]</CommandText>
      </Query>
      <Fields>
        <Field Name="TRATAMENTOID">
          <DataField>TRATAMENTOID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DESCRICAO">
          <DataField>DESCRICAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_Informacoes">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DATAOCORRENCIA">
            <Value>=Parameters!DATAOCORRENCIA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CLASSE">
            <Value>=Parameters!CLASSE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SUBCLASSE">
            <Value>=Parameters!SUBCLASSE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TRATAMENTO">
            <Value>=Parameters!TRATAMENTO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	  O.[OCORRENCIAID] AS N_OCORRENCIA
	  ,U.NOME_COMP AS ESCOLA
	  ,M.NOME AS MUNICIPIO
	  ,[CENSO]
	  ,R.REGIONAL
	  ,[DATAOCORRENCIA]
	  ,SUBSTRING(iif(T.DESCRICAO is null, '',T.DESCRICAO),0,100) AS TRATAMENTO
	   ,C.DESCRICAO AS CLASSE
 	   ,S.DESCRICAO AS SUBCLASSE
	   ,YEAR(O.DATACADASTRO) AS ANO
	  ,pv.NOME_COMPL as VITIMA
      ,v.[TIPO] as VITIMA_TIPO
      ,v.[DESCONHECIDO] as VITIMA_DESCONHECIDO
	  ,PA.NOME_COMPL AS ACUSADO
	  ,A.TIPO AS ACUSADO_TIPO
	  ,A.DESCONHECIDO AS ACUSADO_DESCONHECIDO
  FROM [LYCEUM].[Ocorrencias].[OCORRENCIA] O
  INNER JOIN LY_UNIDADE_ENSINO U							ON U.UNIDADE_ENS   = O.CENSO
  INNER JOIN MUNICIPIO M								ON U.MUNICIPIO	   = M.CODIGO
  INNER JOIN TCE_REGIONAL R							ON R.ID_REGIONAL   = U.ID_REGIONAL
  LEFT JOIN  [LYCEUM].[Ocorrencias].[OCORRENCIATRATAMENTO] OT   
		ON OT.OCORRENCIAID = O.OCORRENCIAID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[TRATAMENTO] T					ON T.TRATAMENTOID  = OT.TRATAMENTOID	
  LEFT JOIN  [LYCEUM].[Ocorrencias].[CLASSE] C						ON C.CLASSEID      = O.CLASSEID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[SUBCLASSE] S					ON S.SUBCLASSEID   = O.SUBCLASSEID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[VITIMA] v				    ON V.OCORRENCIAID = O.OCORRENCIAID
  LEFT JOIN  [LYCEUM].[dbo].[LY_PESSOA] pv						on v.[PESSOAID] = pv.PESSOA
  LEFT JOIN  [LYCEUM].[Ocorrencias].[ACUSADO] A				    ON A.OCORRENCIAID = O.OCORRENCIAID
  LEFT JOIN  [LYCEUM].[dbo].[LY_PESSOA] PA						on A.[PESSOAID] = PA.PESSOA
where  (R.ID_REGIONAL = @REGIONAL or @REGIONAL = 0) AND 
             (U.MUNICIPIO = @MUNICIPIO or @MUNICIPIO ='0') AND 
             (U.UNIDADE_ENS = @ESCOLA or @ESCOLA ='0') AND
            (YEAR(DATAOCORRENCIA) = @ANO OR @ANO =0) AND
(DATAOCORRENCIA = @DATAOCORRENCIA OR @DATAOCORRENCIA IS NULL)	AND
            (C.CLASSEID= @CLASSE OR @CLASSE =0) AND
            ( O.SUBCLASSEID = @SUBCLASSE OR @SUBCLASSE =0) AND
            (T.TRATAMENTOID= @TRATAMENTO OR @TRATAMENTO=0) 
  order by O.[OCORRENCIAID]</CommandText>
      </Query>
      <Fields>
        <Field Name="N_OCORRENCIA">
          <DataField>N_OCORRENCIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATAOCORRENCIA">
          <DataField>DATAOCORRENCIA</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="TRATAMENTO">
          <DataField>TRATAMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CLASSE">
          <DataField>CLASSE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SUBCLASSE">
          <DataField>SUBCLASSE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VITIMA">
          <DataField>VITIMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VITIMA_TIPO">
          <DataField>VITIMA_TIPO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VITIMA_DESCONHECIDO">
          <DataField>VITIMA_DESCONHECIDO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ACUSADO">
          <DataField>ACUSADO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ACUSADO_TIPO">
          <DataField>ACUSADO_TIPO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ACUSADO_DESCONHECIDO">
          <DataField>ACUSADO_DESCONHECIDO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DT_Ocorrencias">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DATAOCORRENCIA">
            <Value>=Parameters!DATAOCORRENCIA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CLASSE">
            <Value>=Parameters!CLASSE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SUBCLASSE">
            <Value>=Parameters!SUBCLASSE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TRATAMENTO">
            <Value>=Parameters!TRATAMENTO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	DISTINCT  O.[OCORRENCIAID] AS N_OCORRENCIA
  FROM [LYCEUM].[Ocorrencias].[OCORRENCIA] O
  INNER JOIN LY_UNIDADE_ENSINO U							ON U.UNIDADE_ENS   = O.CENSO
  INNER JOIN MUNICIPIO M								ON U.MUNICIPIO	   = M.CODIGO
  INNER JOIN TCE_REGIONAL R							ON R.ID_REGIONAL   = U.ID_REGIONAL
  LEFT JOIN  [LYCEUM].[Ocorrencias].[OCORRENCIATRATAMENTO] OT   
		ON OT.OCORRENCIAID = O.OCORRENCIAID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[TRATAMENTO] T					ON T.TRATAMENTOID  = OT.TRATAMENTOID	
  LEFT JOIN  [LYCEUM].[Ocorrencias].[CLASSE] C						ON C.CLASSEID      = O.CLASSEID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[SUBCLASSE] S					ON S.SUBCLASSEID   = O.SUBCLASSEID
  LEFT JOIN  [LYCEUM].[Ocorrencias].[VITIMA] v				    ON V.OCORRENCIAID = O.OCORRENCIAID
  LEFT JOIN  [LYCEUM].[dbo].[LY_PESSOA] pv						on v.[PESSOAID] = pv.PESSOA
  LEFT JOIN  [LYCEUM].[Ocorrencias].[ACUSADO] A				    ON A.OCORRENCIAID = O.OCORRENCIAID
  LEFT JOIN  [LYCEUM].[dbo].[LY_PESSOA] PA						on A.[PESSOAID] = PA.PESSOA
where  (R.ID_REGIONAL = @REGIONAL or @REGIONAL = 0) AND 
             (U.MUNICIPIO = @MUNICIPIO or @MUNICIPIO ='0') AND 
             (U.UNIDADE_ENS = @ESCOLA or @ESCOLA ='0') AND
            (YEAR(DATAOCORRENCIA) = @ANO OR @ANO =0) AND
(DATAOCORRENCIA = @DATAOCORRENCIA OR @DATAOCORRENCIA IS NULL)	AND
            (C.CLASSEID= @CLASSE OR @CLASSE =0) AND
            ( O.SUBCLASSEID = @SUBCLASSE OR @SUBCLASSE =0) AND
            (T.TRATAMENTOID= @TRATAMENTO OR @TRATAMENTO=0) 
  order by O.[OCORRENCIAID]</CommandText>
      </Query>
      <Fields>
        <Field Name="N_OCORRENCIA">
          <DataField>N_OCORRENCIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
