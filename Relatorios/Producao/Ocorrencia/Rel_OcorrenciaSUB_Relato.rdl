  <DataSources>
    <DataSource Name="DBLyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>a807f783-f9ea-45c5-92c6-af7a50187174</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CH_ocorrencia">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@OCORRENCIAID">
            <Value>=Parameters!OCORRENCIAID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>  SELECT	  O.[OCORRENCIAID] AS N_OCORRENCIA
	  ,O.RELATO
	  ,O.OBSERVACAO
	  ,IIF(o.USOARMA = 0 , 'NÃO', 'SIM') AS USOARMA
	  ,o.REGISTROOCORRENCIA
	  ,B.DESCRICAO AS BATALHAO
	  ,D.DESCRICAO AS DELEGACIA
	    FROM [LYCEUM].[Ocorrencias].[OCORRENCIA] O
  inner join [LYCEUM].[Ocorrencias].[BATALHAO] B on O.BATALHAOID = B.BATALHAOID
  INNER JOIN [LYCEUM].[Ocorrencias].[DELEGACIA] D ON D.DELEGACIAID = O.DELEGACIAID
where O.[OCORRENCIAID]  =  @OCORRENCIAID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="N_OCORRENCIA">
          <DataField>N_OCORRENCIA</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RELATO">
          <DataField>RELATO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OBSERVACAO">
          <DataField>OBSERVACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="USOARMA">
          <DataField>USOARMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REGISTROOCORRENCIA">
          <DataField>REGISTROOCORRENCIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BATALHAO">
          <DataField>BATALHAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DELEGACIA">
          <DataField>DELEGACIA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
