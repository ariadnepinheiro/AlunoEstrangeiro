  <DataSources>
    <DataSource Name="DBLyceum">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>a807f783-f9ea-45c5-92c6-af7a50187174</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CH_Tratamento">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@OCORRENCIAID">
            <Value>=Parameters!OCORRENCIAID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT TOP (1000) a.[OCORRENCIAENCAMINHAMENTOID]
      ,a.[ENCAMINHAMENTO]
	  ,b.NOMEARQUIVO
	  ,b.TIPOARQUIVO
  FROM [LYCEUM].[Ocorrencias].[OCORRENCIAENCAMINHAMENTO] a
  left join [LYCEUM].[Ocorrencias].[OCORRENCIAENCAMINHAMENTOARQUIVO]  b on a.[OCORRENCIAENCAMINHAMENTOID] = b.[OCORRENCIAENCAMINHAMENTOID]
  where a.[OCORRENCIAID] =  @OCORRENCIAID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="OCORRENCIAENCAMINHAMENTOID">
          <DataField>OCORRENCIAENCAMINHAMENTOID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ENCAMINHAMENTO">
          <DataField>ENCAMINHAMENTO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOMEARQUIVO">
          <DataField>NOMEARQUIVO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPOARQUIVO">
          <DataField>TIPOARQUIVO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="OCORRENCIAID">
      <DataType>String</DataType>
      <Prompt>OCORRENCIAID</Prompt>
    </ReportParameter>
