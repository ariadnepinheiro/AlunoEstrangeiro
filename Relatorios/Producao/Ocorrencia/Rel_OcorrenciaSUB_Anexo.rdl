  <DataSets>
    <DataSet Name="CH_Anexo">
      <Query>
        <DataSourceName>DBLyceum</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@OCORRENCIAID">
            <Value>=Parameters!OCORRENCIAID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText> SELECT  [ARQUIVOOCORRENCIAID]
      ,[OCORRENCIAID]
      ,[TIPOARQUIVO]
      ,[NOMEARQUIVO]
      ,[USUARIOID]
      ,[DATACADASTRO]
      ,[DATAALTERACAO]
  FROM [LYCEUM].[Ocorrencias].[ARQUIVOOCORRENCIA]
  where [OCORRENCIAID] = @OCORRENCIAID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
