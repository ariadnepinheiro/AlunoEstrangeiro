  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LYCEUM</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>229031ba-5c11-4e90-a47d-c1621f78e578</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT	REGIONAL, MUNICIPIO, CENSO, UNIDADE, ANO, PERIODO, 
		CASE WHEN DATA_FINALIZACAO IS NOT NULL THEN 'FINALIZADO'
			 WHEN DATA_PARCIAL IS NOT NULL THEN 'PARCIAL'
			 ELSE 'PENDENTE' END STATUS, DATA_PARCIAL, SUBSTRING(CONVERT(VARCHAR(20), HORA_PARCIAL),1,5) HORA_PARCIAL, 
			 DATA_FINALIZACAO, SUBSTRING(CONVERT(VARCHAR(20), HORA_FINALIZACAO),1,5) HORA_FINALIZACAO, 
			 ANALISE_SEEDUC
FROM	(
			SELECT	R.REGIONAL, M.NOME MUNICIPIO, UE.UNIDADE_ENS CENSO, UE.NOME_COMP UNIDADE, CASE WHEN V.PERIODO = 2 THEN '2o.SEMESTRE' ELSE 'ANUAL E 1o.SEMESTRE' END PERIODO,
					V.ANO, CONVERT(DATE, MAX(II.DT_ALTERACAO)) DATA_PARCIAL, CONVERT(TIME, MAX(II.DT_ALTERACAO)) HORA_PARCIAL, 
					CONVERT(DATE, MAX(F.DT_FINALIZACAO)) DATA_FINALIZACAO, CONVERT(TIME, MAX(F.DT_FINALIZACAO)) HORA_FINALIZACAO, 
					ISNULL(AA.ANALISE_SUPLAN, ISNULL(ANALISE_SUPED,ANALISEDIESP)) ANALISE_SEEDUC
			FROM	TCE_CTV_AGENDA_CONF_TURNO_VAGA V 
			JOIN	TCE_CTV_CONF_TURNO_INICIAL I
			ON		I.ID_AGENDA_CONF_TURNO_VAGA = V.ID_AGENDA_CONF_TURNO_VAGA			
			LEFT JOIN	TCE_CTV_CONF_VAGA II 
			ON		II.ID_AGENDA_CONF_TURNO_VAGA = V.ID_AGENDA_CONF_TURNO_VAGA
			AND		II.CENSO = I.CENSO
			JOIN	LY_UNIDADE_ENSINO UE 
			ON		UE.UNIDADE_ENS = I.CENSO
			JOIN	HADES..TCE_MUNICIPIO M 
			ON		M.ID_MUNICIPIO = UE.MUNICIPIO
			JOIN	TCE_REGIONAL R
			ON		R.ID_REGIONAL = UE.ID_REGIONAL
			LEFT	JOIN TCE_CTV_FINALIZADO F
			ON		F.CENSO = I.CENSO
			AND		F.ID_AGENDA_CONF_TURNO_VAGA = I.ID_AGENDA_CONF_TURNO_VAGA
			AND		F.VAGA = 1
			LEFT JOIN TCE_CTV_ANALISE AA
			ON		AA.CENSO = I.CENSO
			AND		AA.ANO = V.ANO
			AND		AA.PERIODO = V.PERIODO
			AND		AA.VAGA = 1
			WHERE	NOT EXISTS (
								SELECT	1
								FROM	TCE_CTV_RESTRICAO R
								WHERE	R.CENSO = I.CENSO
								AND		R.ID_AGENDA_CONF_TURNO_VAGA = I.ID_AGENDA_CONF_TURNO_VAGA
								)
			AND		R.ID_REGIONAL = ISNULL(@COORD, R.ID_REGIONAL)
			AND		M.ID_MUNICIPIO = ISNULL(@MUNIC, M.ID_MUNICIPIO)
			AND		UE.UNIDADE_ENS = ISNULL(@ESCOLA, UE.UNIDADE_ENS) 
			AND		V.ANO = @ANO
			AND		EXISTS (
							SELECT	1
							FROM	LY_UNIDADE_ENSINO_SITUACAO US
							WHERE	US.UNIDADE_ENS = UE.UNIDADE_ENS
							AND		US.SITUACAO = 'ESTADUAL'
							AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN 
																							(
																							SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO)) 
																							FROM LY_UNIDADE_ENSINO_SITUACAO GROUP BY UNIDADE_ENS
																							)
							)
			AND		(UE.SIT_FUNCIONAMENTO IS NULL OR UE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')								
			GROUP BY R.REGIONAL, M.NOME, UE.UNIDADE_ENS, UE.NOME_COMP, V.ANO, CASE WHEN V.PERIODO = 2 THEN '2o.SEMESTRE' ELSE 'ANUAL E 1o.SEMESTRE' END,
			ISNULL(AA.ANALISE_SUPLAN, ISNULL(ANALISE_SUPED,ANALISEDIESP))
) A 
</CommandText>
      </Query>
      <Fields>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MUNICIPIO">
          <DataField>MUNICIPIO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CENSO">
          <DataField>CENSO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERIODO">
          <DataField>PERIODO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_PARCIAL">
          <DataField>DATA_PARCIAL</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="HORA_PARCIAL">
          <DataField>HORA_PARCIAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_FINALIZACAO">
          <DataField>DATA_FINALIZACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="HORA_FINALIZACAO">
          <DataField>HORA_FINALIZACAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ANALISE_SEEDUC">
          <DataField>ANALISE_SEEDUC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="COORDENADORIA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select null nucleo,' TODAS' descricao 
union
select '0' nucleo,' Selecione...' descricao 
union
select  convert(varchar(10),l1.id_regional),SUBSTRING(l1.regional,1,35) from tce_regional L1
join LY_UNIDADE_ENSINO l2 on L1.id_regional=l2.id_regional
order by descricao</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nucleo">
          <DataField>nucleo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="descricao">
          <DataField>descricao</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select null codigo,' TODOS' nome  
union
select 'NULO' ,' Selecione...'  
union
select distinct convert(varchar(10), L1.id_municipio), L1.nome from LY_UNIDADE_ENSINO l2
join hades..tce_municipio l1 on l1.id_municipio=l2.MUNICIPIO
join tce_regional n1 on n1.id_regional=l2.id_regional
where 
	(convert(varchar(10), n1.id_regional) = ISNULL(@COORD,n1.id_regional)or n1.id_regional is null)
ORDER BY NOME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="codigo">
          <DataField>codigo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nome">
          <DataField>nome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@COORD">
            <Value>=Parameters!COORD.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNIC">
            <Value>=Parameters!MUNIC.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'NULO' UNIDADE_ENS, ' Selecione...' NOME_COMP 
UNION
select null UNIDADE_ENS, ' TODAS' NOME_COMP 
union
select ue.UNIDADE_ENS,substring(ue.NOME_COMP,1,50)NOME_COMP from LY_UNIDADE_ENSINO ue 
where (ue.id_regional = ISNULL(@COORD,ue.id_regional) or ue.id_regional is null)
AND (ue.MUNICIPIO = ISNULL(@MUNIC,ue.municipio)or ue.MUNICIPIO is null)
order by NOME_COMP </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME_COMP">
          <DataField>NOME_COMP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO_LETIVO">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 	DISTINCT ANO
FROM 	LY_PERIODO_LETIVO
ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
