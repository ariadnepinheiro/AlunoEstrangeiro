  <Code>
    Public Function Capitaliza(texto As String) As String
    If texto Is Nothing Then Return ""

    Dim preposicoes() As String = {"da", "de", "di", "do", "dos", "das", "du", "d’"}

    ' separar e remover entradas vazias
    Dim raw() As String = texto.Trim().Split(New Char() {" "c})
    Dim words As New System.Collections.ArrayList()
    For Each w As String In raw
    If Not String.IsNullOrEmpty(w) AndAlso w.Trim().Length &gt; 0 Then
    words.Add(w.Trim())
    End If
    Next

    For i As Integer = 0 To words.Count - 1
    Dim tmp As String = words(i).ToString().ToLower()
    If i = 0 Or Array.IndexOf(preposicoes, tmp) = -1 Then
    If tmp.Length &gt; 0 Then words(i) = Char.ToUpper(tmp(0)) &amp; tmp.Substring(1)
    Else
    words(i) = tmp
    End If
    Next

    Dim sb As New System.Text.StringBuilder()
    For i As Integer = 0 To words.Count - 1
    If i &gt; 0 Then sb.Append(" ")
    sb.Append(words(i).ToString())
    Next

    Return sb.ToString()
    End Function
  </Code>
