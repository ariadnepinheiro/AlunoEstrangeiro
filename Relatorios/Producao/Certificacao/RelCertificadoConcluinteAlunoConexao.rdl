  <DataSources>
    <DataSource Name="LYCEUM">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.11.69.201;Initial Catalog=LYCEUM</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>3026eee8-b6eb-4a78-b97b-7e4085061b5b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CERTIFICADO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ALUNO">
            <Value>=Parameters!ALUNO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SET LANGUAGE 'Portuguese'

SELECT DISTINCT
			UE.NOME_COMP AS ESCOLA,
			UPPER(TDC.DESCRICAO) AS TIPODOCUMENTO,
			DC.CODIGOVALIDOR,
            UPPER(P.NOME_COMPL) AS NOMEALUNO,
            LOWER(P.NOME_MAE) AS NOMEMAE,
            LOWER(P.NOME_PAI) AS NOMEPAI,
            DATENAME(DAY, P.DT_NASC) + ' de ' +
			DATENAME(MONTH, P.DT_NASC) + ' de ' +
			DATENAME(YEAR, P.DT_NASC) AS DTNASCIMENTO,
            MU.NOME AS NATURALIDADE,
            P.NACIONALIDADE,
            P.CPF,
            P.RG_NUM,
            P.RG_EMISSOR + '/' + P.RG_UF AS RG_EMISSOR,
            P.RG_UF,
			--CONSULTA QUE OBTÉM A CARGA HORÁRIA TOTAL DO CURSO DO ALUNO
			(SELECT CEILING(SUM(ISNULL(LD.HORAS_ATIV, 0) + ISNULL(LD.HORAS_AULA, 0) + ISNULL(LD.HORAS_ESTAGIO, 0) + ISNULL(LD.HORAS_LAB, 0))) AS TOTALHORASAULA
			FROM	LY_HISTMATRICULA LM (NOLOCK) 
					JOIN	LY_ALUNO LA (NOLOCK) ON LM.ALUNO = LA.ALUNO 
									AND LM.SITUACAO_HIST &lt;&gt; 'CANCELADO' 
									AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
									AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
									AND ISNULL( LM.CONCOMITANTE, 'N') = 'N'
									AND ISNULL( LM.OPTATIVAREFORCO, 'N') = 'N'
					JOIN	TCE_SITUACAO_FINAL_ALUNO TSFA (NOLOCK) ON TSFA.ALUNO = LM.ALUNO 
									AND TSFA.ANO = LM.ANO
									AND TSFA.PERIODO = LM.SEMESTRE
									AND	TSFA.TURMA = LM.TURMA
									AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
									AND TSFA.situacao_final in ('Aprovado', 'Aprovado Com Dep','Promovido')
					JOIN	LY_TURMA LT (NOLOCK) ON LM.ANO = LT.ANO 
									AND LM.SEMESTRE = LT.SEMESTRE 
									AND LM.TURMA = LT.TURMA 
									AND LM.DISCIPLINA = LT.DISCIPLINA 
					JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
					JOIN    MUNICIPIO MU (NOLOCK) ON LUE.MUNICIPIO = MU.CODIGO		
					JOIN	LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA) 		
					JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LT.CURSO 
					JOIN	CertificacaoEscolar.TIPOCONCLUSAO_MODALIDADETIPO tm (nolock) on (tm.TIPO = LC.TIPO and tm.MODALIDADE = lc.MODALIDADE)
					LEFT JOIN LY_MODALIDADE_CURSO MDC(NOLOCK) ON  (MDC.MODALIDADE=LC.MODALIDADE AND MDC.MODALIDADE=TM.MODALIDADE)
					LEFT JOIN LY_TIPO_CURSO  TC ON (TC.TIPO=LC.TIPO) 
			WHERE  LM.ALUNO = @ALUNO) AS TOTALHORASAULA,
			--CONSULTA QUE OBTÉM A CARGA HORÁRIA TOTAL EM HORAS-RELÓGIO DO CURSO DO ALUNO
			(SELECT CEILING(SUM(ISNULL(LD.HORAS_ATIV, 0) + ISNULL(LD.HORAS_AULA, 0) + ISNULL(LD.HORAS_ESTAGIO, 0) + ISNULL(LD.HORAS_LAB, 0)) * 50 / 60) AS TOTALHORASRELOGIO
			FROM	LY_HISTMATRICULA LM (NOLOCK) 
					JOIN	LY_ALUNO LA (NOLOCK) ON LM.ALUNO = LA.ALUNO 
									AND LM.SITUACAO_HIST &lt;&gt; 'CANCELADO' 
									and ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N'
									and ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N'
									and ISNULL( LM.CONCOMITANTE, 'N') = 'N'
									and ISNULL( LM.OPTATIVAREFORCO, 'N') = 'N'
					JOIN	TCE_SITUACAO_FINAL_ALUNO TSFA (NOLOCK) ON TSFA.ALUNO = LM.ALUNO 
									AND TSFA.ANO = LM.ANO
									AND TSFA.PERIODO = LM.SEMESTRE
									AND	TSFA.TURMA = LM.TURMA
									AND ISNULL(LM.DEPENDENCIA, 'N') = 'N'
									and TSFA.situacao_final in ('Aprovado', 'Aprovado Com Dep','Promovido')
					JOIN	LY_TURMA LT (NOLOCK) ON LM.ANO = LT.ANO 
									AND LM.SEMESTRE = LT.SEMESTRE 
									AND LM.TURMA = LT.TURMA 
									AND LM.DISCIPLINA = LT.DISCIPLINA 
					JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
					JOIN    MUNICIPIO MU (NOLOCK) ON LUE.MUNICIPIO = MU.CODIGO		
					JOIN	LY_DISCIPLINA LD (NOLOCK) ON LD.DISCIPLINA = ISNULL(LT.DISCIPLINA_MULTIPLA, LT.DISCIPLINA) 		
					JOIN	LY_CURSO LC (NOLOCK) ON LC.CURSO = LT.CURSO 
					JOIN	CertificacaoEscolar.TIPOCONCLUSAO_MODALIDADETIPO tm (nolock) on (tm.TIPO = LC.TIPO and tm.MODALIDADE = lc.MODALIDADE)
					LEFT JOIN LY_MODALIDADE_CURSO MDC(NOLOCK) ON  (MDC.MODALIDADE=LC.MODALIDADE AND MDC.MODALIDADE=TM.MODALIDADE)
					LEFT JOIN LY_TIPO_CURSO  TC ON (TC.TIPO=LC.TIPO) 
			WHERE  LM.ALUNO = @ALUNO) AS TOTALHORASRELOGIO,
			--CONSULTA QUE OBTÉM A DATA DE CONCLUSÃO DO CURSO DO ALUNO
			(SELECT DISTINCT DATENAME(DAY, PL.DT_FIM_AULA) + ' de ' +
							DATENAME(MONTH, PL.DT_FIM_AULA) + ' de ' +
							DATENAME(YEAR, PL.DT_FIM_AULA) AS DATACONCLUSAO
			FROM   LY_ALUNO A
			INNER JOIN LY_H_CURSOS_CONCL CC ON CC.ALUNO = A.ALUNO AND MOTIVO = 'CONCLUSAO'
			INNER JOIN LY_PERIODO_LETIVO PL ON PL.ANO = CC.ANO_ENCERRAMENTO AND PL.PERIODO=CC.SEM_ENCERRAMENTO
			WHERE a.ALUNO = @ALUNO) AS DATACONCLUSAO,
            'ENSINO ' + UPPER(TC.DESCRICAO) AS TIPO_CONCLUSAO,
			UEC.ATO,
            DATENAME(DAY, UEC.DT_IMPLANTACAO) + ' de ' +
			DATENAME(MONTH, UEC.DT_IMPLANTACAO) + ' de ' +
			DATENAME(YEAR, UEC.DT_IMPLANTACAO) AS DATAAUTORIZA,
            DC.NUMERO AS NUMLIVRO,
            DC.FOLHAS AS NUMFL,
            DC.LIVRO,
            DC.OBSERVACAO,
			LOWER(TM.NOME) AS MUNCIPIOESCOLA,
			TR.REGIONAL,
            DATENAME(DAY, DG.DATAALTERACAO) + ' de ' +
			DATENAME(MONTH, DG.DATAALTERACAO) + ' de ' +
			DATENAME(YEAR, DG.DATAALTERACAO) AS DATAALTERACAO
FROM dbo.LY_ALUNO AS A (NOLOCK)
		JOIN dbo.LY_PESSOA AS P 
		ON A.PESSOA = P.PESSOA		
		JOIN CertificacaoEscolar.DOCUMENTOCERTIFICACAO AS DC
		ON DC.ALUNO = A.ALUNO
		JOIN CertificacaoEscolar.DOCUMENTOGERADO AS DG
		ON DG.DOCUMENTOCERTID = DC.DOCUMENTOCERTID
		JOIN CertificacaoEscolar.TIPOCONCLUSAO AS TC
		ON TC.TIPOCONCLUSAOID = DC.TIPOCONCLUSAOID
		JOIN dbo.LY_CURSO AS C
		ON A.CURSO = C.CURSO
		JOIN CertificacaoEscolar.TIPODOCUMENTOCERTIFICA AS TDC
		ON TDC.TIPO_DOCUMENTO = DC.DOCUMENTOID
		JOIN dbo.LY_UNIDADE_ENSINO_CURSOS UEC
		ON UEC.CURSO = A.CURSO
		JOIN dbo.LY_UNIDADE_ENSINO AS UE
		ON UE.UNIDADE_ENS = A.UNIDADE_ENSINO
		JOIN dbo.TCE_REGIONAL AS TR
		ON TR.ID_REGIONAL = UE.ID_REGIONAL
		JOIN HADES.dbo.HD_MUNICIPIO AS MU
		ON MU.MUNICIPIO = P.END_MUNICIPIO
		JOIN HADES.dbo.TCE_MUNICIPIO AS TM
		ON TM.ID_MUNICIPIO = UE.MUNICIPIO
WHERE 	TDC.DESCRICAO LIKE '%CERTIFICADO%'
		AND DC.ALUNO = @ALUNO</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
