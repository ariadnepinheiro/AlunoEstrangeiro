  <DataSources>
    <DataSource Name="LYCEUM">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3026eee8-b6eb-4a78-b97b-7e4085061b5b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="REGIONAL">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT	null ID_REGIONAL, null REGIONAL
          UNION
          SELECT  TR.ID_REGIONAL, SUBSTRING(TR.REGIONAL,1,35)
          FROM	TCE_REGIONAL TR (NOLOCK)
          JOIN	LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
          JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
          WHERE	(LUUF.USUARIO = ISNULL(@usuario,LUUF.USUARIO) OR LUUF.USUARIO IS NULL)

          ORDER	BY REGIONAL
        </CommandText>
      </Query>
      <Fields>
        <Field Name="ID_REGIONAL">
          <DataField>ID_REGIONAL</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="REGIONAL">
          <DataField>REGIONAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MUNICIPIO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT	null CODIGO,null NOME
          UNION
          SELECT	DISTINCT M.CODIGO, M.NOME
          FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
          JOIN	MUNICIPIO M (NOLOCK) ON M.CODIGO = LUE.MUNICIPIO
          JOIN	TCE_REGIONAL TR (NOLOCK) ON LUE.ID_REGIONAL = TR.ID_REGIONAL
          JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
          WHERE	TR.ID_REGIONAL = @REGIONAL
          AND 	(LUUF.USUARIO = ISNULL(@usuario, LUUF.USUARIO) OR LUUF.USUARIO IS NULL)

          ORDER	BY NOME
        </CommandText>
      </Query>
      <Fields>
        <Field Name="CODIGO">
          <DataField>CODIGO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ESCOLA">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@REGIONAL">
            <Value>=Parameters!REGIONAL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MUNICIPIO">
            <Value>=Parameters!MUNICIPIO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@usuario">
            <Value>=Parameters!usuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT	null UNIDADE_ENS, null ESCOLA
          UNION
          SELECT	LUE.UNIDADE_ENS, SUBSTRING (LUE.NOME_COMP,1,50) ESCOLA
          FROM	LY_UNIDADE_ENSINO LUE (NOLOCK)
          JOIN	TCE_REGIONAL TR (NOLOCK) ON TR.ID_REGIONAL = LUE.ID_REGIONAL
          JOIN	LY_USUARIO_UNIDADE_FIS LUUF (NOLOCK) ON LUUF.UNIDADE_FIS = LUE.UNIDADE_ENS
          WHERE	TR.ID_REGIONAL = @REGIONAL
          AND		LUE.MUNICIPIO = @MUNICIPIO
          AND		(LUUF.USUARIO = ISNULL(@usuario, LUUF.usuario) OR LUUF.USUARIO IS NULL)
          AND		EXISTS (
          SELECT	1
          FROM	LY_UNIDADE_ENSINO_SITUACAO US (NOLOCK)
          WHERE	US.UNIDADE_ENS = LUE.UNIDADE_ENS
          AND		US.SITUACAO = 'ESTADUAL'
          AND		US.UNIDADE_ENS+CONVERT(VARCHAR(20),US.DT_SITUACAO) IN
          (
          SELECT	UNIDADE_ENS+CONVERT(VARCHAR(20),MAX(DT_SITUACAO))
          FROM LY_UNIDADE_ENSINO_SITUACAO (NOLOCK) GROUP BY UNIDADE_ENS
          )
          )
          AND		(LUE.SIT_FUNCIONAMENTO IS NULL OR LUE.SIT_FUNCIONAMENTO = 'EMATIVIDADE')
          ORDER	BY ESCOLA
        </CommandText>
      </Query>
      <Fields>
        <Field Name="UNIDADE_ENS">
          <DataField>UNIDADE_ENS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ESCOLA">
          <DataField>ESCOLA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ANO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <CommandText>SELECT null               ANO,
       null NOME
UNION
select distinct T.ANO, CONVERT (VARCHAR, T.ANO) AS NOME FROM  LY_TURMA T ORDER BY ANO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ANO">
          <DataField>ANO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TURMA">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  null TURMA

UNION

SELECT DISTINCT HM.TURMA           
FROM   LY_HISTMATRICULA HM 
        JOIN LY_TURMA T (NOLOCK) 
            ON T.DISCIPLINA = HM.DISCIPLINA 
            AND T.TURMA = HM.TURMA 
            AND T.ANO = HM.ANO 
            AND T.SEMESTRE = HM.SEMESTRE 
        JOIN LY_SERIE S 
            ON S.CURSO = T.CURSO 
            AND S.TURNO = T.TURNO 
            AND S.CURRICULO = T.CURRICULO 
            AND S.SERIE = T.SERIE 
        JOIN LY_CURSO C 
            ON C.CURSO = T.CURSO 
        JOIN CERTIFICACAOESCOLAR.TIPOCONCLUSAO_MODALIDADETIPO TM (NOLOCK) 
            ON TM.TIPO = C.TIPO 
            AND TM.MODALIDADE = C.MODALIDADE 
WHERE  S.EMITE_CERTIFICACAO = 'S' 
        AND T.FACULDADE = @ESCOLA
        AND T.SEMESTRE = @SEMESTRE 
		AND HM.ANO = @ANO     </CommandText>
      </Query>
      <Fields>
        <Field Name="TURMA">
          <DataField>TURMA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="RELATORIO">
      <Query>
        <DataSourceName>LYCEUM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ESCOLA">
            <Value>=Parameters!ESCOLA.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ANO">
            <Value>=Parameters!ANO.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SEMESTRE">
            <Value>=Parameters!SEMESTRE.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TURMA">
            <Value>=Parameters!TURMA.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
isnull( DOCCERT.AUTORIZADO,0) AUTORIZADO,
CASE 
WHEN P.RG_NUM = NULL 
OR P.RG_NUM = '' 
OR ( P.NOME_COMPL = NULL 
OR P.NOME_COMPL = '' ) 
OR ( LM.ALUNO = NULL 
OR LM.ALUNO = '' ) 
OR ( LT.TURMA = NULL 
OR LT.TURMA = '' ) 
OR ( LT.TURNO = NULL 
OR LT.TURNO = '' ) 
OR ( LT.CURSO = NULL 
OR LT.CURSO = '' ) 
OR ( TSFA.SITUACAO_FINAL = NULL 
OR TSFA.SITUACAO_FINAL = '' ) 
OR ( EMITE_CERTIFICACAO = NULL 
OR EMITE_CERTIFICACAO = '' ) 
OR ( DOCCERT.NUMERO = NULL 
OR DOCCERT.NUMERO = '' ) 
OR ( DOCCERT.AUTORIZADO = NULL 
OR DOCCERT.AUTORIZADO = '' ) 
OR ( ES.NUMERO_ATO_OFICIAL = NULL 
OR ES.NUMERO_ATO_OFICIAL = '' ) 
OR ( P.RG_EMISSOR = NULL 
OR P.RG_EMISSOR = '' ) 
OR ( P.RG_NUM = NULL 
OR P.RG_NUM = '' ) 
OR ( P.RG_UF = NULL 
OR P.RG_UF = '' ) 
OR ( P.RG_TIPO = NULL 
OR P.RG_TIPO = '' ) 
OR ( P.DT_NASC = NULL 
OR P.DT_NASC = '' ) 
OR ( MNASC.NOME = NULL 
OR MNASC.NOME = '' ) 
OR ( MNASC.UF = NULL 
OR MNASC.UF = '' ) 
OR ( P.NOME_MAE = NULL 
OR P.NOME_MAE = '' ) 
OR ( P.NOME_PAI = NULL 
OR P.NOME_PAI = '' ) 
OR ( UC.ATO = NULL 
OR UC.ATO = '' ) 
OR ( UC.DT_IMPLANTACAO = NULL 
OR UC.DT_IMPLANTACAO = '' ) THEN 'Não' 
ELSE 'Sim' 
END AS CADASTRO_COMPLETO, 
LT.FACULDADE as CENSO,
REG.REGIONAL as REGIONAL,
MUN.NOME as MUNICIPIO,
LUE.NOME_COMP as ESCOLA,
LA.CONCURSO as DESC_MODALIDADE,
TPCONCLUSAO.DESCRICAO TIPO_CONCLUSAO, 
TPDOCCERT.DESCRICAO TIPO_DOCUMENTO, 
TM.TIPO, 
TM.TIPOCONCLUSAOID, 
LM.ALUNO AS MATRICULA, 
P.NOME_COMPL AS NOMEDOALUNO, 
LT.TURMA, 
LT.CURSO, 
LC.NOME as NOME_CURSO,
LT.TURNO as TURNO,
LA.SERIE,
LC.TIPO_CURSO, 
DOCCERT.AUTORIZADO as DOCCERT_AUTORIZADO, 
ES.NUMERO_ATO_OFICIAL UE_ATO, 
cast(es.DT_DOU as date) UE_DT,
P.RG_EMISSOR ORGÃO_EMISSOR, 
P.RG_NUM MUMERO_DOC, 
P.RG_UF UF_EXPEDICAO, 
P.RG_TIPO TIPO_DOC_RG, 
cast(P.DT_NASC as date) DataNascimento, 
MNASC.NOME AS MUNICIPIO_NASC, 
MNASC.UF AS UF_NASC, 
P.NOME_MAE, 
P.NOME_PAI, 
P.E_MAIL,
UC.ATO AS ato_curso, 
cast(uc.dt_do as Date) AS dt_do_curso,
LM.ANO as ANO_CONCLUSAO,
DOCGERADO.NUMEROGERADO,
DOCCERT.FOLHAS,
DOCCERT.NUMERO,
DOCCERT.OBSERVACAO,
TPDOCCERT.DESCRICAO,
DOCGERADO.DATACADASTRO,
ltc.DESCRICAO + ' - ' + lmc.DESCRICAO as DESCRICAO_MODALIDADE

FROM LY_HISTMATRICULA LM (NOLOCK) 
JOIN LY_ALUNO LA (NOLOCK) ON LM.ALUNO = LA.ALUNO AND LM.SITUACAO_HIST &lt;&gt; 'CANCELADO' AND ISNULL(LM.MAIS_EDUCACAO, 'N') = 'N' AND ISNULL(LM.EDUC_ESPECIAL, 'N') = 'N' AND ISNULL(LM.CONCOMITANTE, 'N') = 'N' AND ISNULL(LM.OPTATIVAREFORCO, 'N') = 'N' 
INNER JOIN LY_PESSOA P ON P.PESSOA = LA.PESSOA 
LEFT JOIN HADES.DBO.HD_MUNICIPIO MNASC ( NOLOCK ) ON P.MUNICIPIO_NASC = MNASC.MUNICIPIO 
JOIN TCE_SITUACAO_FINAL_ALUNO TSFA (NOLOCK) ON TSFA.ALUNO = LM.ALUNO AND TSFA.ANO = LM.ANO AND TSFA.PERIODO = LM.SEMESTRE AND TSFA.TURMA = LM.TURMA AND ISNULL(LM.DEPENDENCIA, 'N') = 'N' AND TSFA.SITUACAO_FINAL IN ( 'Aprovado', 'Aprovado Com Dep' ) 
JOIN LY_TURMA LT (NOLOCK) ON LM.ANO = LT.ANO AND LM.SEMESTRE = LT.SEMESTRE AND LM.TURMA = LT.TURMA AND LM.DISCIPLINA = LT.DISCIPLINA 
JOIN LY_UNIDADE_ENSINO LUE (NOLOCK) ON LUE.UNIDADE_ENS = LT.UNIDADE_RESPONSAVEL 
LEFT JOIN LY_UNIDADE_ENSINO_SITUACAO ES ON LUE.UNIDADE_ENS = ES.UNIDADE_ENS 
JOIN LY_CURSO LC (NOLOCK) ON LC.CURSO = LT.CURSO 
inner join LY_TIPO_CURSO ltc on ltc.TIPO = lc.TIPO
inner join LY_MODALIDADE_CURSO lmc on lmc.MODALIDADE = lc.MODALIDADE
LEFT JOIN LY_UNIDADE_ENSINO_CURSOS UC (NOLOCK) ON UC.CURSO = LT.CURSO AND UC.UNIDADE_ENS = @ESCOLA AND UC.TURNO = LT.TURNO 
JOIN CERTIFICACAOESCOLAR.TIPOCONCLUSAO_MODALIDADETIPO TM (NOLOCK) ON ( TM.TIPO = LC.TIPO AND TM.MODALIDADE = LC.MODALIDADE ) 
JOIN LY_SERIE SE ON SE.CURSO = LT.CURSO AND SE.TURNO = LT.TURNO AND SE.CURRICULO = LT.CURRICULO AND SE.SERIE = LT.SERIE 
LEFT JOIN [CERTIFICACAOESCOLAR].[DOCUMENTOCERTIFICACAO] DOCCERT (NOLOCK) ON TSFA.ALUNO = DOCCERT.ALUNO 
LEFT JOIN [CertificacaoEscolar].[DOCUMENTOGERADO] DOCGERADO (NOLOCK) ON DOCGERADO.DOCUMENTOCERTID = DOCCERT.DOCUMENTOCERTID
LEFT JOIN [CERTIFICACAOESCOLAR].TIPODOCUMENTOCERTIFICA TPDOCCERT(NOLOCK) ON TPDOCCERT.DOCUMENTOID = DOCCERT.DOCUMENTOID 
LEFT JOIN [CERTIFICACAOESCOLAR].TIPOCONCLUSAO TPCONCLUSAO (NOLOCK) ON TPCONCLUSAO.TIPOCONCLUSAOID = DOCCERT.TIPOCONCLUSAOID 
LEFT JOIN [CERTIFICACAOESCOLAR].TIPOCONCLUSAO_MODALIDADETIPO MODTIPO (NOLOCK) on MODTIPO.TIPOCONCLUSAOID = TPCONCLUSAO.TIPOCONCLUSAOID and MODTIPO.TIPO = ltc.TIPO and MODTIPO.MODALIDADE = lc.MODALIDADE
INNER JOIN REGIONAL REG on REG.POLO = LUE.ID_REGIONAL
INNER JOIN MUNICIPIO MUN on MUN.CODIGO = LUE.MUNICIPIO

WHERE ISNULL(SE.EMITE_CERTIFICACAO, 'N') = 'S' 
AND ANO_SERIE_CONCLUINTE = 'S' 
AND ES.ATO_OFICIAL LIKE 'Criacao' 
AND LT.FACULDADE = @ESCOLA
AND LT.ANO = @ANO 
AND LT.SEMESTRE = @SEMESTRE
AND LT.TURMA = @TURMA</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AUTORIZADO">
          <DataField>AUTORIZADO</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="CADASTRO_COMPLETO">
          <DataField>CADASTRO_COMPLETO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
