          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESC_MODALIDADE">
          <DataField>DESC_MODALIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO_CONCLUSAO">
          <DataField>TIPO_CONCLUSAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
