  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>dblyceum</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>81a138d5-65a7-4b23-87c4-310cf071125f</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CICLO">
            <Value>=Parameters!CICLO.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
SA.MATRICULA AS MATRICULA_AVALIADO, 
SA.NOME AS NOME, 
F.DESCRICAO AS FUNCAO, 
VS.NOME AS UNIDADE, 
CONVERT (DATE, SA.DATAFIMAUTOAVALIACAO) AS DATA_AVALIACAO, 
SA.MATRICULAAVALIADOR AS MATRICULA_AVALIADOR,
SUM(G.SIGLA * C.PESOAVALIADO) AS AUTO_AVALIACAO,
0 AS AVALIACAO,
(C.PESOAVALIADO + C.PESOAVALIADOR) AS TOTAL_PESOS,
0 AS RANK
FROM STATUSAVALIACAO SA (NOLOCK)
JOIN VW_FUNCAO F (NOLOCK) ON F.FUNCAOID = SA.FUNCAOID
JOIN VW_SETOR VS (NOLOCK) ON VS.SETORID = SA.SETORID
LEFT JOIN AVALIACAOGRAU AG (NOLOCK) ON AG.MATRICULA = SA.MATRICULA
			AND AG.CPF = SA.CPF
			AND AG.CPFAVALIADOR = SA.CPFAVALIADOR
			AND AG.MATRICULAAVALIADOR = SA.MATRICULAAVALIADOR
			AND AG.CICLOID = SA.CICLOID
LEFT JOIN GRAU G (NOLOCK) ON G.GRAUID = AG.GRAUID
			AND G.CRITERIOID = AG.CRITERIOID
LEFT JOIN CRITERIO C (NOLOCK) ON C.CRITERIOID = G.CRITERIOID
--JOIN CICLOCRITERIO CC ON CC.CRITERIOID = C.CRITERIOID
JOIN CICLO CI (NOLOCK) ON CI.CICLOID = SA.CICLOID

WHERE
--SA.MATRICULA IN  ('00003632', '00007831') -- ('02410074') --'50148386')
SA.DATAFIMAUTOAVALIACAO IS NOT NULL
AND SA.MATRICULA = SA.MATRICULAAVALIADOR 
AND (CI.CICLOID = ISNULL (@CICLO, CI.CICLOID) OR CI.CICLOID IS NULL)

GROUP BY 
SA.MATRICULA, 
SA.NOME, 
F.DESCRICAO, 
VS.NOME, 
SA.DATAFIMAUTOAVALIACAO,
SA.MATRICULAAVALIADOR,
C.PESOAVALIADO,
C.PESOAVALIADOR

UNION

SELECT DISTINCT
SA.MATRICULA AS MATRICULA_AVALIADO, 
SA.NOME AS NOME, 
F.DESCRICAO AS FUNCAO, 
VS.NOME AS UNIDADE, 
CONVERT (DATE, SA.DATAFIMAUTOAVALIACAO) AS DATA_AVALIACAO, 
SA.MATRICULAAVALIADOR AS MATRICULA_AVALIADOR,
0 AS AUTO_AVALIACAO,
ISNULL (SUM(G.SIGLA * C.PESOAVALIADOR), 0) AS AVALIACAO,
(SELECT DISTINCT (PESOAVALIADO + PESOAVALIADOR) FROM CRITERIO)  AS TOTAL_PESOS,
RANK() OVER (PARTITION BY SA.MATRICULA, VS.NOME ORDER BY SA.MATRICULAAVALIADOR) AS RANK
FROM STATUSAVALIACAO SA (NOLOCK)
JOIN VW_FUNCAO F (NOLOCK) ON F.FUNCAOID = SA.FUNCAOID
JOIN VW_SETOR VS (NOLOCK) ON VS.SETORID = SA.SETORID
LEFT JOIN AVALIACAOGRAU AG (NOLOCK) ON AG.MATRICULA = SA.MATRICULA
			AND AG.CPF = SA.CPF
			AND AG.CPFAVALIADOR = SA.CPFAVALIADOR
			AND AG.MATRICULAAVALIADOR = SA.MATRICULAAVALIADOR
			AND AG.CICLOID = SA.CICLOID
LEFT JOIN GRAU G (NOLOCK) ON G.GRAUID = AG.GRAUID
			AND G.CRITERIOID = AG.CRITERIOID
LEFT JOIN CRITERIO C (NOLOCK) ON C.CRITERIOID = G.CRITERIOID
--JOIN CICLOCRITERIO CC ON CC.CRITERIOID = C.CRITERIOID
JOIN CICLO CI (NOLOCK) ON CI.CICLOID = SA.CICLOID

WHERE
--SA.MATRICULA IN  ('00003632', '00007831') -- ('02410074') --'50148386')
SA.DATAFIMAUTOAVALIACAO IS NOT NULL
AND SA.MATRICULA &lt;&gt; SA.MATRICULAAVALIADOR 
AND (CI.CICLOID = ISNULL (@CICLO, CI.CICLOID) OR CI.CICLOID IS NULL)

GROUP BY 
SA.MATRICULA, 
SA.NOME, 
F.DESCRICAO, 
VS.NOME, 
SA.DATAFIMAUTOAVALIACAO,
SA.MATRICULAAVALIADOR,
C.PESOAVALIADO,
C.PESOAVALIADOR</CommandText>
      </Query>
      <Fields>
        <Field Name="MATRICULA_AVALIADO">
          <DataField>MATRICULA_AVALIADO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOME">
          <DataField>NOME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCAO">
          <DataField>FUNCAO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIDADE">
          <DataField>UNIDADE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_AVALIACAO">
          <DataField>DATA_AVALIACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MATRICULA_AVALIADOR">
          <DataField>MATRICULA_AVALIADOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AVALIACAO">
          <DataField>AVALIACAO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AUTO_AVALIACAO">
          <DataField>AUTO_AVALIACAO</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RANK">
          <DataField>RANK</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="TOTAL_PESOS">
          <DataField>TOTAL_PESOS</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Ciclo">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT NULL CICLOID,' TODAS' CICLO
UNION
SELECT CICLOID, NOME FROM CICLO (NOLOCK)
UNION
SELECT -1 CICLOID, ' Selecione...' CICLO 
ORDER BY CICLOID </CommandText>
      </Query>
      <Fields>
        <Field Name="CICLOID">
          <DataField>CICLOID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CICLO">
          <DataField>CICLO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="CICLO">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>-1</Value>
        </Values>
      </DefaultValue>
      <Prompt>Ciclo</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>Ciclo</DataSetName>
          <ValueField>CICLOID</ValueField>
          <LabelField>CICLO</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
  </ReportParameters>
